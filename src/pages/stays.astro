<script is:inline set:html={"// Pin <-> card hover sync\n  (function(){\n    document.querySelectorAll('.map-pane .pin').forEach(pin=>{\n      const slug = pin.dataset.slug;\n      pin.addEventListener('mouseenter',()=>{\n        const card = document.querySelector(`.apts .apt[data-slug=\"${slug}\"]`);\n        if(card) card.classList.add('active');\n      });\n      pin.addEventListener('mouseleave',()=>{\n        const card = document.querySelector(`.apts .apt[data-slug=\"${slug}\"]`);\n        if(card) card.classList.remove('active');\n      });\n    });\n    document.querySelectorAll('.apts .apt').forEach(card=>{\n      const slug = card.dataset.slug;\n      card.addEventListener('mouseenter',()=>{\n        const pin = document.querySelector(`.map-pane .pin[data-slug=\"${slug}\"]`);\n        if(pin) pin.classList.add('active');\n      });\n      card.addEventListener('mouseleave',()=>{\n        const pin = document.querySelector(`.map-pane .pin[data-slug=\"${slug}\"]`);\n        if(pin) pin.classList.remove('active');\n      });\n    });\n  })();\n\n  // Filter drawer + chips \u2014 unified state\n  (function(){\n    const btn = document.getElementById('filterBtn');\n    const more = document.getElementById('moreFilters');\n    const drawer = document.getElementById('drawer');\n    const backdrop = document.getElementById('drawerBackdrop');\n    const close = document.getElementById('drawerClose');\n    const stripClear = document.getElementById('stripClear');\n    const drawerClear = document.querySelector('.drawer .clear');\n\n    const chips = document.querySelectorAll('.filters-strip .chip[data-filter]');\n    const checks = document.querySelectorAll('.drawer .checks input[data-filter]');\n    const opts = document.querySelectorAll('.drawer .opt'); // beds + stay length\n\n    function openDrawer(){drawer.classList.add('open');backdrop.classList.add('open');document.body.style.overflow='hidden'}\n    function shutDrawer(){drawer.classList.remove('open');backdrop.classList.remove('open');document.body.style.overflow=''}\n    if(btn) btn.addEventListener('click', openDrawer);\n    if(more) more.addEventListener('click', openDrawer);\n    close.addEventListener('click', shutDrawer);\n    backdrop.addEventListener('click', shutDrawer);\n    document.addEventListener('keydown', e=>{if(e.key==='Escape' && drawer.classList.contains('open')) shutDrawer()});\n\n    function refreshClearVisibility(){\n      const anyChipOn = Array.from(chips).some(c => c.classList.contains('on'));\n      const anyCheckOn = Array.from(checks).some(c => c.checked);\n      const anyOptOn = Array.from(opts).some(o => o.classList.contains('on'));\n      const hasAny = anyChipOn || anyCheckOn || anyOptOn;\n      if(stripClear){\n        stripClear.hidden = !hasAny;\n      }\n    }\n\n    // Chip click \u2014 toggle chip + matching checkbox\n    chips.forEach(chip => {\n      chip.addEventListener('click', () => {\n        const key = chip.dataset.filter;\n        const isOn = chip.classList.toggle('on');\n        const check = document.querySelector(`.drawer .checks input[data-filter=\"${key}\"]`);\n        if(check) check.checked = isOn;\n        refreshClearVisibility();\n      });\n    });\n\n    // Checkbox change \u2014 toggle matching chip\n    checks.forEach(check => {\n      check.addEventListener('change', () => {\n        const key = check.dataset.filter;\n        const chip = document.querySelector(`.filters-strip .chip[data-filter=\"${key}\"]`);\n        if(chip) chip.classList.toggle('on', check.checked);\n        refreshClearVisibility();\n      });\n    });\n\n    // Drawer opt buttons (beds, stay length) \u2014 just toggle visually\n    opts.forEach(o => {\n      o.addEventListener('click', () => {\n        o.classList.toggle('on');\n        refreshClearVisibility();\n      });\n    });\n\n    function clearAll(){\n      chips.forEach(c => c.classList.remove('on'));\n      checks.forEach(c => { c.checked = false; });\n      opts.forEach(o => o.classList.remove('on'));\n      // clear price inputs in drawer\n      document.querySelectorAll('.drawer .price-range input').forEach(i => i.value = '');\n      refreshClearVisibility();\n    }\n\n    if(stripClear) stripClear.addEventListener('click', clearAll);\n    if(drawerClear) drawerClear.addEventListener('click', clearAll);\n\n    refreshClearVisibility();\n  })();\n\n  // Mobile view toggle\n  (function(){\n    const left = document.getElementById('leftPane');\n    const right = document.getElementById('rightPane');\n    const btnL = document.getElementById('viewList');\n    const btnM = document.getElementById('viewMap');\n    if(!btnL||!btnM)return;\n    btnL.addEventListener('click',()=>{\n      left.classList.remove('hidden');\n      right.classList.remove('visible');\n      btnL.classList.add('active');\n      btnM.classList.remove('active');\n    });\n    btnM.addEventListener('click',()=>{\n      left.classList.add('hidden');\n      right.classList.add('visible');\n      btnL.classList.remove('active');\n      btnM.classList.add('active');\n    });\n  })();"}></script>
<Fragment set:html={"<div class=\"cal-pop\" id=\"calPop\" hidden>\n  <div class=\"cal-head\">\n    <button class=\"cal-nav\" id=\"calPrev\" type=\"button\" aria-label=\"previous\">\u2039</button>\n    <div class=\"cal-months\" id=\"calMonths\"></div>\n    <button class=\"cal-nav\" id=\"calNext\" type=\"button\" aria-label=\"next\">\u203a</button>\n  </div>\n  <div class=\"cal-legend\">\n    <span class=\"cal-leg\"><span class=\"ll green\"></span>$ available</span>\n    <span class=\"cal-leg\"><span class=\"ll yellow\"></span>$$ peak</span>\n    <span class=\"cal-leg\"><span class=\"ll coral\"></span>$$$ booked</span>\n    <span class=\"cal-leg-night\" id=\"calNight\">\u2014 pick dates</span>\n    <button class=\"cal-apply\" id=\"calApply\" type=\"button\">done \u2192</button>\n  </div>\n</div>\n<div class=\"guest-pop\" id=\"guestPop\" hidden>\n  <div class=\"gp-head\">\u2014 who's coming</div>\n  <div class=\"gp-row\">\n    <div class=\"gp-info\">\n      <div class=\"gp-title\">adults</div>\n      <div class=\"gp-sub\">\u2014 ages 13+</div>\n    </div>\n    <div class=\"gp-ctrl\">\n      <button class=\"gp-btn\" data-action=\"adults-\" type=\"button\">\u2212</button>\n      <span class=\"gp-num\" id=\"gpAdults\">2</span>\n      <button class=\"gp-btn\" data-action=\"adults+\" type=\"button\">+</button>\n    </div>\n  </div>\n  <div class=\"gp-row\">\n    <div class=\"gp-info\">\n      <div class=\"gp-title\">children</div>\n      <div class=\"gp-sub\">\u2014 ages 2\u201312</div>\n    </div>\n    <div class=\"gp-ctrl\">\n      <button class=\"gp-btn\" data-action=\"children-\" type=\"button\">\u2212</button>\n      <span class=\"gp-num\" id=\"gpChildren\">0</span>\n      <button class=\"gp-btn\" data-action=\"children+\" type=\"button\">+</button>\n    </div>\n  </div>\n  <div class=\"gp-row\">\n    <div class=\"gp-info\">\n      <div class=\"gp-title\">infants</div>\n      <div class=\"gp-sub\">\u2014 under 2</div>\n    </div>\n    <div class=\"gp-ctrl\">\n      <button class=\"gp-btn\" data-action=\"infants-\" type=\"button\">\u2212</button>\n      <span class=\"gp-num\" id=\"gpInfants\">0</span>\n      <button class=\"gp-btn\" data-action=\"infants+\" type=\"button\">+</button>\n    </div>\n  </div>\n  <div class=\"gp-foot\">\n    <span class=\"gp-note\">max 6 guests</span>\n    <button class=\"gp-apply\" id=\"gpApply\" type=\"button\">apply \u2192</button>\n  </div>\n</div>"} />
<script is:inline set:html={"document.addEventListener('DOMContentLoaded', function(){\n  const dateField = document.getElementById('searchDates');\n  const dateVal = document.getElementById('searchDatesVal');\n  const guestField = document.getElementById('searchGuests');\n  const guestVal = document.getElementById('searchGuestsVal');\n  const calPop = document.getElementById('calPop');\n  const calMonths = document.getElementById('calMonths');\n  const calPrev = document.getElementById('calPrev');\n  const calNext = document.getElementById('calNext');\n  const calNight = document.getElementById('calNight');\n  const guestPop = document.getElementById('guestPop');\n  const gpApply = document.getElementById('gpApply');\n  if(!dateField||!calPop||!guestPop)return;\n\n  // ===== CALENDAR =====\n  const today = new Date(); today.setHours(0,0,0,0);\n  const BOOKED = new Set();\n  const PEAK = new Set();\n  let viewYear = today.getFullYear();\n  let viewMonth = today.getMonth();\n  let startDate = null, endDate = null, mode = 'start';\n  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];\n  const weekDays = ['Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa', 'Su'];\n  function fmtKey(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0')}\n  function fmtPretty(d){\n    if(!d)return null;\n    return `${d.getDate().toString().padStart(2,'0')} ${monthNames[d.getMonth()].slice(0,3).toLowerCase()}`;\n  }\n  function renderMonth(year, month){\n    const first = new Date(year, month, 1);\n    const last = new Date(year, month+1, 0);\n    const startWeekday = (first.getDay() + 6) % 7;\n    const daysInMonth = last.getDate();\n    let html = `<div class=\"cal-month\"><div class=\"cal-title\">${monthNames[month]} ${year}</div>`;\n    html += '<div class=\"cal-week\">';\n    weekDays.forEach(w => html += `<div class=\"cal-week-day\">${w}</div>`);\n    html += '</div><div class=\"cal-grid\">';\n    for(let i=0;i<startWeekday;i++) html += '<button class=\"cal-day empty\" disabled></button>';\n    for(let d=1;d<=daysInMonth;d++){\n      const date = new Date(year, month, d);\n      const key = fmtKey(date);\n      let cls = 'cal-day';\n      if(date < today) cls += ' past';\n      else if(BOOKED.has(key)) cls += ' booked';\n      else if(PEAK.has(key)) cls += ' peak';\n      else cls += ' av';\n      if(startDate && fmtKey(startDate) === key){\n        cls = cls.replace(/av|peak/, '') + ' start';\n        if(endDate && fmtKey(endDate) === key) cls += ' range-single';\n      }\n      if(endDate && fmtKey(endDate) === key) cls = cls.replace(/av|peak/, '') + ' end';\n      if(startDate && endDate && date > startDate && date < endDate){\n        cls = cls.replace(/av|peak/, '') + ' inside';\n      }\n      html += `<button class=\"${cls}\" data-date=\"${key}\">${d}</button>`;\n    }\n    html += '</div></div>';\n    return html;\n  }\n  function render(){\n    const nm = viewMonth + 1 > 11 ? 0 : viewMonth + 1;\n    const ny = viewMonth + 1 > 11 ? viewYear + 1 : viewYear;\n    calMonths.innerHTML = renderMonth(viewYear, viewMonth) + renderMonth(ny, nm);\n    calMonths.querySelectorAll('.cal-day:not(.past):not(.booked):not(.empty)').forEach(btn=>{\n      btn.addEventListener('click', (ev)=>{\n        ev.stopPropagation();\n        const [yy,mm,dd] = btn.dataset.date.split('-').map(Number); const d = new Date(yy, mm-1, dd);\n        if(mode === 'start' || (startDate && d <= startDate)){\n          startDate = d; endDate = null; mode = 'end';\n        } else {\n          endDate = d; mode = 'start';\n        }\n        updateLabels(); render();\n      });\n    });\n  }\n  function updateLabels(){\n    if(startDate && endDate){\n      dateVal.textContent = `${fmtPretty(startDate)} → ${fmtPretty(endDate)}`;\n      dateVal.classList.remove('empty');\n    } else if(startDate){\n      dateVal.textContent = `${fmtPretty(startDate)} → ...`;\n      dateVal.classList.remove('empty');\n    } else {\n      dateVal.textContent = 'add dates';\n      dateVal.classList.add('empty');\n    }\n    if(startDate && endDate){\n      const nights = Math.round((endDate - startDate) / 86400000);\n      calNight.textContent = `✓ ${nights} ${nights===1?'night':'nights'}`;\n    } else if(startDate){\n      calNight.textContent = '→ now pick checkout';\n    } else {\n      calNight.textContent = '→ pick arrival';\n    }\n  }\n  let scrollYOpen = null;\n  function openCal(){\n    closeGuest();\n    calPop.hidden = false;\n    dateField.classList.add('active');\n    const rect = dateField.getBoundingClientRect();\n    calPop.style.top = (rect.bottom + 8) + 'px';\n    calPop.style.left = Math.max(14, Math.min(window.innerWidth - calPop.offsetWidth - 14, rect.left)) + 'px';\n    if(!startDate) mode = 'start';\n    else if(startDate && !endDate) mode = 'end';\n    else mode = 'start';\n    render();\n    setTimeout(()=>{\n      calPop.style.left = Math.max(14, Math.min(window.innerWidth - calPop.offsetWidth - 14, rect.left)) + 'px';\n    }, 10);\n    scrollYOpen = window.scrollY;\n  }\n  function closeCal(){\n    calPop.hidden = true;\n    dateField.classList.remove('active');\n  }\n  dateField.addEventListener('click', e=>{ e.stopPropagation(); calPop.hidden ? openCal() : closeCal(); });\n  calPrev.addEventListener('click', (ev)=>{ev.stopPropagation(); viewMonth--; if(viewMonth<0){viewMonth=11;viewYear--} render(); });\n  calNext.addEventListener('click', (ev)=>{ev.stopPropagation(); viewMonth++; if(viewMonth>11){viewMonth=0;viewYear++} render(); });\n  const calApply = document.getElementById('calApply');\n  if(calApply) calApply.addEventListener('click', ()=>closeCal());\n\n  // ===== GUESTS =====\n  const guestState = {adults: 2, children: 0, infants: 0};\n  const MAX = 6;\n  const gpEls = {adults: document.getElementById('gpAdults'), children: document.getElementById('gpChildren'), infants: document.getElementById('gpInfants')};\n  function gpUpdate(){\n    gpEls.adults.textContent = guestState.adults;\n    gpEls.children.textContent = guestState.children;\n    gpEls.infants.textContent = guestState.infants;\n    guestPop.querySelectorAll('.gp-btn').forEach(btn=>{\n      const k = btn.dataset.action.replace(/[+\\-]/,'');\n      const op = btn.dataset.action.slice(-1);\n      if(op === '-'){\n        btn.disabled = (k === 'adults' ? guestState[k] <= 1 : guestState[k] <= 0);\n      } else {\n        const total = guestState.adults + guestState.children;\n        btn.disabled = (k !== 'infants' && total >= MAX);\n      }\n    });\n  }\n  function gpSyncLabel(){\n    const total = guestState.adults + guestState.children;\n    const infants = guestState.infants;\n    let label = `${total} ${total === 1 ? 'guest' : 'guests'}`;\n    if(infants) label += ` · ${infants} ${infants === 1 ? 'infant' : 'infants'}`;\n    guestVal.textContent = label;\n  }\n  function openGuest(){\n    closeCal();\n    guestPop.hidden = false;\n    guestField.classList.add('active');\n    const rect = guestField.getBoundingClientRect();\n    guestPop.style.top = (rect.bottom + 8) + 'px';\n    guestPop.style.left = Math.max(14, Math.min(window.innerWidth - 360 - 14, rect.left)) + 'px';\n    gpUpdate();\n  }\n  function closeGuest(){\n    guestPop.hidden = true;\n    guestField.classList.remove('active');\n  }\n  guestField.addEventListener('click', e=>{ e.stopPropagation(); guestPop.hidden ? openGuest() : closeGuest(); });\n  guestPop.querySelectorAll('.gp-btn').forEach(btn=>{\n    btn.addEventListener('click', ()=>{\n      const k = btn.dataset.action.replace(/[+\\-]/,'');\n      const op = btn.dataset.action.slice(-1);\n      if(op === '+') guestState[k]++;\n      else guestState[k]--;\n      gpUpdate();\n    });\n  });\n  gpApply.addEventListener('click', ()=>{ gpSyncLabel(); closeGuest(); });\n\n  // ===== OUTSIDE CLICK =====\n  document.addEventListener('click', e=>{\n    if(!calPop.hidden && !calPop.contains(e.target) && !dateField.contains(e.target)) closeCal();\n    if(!guestPop.hidden && !guestPop.contains(e.target) && !guestField.contains(e.target)) closeGuest();\n  });\n  gpSyncLabel();\n  // close popups on scroll\n  window.addEventListener('scroll', ()=>{\n    if(scrollYOpen === null) return;\n    const delta = Math.abs(window.scrollY - scrollYOpen);\n    if(!calPop.hidden && delta > 30) closeCal();\n    if(!guestPop.hidden && delta > 30) closeGuest();\n  }, {passive:true});\n  // closeOnScroll: enabled\n});"}></script>
<script is:inline>
(function () {
  if (window.matchMedia('(max-width:880px)').matches) return;
  var ticking = false;
  function update() { ticking = false; var y = window.scrollY || document.documentElement.scrollTop || 0; document.body.classList.toggle('stays-scrolled', y > 120); }
  window.addEventListener('scroll', function () { if (!ticking) { requestAnimationFrame(update); ticking = true; } }, { passive: true });
  update();
})();
</script>
