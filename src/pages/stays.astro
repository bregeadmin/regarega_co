<script is:inline set:html={"// Pin <-> card hover sync\n  (function(){\n    document.querySelectorAll('.map-pane .pin').forEach(pin=>{\n      const slug = pin.dataset.slug;\n      pin.addEventListener('mouseenter',()=>{\n        const card = document.querySelector(`.apts .apt[data-slug=\"${slug}\"]`);\n        if(card) card.classList.add('active');\n      });\n      pin.addEventListener('mouseleave',()=>{\n        const card = document.querySelector(`.apts .apt[data-slug=\"${slug}\"]`);\n        if(card) card.classList.remove('active');\n      });\n    });\n    document.querySelectorAll('.apts .apt').forEach(card=>{\n      const slug = card.dataset.slug;\n      card.addEventListener('mouseenter',()=>{\n        const pin = document.querySelector(`.map-pane .pin[data-slug=\"${slug}\"]`);\n        if(pin) pin.classList.add('active');\n      });\n      card.addEventListener('mouseleave',()=>{\n        const pin = document.querySelector(`.map-pane .pin[data-slug=\"${slug}\"]`);\n        if(pin) pin.classList.remove('active');\n      });\n    });\n  })();\n\n  // Filter drawer + chips \u2014 unified state\n  (function(){\n    const btn = document.getElementById('filterBtn');\n    const more = document.getElementById('moreFilters');\n    const drawer = document.getElementById('drawer');\n    const backdrop = document.getElementById('drawerBackdrop');\n    const close = document.getElementById('drawerClose');\n    const stripClear = document.getElementById('stripClear');\n    const drawerClear = document.querySelector('.drawer .clear');\n\n    const chips = document.querySelectorAll('.filters-strip .chip[data-filter]');\n    const checks = document.querySelectorAll('.drawer .checks input[data-filter]');\n    const opts = document.querySelectorAll('.drawer .opt'); // beds + stay length\n\n    function openDrawer(){drawer.classList.add('open');backdrop.classList.add('open');document.body.style.overflow='hidden'}\n    function shutDrawer(){drawer.classList.remove('open');backdrop.classList.remove('open');document.body.style.overflow=''}\n    if(btn) btn.addEventListener('click', openDrawer);\n    if(more) more.addEventListener('click', openDrawer);\n    close.addEventListener('click', shutDrawer);\n    backdrop.addEventListener('click', shutDrawer);\n    document.addEventListener('keydown', e=>{if(e.key==='Escape' && drawer.classList.contains('open')) shutDrawer()});\n\n    function refreshClearVisibility(){\n      const anyChipOn = Array.from(chips).some(c => c.classList.contains('on'));\n      const anyCheckOn = Array.from(checks).some(c => c.checked);\n      const anyOptOn = Array.from(opts).some(o => o.classList.contains('on'));\n      const hasAny = anyChipOn || anyCheckOn || anyOptOn;\n      if(stripClear){\n        stripClear.hidden = !hasAny;\n      }\n    }\n\n    // Chip click \u2014 toggle chip + matching checkbox\n    chips.forEach(chip => {\n      chip.addEventListener('click', () => {\n        const key = chip.dataset.filter;\n        const isOn = chip.classList.toggle('on');\n        const check = document.querySelector(`.drawer .checks input[data-filter=\"${key}\"]`);\n        if(check) check.checked = isOn;\n        refreshClearVisibility();\n      });\n    });\n\n    // Checkbox change \u2014 toggle matching chip\n    checks.forEach(check => {\n      check.addEventListener('change', () => {\n        const key = check.dataset.filter;\n        const chip = document.querySelector(`.filters-strip .chip[data-filter=\"${key}\"]`);\n        if(chip) chip.classList.toggle('on', check.checked);\n        refreshClearVisibility();\n      });\n    });\n\n    // Drawer opt buttons (beds, stay length) \u2014 just toggle visually\n    opts.forEach(o => {\n      o.addEventListener('click', () => {\n        o.classList.toggle('on');\n        refreshClearVisibility();\n      });\n    });\n\n    function clearAll(){\n      chips.forEach(c => c.classList.remove('on'));\n      checks.forEach(c => { c.checked = false; });\n      opts.forEach(o => o.classList.remove('on'));\n      // clear price inputs in drawer\n      document.querySelectorAll('.drawer .price-range input').forEach(i => i.value = '');\n      refreshClearVisibility();\n    }\n\n    if(stripClear) stripClear.addEventListener('click', clearAll);\n    if(drawerClear) drawerClear.addEventListener('click', clearAll);\n\n    refreshClearVisibility();\n  })();\n\n  // Mobile view toggle\n  (function(){\n    const left = document.getElementById('leftPane');\n    const right = document.getElementById('rightPane');\n    const btnL = document.getElementById('viewList');\n    const btnM = document.getElementById('viewMap');\n    if(!btnL||!btnM)return;\n    btnL.addEventListener('click',()=>{\n      left.classList.remove('hidden');\n      right.classList.remove('visible');\n      btnL.classList.add('active');\n      btnM.classList.remove('active');\n    });\n    btnM.addEventListener('click',()=>{\n      left.classList.add('hidden');\n      right.classList.add('visible');\n      btnL.classList.remove('active');\n      btnM.classList.add('active');\n    });\n  })();"}></script>
