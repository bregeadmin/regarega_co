---
import Site from '../layouts/Site.astro';
import { supabase, applyNames, type Apartment } from '../lib/supabase';
import { GMAPS_KEY } from '../lib/maps';
import { teaser } from '../lib/text';
const { data } = await supabase
  .from('apartments_public')
  .select('id,slug,title,summary,neighborhood,bedrooms,max_guests,price_from,photos,lat,lng')
  .order('price_from', { ascending: true });
const apartments = ((data as Apartment[]) || []).map(applyNames);
const ph = (a: Apartment) => (a.photos && a.photos[0]) || `https://picsum.photos/seed/${a.slug}/900/700`;
const mapData = apartments.filter((a)=>a.lat!=null&&a.lng!=null).map((a)=>({slug:a.slug,title:a.title,lat:a.lat,lng:a.lng,photo:(a.photos&&a.photos[0])||'',href:`/stays/${a.slug}`,sub:(a.bedrooms===0?'studio':`${a.bedrooms??1} bed`)+` · ${a.max_guests??2} guests`,cta:a.price_from?`₾${a.price_from} / night`:'from ₾X / night',pill:a.price_from?`₾${a.price_from}`:'₾X'}));

const initJs = "window.__initGMap=function(){"
  + "var api=RegaMap.stays('staysMap',MAP_DATA,{cardSel:'.apts .apt',cluster:true,fullscreen:false});"
  + "if(!api)return;"
  + "var right=document.getElementById('rightPane');var pane=document.querySelector('.map-pane');"
  + "var exp=pane&&pane.querySelector('.map-expand');var near=pane&&pane.querySelector('.map-near');"
  + "function setExpanded(on){right.classList.toggle('expanded',on);document.documentElement.classList.toggle('map-locked',on);document.body.classList.toggle('map-locked',on);if(window.google&&api.map)setTimeout(function(){google.maps.event.trigger(api.map,'resize');api.refit();},90);}"
  + "if(exp)exp.addEventListener('click',function(){setExpanded(!right.classList.contains('expanded'));});"
  + "document.addEventListener('keydown',function(e){if(e.key==='Escape'&&right.classList.contains('expanded'))setExpanded(false);});"
  + "if(near)near.addEventListener('click',function(){var b=this;b.classList.add('loading');api.locate(function(u){b.classList.remove('loading');if(!u){b.classList.add('err');setTimeout(function(){b.classList.remove('err');},2200);}});});"
  + "};";
---
<Site title="all apartments — rega rega batumi" description="checked flats in batumi. pick from list or map.">

<Fragment set:html={'<div class="subhead">\n  <div class="row">\n    <div class="crumbs">\n      <a href="/">rega rega</a>\n      <span class="sep">/</span>\n      <span class="cur">all apartments</span>\n    </div>\n\n    <div class="searchbar">\n      <div class="field" id="searchLocation">\n        <span class="lbl">— location</span>\n        <span class="field-val">Batumi</span>\n      </div>\n      <div class="field date-field" id="searchDates">\n        <span class="lbl">— check in | check out</span>\n        <span class="field-val empty" id="searchDatesVal">add dates</span>\n      </div>\n      <div class="field" id="searchGuests">\n        <span class="lbl">— guests</span>\n        <span class="field-val" id="searchGuestsVal">2 guests</span>\n      </div>\n      <button class="submit" aria-label="search">\n        <svg viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="m20 20-4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>\n      </button>\n    </div>\n\n    <div class="controls">\n      <button class="filter-btn" id="filterBtn">\n        <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M2 3h9M3.5 6.5h6M5 10h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>\n        Filters\n      </button>\n      <div class="view-toggle">\n        <button class="active" data-view="list" id="viewList">List</button>\n        <button data-view="map" id="viewMap">Map</button>\n      </div>\n    </div>\n  </div>\n</div>'} />

<Fragment set:html={'<div class="filters-strip">\n  <div class="row">\n    <button class="filters-pill" id="moreFilters">\n      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 3h10M3.5 7h7M5 11h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>\n      Filters\n      <span class="ct" id="filterCount" hidden></span>\n    </button>\n    <div class="sort">\n      <select id="sort">\n        <option>Sort: recommended</option>\n        <option>Sort: price · low to high</option>\n        <option>Sort: price · high to low</option>\n        <option>Sort: newest</option>\n      </select>\n    </div>\n  </div>\n</div>'} />

<section class="split">
  <div class="container">
    <div class="left" id="leftPane">
      <div class="left-head">
        <h1>all our <em>apartments</em>.</h1>
        <div class="count"><b>{apartments.length} places</b> · pick from list or map</div>
      </div>

      <div class="apts">
        {apartments.map((a) => (
          <a class="apt" data-slug={a.slug} href={`/stays/${a.slug}`}>
            <div class="ph">
              <img src={ph(a)} alt={a.title} loading="lazy" />
              <button class="fav" type="button" onclick="event.preventDefault();this.textContent=this.textContent==='♡'?'♥':'♡'">♡</button>
            </div>
            <div class="info">
              <div>
                <h4>{a.title}</h4>
                {a.summary && <p class="desc">{teaser(a.summary)}</p>}
              </div>
              <div class="specs">
                <span>{a.bedrooms === 0 ? 'studio' : `${a.bedrooms ?? 1} bed`}</span>
                {a.neighborhood && <span>{a.neighborhood}</span>}
                <span>{a.max_guests ?? 2} guests</span>
              </div>
              <div class="price-row">
                <div class="price"><span class="from">from</span>₾{a.price_from ?? 'X'}<span class="u">/night</span></div>
                <span class="cta">view →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <Fragment set:html={'<div class="right" id="rightPane"><div class="map-pane">' +
      '<button class="map-expand" type="button" aria-label="expand map"><svg class="ic-exp" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 2H2v4M10 2h4v4M6 14H2v-4M10 14h4v-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg><svg class="ic-close" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></button>' +
      '<button class="map-near" type="button"><svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="2.6" fill="currentColor"/><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4"/><path d="M8 0.5v3M8 12.5v3M0.5 8h3M12.5 8h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg> near me</button>' +
      '<div id="staysMap"></div></div></div>'} />
  </div>
</section>

<Fragment set:html={"<aside class=\"drawer\" id=\"drawer\">\n  <div class=\"dhead\">\n    <h3>filters</h3>\n    <button class=\"close\" id=\"drawerClose\" aria-label=\"close\">\u2715</button>\n  </div>\n  <div class=\"dbody\">\n    <div class=\"group\">\n      <h5>\u2014 beds</h5>\n      <div class=\"opts\">\n        <button class=\"opt\">studio</button>\n        <button class=\"opt\">1</button>\n        <button class=\"opt\">2</button>\n        <button class=\"opt\">3+</button>\n      </div>\n    </div>\n\n    <div class=\"group\">\n      <h5>\u2014 price / night, USD</h5>\n      <div class=\"price-range\">\n        <input type=\"number\" placeholder=\"50\" min=\"0\">\n        <span>\u2014</span>\n        <input type=\"number\" placeholder=\"300\" min=\"0\">\n      </div>\n    </div>\n\n    <div class=\"group\">\n      <h5>\u2014 amenities</h5>\n      <div class=\"checks\">\n        <label><input type=\"checkbox\" data-filter=\"sea-view\"> Sea view</label>\n        <label><input type=\"checkbox\" data-filter=\"balcony\"> Balcony or terrace</label>\n        <label><input type=\"checkbox\" data-filter=\"pool\"> Pool</label>\n        <label><input type=\"checkbox\" data-filter=\"parking\"> Parking</label>\n        <label><input type=\"checkbox\" data-filter=\"workspace\"> Workspace</label>\n        <label><input type=\"checkbox\" data-filter=\"pet-friendly\"> Pet-friendly</label>\n        <label><input type=\"checkbox\" data-filter=\"family\"> Family-sized (3+ beds)</label>\n      </div>\n    </div>\n\n    <div class=\"group\">\n      <h5>\u2014 stay length</h5>\n      <div class=\"opts\">\n        <button class=\"opt\">short (1\u20146 nights)</button>\n        <button class=\"opt\">week+</button>\n        <button class=\"opt\">month+</button>\n      </div>\n    </div>\n  </div>\n  <div class=\"dfoot\">\n    <button class=\"clear\">clear all</button>\n    <button class=\"apply\">show 6 places</button>\n  </div>\n</aside>"} />

<style is:global set:html={'.subhead{position:fixed;left:0;right:0;top:72px;z-index:40;background:var(--bg);border-bottom:1px solid var(--line);padding:18px 28px}\n.subhead .row{max-width:1500px;margin:0 auto;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:18px}\n.subhead .crumbs{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.04em;text-transform:none;color:var(--ink-soft);font-weight:500;display:flex;align-items:center;gap:8px}\n.subhead .crumbs a:hover{color:var(--ink)}\n.subhead .crumbs .sep{opacity:.4}\n.subhead .crumbs .cur{color:var(--ink);font-weight:600}\n.searchbar{display:grid;grid-template-columns:1fr 1.6fr 1fr auto;align-items:stretch;gap:0;background:var(--paper);border:1px solid var(--line-strong);border-radius:999px;overflow:hidden;max-width:880px;margin:0 auto;width:100%;height:62px}\n.searchbar .field{padding:10px 20px;display:flex;flex-direction:column;gap:2px;justify-content:center;border-right:1px solid var(--line);transition:background .2s ease;cursor:pointer;min-width:0}\n.searchbar .field:hover{background:#fff}\n.searchbar .field .lbl{font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);font-weight:600}\n.searchbar .field input,.searchbar .field select{font-family:"Bricolage Grotesque",sans-serif;font-weight:600;font-size:15px;border:0;background:transparent;outline:0;padding:0;color:var(--ink);width:100%;cursor:pointer;text-overflow:ellipsis;line-height:1.3}\n.searchbar .field input[type="date"]{font-family:"Bricolage Grotesque",sans-serif;color:var(--ink)}\n.searchbar .field input[type="date"]:invalid{color:var(--ink-soft)}\n.searchbar .field input[type="date"]::-webkit-calendar-picker-indicator{cursor:pointer;opacity:.55;transition:opacity .2s ease;margin-left:4px}\n.searchbar .field input[type="date"]::-webkit-calendar-picker-indicator:hover{opacity:1}\n.searchbar .submit{display:flex;align-items:center;justify-content:center;width:54px;height:54px;background:var(--ink);color:#fff;border:0;cursor:pointer;border-radius:50%;margin:4px;transition:background .2s ease;flex:none}\n.searchbar .submit:hover{background:var(--page)}\n.searchbar .submit svg{width:20px;height:20px}\n.subhead .controls{display:flex;align-items:center;gap:10px;justify-self:end}\n.subhead .filter-btn{display:none;align-items:center;gap:8px;padding:9px 14px;border:1px solid var(--line-strong);border-radius:999px;background:transparent;font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;cursor:pointer;color:var(--ink);transition:all .2s ease;white-space:nowrap}\n.subhead .filter-btn:hover{background:var(--ink);color:#fff;border-color:var(--ink)}\n.subhead .filter-btn .ct{background:var(--page);color:#fff;padding:1px 6px;border-radius:999px;font-size:9px;min-width:18px;text-align:center}\n.subhead .view-toggle{display:none;border:1px solid var(--line-strong);border-radius:999px;padding:3px;background:var(--paper)}\n.subhead .view-toggle button{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;border:0;background:transparent;color:var(--ink-soft);padding:6px 12px;border-radius:999px;cursor:pointer;display:inline-flex;align-items:center;gap:5px}\n.subhead .view-toggle button.active{background:var(--ink);color:#fff}\n.filters-strip{position:fixed;left:0;right:0;top:170px;z-index:39;background:var(--bg);border-bottom:1px solid var(--line);padding:14px 28px}\n.filters-strip .row{max-width:1500px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;gap:14px;flex-wrap:wrap}\n.filters-strip .chips{display:flex;flex-wrap:wrap;gap:8px;align-items:center}\n.filters-strip .chip{display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border:1px solid var(--line-strong);border-radius:999px;background:var(--paper);font-family:"Bricolage Grotesque",sans-serif;font-weight:600;font-size:13px;color:var(--ink);cursor:pointer;transition:all .2s ease;white-space:nowrap}\n.filters-strip .chip:hover{background:var(--ink);color:#fff;border-color:var(--ink)}\n.filters-strip .chip.on{background:var(--ink);color:#fff;border-color:var(--ink)}\n.filters-strip .more{display:inline-flex;align-items:center;gap:6px;padding:9px 16px;border:1px dashed var(--line-strong);border-radius:999px;background:transparent;font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;color:var(--ink);cursor:pointer;transition:all .2s ease;white-space:nowrap}\n.filters-strip .more:hover{background:var(--ink);color:#fff;border-color:var(--ink);border-style:solid}\n.filters-strip .more .plus{display:inline-flex;align-items:center;justify-content:center;width:14px;height:14px;border-radius:50%;background:var(--page);color:#fff;font-weight:800;font-size:11px;font-family:"Bricolage Grotesque",sans-serif;letter-spacing:0}\n.filters-strip .strip-clear{display:inline-flex;align-items:center;gap:6px;padding:9px 14px;background:transparent;border:0;font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;color:var(--page);cursor:pointer;transition:color .2s ease;white-space:nowrap}\n.filters-strip .strip-clear:hover{color:var(--accent-deep);text-decoration:underline}\n.filters-strip .sort{display:inline-flex;align-items:center;gap:8px;font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-soft);font-weight:600;flex:none}\n.filters-strip .sort select{font-family:"Bricolage Grotesque",sans-serif;font-weight:600;font-size:13px;text-transform:none;letter-spacing:0;color:var(--ink);border:0;background:transparent;outline:0;cursor:pointer;padding:9px 14px;border:1px solid var(--line-strong);border-radius:999px}\n.filters-strip .sort select:hover{border-color:var(--ink)}\n.split{padding-top:240px}\n.split .container{display:grid;grid-template-columns:1fr 480px;min-height:calc(100vh - 240px)}\n.split .left{padding:24px 28px 64px;min-width:0}\n.split .right{position:sticky;top:240px;height:calc(100vh - 240px);border-left:1px solid var(--line);overflow:hidden}\n.left-head{display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:14px;margin-bottom:18px}\n.left-head h1{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(32px,3.5vw,48px);line-height:.95;letter-spacing:-.035em;text-transform:lowercase}\n.left-head h1 em{font-style:italic;color:var(--page)}\n.left-head .count{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);font-weight:600}\n.left-head .count b{color:var(--ink)}\n.apts{display:flex;flex-direction:column;gap:16px}\n.apt{display:grid;grid-template-columns:280px 1fr;background:var(--paper);border:1px solid var(--line);border-radius:14px;overflow:hidden;text-decoration:none;transition:border-color .25s ease,transform .25s ease}\n.apt:hover,.apt.active{border-color:var(--page);transform:translateY(-2px)}\n.apt .ph{position:relative;aspect-ratio:5/4;overflow:hidden;background:var(--bg-2)}\n.apt .ph img{width:100%;height:100%;object-fit:cover;transition:transform .8s cubic-bezier(.2,.7,.2,1)}\n.apt:hover .ph img{transform:scale(1.06)}\n.apt .ph .badge{position:absolute;top:12px;left:12px;padding:5px 10px;background:#fff;color:var(--ink);font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;border-radius:999px}\n.apt .ph .badge.hot{background:var(--page);color:#fff}\n.apt .ph .fav{position:absolute;top:12px;right:12px;width:32px;height:32px;border:0;background:#ffffff80;backdrop-filter:blur(6px);border-radius:50%;font-size:14px;color:var(--ink);cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s ease}\n.apt .ph .fav:hover{background:#fff;color:var(--page)}\n.ap