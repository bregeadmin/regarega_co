<Site title={'rega rega — apartments &amp; the batumi guide'}>
<Fragment set:html={'<section class="hero">\n  <div class="hero-main">\n    <a class="hero-main-img" href="/stays" aria-label="all apartments">\n      <img src="https://images.unsplash.com/photo-1502672023488-70e25813eb80?w=2000&q=80" alt="bre apartment" onerror="this.src=\'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=2000&q=80\'"/>\n    </a>\n    <h1 class="hero-h1">\n      find a flat,<br/>\n      <span class="row2"><em>fall</em> for the city</span>\n    </h1>\n    <form class="hero-search" id="heroSearch" onsubmit="return submitHeroSearch(event)">\n      <button type="button" class="hs-field" id="hsDateBtn">\n        <span class="hs-lbl">— dates</span>\n        <span class="hs-val" id="hsDateVal">add dates</span>\n      </button>\n      <button type="button" class="hs-field" id="hsGuestBtn">\n        <span class="hs-lbl">— guests</span>\n        <span class="hs-val" id="hsGuestVal">2 guests</span>\n      </button>\n      <button type="submit" class="hs-submit" aria-label="search">\n        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>\n      </button>\n    </form>\n  </div>\n\n  <div class="hero-side">\n    ' + heroEdition + '\n    ' + heroSimple + '\n  </div>\n</section>\n\n<section class="pad" id="stays">\n  <div class="section-head reveal">\n    <div>\n      <div class="meta"><span class="dot"></span>— 01 / available now</div>\n      <h2 style="margin-top:18px">stay with<br/><em>us</em>.</h2>\n    </div>\n    <div class="right"><b>apartments across batumi</b>. honestly photographed, fairly priced, stocked with the things you forgot to bring. each one with its own guide.</div>\n  </div>\n\n  <div class="apts">' + homeApts + '</div>\n\n  <div class="more"><a href="/stays">see all apartments →</a></div>\n</section>\n\n<section class="spread">\n  <img src="https://images.unsplash.com/photo-1604542031658-5799ca5d7936?w=2400&q=80" alt="batumi old town"/>\n  <div class="inner">\n    <h2>the batumi<br/>we <em>actually</em><br/>recommend.</h2>\n    <p class="lede">our own city guide — written by us, not scraped from tripadvisor. cafés, restaurants, beaches, wellness, nightlife — sorted by where you\'ll actually want to spend an afternoon.</p>\n    <div class="spread-cta">\n      <a class="btn" href="/guide">open the guide →</a>\n    </div>\n  </div>\n</section>\n\n<section class="guide-wrap" id="guide">\n  <div class="section-head reveal">\n    <div>\n      <div class="meta"><span class="dot"></span>— in this issue</div>\n    </div>\n    <div class="right">a selection from <b>four worlds</b>. ' + places.length + ' spots, hand-picked.</div>\n  </div>\n\n  <div class="guide-categories">' + guideCats + '</div>\n</section>\n\n<section class="now">\n  <div class="now-grid">\n    <div>\n      <div class="now-label"><span class="pulse"></span>right now in batumi</div>\n      <div class="now-val"><span id="nowDate">today</span><span class="small" id="nowDesc">checking the sky…</span></div>\n    </div>\n    <div>\n      <div class="now-label">temperature</div>\n      <div class="now-val"><span id="nowTemp">—</span><em>°</em>C<span class="small" id="nowWind">light sea breeze</span></div>\n    </div>\n    <div>\n      <div class="now-label">sunset</div>\n      <div class="now-val" id="nowSunset">—:—<span class="small">over the black sea</span></div>\n    </div>\n    <div>\n      <div class="now-label">from the guide</div>\n      <div class="now-val">' + nowGuide + '</div>\n    </div>\n  </div>\n</section>\n\n<section class="pull">\n  <blockquote class="reveal">\n    we do<br/>the <span class="underline"><em>flat</em></span>.<br/>you do<br/>the <span class="underline"><em>city</em></span>.\n  </blockquote>\n  <div class="sig">— bre, batumi</div>\n</section>\n\n<section class="doors-wrap" id="own">\n  <div class="section-head reveal">\n    <div>\n      <div class="meta"><span class="dot"></span>— not here to book?</div>\n      <h2 style="margin-top:18px">we help you <em>buy</em><br/>and <em>manage</em> after.</h2>\n    </div>\n    <div class="right">if you own a flat in batumi — or want to — let\'s talk. we\'ve done this <b>120+ times</b> already.</div>\n  </div>\n\n  <div class="doors">\n    <a class="door reveal" href="/own">\n      <div>\n        <div class="num">i. for owners</div>\n        <h3>just hand us<br/>the <em>keys</em>.</h3>\n        <p>full-service short and mid-term rental. 30% commission, all-in. guests in 5 languages, photos, dynamic pricing, cleaning, the lot.</p>\n      </div>\n      <div>\n        <div class="stat"><b>30%</b><span>commission · all-in</span></div>\n        <span class="cta">how it works <span>→</span></span>\n      </div>\n    </a>\n\n    <a class="door reveal" href="/invest" id="invest">\n      <div>\n        <div class="num">ii. for investors</div>\n        <h3>buy a flat<br/>that <em>pays</em>.</h3>\n        <p>we find the best flats, renovate, list, manage. you see numbers, not stress. average net yield across our portfolio.</p>\n      </div>\n      <div>\n        <div class="stat"><b>11%</b><span>annual yield · avg.</span></div>\n        <span class="cta">talk to us <span>→</span></span>\n      </div>\n    </a>\n  </div>\n</section>\n\n<section class="contact" id="contact">\n  <h2 class="reveal">say<br/><em>hi</em>.</h2>\n\n  <div class="channels reveal">\n    <a class="channel" href="https://t.me/bre_ge"><span class="label">telegram</span><span class="value">@bre_ge</span><span class="ar">→</span></a>\n    <a class="channel" href="https://wa.me/4917659698164" target="_blank" rel="noopener"><span class="label">whatsapp</span><span class="value">+49 176 596 981 64</span><span class="ar">→</span></a>\n    <a class="channel" href="tel:+995585889601"><span class="label">phone</span><span class="value">+995 585 889 601</span><span class="ar">→</span></a>\n    <a class="channel" href="https://t.me/batumirealflats"><span class="label">channel</span><span class="value">t.me/batumirealflats</span><span class="ar">→</span></a>\n    <div class="channel"><span class="label">office</span><span class="value">batumi, georgia</span><span class="ar">— 41.6°N 41.6°E</span></div>\n  </div>\n</section>\n\n<section class="footer-guide">\n  <div class="footer-guide-head">\n    <h4>last week<br/>we <em>wrote</em> ↓</h4>\n    <a href="/guide" class="all">all ' + places.length + ' places →</a>\n  </div>\n  <div class="footer-posts">' + footPosts + '</div>\n</section>'} />
<style is:global set:html={'.hero{\n    position:relative;height:100vh;min-height:640px;max-height:880px;overflow:hidden;\n    padding:88px 24px 24px;\n    display:grid;grid-template-columns:1.4fr 1fr;gap:16px;\n  }\n.hero-main{\n    display:block;position:relative;border-radius:18px;overflow:hidden;background:#0a0908;\n  }\n.hero-main-img{display:block;position:absolute;inset:0;text-decoration:none;color:inherit}\n.hero-main-img img{width:100%;height:100%;object-fit:cover;transform:scale(1.05);animation:slowzoom 22s ease-out infinite alternate}\n.hero-main::after{\n    content:"";position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(180deg, #0a09084d 0%, transparent 25%, transparent 45%, #0a0908e0 100%);\n  }\n.hero-h1{\n    position:absolute;left:32px;right:32px;bottom:118px;z-index:2;color:#fff;\n    font-family:"Bricolage Grotesque",sans-serif;font-weight:800;\n    font-size:clamp(40px,4.5vw,80px);line-height:.92;letter-spacing:-.04em;\n    text-transform:lowercase;pointer-events:none;\n    opacity:0;animation:rise 1.1s cubic-bezier(.2,.7,.2,1) .3s forwards;\n  }\n.hero-h1 em{font-style:italic;color:var(--accent)}\n.hero-h1 .row2{display:block;margin-left:.5em}\n.hero-search{\n    position:absolute;left:24px;right:24px;bottom:24px;z-index:3;\n    display:grid;grid-template-columns:1.4fr 1fr auto;gap:0;\n    background:rgba(255,255,255,0.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);\n    border-radius:14px;padding:6px;\n    box-shadow:0 8px 32px rgba(0,0,0,0.18);\n    opacity:0;animation:rise 1.1s cubic-bezier(.2,.7,.2,1) .65s forwards;\n  }\n.hs-field{\n    background:transparent;border:none;cursor:pointer;text-align:left;padding:12px 18px;\n    border-radius:10px;display:flex;flex-direction:column;gap:3px;\n    transition:background .12s;\n    border-right:1px solid rgba(10,9,8,0.08);\n  }\n.hs-field:hover{background:rgba(10,9,8,0.04)}\n.hs-field:last-of-type{border-right:none}\n.hs-lbl{\n    font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.18em;\n    color:var(--ink-soft);font-weight:600;text-transform:uppercase;\n  }\n.hs-val{\n    font-family:"Bricolage Grotesque",sans-serif;font-size:15px;color:var(--ink);\n    font-weight:600;text-transform:lowercase;letter-spacing:-.01em;\n  }\n.hs-val.empty{color:var(--ink-fade);font-weight:400}\n.hs-submit{\n    background:var(--ink);border:none;color:#fff;border-radius:10px;\n    width:54px;height:auto;cursor:pointer;\n    display:flex;align-items:center;justify-content:center;\n    transition:background .15s;\n  }\n.hs-submit:hover{background:var(--accent)}\n.hero-side{display:grid;grid-template-rows:1.5fr 1fr;gap:16px;min-height:0}\n.hero-card{\n    position:relative;border-radius:18px;overflow:hidden;background:var(--bg-2);\n    opacity:0;animation:rise 1.1s cubic-bezier(.2,.7,.2,1) forwards;\n  }\n.hero-card:nth-of-type(1){animation-delay:.5s}\n.hero-card:nth-of-type(2){animation-delay:.7s}\n.hero-card img{width:100%;height:100%;object-fit:cover}\n.hero-card.edition{\n    background:var(--accent);color:#fff;display:flex;flex-direction:column;justify-content:space-between;padding:24px;\n  }\n.hero-card.edition img{position:absolute;inset:0;mix-blend-mode:multiply;opacity:.7}\n.hero-card.edition::after{\n    content:"";position:absolute;inset:0;background:linear-gradient(170deg, #ff4d2ed9 0%, #ff4d2e99 100%);\n  }\n.hero-card.edition > *{position:relative;z-index:2}\n.hero-card.edition .ed-no{\n    font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;font-weight:600;text-transform:uppercase;\n    display:flex;align-items:center;gap:10px;\n  }\n.hero-card.edition .ed-no::before{content:"";width:24px;height:1px;background:#fff}\n.hero-card.edition h4{\n    font-family:"Bricolage Grotesque",sans-serif;font-weight:800;\n    font-size:clamp(28px,3vw,42px);letter-spacing:-.03em;line-height:.95;text-transform:lowercase;\n  }\n.hero-card.edition h4 em{font-style:italic}\n.hero-card.edition .ed-foot{