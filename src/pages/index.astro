---
import Site from '../layouts/Site.astro';
import { supabase, applyNames, type Apartment } from '../lib/supabase';
import news from '../data/news.json';
const { data } = await supabase.from('apartments_public').select('id,slug,title,bedrooms,max_guests,price_from,photos,neighborhood').limit(6);
const apts = ((data as Apartment[]) || []).map(applyNames);
const homeApts = apts.map((a) => {
  const photo = (a.photos && a.photos[0]) || `https://picsum.photos/seed/${a.slug}/1200/900`;
  const bedType = a.bedrooms === 0 ? 'studio' : `${a.bedrooms ?? 1} bed`;
  const price = a.price_from ? `₾${a.price_from}<span class="u">/NT</span>` : `<span style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.04em">on request</span>`;
  const dist = a.neighborhood ? `<span class="dist">${a.neighborhood}</span>` : '';
  return `<a class="apt reveal" href="/stays/${a.slug}"><div class="ph"><img src="${photo}" alt="${a.title}"/><button class="fav" type="button" onclick="event.preventDefault();this.textContent=this.textContent==='♡'?'♥':'♡'">♡</button></div><div class="info"><div class="top"><h4>${a.title}</h4><div class="price">${price}</div></div><div class="sub"><span>${bedType} · ${a.max_guests ?? 2} guests</span>${dist}</div></div></a>`;
}).join('');

// --- real guide data for the homepage (from DB + news.json) ---
const { data: gpData } = await supabase.from('guide_places')
  .select('slug,title,name,category,tags,photos,image,take_title,summary').eq('status', 'published');
const places = (gpData as any[]) || [];
const counts: Record<string, number> = {};
places.forEach((p) => { counts[p.category] = (counts[p.category] || 0) + 1; });
const e2 = (s: any) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const md2 = (s: any) => e2(s).replace(/\*([^*]+)\*/g, '<em>$1</em>');
const gph = (p: any) => (p && ((p.photos && p.photos[0]) || p.image)) || '';
const clip2 = (s: any, n: number) => { const t = String(s || '').replace(/\s+/g, ' ').replace(/\*\*?/g, '').trim(); return t.length > n ? t.slice(0, n).replace(/[ ,;:.]+\S*$/, '') + '…' : t; };
const byCat = (c: string) => places.filter((p) => p.category === c);
const fmtDM = (d: string) => { const m = (d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? (m[3] + '/' + m[2]) : ''; };
const CATLBL: Record<string, string> = { 'eat-drink': 'eat & drink', 'wellness': 'wellness', 'work': 'work & remote', 'move-around': 'move around' };
const newsArr = (news as any[]).slice().sort((a, b) => String(b.date || '').localeCompare(String(a.date || '')));
const ed = newsArr[0];

const heroEdition = ed
  ? '<a class="hero-card edition" href="/guide/news/' + ed.slug + '"><img src="' + e2(ed.image || '') + '" alt=""/>' +
    '<div class="ed-no">the batumi guide · this week</div><h4>' + md2(ed.headline || ed.title) + '</h4>' +
    '<div class="ed-foot"><span><b>read the issue</b></span><span>↗</span></div></a>'
  : '';

const heroPick = places.find((p) => p.slug === 'bolt-taxi') || byCat('move-around')[0] || places[0];
const heroSimple = heroPick
  ? '<a class="hero-card simple" href="/guide/' + heroPick.slug + '"><span class="label">— from the guide</span>' +
    '<img src="' + e2(gph(heroPick)) + '" alt=""/><div class="meta"><h4>' + e2(heroPick.title || heroPick.name) + '</h4>' +
    '<div class="sub">↳ ' + (CATLBL[heroPick.category] || heroPick.category) + '</div></div></a>'
  : '';

const catCol = (key: string, h3: string) => {
  const list = byCat(key); if (!list.length) return '';
  const feat = list[0], posts = list.slice(1, 3);
  const tag = (p: any) => (p.tags && p.tags[0]) ? e2(p.tags[0]) : (CATLBL[key] || key);
  const featHtml = '<a class="feat" href="/guide/' + feat.slug + '"><div class="ph"><img src="' + e2(gph(feat)) + '" alt=""/><span class="tag">' + tag(feat) + '</span></div>' +
    '<div class="body"><span class="kicker">' + (CATLBL[key] || key) + '</span><h4>' + e2(feat.title || feat.name) + '</h4><p>' + e2(clip2(feat.summary || feat.take_title, 92)) + '</p></div></a>';
  const postsHtml = posts.map((p) => '<a class="post" href="/guide/' + p.slug + '"><div class="ph"><img src="' + e2(gph(p)) + '" alt=""/></div><div class="body"><span class="kicker">' + tag(p) + '</span><h4>' + e2(p.title || p.name) + '</h4></div></a>').join('');
  return '<div class="cat reveal"><div class="cat-head"><h3>' + h3 + '</h3><span class="count">' + (counts[key] || 0) + ' spots</span></div>' + featHtml + '<div class="cat-posts">' + postsHtml + '</div></div>';
};
const guideCats = catCol('eat-drink', 'eat &amp; <em>drink</em>') + catCol('wellness', '<em>wellness</em>') + catCol('move-around', 'move <em>around</em>');

const nowGuide = ed
  ? '<a href="/guide/news/' + ed.slug + '">' + e2(clip2(ed.title, 26)) + '</a><span class="small">→ fresh from batumi</span>'
  : '<a href="/guide">open the guide</a><span class="small">→ ' + places.length + ' places</span>';

const footPlace = byCat('eat-drink')[0];
const footItems = newsArr.slice(0, 2).map((n) => ({ href: '/guide/news/' + n.slug, ph: e2(n.image || ''), kick: 'news · ' + fmtDM(n.date), title: e2(n.title) }))
  .concat(footPlace ? [{ href: '/guide/' + footPlace.slug, ph: e2(gph(footPlace)), kick: 'eat & drink', title: e2(footPlace.title || footPlace.name) }] : []);
const footPosts = footItems.map((it) => '<a class="fp" href="' + it.href + '"><div class="ph"><img src="' + it.ph + '" alt=""/></div><div class="body"><div class="kicker">' + it.kick + '</div><h5>' + it.title + '</h5></div></a>').join('');
