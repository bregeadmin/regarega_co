<script is:inline>

  

  const cursor = document.getElementById('cursor');
    let mx=window.innerWidth/2, my=window.innerHeight/2, cx=mx, cy=my;
  window.addEventListener('mousemove', e => { mx=e.clientX; my=e.clientY; });
  function loop(){
    cx += (mx-cx)*0.7; cy += (my-cy)*0.7;
    if(cursor) cursor.style.transform = `translate(${cx}px,${cy}px) translate(-50%,-50%)`;
    requestAnimationFrame(loop);
  }
  loop();

  function clearCursorColors(){ cursor.classList.remove('teal','yellow','pink'); }

  document.querySelectorAll('a:not(.apt):not(.feat):not(.post):not(.hero-card):not(.fp):not(.spread):not(.channel):not(.door), button:not(.hs-field):not(.hs-submit)').forEach(el => {
    el.addEventListener('mouseenter', () => { clearCursorColors(); cursor.classList.add('big'); });
    el.addEventListener('mouseleave', () => cursor.classList.remove('big'));
  });

  document.querySelectorAll('.apt').forEach(el => {
    el.addEventListener('mouseenter', () => { clearCursorColors(); cursor.classList.add('text','teal'); cursor.setAttribute('data-label','view →'); });
    el.addEventListener('mouseleave', () => { cursor.classList.remove('text','teal'); cursor.removeAttribute('data-label'); });
  });

  document.querySelectorAll('.feat, .post, .hero-card, .fp, .spread').forEach(el => {
    el.addEventListener('mouseenter', () => { clearCursorColors(); cursor.classList.add('text','yellow'); cursor.setAttribute('data-label','read →'); });
    el.addEventListener('mouseleave', () => { cursor.classList.remove('text','yellow'); cursor.removeAttribute('data-label'); });
  });

  document.querySelectorAll('.channel').forEach(el => {
    el.addEventListener('mouseenter', () => { clearCursorColors(); cursor.classList.add('text','pink'); cursor.setAttribute('data-label','say hi →'); });
    el.addEventListener('mouseleave', () => { cursor.classList.remove('text','pink'); cursor.removeAttribute('data-label'); });
  });

  document.querySelectorAll('.door').forEach(el => {
    el.addEventListener('mouseenter', () => { clearCursorColors(); cursor.classList.add('text'); cursor.setAttribute('data-label','learn →'); });
    el.addEventListener('mouseleave', () => { cursor.classList.remove('text'); cursor.removeAttribute('data-label'); });
  });

  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, {threshold: 0.12, rootMargin: '0px 0px -80px 0px'});
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  let calYear = 2026, calMonth = 4;

  // burger menu
  (function(){
    const burger = document.getElementById('burger');
    const overlay = document.getElementById('menuOverlay');
    if (!burger || !overlay) return;
    function open(){
      overlay.hidden = false;
      requestAnimationFrame(()=> overlay.classList.add('open'));
      burger.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function close(){
      overlay.classList.remove('open');
      burger.classList.remove('open');
      document.body.style.overflow = '';
      setTimeout(()=> overlay.hidden = true, 320);
    }
    burger.addEventListener('click', () => {
      if (overlay.classList.contains('open')) close(); else open();
    });
    overlay.addEventListener('click', e => {
      if (e.target === overlay) close();
    });
    overlay.querySelectorAll('.menu-item, .menu-tg').forEach(a => {
      a.addEventListener('click', close);
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && overlay.classList.contains('open')) close();
    });
  })();

  // ===== LIVE "RIGHT NOW IN BATUMI" =====
  (function(){
    const BATUMI = { lat: 41.6508, lng: 41.6357, tz: 'Asia/Tbilisi' };

    // 1. Date — local Batumi time
    function setDate(){
      const now = new Date();
      const local = new Date(now.toLocaleString('en-US', {timeZone: BATUMI.tz}));
      const days = ['sunday','monday','tuesday','wednesday','thursday','friday','saturday'];
      const months = ['january','february','march','april','may','june','july','august','september','october','november','december'];
      const dateStr = `${days[local.getDay()]}, ${months[local.getMonth()]} ${local.getDate()}`;
      const el = document.getElementById('nowDate');
      if (el) el.textContent = dateStr;
    }
    setDate();
    setInterval(setDate, 60000);

    // 2. Weather + sunset — Open-Meteo, no API key
    function fetchWeather(){
      const url = `https://api.open-meteo.com/v1/forecast?latitude=${BATUMI.lat}&longitude=${BATUMI.lng}&current=temperature_2m,wind_speed_10m,weather_code&daily=sunset&timezone=${BATUMI.tz}`;
      fetch(url).then(r => r.json()).then(d => {
        if (!d || !d.current) return;
        const t = Math.round(d.current.temperature_2m);
        const wind = Math.round(d.current.wind_speed_10m);
        const code = d.current.weather_code;
        const sunset = d.daily && d.daily.sunset && d.daily.sunset[0];

        const tempEl = document.getElementById('nowTemp');
        if (tempEl) tempEl.textContent = t;

        const windEl = document.getElementById('nowWind');
        if (windEl) windEl.textContent = describeWind(wind);

        const descEl = document.getElementById('nowDesc');
        if (descEl) descEl.textContent = describeSky(code);

        if (sunset) {
          const time = sunset.split('T')[1].slice(0,5);
          const sunsetEl = document.getElementById('nowSunset');
          if (sunsetEl) sunsetEl.innerHTML = `${time}<span class="small">over the black sea</span>`;
        }
      }).catch(()=>{});
    }
    function describeSky(code){
      if (code === 0) return 'clear sky';
      if (code <= 3) return 'a bit of cloud';
      if (code <= 48) return 'foggy morning';
      if (code <= 67) return 'rain over the city';
      if (code <= 77) return 'snow on the hills';
      if (code <= 82) return 'rain showers';
      if (code <= 99) return 'thunderstorm';
      return 'mixed weather';
    }
    function describeWind(kmh){
      if (kmh < 5) return 'still air';
      if (kmh < 15) return 'light sea breeze';
      if (kmh < 25) return 'fresh breeze';
      if (kmh < 40) return 'windy';
      return 'strong wind';
    }
    fetchWeather();
    setInterval(fetchWeather, 10 * 60000); // refresh every 10 min
  })();



  // HOME DOT — flies on first scroll, fades after (per session)
  (function(){
    if(window.innerWidth < 880) return;
    const centerLogo = document.querySelector('.topbar .ctr');
    const centerDotEl = centerLogo && centerLogo.querySelector('.d');
    const leftDot = document.querySelector('.home-dot');
    const flyingDot = document.getElementById('flyingDot');
    if(!centerLogo || !centerDotEl || !leftDot || !flyingDot) return;

    const KEY = 'bre_dot_flight_seen';
    let hasSeenFlight = false;
    try { hasSeenFlight = sessionStorage.getItem(KEY) === 'yes'; } catch(e){}

    let state = 'top';
    let flying = false;

    function doFlight(){
      const centerRect = centerDotEl.getBoundingClientRect();
      const startX = centerRect.left + centerRect.width/2;
      const startY = centerRect.top + centerRect.height/2;
      leftDot.classList.add('expanded');
      setTimeout(()=>{
        const leftRect = leftDot.getBoundingClientRect();
        const endX = leftRect.left + leftRect.width/2;
        const endY = leftRect.top + leftRect.height/2;
        flyingDot.style.transition = 'none';
        flyingDot.style.transform = 'translate('+(startX-7)+'px, '+(startY-7)+'px) scale(0.71)';
        flyingDot.style.opacity = '1';
        centerDotEl.classList.add('hidden');
        flyingDot.getBoundingClientRect();
        flyingDot.style.transition = 'transform .85s cubic-bezier(.5,0,.2,1)';
        flyingDot.style.transform = 'translate('+(endX-7)+'px, '+(endY-7)+'px) scale(1)';
        setTimeout(()=>{
          leftDot.classList.add('visible','pulsing');
          flyingDot.style.transition = 'none';
          flyingDot.style.opacity = '0';
          flying = false;
          state = 'scrolled';
          try { sessionStorage.setItem(KEY, 'yes'); } catch(e){}
          hasSeenFlight = true;
        }, 860);
      }, 360);
    }

    function doFade(direction){
      if(direction === 'out'){
        centerDotEl.classList.add('hidden');
        leftDot.classList.add('expanded');
        setTimeout(()=> leftDot.classList.add('visible','pulsing'), 180);
        state = 'scrolled';
      } else {
        leftDot.classList.remove('visible','pulsing');
        setTimeout(()=>{
          leftDot.classList.remove('expanded');
          centerDotEl.classList.remove('hidden');
        }, 200);
        state = 'top';
      }
    }

    function onScroll(){
      const y = window.scrollY || document.documentElement.scrollTop;
      if(flying) return;
      if(y > 60 && state === 'top'){
        if(!hasSeenFlight){
          flying = true;
          state = 'flying';
          doFlight();
        } else {
          doFade('out');
        }
      } else if(y <= 60 && state === 'scrolled'){
        doFade('in');
      }
    }

    window.addEventListener('scroll', onScroll, {passive:true});
    onScroll();
  })();




  // Topbar scroll state — adds .scrolled class when scrolled past hero
  (function(){
    const tb = document.querySelector('.topbar');
    if(!tb) return;
    function update(){
      const y = window.scrollY || document.documentElement.scrollTop;
      if(y > 40) tb.classList.add('scrolled');
      else tb.classList.remove('scrolled');
    }
    window.addEventListener('scroll', update, {passive:true});
    update();
  })();
  // HERO SEARCHBAR — redirect to /stays where full pickers live
  function submitHeroSearch(e){
    e.preventDefault();
    window.location.href = '/stays';
    return false;
  }
  // Clicking any field also goes to /stays
  ['hsDateBtn','hsGuestBtn'].forEach(id=>{
    const el = document.getElementById(id);
    if(el) el.addEventListener('click', ()=>{ window.location.href='/stays'; });
  });

</script>
