---
import Site from '../layouts/Site.astro';
---
<Site>
<section class="hero">
  <div class="hero-main">
    <a class="hero-main-img" href="/stays" aria-label="all apartments">
      <img src="https://images.unsplash.com/photo-1502672023488-70e25813eb80?w=2000&q=80" alt="bre apartment" onerror="this.src='https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=2000&q=80'"/>
    </a>
    <h1 class="hero-h1">
      find a flat,<br/>
      <span class="row2"><em>fall</em> for the city</span>
    </h1>
    <form class="hero-search" id="heroSearch" onsubmit="return submitHeroSearch(event)">
      <button type="button" class="hs-field" id="hsDateBtn">
        <span class="hs-lbl">— dates</span>
        <span class="hs-val" id="hsDateVal">add dates</span>
      </button>
      <button type="button" class="hs-field" id="hsGuestBtn">
        <span class="hs-lbl">— guests</span>
        <span class="hs-val" id="hsGuestVal">2 guests</span>
      </button>
      <button type="submit" class="hs-submit" aria-label="search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
    </form>
  </div>

  <div class="hero-side">
    <a class="hero-card edition" href="/guide">
      <img src="https://images.unsplash.com/photo-1559561853-08451507cbe7?w=900&q=80" alt=""/>
      <div class="ed-no">the batumi guide · this week</div>
      <h4>oyster <em>weekend</em>,<br/>and how to find<br/>the best coffee.</h4>
      <div class="ed-foot">
        <span><b>read the issue</b></span>
        <span>↗</span>
      </div>
    </a>
    <a class="hero-card simple" href="/guide/bolt-taxi-batumi">
      <span class="label">— from the guide</span>
      <img src="https://images.unsplash.com/photo-1502920514313-52581002a659?w=900&q=80" alt=""/>
      <div class="meta">
        <h4>bolt taxi — how it works in batumi</h4>
        <div class="sub">↳ a 4-min explainer</div>
      </div>
    </a>
  </div>
</section>

<section class="pad" id="stays">
  <div class="section-head reveal">
    <div>
      <div class="meta"><span class="dot"></span>— 01 / available now</div>
      <h2 style="margin-top:18px">stay with<br/><em>us</em>.</h2>
    </div>
    <div class="right"><b>apartments across batumi</b>. honestly photographed, fairly priced, stocked with the things you forgot to bring. each one with its own guide.</div>
  </div>

  <div class="apts">
    <a class="apt reveal" href="/stays/orbi-21">
      <div class="ph">
        <img src="https://images.unsplash.com/photo-1502672023488-70e25813eb80?w=1200&q=80" alt=""/>
        <span class="badge hot">just listed</span>
        <button class="fav" type="button" onclick="event.preventDefault();this.textContent=this.textContent==='♡'?'♥':'♡'">♡</button>
      </div>
      <div class="info">
        <div class="top"><h4>orbi sea towers — 21st</h4><div class="price">$185<span class="u">/NT</span></div></div>
        <div class="sub"><span>1 bed · 48m² · sea view</span><span class="dist">hot beach</span></div>
      </div>
    </a>

    <a class="apt reveal" href="/stays/boulevard-loft">
      <div class="ph">
        <img src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=1200&q=80" alt=""/>
        <button class="fav" type="button" onclick="event.preventDefault();this.textContent=this.textContent==='♡'?'♥':'♡'">♡</button>
      </div>
      <div class="info">
        <div class="top"><h4>old boulevard loft</h4><div class="price">$95<span class="u">/NT</span></div></div>
        <div class="sub"><span>studio · 36m²</span><span class="dist">old town</span></div>
      </div>
    </a>

    <a class="apt reveal" href="/stays/botanical">
      <div class="ph">
        <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=1200&q=80" alt=""/>
        <span class="badge">long stay</span>
        <button class="fav" type="button" onclick="event.preventDefault();this.textContent=this.textContent==='♡'?'♥':'♡'">♡</button>
      </div>
      <div class="info">
        <div class="top"><h4>botanical garden house</h4><div class="price">$140<span class="u">/NT</span></div></div>
        <div class="sub"><span>2 bed · 72m² · garden</span><span class="dist">botanical</span></div>
      </div>
    </a>

    <a class="apt reveal" href="/stays/chavchavadze">
      <div class="ph">
        <img src="https://images.unsplash.com/photo-1493809842364-78817add7ffb?w=1200&q=80" alt=""/>
        <button class="fav" type="button" onclick="event.preventDefault();this.textContent=this.textContent==='♡'?'♥':'♡'">♡</button>
      </div>
      <div class="info">
        <div class="top"><h4>chavchavadze, 4th line</h4><div class="price">$78<span class="u">/NT</span></div></div>
        <div class="sub"><span>1 bed · 42m² · city</span><span class="dist">chavchavadze</span></div>
      </div>
    </a>

    <a class="apt reveal" href="/stays/arena">
      <div class="ph">
        <img src="https://images.unsplash.com/photo-1505691938895-1758d7feb511?w=1200&q=80" alt=""/>
        <span class="badge hot">2 nights left</span>
        <button class="fav" type="button" onclick="event.preventDefault();this.textContent=this.textContent==='♡'?'♥':'♡'">♡</button>
      </div>
      <div class="info">
        <div class="top"><h4>black sea arena view</h4><div class="price">$160<span class="u">/NT</span></div></div>
        <div class="sub"><span>2 bed · 65m² · sea</span><span class="dist">arena</span></div>
      </div>
    </a>

    <a class="apt reveal" href="/stays/gonio">
      <div class="ph">
        <img src="https://images.unsplash.com/photo-1554995207-c18c203602cb?w=1200&q=80" alt=""/>
        <span class="badge">house</span>
        <button class="fav" type="button" onclick="event.preventDefault();this.textContent=this.textContent==='♡'?'♥':'♡'">♡</button>
      </div>
      <div class="info">
        <div class="top"><h4>gonio cape</h4><div class="price">$240<span class="u">/NT</span></div></div>
        <div class="sub"><span>4 bed · 180m² · beach</span><span class="dist">gonio</span></div>
      </div>
    </a>
  </div>

  <div class="more"><a href="/stays">see all apartments →</a></div>
</section>

<section class="spread">
  <img src="https://images.unsplash.com/photo-1604542031658-5799ca5d7936?w=2400&q=80" alt="batumi old town"/>
  <div class="inner">
    <h2>the batumi<br/>we <em>actually</em><br/>recommend.</h2>
    <p class="lede">our own city guide — written by us, not scraped from tripadvisor. cafés, restaurants, beaches, wellness, nightlife — sorted by where you'll actually want to spend an afternoon.</p>
    <div class="spread-cta">
      <a class="btn" href="/guide">open the guide →</a>
    </div>
  </div>
</section>

<section class="guide-wrap" id="guide">
  <div class="section-head reveal">
    <div>
      <div class="meta"><span class="dot"></span>— in this issue</div>
    </div>
    <div class="right">a selection from <b>eight categories</b>. one hundred plus spots, hand-picked.</div>
  </div>

  <div class="guide-categories">
    <div class="cat reveal">
      <div class="cat-head">
        <h3>eat &amp; <em>drink</em></h3>
        <span class="count">42 spots</span>
      </div>
      <a class="feat" href="/guide/nova-coffee">
        <div class="ph">
          <img src="https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=1000&q=80" alt=""/>
          <span class="tag">coffee</span>
        </div>
        <div class="body">
          <span class="kicker">eat &amp; drink · 3 min read</span>
          <h4>nova coffee — proper specialty in town</h4>
          <p>a clean room, a real espresso machine, beans roasted weekly. you can sit and read.</p>
        </div>
      </a>
      <div class="cat-posts">
        <a class="post" href="/guide/milevski-coffee">
          <div class="ph"><img src="https://images.unsplash.com/photo-1559561853-08451507cbe7?w=400&q=80" alt=""/></div>
          <div class="body"><span class="kicker">coffee</span><h4>milevski coffee — pour-over &amp; community</h4></div>
        </a>
        <a class="post" href="/guide/japan-33">
          <div class="ph"><img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=400&q=80" alt=""/></div>
          <div class="body"><span class="kicker">restaurant</span><h4>japan 33 — sunset dinners over the sea</h4></div>
        </a>
      </div>
    </div>

    <div class="cat reveal">
      <div class="cat-head">
        <h3>move <em>around</em></h3>
        <span class="count">12 posts</span>
      </div>
      <a class="feat" href="/guide/bolt-taxi-batumi">
        <div class="ph">
          <img src="https://images.unsplash.com/photo-1502920514313-52581002a659?w=1000&q=80" alt=""/>
          <span class="tag">how-to</span>
        </div>
        <div class="body">
          <span class="kicker">move around · 4 min read</span>
          <h4>bolt taxi — how it works in batumi</h4>
          <p>the local uber. 3 taps, card payment, anywhere from old town to gonio for under 10 lari.</p>
        </div>
      </a>
      <div class="cat-posts">
        <a class="post" href="/guide/airport-transfer">
          <div class="ph"><img src="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=400&q=80" alt=""/></div>
          <div class="body"><span class="kicker">how-to</span><h4>from the airport — three options that actually work</h4></div>
        </a>
        <a class="post" href="/guide/marshrutkas">
          <div class="ph"><img src="https://images.unsplash.com/photo-1473445730015-841f29a9490b?w=400&q=80" alt=""/></div>
          <div class="body"><span class="kicker">how-to</span><h4>marshrutkas — the local mini-bus, decoded</h4></div>
        </a>
      </div>
    </div>

    <div class="cat reveal">
      <div class="cat-head">
        <h3><em>wellness</em></h3>
        <span class="count">18 spots</span>
      </div>
      <a class="feat" href="/guide/pure-bistro-oyster-weekend">
        <div class="ph">
          <img src="https://images.unsplash.com/photo-1559561853-08451507cbe7?w=1000&q=80" alt=""/>
          <span class="tag news">news · 07/05</span>
        </div>
        <div class="body">
          <span class="kicker">news · this saturday</span>
          <h4>pure bistro — oyster weekend, 08–10/05</h4>
          <p>fresh oysters, cava and crémant at one of our favorite brunch &amp; dinner spots in batumi.</p>
        </div>
      </a>
      <div class="cat-posts">
        <a class="post" href="/guide/kava-lova-popup">
          <div class="ph"><img src="https://images.unsplash.com/photo-1551782450-a2132b4ba21d?w=400&q=80" alt=""/></div>
          <div class="body"><span class="kicker">news · 13/05</span><h4>15/05 cocktail pop-up at kava lova with vanya</h4></div>
        </a>
        <a class="post" href="/guide/botanical-garden-may">
          <div class="ph"><img src="https://images.unsplash.com/photo-1530631673369-bc20fdb32288?w=400&q=80" alt=""/></div>
          <div class="body"><span class="kicker">photo essay</span><h4>the botanical garden, in may</h4></div>
        </a>
      </div>
    </div>
  </div>
</section>

<section class="now">
  <div class="now-grid">
    <div>
      <div class="now-label"><span class="pulse"></span>right now in batumi</div>
      <div class="now-val"><span id="nowDate">today</span><span class="small" id="nowDesc">checking the sky…</span></div>
    </div>
    <div>
      <div class="now-label">temperature</div>
      <div class="now-val"><span id="nowTemp">—</span><em>°</em>C<span class="small" id="nowWind">light sea breeze</span></div>
    </div>
    <div>
      <div class="now-label">sunset</div>
      <div class="now-val" id="nowSunset">—:—<span class="small">over the black sea</span></div>
    </div>
    <div>
      <div class="now-label">from the guide</div>
      <div class="now-val"><a href="/guide/pure-bistro-oyster-weekend">oyster weekend</a><span class="small">→ pure bistro, sat–sun</span></div>
    </div>
  </div>
</section>

<section class="pull">
  <blockquote class="reveal">
    we do<br/>the <span class="underline"><em>flat</em></span>.<br/>you do<br/>the <span class="underline"><em>city</em></span>.
  </blockquote>
  <div class="sig">— bre, batumi</div>
</section>

<section class="doors-wrap" id="own">
  <div class="section-head reveal">
    <div>
      <div class="meta"><span class="dot"></span>— not here to book?</div>
      <h2 style="margin-top:18px">we help you <em>buy</em><br/>and <em>manage</em> after.</h2>
    </div>
    <div class="right">if you own a flat in batumi — or want to — let's talk. we've done this <b>120+ times</b> already.</div>
  </div>

  <div class="doors">
    <a class="door reveal" href="/own">
      <div>
        <div class="num">i. for owners</div>
        <h3>just hand us<br/>the <em>keys</em>.</h3>
        <p>full-service short and mid-term rental. 30% commission, all-in. guests in 5 languages, photos, dynamic pricing, cleaning, the lot.</p>
      </div>
      <div>
        <div class="stat"><b>30%</b><span>commission · all-in</span></div>
        <span class="cta">how it works <span>→</span></span>
      </div>
    </a>

    <a class="door reveal" href="/invest" id="invest">
      <div>
        <div class="num">ii. for investors</div>
        <h3>buy a flat<br/>that <em>pays</em>.</h3>
        <p>we find the best flats, renovate, list, manage. you see numbers, not stress. average net yield across our portfolio.</p>
      </div>
      <div>
        <div class="stat"><b>11%</b><span>annual yield · avg.</span></div>
        <span class="cta">talk to us <span>→</span></span>
      </div>
    </a>
  </div>
</section>

<section class="contact" id="contact">
  <h2 class="reveal">say<br/><em>hi</em>.</h2>

  <div class="channels reveal">
    <a class="channel" href="https://t.me/bre_ge"><span class="label">telegram</span><span class="value">@bre_ge</span><span class="ar">→</span></a>
    <a class="channel" href="#"><span class="label">whatsapp</span><span class="value">+49 176 596 981 64</span><span class="ar">→</span></a>
    <a class="channel" href="tel:+995585889601"><span class="label">phone</span><span class="value">+995 585 889 601</span><span class="ar">→</span></a>
    <a class="channel" href="https://t.me/batumirealflats"><span class="label">channel</span><span class="value">t.me/batumirealflats</span><span class="ar">→</span></a>
    <div class="channel"><span class="label">office</span><span class="value">batumi, georgia</span><span class="ar">— 41.6°N 41.6°E</span></div>
  </div>
</section>

<section class="footer-guide">
  <div class="footer-guide-head">
    <h4>last week<br/>we <em>wrote</em> ↓</h4>
    <a href="/guide" class="all">all 100+ posts →</a>
  </div>
  <div class="footer-posts">
    <a class="fp" href="/guide/pure-bistro-oyster-weekend">
      <div class="ph"><img src="https://images.unsplash.com/photo-1559561853-08451507cbe7?w=300&q=80" alt=""/></div>
      <div class="body">
        <div class="kicker">news · 07/05</div>
        <h5>oyster weekend at pure bistro, 08–10/05</h5>
      </div>
    </a>
    <a class="fp" href="/guide/kava-lova-popup">
      <div class="ph"><img src="https://images.unsplash.com/photo-1551782450-a2132b4ba21d?w=300&q=80" alt=""/></div>
      <div class="body">
        <div class="kicker">news · 13/05</div>
        <h5>15/05 cocktail pop-up at kava lova with vanya</h5>
      </div>
    </a>
    <a class="fp" href="/guide/japan-33">
      <div class="ph"><img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=300&q=80" alt=""/></div>
      <div class="body">
        <div class="kicker">restaurant · new</div>
        <h5>japan 33 — sunset dinners over the sea</h5>
      </div>
    </a>
  </div>
</section>

<style is:global>
.hero{
    position:relative;height:100vh;min-height:640px;max-height:880px;overflow:hidden;
    padding:88px 24px 24px;
    display:grid;grid-template-columns:1.4fr 1fr;gap:16px;
  }
.hero-main{
    display:block;position:relative;border-radius:18px;overflow:hidden;background:#0a0908;
  }
.hero-main-img{display:block;position:absolute;inset:0;text-decoration:none;color:inherit}
.hero-main-img img{width:100%;height:100%;object-fit:cover;transform:scale(1.05);animation:slowzoom 22s ease-out infinite alternate}
.hero-main::after{
    content:"";position:absolute;inset:0;pointer-events:none;
    background:linear-gradient(180deg, #0a09084d 0%, transparent 25%, transparent 45%, #0a0908e0 100%);
  }
.hero-h1{
    position:absolute;left:32px;right:32px;bottom:118px;z-index:2;color:#fff;
    font-family:"Bricolage Grotesque",sans-serif;font-weight:800;
    font-size:clamp(40px,4.5vw,80px);line-height:.92;letter-spacing:-.04em;
    text-transform:lowercase;pointer-events:none;
    opacity:0;animation:rise 1.1s cubic-bezier(.2,.7,.2,1) .3s forwards;
  }
.hero-h1 em{font-style:italic;color:var(--accent)}
.hero-h1 .row2{display:block;margin-left:.5em}
.hero-search{
    position:absolute;left:24px;right:24px;bottom:24px;z-index:3;
    display:grid;grid-template-columns:1.4fr 1fr auto;gap:0;
    background:rgba(255,255,255,0.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
    border-radius:14px;padding:6px;
    box-shadow:0 8px 32px rgba(0,0,0,0.18);
    opacity:0;animation:rise 1.1s cubic-bezier(.2,.7,.2,1) .65s forwards;
  }
.hs-field{
    background:transparent;border:none;cursor:pointer;text-align:left;padding:12px 18px;
    border-radius:10px;display:flex;flex-direction:column;gap:3px;
    transition:background .12s;
    border-right:1px solid rgba(10,9,8,0.08);
  }
.hs-field:hover{background:rgba(10,9,8,0.04)}
.hs-field:last-of-type{border-right:none}
.hs-lbl{
    font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.18em;
    color:var(--ink-soft);font-weight:600;text-transform:uppercase;
  }
.hs-val{
    font-family:"Bricolage Grotesque",sans-serif;font-size:15px;color:var(--ink);
    font-weight:600;text-transform:lowercase;letter-spacing:-.01em;
  }
.hs-val.empty{color:var(--ink-fade);font-weight:400}
.hs-submit{
    background:var(--ink);border:none;color:#fff;border-radius:10px;
    width:54px;height:auto;cursor:pointer;
    display:flex;align-items:center;justify-content:center;
    transition:background .15s;
  }
.hs-submit:hover{background:var(--accent)}
.hero-side{display:grid;grid-template-rows:1.5fr 1fr;gap:16px;min-height:0}
.hero-card{
    position:relative;border-radius:18px;overflow:hidden;background:var(--bg-2);
    opacity:0;animation:rise 1.1s cubic-bezier(.2,.7,.2,1) forwards;
  }
.hero-card:nth-of-type(1){animation-delay:.5s}
.hero-card:nth-of-type(2){animation-delay:.7s}
.hero-card img{width:100%;height:100%;object-fit:cover}
.hero-card.edition{
    background:var(--accent);color:#fff;display:flex;flex-direction:column;justify-content:space-between;padding:24px;
  }
.hero-card.edition img{position:absolute;inset:0;mix-blend-mode:multiply;opacity:.7}
.hero-card.edition::after{
    content:"";position:absolute;inset:0;background:linear-gradient(170deg, #ff4d2ed9 0%, #ff4d2e99 100%);
  }
.hero-card.edition > *{position:relative;z-index:2}
.hero-card.edition .ed-no{
    font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;font-weight:600;text-transform:uppercase;
    display:flex;align-items:center;gap:10px;
  }
.hero-card.edition .ed-no::before{content:"";width:24px;height:1px;background:#fff}
.hero-card.edition h4{
    font-family:"Bricolage Grotesque",sans-serif;font-weight:800;
    font-size:clamp(28px,3vw,42px);letter-spacing:-.03em;line-height:.95;text-transform:lowercase;
  }
.hero-card.edition h4 em{font-style:italic}
.hero-card.edition .ed-foot{
    display:flex;justify-content:space-between;align-items:flex-end;
    font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.18em;font-weight:500;text-transform:uppercase;
  }
.hero-card.edition .ed-foot b{font-weight:600}
.hero-card.simple .label{
    position:absolute;top:18px;left:18px;z-index:2;
    background:#fff;color:var(--ink);padding:6px 10px;border-radius:999px;
    font-family:"JetBrains Mono",monospace;font-size:9px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;
  }
.hero-card.simple .meta{position:absolute;left:18px;right:18px;bottom:18px;z-index:2;color:#fff}
.hero-card.simple .meta::before{content:"";position:absolute;inset:-60px -18px -18px -18px;background:linear-gradient(to top, #000c, transparent);z-index:-1;pointer-events:none}
.hero-card.simple .meta h4{font-family:"Bricolage Grotesque",sans-serif;font-weight:700;font-size:18px;letter-spacing:-.025em;line-height:1.1;text-transform:lowercase}
.hero-card.simple .meta .sub{font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.18em;text-transform:uppercase;opacity:.85;margin-top:6px;font-weight:500}
section{position:relative;z-index:2}
.pad{padding:140px 28px}
.section-head{display:flex;justify-content:space-between;align-items:flex-end;gap:32px;margin-bottom:56px;flex-wrap:wrap}
