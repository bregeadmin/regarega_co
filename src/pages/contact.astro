---
import Site from '../layouts/Site.astro';
const content = '<section class="hero">\n  <div class="meta-line"><span class="dot"></span>— contact &amp; help</div>\n  <h1>talk to <em>us</em>.</h1>\n  <p>The fastest way to reach us is <b>Telegram</b> — we read it within minutes during waking hours. Email and WhatsApp work too. We answer in English, Russian and Georgian.</p>\n</section>\n\n<section class="channels">\n  <a class="channel-card" href="https://t.me/bre_ge">\n    <div class="ch-top">\n      <h3>Telegram</h3>\n      <span class="ch-icon primary">primary</span>\n    </div>\n    <p><b>@bre_ge</b> — apartments, bookings, owner questions. Usually replied within 30 minutes.</p>\n    <span class="ch-action">↗ open in telegram</span>\n  </a>\n\n  <a class="channel-card" href="https://wa.me/995585889601">\n    <div class="ch-top">\n      <h3>WhatsApp</h3>\n      <span class="ch-icon">also good</span>\n    </div>\n    <p><b>+995 585 889 601</b> — voice notes and photos easier to share here. Same number as our phone.</p>\n    <span class="ch-action">↗ open in whatsapp</span>\n  </a>\n\n  <a class="channel-card" href="mailto:hello@bre.ge">\n    <div class="ch-top">\n      <h3>Email</h3>\n      <span class="ch-icon">for long stuff</span>\n    </div>\n    <p><b>hello@bre.ge</b> — contracts, attachments, anything that needs a paper trail. Usually replied within a day.</p>\n    <span class="ch-action">↗ write us</span>\n  </a>\n\n  <a class="channel-card" href="tel:+995585889601">\n    <div class="ch-top">\n      <h3>Phone</h3>\n      <span class="ch-icon">when needed</span>\n    </div>\n    <p><b>+995 585 889 601</b> — call us if it\'s urgent. We don\'t always pick up, but we\'ll call back.</p>\n    <span class="ch-action">↗ call</span>\n  </a>\n</section>\n\n<section class="form-wrap">\n  <div class="form-intro">\n    <div class="meta-line"><span class="dot"></span>— or write directly</div>\n    <h2>or <em>write</em> us right here.</h2>\n    <p>If you don\'t have Telegram or just prefer a form — this works too. Goes straight to our inbox.</p>\n  </div>\n  <form class="form" onsubmit="event.preventDefault();this.querySelector(\'.submit\').textContent=\'thanks — we\\\'ll reply soon\';this.querySelector(\'.submit\').disabled=true;">\n    <div class="row">\n      <div class="field">\n        <label>— your name</label>\n        <input type="text" placeholder="Mike Johnson" required>\n      </div>\n      <div class="field">\n        <label>— how to reach you</label>\n        <input type="text" placeholder="email or @telegram" required>\n      </div>\n    </div>\n    <div class="field">\n      <label>— what\'s this about</label>\n      <select>\n        <option>I want to book an apartment</option>\n        <option>I\'m an owner — manage my flat</option>\n        <option>I want to invest in Batumi</option>\n        <option>Press / partnership</option>\n        <option>Something else</option>\n      </select>\n    </div>\n    <div class="field">\n      <label>— your message</label>\n      <textarea placeholder="Tell us what you need. Even rough drafts are fine — we\'ll figure it out together." required></textarea>\n    </div>\n    <button type="submit" class="submit">Send →</button>\n    <p class="note">We read every message ourselves. <b>No bots, no autoresponders.</b> Replies come from a real human within a day, usually faster.</p>\n  </form>\n</section>\n\n<section class="faq-pointer">\n  <div class="inner">\n    <h3>Have a quick question?</h3>\n    <p>For anything time-sensitive — when you\'re already on the way, in the apartment, or need a number changed — Telegram is the fastest. We\'re real people with real notifications.</p>\n    <a href="https://t.me/bre_ge" class="tg-btn">↗ open telegram now</a>\n  </div>\n</section>';
const css = '.hero{padding:160px 28px 80px;text-align:left;max-width:1400px;margin:0 auto}\n.meta-line{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);font-weight:500;display:flex;align-items:center;gap:14px;margin-bottom:24px}\n.meta-line .dot{width:6px;height:6px;border-radius:50%;background:var(--page)}\n.hero p{font-size:17px;line-height:1.55;color:var(--ink-soft);max-width:48ch;margin-top:24px}\n.hero p b{color:var(--ink);font-weight:600}\n.channels{padding:0 28px 80px;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:repeat(2,1fr);gap:18px}\n.channel-card{display:flex;flex-direction:column;justify-content:space-between;gap:18px;padding:28px 32px;background:var(--paper);border:1px solid var(--line);border-radius:14px;min-height:200px;transition:border-color .25s ease,transform .25s ease}\n.channel-card:hover{border-color:var(--page);transform:translateY(-2px)}\n.channel-card .ch-top{display:flex;justify-content:space-between;align-items:flex-start;gap:14px}\n.channel-card h3{font-family:"Bricolage Grotesque",sans-serif;font-weight:700;font-size:28px;letter-spacing:-.025em;line-height:1.05;text-transform:lowercase}\n.channel-card .ch-icon{font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;color:var(--ink-soft);padding:5px 10px;border:1px solid var(--line-strong);border-radius:999px}\n.channel-card .ch-icon.primary{background:var(--page);color:#fff;border-color:var(--page)}\n.channel-card p{font-size:14.5px;line-height:1.55;color:var(--ink-soft)}\n.channel-card p b{color:var(--ink);font-weight:600}\n.channel-card .ch-action{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;color:var(--page);display:inline-flex;align-items:center;gap:6px}\n.form-wrap{padding:0 28px 100px;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1fr 1.4fr;gap:60px;align-items:start}\n.form-intro h2{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(36px,5vw,56px);line-height:.95;letter-spacing:-.035em;text-transform:lowercase}\n.form-intro h2 em{font-style:italic;color:var(--page)}\n.form-intro p{margin-top:20px;font-size:15px;line-height:1.6;color:var(--ink-soft);max-width:36ch}\n.form-intro .meta-line{margin-bottom:18px}\n.form{display:flex;flex-direction:column;gap:14px;padding:32px;background:var(--paper);border:1px solid var(--line);border-radius:14px}\n.form .field{display:flex;flex-direction:column;gap:5px}\n.form label{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);font-weight:600}\n.form input,.form select,.form textarea{font-family:"Bricolage Grotesque",sans-serif;font-weight:500;font-size:15px;padding:12px 14px;border:1px solid var(--line-strong);border-radius:8px;background:#fff;color:var(--ink);outline:0;transition:border-color .2s ease}\n.form input:focus,.form select:focus,.form textarea:focus{border-color:var(--page)}\n.form textarea{min-height:120px;resize:vertical;line-height:1.5}\n.form .row{display:grid;grid-template-columns:1fr 1fr;gap:14px}\n.form .submit{padding:16px 24px;background:var(--ink);color:#fff;border:0;border-radius:999px;font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;cursor:pointer;transition:background .2s ease;margin-top:4px}\n.form .submit:hover{background:var(--page)}\n.form .note{font-size:12px;color:var(--ink-soft);line-height:1.5}\n.form .note b{color:var(--ink)}\n.faq-pointer{padding:60px 28px;background:var(--bg-2);text-align:center}\n.faq-pointer .inner{max-width:680px;margin:0 auto}\n.faq-pointer h3{font-family:"Bricolage Grotesque",sans-serif;font-weight:700;font-size:28px;letter-spacing:-.025em;text-transform:lowercase;margin-bottom:14px}\n.faq-pointer p{font-size:15px;line-height:1.6;color:var(--ink-soft);margin-bottom:24px}\n.faq-pointer .tg-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 24px;background:var(--ink);color:#fff;border-radius:999px;font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;transition:background .2s ease}\n.faq-pointer .tg-btn:hover{background:var(--page)}\n@media (max-width:880px){\n.hero{padding:100px 14px 40px}\n.channels{padding:0 14px 48px;grid-template-columns:1fr;gap:12px}\n.channel-card{padding:22px 24px;min-height:auto}\n.form-wrap{padding:0 14px 64px;grid-template-columns:1fr;gap:32px}\n.form{padding:22px}\n.form .row{grid-template-columns:1fr;gap:14px}\n.faq-pointer{padding:48px 14px}\n}';
const js = "const cursor = document.getElementById('cursor');\nlet mx=window.innerWidth/2,my=window.innerHeight/2,cx=mx,cy=my;\nwindow.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});\nfunction loop(){cx+=(mx-cx)*0.7;cy+=(my-cy)*0.7;if(cursor)cursor.style.transform=`translate(${cx}px,${cy}px) translate(-50%,-50%)`;requestAnimationFrame(loop)}\nloop();\ndocument.querySelectorAll('a,button').forEach(el=>{\n  el.addEventListener('mouseenter',()=>cursor.classList.add('big'));\n  el.addEventListener('mouseleave',()=>cursor.classList.remove('big'));\n});\n\n// HOME DOT\n(function(){\n  if(window.innerWidth < 880) return;\n  const centerLogo = document.querySelector('.topbar .ctr');\n  const centerDotEl = centerLogo && centerLogo.querySelector('.d');\n  const leftDot = document.querySelector('.home-dot');\n  const flyingDot = document.getElementById('flyingDot');\n  if(!centerLogo||!centerDotEl||!leftDot||!flyingDot)return;\n  const KEY='bre_dot_flight_seen';\n  let hasSeenFlight=false;\n  try{hasSeenFlight=sessionStorage.getItem(KEY)==='yes'}catch(e){}\n  let state='top',flying=false;\n  function doFlight(){\n    const centerRect=centerDotEl.getBoundingClientRect();\n    const startX=centerRect.left+centerRect.width/2,startY=centerRect.top+centerRect.height/2;\n    leftDot.classList.add('expanded');\n    setTimeout(()=>{\n      const leftRect=leftDot.getBoundingClientRect();\n      const endX=leftRect.left+leftRect.width/2,endY=leftRect.top+leftRect.height/2;\n      flyingDot.style.transition='none';\n      flyingDot.style.transform='translate('+(startX-7)+'px,'+(startY-7)+'px) scale(0.71)';\n      flyingDot.style.opacity='1';\n      centerDotEl.classList.add('hidden');\n      flyingDot.getBoundingClientRect();\n      flyingDot.style.transition='transform .85s cubic-bezier(.5,0,.2,1)';\n      flyingDot.style.transform='translate('+(endX-7)+'px,'+(endY-7)+'px) scale(1)';\n      setTimeout(()=>{\n        leftDot.classList.add('visible','pulsing');\n        flyingDot.style.transition='none';\n        flyingDot.style.opacity='0';\n        flying=false;state='scrolled';\n        try{sessionStorage.setItem(KEY,'yes')}catch(e){}\n        hasSeenFlight=true;\n      },860);\n    },360);\n  }\n  function doFade(direction){\n    if(direction==='out'){\n      centerDotEl.classList.add('hidden');\n      leftDot.classList.add('expanded');\n      setTimeout(()=>leftDot.classList.add('visible','pulsing'),180);\n      state='scrolled';\n    } else {\n      leftDot.classList.remove('visible','pulsing');\n      setTimeout(()=>{leftDot.classList.remove('expanded');centerDotEl.classList.remove('hidden')},200);\n      state='top';\n    }\n  }\n  window.addEventListener('scroll',()=>{\n    const y=window.scrollY||document.documentElement.scrollTop;\n    if(flying)return;\n    if(y>60&&state==='top'){\n      if(!hasSeenFlight){flying=true;state='flying';doFlight()}\n      else{doFade('out')}\n    } else if(y<=60&&state==='scrolled'){doFade('in')}\n  },{passive:true});\n})();\n\n  // Topbar scroll state — adds .scrolled class when scrolled past hero\n  (function(){\n    const tb = document.querySelector('.topbar');\n    if(!tb) return;\n    function update(){\n      const y = window.scrollY || document.documentElement.scrollTop;\n      if(y > 40) tb.classList.add('scrolled');\n      else tb.classList.remove('scrolled');\n    }\n    window.addEventListener('scroll', update, {passive:true});\n    update();\n  })();";
---
<Site title={'contact — rega rega'}>
<Fragment set:html={content} />
<style is:global set:html={css}></style>
<script is:inline set:html={js}></script>
</Site>
