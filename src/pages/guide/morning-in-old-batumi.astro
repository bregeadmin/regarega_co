ative;overflow:hidden;height:min(70vh,640px);min-height:380px}\n.hero-photo img{width:100%;height:100%;object-fit:cover;transform:scale(1.04);animation:slowzoom 22s ease-out infinite alternate}\n.hero-photo .cap{position:absolute;left:28px;bottom:18px;color:#fff;font-family:\"JetBrains Mono\",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:500;text-shadow:0 1px 6px #0a09088c;background:#0a09084d;backdrop-filter:blur(4px);padding:6px 12px;border-radius:999px}\n.lede{padding:88px 28px 32px}\n.lede .inner{max-width:680px;margin:0 auto;font-family:\"Newsreader\",Georgia,serif;font-style:italic;font-size:clamp(22px,2.3vw,30px);line-height:1.45;color:var(--ink);font-weight:400}\n.lede .inner p + p{margin-top:18px}\n.lede .inner em{color:var(--page);font-style:italic}\n.section{padding:40px 28px}\n.section .inner{max-width:680px;margin:0 auto}\n.section .time{font-family:\"JetBrains Mono\",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--page);font-weight:700;margin-bottom:18px;display:flex;align-items:center;gap:12px}\n.section .time::before{content:\"\";flex:none;width:24px;height:2px;background:var(--page)}\n.section h2{font-family:\"Bricolage Grotesque\",sans-serif;font-weight:800;font-size:clamp(32px,4vw,52px);line-height:1;letter-spacing:-.035em;text-transform:lowercase;margin-bottom:24px;max-width:18ch}\n.section h2 em{font-style:italic;color:var(--page)}\n.section p{font-family:\"Newsreader\",Georgia,serif;font-size:19px;line-height:1.65;color:var(--ink);font-weight:400;margin-bottom:18px}\n.section p:last-child{margin-bottom:0}\n.section p b{font-weight:600;color:var(--ink)}\n.section p i,.section p em{font-style:italic;color:var(--ink)}\n.inline-photo{padding:32px 28px 40px}\n.inline-photo .inner{max-width:1100px;margin:0 auto}\n.inline-photo img{width:100%;height:auto;border-radius:8px;display:block}\n.inline-photo .cap{margin-top:14px;font-family:\"JetBrains Mono\",monospace;font-size:10px;let