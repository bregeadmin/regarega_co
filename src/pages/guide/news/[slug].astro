---
import Site from '../../../layouts/Site.astro';
import news from '../../../data/news.json';

export async function getStaticPaths() {
  return (news as any[]).map((n) => ({ params: { slug: n.slug }, props: { n } }));
}
const { n } = Astro.props as { n: any };
const esc = (s: any) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const fmtDate = (d: string) => { const m = (d || '').match(/(\d{4})-(\d{2})-(\d{2})/); if (!m) return ''; const mo = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'][+m[2] - 1]; return (+m[3]) + ' ' + mo + ' ' + m[1]; };
const photos = (n.photos && n.photos.length) ? n.photos : (n.image ? [n.image] : []);
const mdInline = (raw: string) => esc(raw).replace(/\*\*([^*]+)\*\*/g, '<b>$1</b>').replace(/\*([^*]+)\*/g, '<em>$1</em>');
const bodyHtml = String(n.body || n.descr || '').split(/\n+/).map((x: string) => x.trim()).filter(Boolean).map((x: string) => '<p>' + mdInline(x) + '</p>').join('');
const galleryHtml = photos.slice(1).map((src: string) => '<div class="g"><img src="' + esc(src) + '" alt="" loading="lazy"></div>').join('');

const content =
  '<article class="news-article">' +
    '<div class="crumbs"><a href="/guide/">guide</a><span class="sep">/</span><a href="/guide#news">news</a><span class="sep">/</span><span class="cur">' + esc(String(n.title).slice(0, 30)) + '…</span></div>' +
    '<div class="eyebrow"><span class="tag">● news</span>' + (fmtDate(n.date) ? '<span class="when">' + esc(fmtDate(n.date)) + '</span>' : '') + '</div>' +
    '<h1>' + esc(n.title) + '</h1>' +
    (photos[0] ? '<div class="hero"><img src="' + esc(photos[0]) + '" alt=""></div>' : '') +
    '<div class="body">' + bodyHtml + '</div>' +
    (galleryHtml ? '<div class="gallery">' + galleryHtml + '</div>' : '') +
    '<a class="back" href="/guide#news">← more from the guide</a>' +
  '</article>';
---
<Site title={String(n.title).slice(0, 60) + ' — news — rega rega batumi'} description={n.descr || ''}>
<style is:inline set:html={".news-article{max-width:780px;margin:0 auto;padding:120px 24px 96px}\n.news-article .crumbs{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);font-weight:500;display:flex;gap:10px;align-items:center;margin-bottom:28px}\n.news-article .crumbs a:hover{color:var(--ink)}\n.news-article .crumbs .sep{opacity:.4}\n.news-article .crumbs .cur{color:var(--ink)}\n.news-article .eyebrow{display:flex;align-items:center;gap:14px;margin-bottom:18px}\n.news-article .eyebrow .tag{display:inline-flex;align-items:center;gap:7px;background:var(--accent);color:#fff;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;font-weight:700;padding:6px 13px;border-radius:999px}\n.news-article .eyebrow .when{font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-soft);font-weight:600}\n.news-article h1{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(30px,4.5vw,52px);line-height:1.04;letter-spacing:-.035em;text-transform:lowercase;margin-bottom:28px}\n.news-article .hero{border-radius:16px;overflow:hidden;aspect-ratio:16/10;background:var(--bg-2);margin-bottom:32px}\n.news-article .hero img{width:100%;height:100%;object-fit:cover}\n.news-article .body p{font-size:19px;line-height:1.65;color:var(--ink);margin-bottom:18px}\n.news-article .body b{font-weight:700;color:var(--ink)}\n.news-article .body em{font-style:italic;color:var(--accent)}\n.news-article .gallery{display:flex;flex-wrap:wrap;gap:8px;margin-top:28px}\n.news-article .gallery .g{width:104px;height:104px;border-radius:8px;overflow:hidden;background:var(--bg-2);transition:transform .2s ease}\n.news-article .gallery .g:hover{transform:translateY(-2px)}\n.news-article .gallery .g img{width:100%;height:100%;object-fit:cover}\n.news-article .back{display:inline-flex;margin-top:48px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;font-weight:600;color:var(--ink);border-bottom:1px solid var(--ink);padding-bottom:4px}\n.news-article .back:hover{color:var(--accent);border-color:var(--accent)}\n@media(max-width:880px){.news-article{padding:90px 16px 64px}.news-article .gallery{grid-template-columns:1fr}}"}></style>
<Fragment set:html={content} />
</Site>
