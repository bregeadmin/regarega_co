---
import Site from '../../../layouts/Site.astro';
import news from '../../../data/news.json';
import { supabase } from '../../../lib/supabase';

const CAT = {
  'eat-drink':   { color: '#ff5e1a', label: 'eat & drink' },
  'wellness':    { color: '#00b5b0', label: 'wellness & slow living' },
  'work':        { color: '#7f77dd', label: 'work & remote life' },
  'move-around': { color: '#3D5AFE', label: 'move around' },
};

export async function getStaticPaths() {
  const { data: gp } = await supabase
    .from('guide_places')
    .select('slug,title,name,category,photos,image')
    .eq('status', 'published');
  const pmap: Record<string, any> = {};
  (gp || []).forEach((p: any) => { pmap[p.slug] = p; });
  return (news as any[]).map((n) => ({
    params: { slug: n.slug },
    props: { n, place: n.place ? (pmap[n.place] || null) : null },
  }));
}

const { n, place } = Astro.props as { n: any; place: any };
const esc = (s: any) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const fmtDate = (d: string) => { const m = (d || '').match(/(\d{4})-(\d{2})-(\d{2})/); if (!m) return ''; const mo = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'][+m[2] - 1]; return (+m[3]) + ' ' + mo + ' ' + m[1]; };
const rawPhotos = (n.photos && n.photos.length) ? n.photos : (n.image ? [n.image] : []);
// clean up the imported tilda gallery: drop the bre.ge logo placeholder, and
// drop resized duplicates that share a filename (tilda stores the same shot twice)
const _seen = new Set<string>();
const photos = rawPhotos.filter((src: string) => {
  if (/___12\.png/.test(src)) return false;
  const base = String(src).split('/').pop() || src;
  if (_seen.has(base)) return false;
  _seen.add(base); return true;
});
const mdInline = (raw: string) => esc(raw).replace(/\*\*([^*]+)\*\*/g, '<b>$1</b>').replace(/\*([^*]+)\*/g, '<em>$1</em>');
const bodyHtml = String(n.body || n.descr || '').split(/\n+/).map((x: string) => x.trim()).filter(Boolean).map((x: string) => '<p>' + mdInline(x) + '</p>').join('');
const galleryHtml = photos.slice(1).map((src: string) => '<button class="g" type="button"><img src="' + esc(src) + '" alt="" loading="lazy"></button>').join('');

// reading time from the body word count
const words = String(n.body || n.descr || '').split(/\s+/).filter(Boolean).length;
const mins = Math.max(1, Math.round(words / 90));

// "the place" card — links a news item to the guide page it is about
let placeHtml = '';
if (place) {
  const pc = CAT[place.category] || { color: '#ff5e1a', label: place.category };
  const pName = place.title || place.name || place.slug;
  const pPhoto = (place.photos && place.photos.length) ? place.photos[0] : (place.image || '');
  placeHtml =
    '<a class="place-card" href="/guide/' + esc(place.slug) + '" style="--pc:' + pc.color + '">' +
      (pPhoto ? '<div class="pc-ph"><img src="' + esc(pPhoto) + '" alt="" loading="lazy"></div>' : '') +
      '<div class="pc-body">' +
        '<div class="pc-eyebrow">the place · ' + esc(pc.label) + '</div>' +
        '<h4>' + esc(pName) + '</h4>' +
        '<span class="pc-go">open in the guide →</span>' +
      '</div>' +
    '</a>';
}

const content =
  '<article class="news-article">' +
    '<div class="crumbs"><a href="/guide/">guide</a><span class="sep">/</span><a href="/guide#news">news</a><span class="sep">/</span><span class="cur">' + esc(String(n.title).slice(0, 30)) + '…</span></div>' +
    '<div class="eyebrow"><span class="tag">● news</span>' + (fmtDate(n.date) ? '<span class="when">' + esc(fmtDate(n.date)) + '</span>' : '') + '</div>' +
    '<h1>' + esc(n.title) + '</h1>' +
    (n.descr ? '<p class="lead">' + mdInline(n.descr) + '</p>' : '') +
    '<div class="byline"><span>by the rega rega team</span><span class="sep"></span><span>' + mins + ' min read</span></div>' +
    (photos[0] ? '<div class="hero"><img src="' + esc(photos[0]) + '" alt=""></div>' : '') +
    '<div class="body">' + bodyHtml + '</div>' +
    placeHtml +
    (galleryHtml ? '<div class="gallery">' + galleryHtml + '</div>' : '') +
    '<a class="back" href="/guide#news">← more from the guide</a>' +
  '</article>';
---
<Site title={String(n.title).slice(0, 60) + ' — news — rega rega batumi'} description={n.descr || ''}>
<style is:inline set:html={".news-article{max-width:780px;margin:0 auto;padding:120px 24px 96px}\n.news-article .crumbs{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);font-weight:500;display:flex;gap:10px;align-items:center;margin-bottom:28px}\n.news-article .crumbs a:hover{color:var(--ink)}\n.news-article .crumbs .sep{opacity:.4}\n.news-article .crumbs .cur{color:var(--ink)}\n.news-article .eyebrow{display:flex;align-items:center;gap:14px;margin-bottom:18px}\n.news-article .eyebrow .tag{display:inline-flex;align-items:center;gap:7px;background:var(--accent);color:#fff;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;font-weight:700;padding:6px 13px;border-radius:999px}\n.news-article .eyebrow .when{font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-soft);font-weight:600}\n.news-article h1{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(30px,4.5vw,52px);line-height:1.04;letter-spacing:-.035em;text-transform:lowercase;margin-bottom:20px}\n.news-article .lead{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(19px,2.1vw,24px);line-height:1.4;font-weight:500;color:var(--ink);margin-bottom:22px}\n.news-article .lead em{font-style:italic;color:var(--accent)}\n.news-article .byline{display:flex;align-items:center;gap:12px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-soft);font-weight:600;margin-bottom:34px}\n.news-article .byline .sep{width:4px;height:4px;border-radius:50%;background:var(--ink-soft);opacity:.5}\n.news-article .hero{border-radius:16px;overflow:hidden;aspect-ratio:16/10;background:var(--bg-2);margin-bottom:32px;cursor:zoom-in}\n.news-article .hero img{width:100%;height:100%;object-fit:cover}\n.news-article .body p{font-size:19px;line-height:1.65;color:var(--ink);margin-bottom:18px}\n.news-article .body b{font-weight:700;color:var(--ink)}\n.news-article .body em{font-style:italic;color:var(--accent)}\n.news-article .place-card{display:flex;gap:18px;align-items:center;margin:40px 0 8px;padding:16px;border:1px solid var(--line);border-radius:16px;background:var(--paper);transition:border-color .2s ease,transform .2s ease,box-shadow .2s ease}\n.news-article .place-card:hover{border-color:var(--pc);transform:translateY(-2px);box-shadow:0 10px 28px rgba(10,9,8,.08)}\n.news-article .place-card .pc-ph{width:96px;height:96px;border-radius:12px;overflow:hidden;flex:none;background:var(--bg-2)}\n.news-article .place-card .pc-ph img{width:100%;height:100%;object-fit:cover}\n.news-article .place-card .pc-eyebrow{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;color:var(--pc);margin-bottom:7px}\n.news-article .place-card h4{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(20px,2.4vw,26px);letter-spacing:-.02em;line-height:1.05;text-transform:lowercase;color:var(--ink);margin-bottom:9px}\n.news-article .place-card .pc-go{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;font-weight:600;color:var(--ink-soft)}\n.news-article .place-card:hover .pc-go{color:var(--pc)}\n.news-article .gallery{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:38px}\n.news-article .gallery .g{aspect-ratio:4/3;border:0;padding:0;border-radius:12px;overflow:hidden;background:var(--bg-2);cursor:zoom-in;transition:transform .2s ease}\n.news-article .gallery .g:first-child{grid-column:1 / -1;aspect-ratio:16/8}\n.news-article .gallery .g:hover{transform:translateY(-2px)}\n.news-article .gallery .g img{width:100%;height:100%;object-fit:cover;display:block}\n.news-article .back{display:inline-flex;margin-top:52px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;font-weight:600;color:var(--ink);border-bottom:1px solid var(--ink);padding-bottom:4px}\n.news-article .back:hover{color:var(--accent);border-color:var(--accent)}\n.news-lightbox{position:fixed;inset:0;z-index:200;background:rgba(10,9,8,.86);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;padding:32px;cursor:zoom-out}\n.news-lightbox.on{display:flex}\n.news-lightbox img{max-width:92vw;max-height:90vh;border-radius:12px;box-shadow:0 24px 60px rgba(0,0,0,.5)}\n@media(max-width:880px){.news-article{padding:90px 16px 64px}.news-article .place-card{gap:14px;padding:13px}.news-article .place-card .pc-ph{width:76px;height:76px}}"}></style>
<Fragment set:html={content} />
<script is:inline>
(function () {
  var ov = document.createElement('div');
  ov.className = 'news-lightbox';
  ov.innerHTML = '<img alt="">';
  document.body.appendChild(ov);
  var im = ov.querySelector('img');
  document.addEventListener('click', function (e) {
    var t = e.target.closest('.news-article .gallery .g, .news-article .hero');
    if (t) { var img = t.querySelector('img'); if (img && img.src) { im.src = img.src; ov.classList.add('on'); } return; }
    if (e.target === ov || e.target === im) ov.classList.remove('on');
  });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') ov.classList.remove('on'); });
})();
</script>
</Site>
