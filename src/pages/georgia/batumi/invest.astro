import Site from '../../../layouts/Site.astro';
---
<Site title={'invest — rega rega'} accent='#1F8A5B' accentDeep='#176E48'>
<Fragment set:html={'<!-- HEADER -->\n<section class="head">\n  <div class="inner">\n    <div>\n      <div class="crumbs">\n        <span class="current"><span class="dot"></span>invest</span>\n      </div>\n      <h1>buy a flat<br/>in <em>batumi</em>.</h1>\n    </div>\n    <p class="lede">we help you <b>find it, renovate it, and rent it</b>. all three steps, or any single one — pick what you need. <b>since 2022</b>, with our own hands.</p>\n  </div>\n</section>\n\n<!-- THE THREE STEPS -->\n<section class="steps3-wrap">\n  <div class="steps3-head">\n    <div>\n      <div class="kicker"><span class="dot"></span>— the three stages</div>\n      <h2>find. <em>renovate</em>.<br/>rent.</h2>\n    </div>\n    <div class="right">we do all three, end-to-end, in about <b>90 days</b> for a typical 50m² flat. or pick the stage you need — <b>each stands on its own</b>.</div>\n  </div>\n\n  <div class="steps3">\n    <a class="step3" href="#find">\n      <span class="nr">01</span>\n      <h3>find</h3>\n      <p>we know the <b>districts, the developers, the contracts</b>. we walk you through what\'s worth buying, where, at what price — and what to avoid.</p>\n      <span class="more">read more ↘</span>\n    </a>\n    <a class="step3" href="#renovate">\n      <span class="nr">02</span>\n      <h3><em>renovate</em></h3>\n      <p>black or white frame to fully furnished, <b>turnkey</b>. fixed price, fixed timeline, weekly photo report. <b>≈ $600/m²</b> all-in.</p>\n      <span class="more">read more ↘</span>\n    </a>\n    <a class="step3" href="#rent">\n      <span class="nr">03</span>\n      <h3>rent</h3>\n      <p>we list, photograph, price, communicate, clean. <b>30 / 70</b> split. monthly report. you own the door, we open it.</p>\n      <span class="more">see /own ↘</span>\n    </a>\n  </div>\n\n  <div class="flex-note">\n    <div class="l">\n      <span class="badge">— important</span>\n      <div class="text"><em>you can pick just one stage.</em> already have a flat? skip to <b>step 2</b> or <b>step 3</b>.</div>\n    </div>\n  </div>\n</section>\n\n<!-- FIND -->\n<section class="pad" id="find">\n  <div class="container">\n    <div class="section-head">\n      <div class="left">\n        <div class="kicker"><span class="dot"></span>— step 01 / find</div>\n        <h2>what we know<br/>about the <em>market</em>.</h2>\n      </div>\n      <div class="right">no commission from sellers. we work for <b>you</b>, not for the building. consult-only on this step if you prefer.</div>\n    </div>\n\n    <div class="find">\n      <div class="find-text">\n        <p>batumi has roughly <b>three layers</b> of property — old soviet stock in the centre, mid-range new builds across the boulevard and chavchavadze, and the towers (orbi, panorama, arena) that dominate the skyline. each plays differently for short-term rental.</p>\n        <p>we walk you through what\'s <b>worth buying</b>, where, at what price — and what to avoid: the buildings with weak management, the developers with delayed handovers, the districts that look great in renderings but don\'t rent in real life.</p>\n        <p>we also help with the boring-but-critical stuff: <b>contracts, cadastral checks, residency questions, the tax setup</b>. georgian property law is friendlier than you\'d think — but only if you know the moves.</p>\n      </div>\n\n      <div class="find-cards">\n        <div class="find-card">\n          <span class="lbl">avg. yield</span>\n          <span class="val"><em>~11%</em></span>\n          <span class="note">net annual yield across our managed portfolio. updated quarterly.</span>\n        </div>\n        <div class="find-card">\n          <span class="lbl">income tax</span>\n          <span class="val"><em>5%</em></span>\n          <span class="note">flat tax on rental income in georgia. setup takes 1 day.</span>\n        </div>\n        <div class="find-card">\n          <span class="lbl">visa-free</span>\n          <span class="val"><em>95+</em></span>\n          <span class="note">countries. property ownership doesn\'t require residency. easy to come, easy to leave.</span>\n        </div>\n        <div class="find-card">\n          <span class="lbl">our experience</span>\n          <span class="val">on-the-ground</span>\n          <span class="note">we already <b>rent and operate</b> across six districts. we know where to buy because <b>we live and earn here</b>.</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- RENOVATE -->\n<section class="reno-wrap" id="renovate">\n  <div class="container">\n    <div class="section-head">\n      <div class="left">\n        <div class="kicker"><span class="dot"></span>— step 02 / renovate</div>\n        <h2>black frame to<br/>first <em>guest</em>.</h2>\n      </div>\n      <div class="right">fixed price agreed upfront, no surprises. weekly photo + video report. about <b>60—90 days</b> for a typical 50m² flat.</div>\n    </div>\n\n    <div class="reno">\n      <div class="reno-text">\n        <p>most buyers in batumi receive their flat as a <b>black or white frame</b> — walls, windows, plumbing rough-in, and not much else. you can\'t move in, you can\'t rent it. you need a renovation that\'s <b>built for rental, not for personal taste</b>.</p>\n        <p>we do <b>turnkey</b> — design, materials, contractors, furniture, appliances, textiles, art on the walls. one team, one timeline, one price. you get weekly photo updates and a finished flat with the keys in our hand, ready for guests.</p>\n        <p>the number on the right is <b>all-in</b>: design, work, materials, furniture, full equipment, decor. nothing extra to buy. nothing forgotten. ready for a guest the day we hand it over.</p>\n        <p>three levels available — <b>economy, comfort, luxury</b>. the figure shown is a typical mid-range comfort tier. we\'ll walk through which level fits your goal at the first call.</p>\n      </div>\n\n      <div class="reno-num">\n        <span class="lbl">— typical all-in</span>\n        <span class="price">≈ $600<span class="unit">/m²</span></span>\n        <p class="desc">design, work, materials, <b>furniture, appliances, textiles, decor</b> — everything except the building itself. a 50m² flat at this level is <b>≈ $30,000</b> turnkey.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- HOME STAGING — buyable separately -->\n<section class="pad">\n  <div class="container">\n    <div class="section-head">\n      <div class="left">\n        <div class="kicker"><span class="dot"></span>— our quality bar, packaged</div>\n        <h2>bre <em>standards</em>.<br/><span style="font-size:.5em;letter-spacing:0;color:var(--ink-soft);font-weight:500;font-style:italic">(or "home staging", if you prefer)</span></h2>\n      </div>\n      <div class="right">already renovated, but it doesn\'t <i>perform</i>? we\'ll bring your flat up to <b>the bre standard</b> — same checklist we use for everything we manage. <b>available on its own</b>.</div>\n    </div>\n\n    <div class="staging">\n      <div class="l">\n        <span class="badge">— standalone service</span>\n        <h3>not just <em>styling</em>.<br/>a complete <em>standard</em>.</h3>\n        <p>we call it home staging because the world knows that word. <b>but it\'s our own standard</b> — a checklist of about 70 things we built over four years of running real apartments: from textile weight and lamp temperature to the welcome cards, the kettle brand, the curtain stop.</p>\n        <p>same flat, twice the rental — that\'s what the standard does. <b>textiles, art, lighting, plants, smart small purchases</b>. we work with what\'s already there and add what\'s missing.</p>\n        <div class="pricing">\n          <div>\n            <span class="k">— typical project</span>\n            <span class="v">2—5 days</span>\n          </div>\n          <div>\n            <span class="k">— what it covers</span>\n            <span class="v">~70 standard items</span>\n          </div>\n          <div>\n            <span class="k">— deliverable</span>\n            <span class="v">photo-ready flat</span>\n          </div>\n        </div>\n      </div>\n      <div class="r"></div>\n    </div>\n  </div>\n</section>\n\n<!-- RENT — short link to /own -->\n<section class="pad" id="rent" style="padding-top:0">\n  <div class="container">\n    <div class="section-head">\n      <div class="left">\n        <div class="kicker"><span class="dot"></span>— step 03 / rent</div>\n        <h2>now it <em>earns</em>.</h2>\n      </div>\n      <div class="right">covered in full on the <b>/own</b> page — same service whether you bought through us or brought your own flat.</div>\n    </div>\n\n    <div class="manage">\n      <div class="manage-text">\n        <p>once it\'s renovated and styled, we take over the rental. <b>listings, photos, dynamic pricing, guest communication, cleaning, the everything.</b></p>\n        <p>you keep <b>70%</b> of net revenue. we keep <b>30%</b> and cover the cost of running the show — welcome kits, laundry, small repairs, monthly report.</p>\n        <p>you own the flat, you cover utilities and one-time equipment. that\'s it. <b>same deal we give every owner</b>, regardless of whether you bought through us.</p>\n      </div>\n      <div class="manage-card">\n        <span class="num">30<span class="pc">/70</span></span>\n        <h4>our cut · your share</h4>\n        <p>30% to us covers all operating work. 70% to you, paid monthly with a transparent report.</p>\n        <a class="lnk" href="/georgia/batumi/own">full /own details →</a>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- WHY BATUMI -->\n<section class="pad" style="background:var(--paper);padding-top:96px;padding-bottom:96px;border-top:1px solid var(--line);border-bottom:1px solid var(--line)">\n  <div class="container">\n    <div class="section-head">\n      <div class="left">\n        <div class="kicker"><span class="dot"></span>— why batumi</div>\n        <h2>numbers we<br/>like <em>about</em> this city.</h2>\n      </div>\n      <div class="right">a quick map of the macro. happy to dig into any of these on the call.</div>\n    </div>\n\n    <div class="why">\n      <div class="why-tile">\n        <span class="nr">01</span>\n        <span class="num"><em>5%</em></span>\n        <h5>flat income tax</h5>\n        <p>flat tax on rental income in georgia. one of the lowest in europe.</p>\n      </div>\n      <div class="why-tile">\n        <span class="nr">02</span>\n        <span class="num">~9<span style="font-size:.5em;letter-spacing:-.02em">months</span></span>\n        <h5>warm season</h5>\n        <p>black sea climate. real high season is may—october, but spring and autumn rent well too.</p>\n      </div>\n      <div class="why-tile">\n        <span class="nr">03</span>\n        <span class="num">95+<span style="font-size:.5em">cn</span></span>\n        <h5>visa-free, ~95 countries</h5>\n        <p>property ownership doesn\'t require residency. easy to come, easy to leave.</p>\n      </div>\n      <div class="why-tile">\n        <span class="nr">04</span>\n        <span class="num"><em>~70%</em></span>\n        <h5>annual occupancy</h5>\n        <p>average across our managed portfolio. real high-season weeks book months ahead, shoulder months pick up.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- PULL QUOTE -->\n<section class="pull">\n  <blockquote>we don\'t <em>sell</em>.<br/>we just <em>recommend</em>.</blockquote>\n  <div class="signoff">— bre · since 2022</div>\n</section>\n\n<!-- CTA -->\n<section class="cta-wrap">\n  <h2>let\'s <em>talk</em><br/>about your flat.</h2>\n  <p>30-minute consult. we map your budget, your goal, and which of the three stages you actually need. honest read on the market, no pitch.</p>\n  <div class="row">\n    <a class="btn primary" href="https://t.me/bre_ge">↗ message on telegram</a>\n    <a class="btn alt" href="tel:+995585889601">+995 585 889 601</a>\n  </div>\n</section>'} />
<style is:global set:html={'.head{padding:140px 28px 72px;border-bottom:1px solid var(--line);position:relative;overflow:hidden}\n.head::before{content:"";position:absolute;top:0;right:0;width:55%;height:100%;background:var(--page);opacity:.06;clip-path:polygon(20% 0,100% 0,100% 100%,0 100%)}\n.head .inner{position:relative;z-index:2;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1.5fr 1fr;gap:48px;align-items:end}\n.head .crumbs{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);font-weight:500;margin-bottom:32px;display:flex;align-items:center;gap:10px}\n.head .crumbs a{color:var(--ink-soft)}\n.head .crumbs a:hover{color:var(--ink)}\n.head .crumbs .sep{opacity:.4}\n.head .crumbs .current{color:var(--green-deep);font-weight:700;background:var(--green-tint);padding:5px 11px;border-radius:999px;display:inline-flex;align-items:center;gap:7px}\n.head .crumbs .current .dot{width:8px;height:8px;border-radius:50%;background:var(--page)}\n.head h1{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(48px,7vw,120px);line-height:.9;letter-spacing:-.045em;text-transform:lowercase}\n.head h1 em{font-style:italic;color:var(--page)}\n.head .lede{font-size:20px;line-height:1.55;color:var(--ink);max-width:42ch;padding-bottom:20px}\n.head .lede b{font-weight:700;color:var(--ink)}\n.steps3-wrap{padding:120px 28px;background:var(--paper);border-bottom:1px solid var(--line)}\n.steps3-head{max-width:1400px;margin:0 auto 48px;display:flex;justify-content:space-between;align-items:flex-end;gap:40px;flex-wrap:wrap}\n.steps3-head .kicker{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--green-deep);font-weight:600;margin-bottom:18px;display:inline-flex;align-items:center;gap:8px;background:var(--green-tint);padding:5px 11px;border-radius:999px;width:fit-content}\n.steps3-head .kicker .dot{display:none}\n.steps3-head h2{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(40px,5.5vw,82px);line-height:.95;letter-spacing:-.04em;text-transform:lowercase;max-width:18ch}\n.steps3-head h2 em{font-style:italic;color:var(--page)}\n.steps3-head .right{max-width:380px;font-size:14.5px;line-height:1.6;color:var(--ink-soft);text-align:right}\n.steps3-head .right b{color:var(--ink)}\n.steps3{max-width:1400px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:18px}\n.step3{position:relative;background:var(--bg);border:1px solid var(--line);border-radius:14px;padding:36px 32px;display:flex;flex-direction:column;gap:18px;transition:transform .3s cubic-bezier(.2,.7,.2,1),border-color .25s ease;overflow:hidden}\n.step3:hover{transform:translateY(-4px);border-color:var(--page)}\n.step3::before{content:"";position:absolute;top:0;left:0;width:5px;height:60px;background:var(--page);border-radius:0 4px 4px 0}\n.step3 .nr{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:64px;line-height:.9;letter-spacing:-.04em;color:var(--page)}\n.step3 h3{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:32px;line-height:1;letter-spacing:-.03em;text-transform:lowercase}\n.step3 h3 em{font-style:italic;color:var(--page)}\n.step3 p{font-size:14.5px;line-height:1.6;color:var(--ink-soft)}\n.step3 p b{color:var(--ink);font-weight:600}\n.step3 .more{margin-top:auto;font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;color:var(--page);display:inline-flex;align-items:center;gap:8px;padding-top:14px;border-top:1px solid var(--line)}\n.flex-note{max-width:1400px;margin:32px auto 0;padding:24px 28px;background:var(--page);color:var(--on-color);border-radius:14px;display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap}\n.flex-note .l{display:flex;align-items:center;gap:14px}\n.flex-note .badge{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;padding:5px 10px;border-radius:999px;background:var(--green-tint);color:var(--green-deep)}\n.flex-note .text{font-family:"Bricolage Grotesque",sans-serif;font-size:18px;font-weight:600;letter-spacing:-.015em}\n.flex-note .text em{font-style:italic;color:rgba(250,247,240,.72)}\nsection.pad{padding:120px 28px}\n.container{max-width:1400px;margin:0 auto}\n.section-head{display:flex;justify-content:space-between;align-items:flex-end;gap:40px;margin-bottom:56px;flex-wrap:wrap}\n.section-head .left{max-width:600px}\n.section-head .kicker{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--green-deep);font-weight:600;margin-bottom:18px;display:inline-flex;align-items:center;gap:8px;background:var(--green-tint);padding:5px 11px;border-radius:999px;width:fit-content}\n.section-head .kicker .dot{display:none}\n.section-head h2{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(40px,5.5vw,82px);line-height:.95;letter-spacing:-.04em;text-transform:lowercase}\n.section-head h2 em{font-style:italic;color:var(--page)}\n.section-head .right{max-width:380px;font-size:14.5px;line-height:1.6;color:var(--ink-soft);text-align:right}\n.section-head .right b{color:var(--ink)}\n.find{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start}\n.find-text{display:flex;flex-direction:column;gap:24px;font-size:15.5px;line-height:1.65;color:var(--ink-soft)}\n.find-text p b{color:var(--ink);font-weight:700}\n.find-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px}\n.find-card{padding:24px 22px;background:var(--paper);border:1px solid var(--line);border-radius:12px;display:flex;flex-direction:column;gap:8px}\n.find-card .lbl{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;color:var(--ink-soft)}\n.find-card .val{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;f