---
import Site from '../../../layouts/Site.astro';
---
<Site title={'own with us — rega rega'} accent='#3D5AFE' accentDeep='#2F49D6'>
<Fragment set:html={'<!-- HEADER -->\n<section class="head">\n  <div class="inner">\n    <div>\n      <div class="crumbs">\n        <span class="current"><span class="dot"></span>own with us</span>\n      </div>\n      <h1>your <em>flat</em>,<br/>our <em>care</em>.</h1>\n    </div>\n    <p class="lede">already have an apartment in batumi? <b>we\'ll take care of it</b> — photos, listings, guests, cleaning, taxes, the everything. <b>since 2022</b>, with our own hands.</p>\n  </div>\n</section>\n\n<!-- THE DEAL — 70/30 -->\n<section class="promise">\n  <div class="inner">\n    <div class="col you">\n      <div>\n        <div class="label">— you keep</div>\n        <div class="num">70<span class="pc">%</span></div>\n      </div>\n      <p class="desc">of net rental revenue. you own the flat, you take the larger share. <b>utility bills and one-time equipment</b> stay on you — everything else, on us.</p>\n    </div>\n    <div class="col us">\n      <div>\n        <div class="label">— we keep</div>\n        <div class="num">30<span class="pc">%</span></div>\n      </div>\n      <p class="desc">covers <b>everything we do</b> — listings, dynamic pricing, guest comms in 5 languages, cleaning, laundry, small repairs, welcome kits, monthly report.</p>\n    </div>\n  </div>\n</section>\n\n<!-- WHAT WE DO -->\n<section class="pad">\n  <div class="container">\n    <div class="section-head">\n      <div class="left">\n        <div class="kicker"><span class="dot"></span>— what we actually do</div>\n        <h2>everything <em>except</em><br/>opening the door.</h2>\n      </div>\n      <div class="right">six things, every month. listed plainly so you know what your 30% pays for.</div>\n    </div>\n\n    <div class="services">\n      <div class="svc">\n        <div class="top">\n          <span class="nr">01</span>\n          <span class="icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1.5" y="2.5" width="11" height="9" rx="1" stroke="currentColor" stroke-width="1.4"/><path d="M3.5 5h7M3.5 7h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></span>\n        </div>\n        <h3>listing &amp; photography</h3>\n        <p>we photograph your flat in <b>real light</b>, write descriptions in two languages, and publish on <b>3—4 platforms</b> (airbnb, booking, our own site, telegram channels). no stock photos, no fake adjectives.</p>\n      </div>\n\n      <div class="svc">\n        <div class="top">\n          <span class="nr">02</span>\n          <span class="icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 11l3-3 2.5 2.5L12 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 6h4v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg></span>\n        </div>\n        <h3>dynamic <em>pricing</em></h3>\n        <p>batumi prices swing. we adjust nightly rates based on <b>season, competitor pricing, and event calendar</b> — so the flat doesn\'t sit empty in shoulder months and doesn\'t undersell in peak.</p>\n      </div>\n\n      <div class="svc">\n        <div class="top">\n          <span class="nr">03</span>\n          <span class="icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 4.5C2 3.7 2.7 3 3.5 3h7c.8 0 1.5.7 1.5 1.5v4c0 .8-.7 1.5-1.5 1.5H5l-2.5 2V4.5z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg></span>\n        </div>\n        <h3>guests, in 5 languages</h3>\n        <p>russian, english, turkish, hebrew, georgian. we reply <b>within minutes</b>, day and night. fast replies move your listing up — and keep guests calm.</p>\n      </div>\n\n      <div class="svc">\n        <div class="top">\n          <span class="nr">04</span>\n          <span class="icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 6c0-2.2 1.8-4 4-4s4 1.8 4 4c0 1.5-.8 2.7-2 3.4V12H5V9.4C3.8 8.7 3 7.5 3 6z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg></span>\n        </div>\n        <h3>the little things</h3>\n        <p>soap, shampoo, conditioner, toothbrushes, slippers, laundry pods. tea, coffee, spices, olive oil. a curated <b>welcome card</b> with the best places in walking distance. small things, but guests notice.</p>\n      </div>\n\n      <div class="svc">\n        <div class="top">\n          <span class="nr">05</span>\n          <span class="icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="4" r="2" stroke="currentColor" stroke-width="1.4"/><path d="M3 12c0-2.2 1.8-4 4-4s4 1.8 4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></span>\n        </div>\n        <h3>cleaning, laundry, fixes</h3>\n        <p>after every guest. plus the small stuff that breaks — lightbulbs, loose handles, dripping taps. <b>plumbers and electricians</b> when needed — coordinated, never bothering you.</p>\n      </div>\n\n      <div class="svc">\n        <div class="top">\n          <span class="nr">06</span>\n          <span class="icon"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="2" y="3" width="10" height="8" rx="1" stroke="currentColor" stroke-width="1.4"/><path d="M4 6h6M4 8h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg></span>\n        </div>\n        <h3>monthly report</h3>\n        <p>at the start of every month, you get the report for the previous one — generated <b>straight from our own accounting system</b>, line by line. bookings, revenue, our cut, your share, operating costs. nothing hidden, nothing manual.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- WHO PAYS WHAT -->\n<section class="split-wrap">\n  <div class="container">\n    <div class="section-head">\n      <div class="left">\n        <div class="kicker"><span class="dot"></span>— who pays for what</div>\n        <h2>transparent.<br/><em>boringly</em> so.</h2>\n      </div>\n      <div class="right">no hidden fees, no "+ extras". if it\'s not in this list, you don\'t pay it.</div>\n    </div>\n\n    <div class="split">\n      <div class="side us">\n        <span class="badge">— our side · we cover</span>\n        <h4>covered by your 30%</h4>\n        <ul>\n          <li>cleaning after every guest</li>\n          <li>laundry of linen &amp; towels</li>\n          <li>welcome kits (toiletries, slippers, coffee, tea, snacks)</li>\n          <li>small in-flat repairs (bulbs, handles, taps)</li>\n          <li>guest communication, 24/7</li>\n          <li>listings on all platforms, photos, descriptions</li>\n          <li>dynamic pricing, calendar management</li>\n          <li>monthly financial report</li>\n        </ul>\n      </div>\n      <div class="side you">\n        <span class="badge">— your side · you cover</span>\n        <h4>still on you</h4>\n        <ul>\n          <li>utility bills (electricity, water, gas, internet) — <i>or hand the logistics to us, that\'s coming to our platform soon</i></li>\n          <li>residential complex / hoa fees</li>\n          <li>textiles, furniture, dishes, decor (replacement &amp; refresh)</li>\n          <li>one-time equipment purchases</li>\n          <li>major repairs (worn floors, replacing appliances)</li>\n          <li>property taxes &amp; income tax declarations</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- PROCESS -->\n<section class="pad">\n  <div class="container">\n    <div class="section-head">\n      <div class="left">\n        <div class="kicker"><span class="dot"></span>— how it goes</div>\n        <h2>from <em>handshake</em><br/>to first guest.</h2>\n      </div>\n      <div class="right">about 2 weeks if everything\'s ready. longer if we\'re styling or renovating first.</div>\n    </div>\n\n    <div class="process">\n      <div class="step">\n        <div class="nr">step 01</div>\n        <h4>meet</h4>\n        <p>30-min call or in person at the flat. we look around, ask about your goals, your budget, how hands-off you want to be.</p>\n        <span class="arr">→</span>\n      </div>\n      <div class="step">\n        <div class="nr">step 02</div>\n        <h4>home staging</h4>\n        <p>we suggest what to add or remove — textiles, art, lighting — to make it photograph (and live) well. optional, but recommended.</p>\n        <span class="arr">→</span>\n      </div>\n      <div class="step">\n        <div class="nr">step 03</div>\n        <h4>photoshoot</h4>\n        <p>real photographer, real light, real wide-angle. 20—40 shots that don\'t lie. all yours to keep.</p>\n        <span class="arr">→</span>\n      </div>\n      <div class="step">\n        <div class="nr">step 04</div>\n        <h4>listing</h4>\n        <p>we write the descriptions (en + ru), set up airbnb, booking, our own channels. live in 3 working days.</p>\n        <span class="arr">→</span>\n      </div>\n      <div class="step">\n        <div class="nr">step 05</div>\n        <h4>first guest</h4>\n        <p>usually within 1—3 weeks of listing, sooner in season. we handle check-in, all communication, cleaning, the lot.</p>\n        <span class="arr">→</span>\n      </div>\n      <div class="step">\n        <div class="nr">step 06</div>\n        <h4>monthly rhythm</h4>\n        <p>first days of each new month: report in your inbox for the previous one, payment to your account. report comes <b>straight from our internal system</b> — every line traceable. quarterly call to check if anything needs adjusting.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- REPORTING -->\n<section class="pad" style="padding-top:0">\n  <div class="container">\n    <div class="section-head">\n      <div class="left">\n        <div class="kicker"><span class="dot"></span>— what you\'ll see, monthly</div>\n        <h2>two things,<br/>every <em>month</em>.</h2>\n      </div>\n    </div>\n\n    <div class="report">\n      <div class="card">\n        <div class="icn"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><rect x="3" y="5" width="16" height="13" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 9h16M7 3v4M15 3v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>\n        <h4>booking calendar</h4>\n        <p>live access. you see who\'s in your flat, when they arrive, when they leave, what they paid. no need to ask — open the link, scroll the month.</p>\n      </div>\n      <div class="card">\n        <div class="icn"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4 18h14M4 4v14M8 14V9M12 14V6M16 14v-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>\n        <h4>financial report</h4>\n        <p>at the start of each new month for the previous one: bookings, revenue, our 30%, your 70%, operating expenses, net to you. all generated <b>from our own bookkeeping platform</b> — receipts attached, every line traceable. pdf and spreadsheet — you pick.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- PULL QUOTE -->\n<section class="pull">\n  <blockquote>you own <em>the flat</em>.<br/>we run <em>everything else</em>.</blockquote>\n  <div class="signoff">— bre · since 2022</div>\n</section>\n\n<!-- OWN ACCOUNTING PLATFORM -->\n<section class="pad" style="background:var(--paper);border-top:1px solid var(--line);border-bottom:1px solid var(--line)">\n  <div class="container">\n    <div class="section-head">\n      <div class="left">\n        <div class="kicker"><span class="dot"></span>— how we stay transparent</div>\n        <h2>we built our<br/><em>own</em> system.</h2>\n      </div>\n      <div class="right">every receipt, every booking, every payout — recorded in <b>our internal platform</b>, designed for one job: making sure owners see exactly what we see. coming to you as a viewer soon.</div>\n    </div>\n    <div class="report" style="margin-top:24px">\n      <div class="card">\n        <div class="icn" style="background:var(--page)"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4 6h14M4 11h14M4 16h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>\n        <h4>every line, traceable</h4>\n        <p>each row in your report links back to the actual booking, receipt, or expense. no aggregations you can\'t drill into. no "miscellaneous". no "service fee" without context.</p>\n      </div>\n      <div class="card">\n        <div class="icn" style="background:var(--page)"><svg width="22" height="22" viewBox="0 0 22 22" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"/><path d="M11 7v4l3 2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>\n        <h4>built, not bought</h4>\n        <p>off-the-shelf PMS systems weren\'t honest enough for us. we built our own admin from scratch — used by us daily, and soon shared with owners as a read-only viewer.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- CTA -->\n<section class="cta-wrap">\n  <h2>let\'s <em>talk</em>.</h2>\n  <p>30-minute call, no pressure, no presentation. we walk through your flat, your numbers, and tell you honestly if it makes sense to work together.</p>\n  <div class="row">\n    <a class="btn primary" href="https://t.me/bre_ge">↗ message on telegram</a>\n    <a class="btn alt" href="tel:+995585889601">+995 585 889 601</a>\n  </div>\n</section>'} />
<style is:global set:html={'.head{padding:140px 28px 72px;border-bottom:1px solid var(--line);position:relative;overflow:hidden}\n.head::before{content:"";position:absolute;top:0;right:0;width:55%;height:100%;background:var(--page);opacity:.06;clip-path:polygon(20% 0,100% 0,100% 100%,0 100%)}\n.head .inner{position:relative;z-index:2;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1.5fr 1fr;gap:48px;align-items:end}\n.head .crumbs{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);font-weight:500;margin-bottom:32px;display:flex;align-items:center;gap:10px}\n.head .crumbs a{color:var(--ink-soft)}\n.head .crumbs a:hover{color:var(--ink)}\n.head .crumbs .sep{opacity:.4}\n.head .crumbs .current{color:var(--blue-dark);font-weight:700;background:var(--blue-tint);padding:5px 11px;border-radius:999px;display:inline-flex;align-items:center;gap:7px}\n.head .crumbs .current .dot{width:8px;height:8px;border-radius:50%;background:var(--page)}\n.head h1{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(48px,7vw,120px);line-height:.9;letter-spacing:-.045em;text-transform:lowercase}\n.head h1 em{font-style:italic;color:var(--page)}\n.head .lede{font-size:20px;line-height:1.55;color:var(--ink);max-width:42ch;padding-bottom:20px}\n.head .lede b{font-weight:700;color:var(--ink)}\n.promise{padding:88px 28px;background:var(--paper);border-bottom:1px solid var(--line);position:relative}\n.promise .inner{max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:0;align-items:stretch}\n.promise .col{padding:48px 40px;display:flex;flex-direction:column;justify-content:space-between;min-height:340px;position:relative}\n.promise .col + .col{border-left:1px solid var(--line)}\n.promise .col .num{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(120px,16vw,220px);line-height:.85;letter-spacing:-.06em}\n.promise .col .num .pc{font-size:.4em;vertical-align:.6em;margin-left:.05em;letter-spacing:-.02em;opacity:.8}\n.promise .col.you .num{color:var(--ink)}\n.promise .col.us .num{color:var(--page)}\n.promise .col .label{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;color:var(--ink-soft);margin-bottom:16px}\n.promise .col .desc{font-size:16px;line-height:1.55;color:var(--ink-soft);max-width:34ch}\n.promise .col .desc b{color:var(--ink);font-weight:700}\nsection.pad{padding:120px 28px}\n.container{max-width:1400px;margin:0 auto}\n.section-head{display:flex;justify-content:space-between;align-items:flex-end;gap:40px;margin-bottom:56px;flex-wrap:wrap}\n.section-head .left{max-width:600px}\n.section-head .kicker{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--blue-dark);font-weight:600;margin-bottom:18px;display:inline-flex;align-items:center;gap:8px;background:var(--blue-tint);padding:5px 11px;border-radius:999px;width:fit-content}\n.section-head .kicker .dot{display:none}\n.section-head h2{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(40px,5.5vw,82px);line-height:.95;letter-spacing:-.04em;text-transform:lowercase}\n.section-head h2 em{font-style:italic;color:var(--page)}\n.section-head .right{max-width:380px;font-size:14px;line-height:1.55;color:var(--ink-soft);text-align:right}\n.services{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:14px;overflow:hidden}\n.svc{background:var(--bg);padding:36px 32px;display:flex;flex-direction:column;gap:14px;transition:background .25s ease}\n.svc:hover{background:var(--paper)}\n.svc .top{display:flex;justify-content:space-between;align-items:flex-start;gap:16px}\n.svc .nr{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;color:var(--ink-soft);font-weight:600}\n.svc .icon{width:32px;height:32px;border-radius:50%;background:var(--page);color:#fff;display:flex;align-items:center;justify-content:center}\n.svc h3{font-family:"Bricolage Grotesque",sans-serif;font-weight:700;font-size:24px;line-height:1.1;letter-spacing:-.025em;text-transform:lowercase}\n.svc h3 em{font-style:italic;color:var(--page)}\n.svc p{font-size:14.5px;line-height:1.6;color:var(--ink-soft)}\n.svc p b{color:var(--ink);font-weight:600}\n.split-wrap{padding:120px 28px;background:var(--paper);border-top:1px solid var(--line);border-bottom:1px solid var(--line)}\n.split{display:grid;grid-template-columns:1fr 1fr;gap:0;background:var(--bg);border-radius:14px;overflow:hidden;border:1px solid var(--line)}\n.split .side{padding:40px 36px;display:flex;flex-direction:column;gap:18px}\n.split .side + .side{border-left:1px solid var(--line)}\n.split .side h4{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:28px;letter-spacing:-.03em;text-transform:lowercase}\n.split .side .badge{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;padding:5px 11px;border-radius:999px;display:inline-flex;align-items:center;gap:6px;width:fit-content}\n.split .side.you .badge{background:var(--paper);color:var(--ink);border:1px solid var(--line)}\n.split .side.us .badge{background:var(--blue-tint);color:var(--blue-dark)}\n.split .side ul{list-style:none;display:flex;flex-direction:column;gap:8px}\n.split .side li{display:flex;align-items:flex-start;gap:12px;font-size:14.5px;line-height:1.5;color:var(--ink)}\n.split .side li::before{content:"";flex:none;width:6px;height:6px;border-radius:50%;background:var(--page);margin-top:7px}\n.process{display:grid;grid-template-columns:repeat(6,1fr);gap:18px}\n.step{position:relative;padding:24px 20px 26px;border:1px solid var(--line);border-radius:12px;background:var(--paper);transition:transform .3s cubic-bezier(.2,.7,.2,1),border-color .25s ease}\n.step:hover{transform:translateY(-3px);border-color:var(--page)}\n.step .nr{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;color:var(--page);font-weight:700;margin-bottom:14px}\n.step h4{font-family:"Bricolage Grotesque",sans-serif;font-weight:700;font-size:17px;line-height:1.2;letter-spacing:-.02em;text-transform:lowercase;margin-bottom:10px}\n.step p{font-size:13px;line-height:1.55;color:var(--ink-soft)}\n.report{display:grid;grid-template-columns:1fr 1fr;gap:32px}\n.report .card{padding:32px;background:var(--paper);border:1px solid var(--line);border-radius:14px;display:flex;flex-direction:column;gap:18px}\n.report .card .icn{width:48px;height:48px;border-radius:50%;background:var(--page);color:#fff;display:flex;align-items:center;justify-content:center}\n.report .card h4{font-family:"Bricolage Grotesque",sans-serif;font-weight:700;font-size:24px;letter-spacing:-.025em;text-transform:lowercase}\n.report .card p{font-size:14.5px;line-height:1.55;color:var(--ink-soft)}\n.pull{padding:140px 28px;background:var(--ink);color:#fff;text-align:center}\n.pull blockquote{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(40px,5.5vw,80px);line-height:1.05;letter-spacing:-.04em;text-transform:lowercase;max-width:18ch;margin:0 auto}\n.pull blockquote em{font-style:italic;color:var(--page)}\n.pull .signoff{margin-top:36px;font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:#ffffff77;font-weight:500}\n.cta-wrap{padding:120px 28px;text-align:center;border-top:1px solid var(--line)}\n.cta-wrap h2{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(48px,7vw,108px);line-height:.95;letter-spacing:-.04em;text-transform:lowercase;max-width:18ch;margin:0 auto 28px}\n.cta-wrap h2 em{font-style:italic;color:var(--page)}\n.cta-wrap p{max-width:42ch;margin:0 auto 40px;font-size:17px;line-height:1.55;color:var(--ink-soft)}\n.cta-wrap .row{display:flex;justify-content:center;gap:14px;flex-wrap:wrap}\n.btn{display:inline-fle