---
import Site from '../../../layouts/Site.astro';
import '../../../styles/guide-hub.css';
import { supabase } from '../../../lib/supabase';
import { GMAPS_KEY } from '../../../lib/maps';
import { priceFrom } from '../../../lib/price';

const { data: gp } = await supabase
  .from('guide_places').select('slug,title,name,category,lat,lng,photos,price,show_on_map,hours')
  .eq('status', 'published');
const places = gp || [];
const { data: newsData } = await supabase.from('news').select('*').eq('status', 'published').order('date', { ascending: false });
const news = newsData || [];
// места с координатами для персонального слоя (ближайшие к квартире гостя — считаются на клиенте)
const personalPlaces = (places as any[])
  .filter((p) => p.lat != null && p.lng != null)
  .map((p) => ({ slug: p.slug, title: p.title || p.name, lat: p.lat, lng: p.lng,
    category: p.category, photo: (p.photos && p.photos[0]) || '',
    href: '/georgia/batumi/guide/' + p.slug }));
const counts: Record<string, number> = {};
places.forEach((p) => { counts[p.category] = (counts[p.category] || 0) + 1; });
const { data: apts } = await supabase.from('apartments_public').select('slug,title,lat,lng,photos,price_from,price_currency');
const aptCount = (apts || []).length;
const total = places.length;

const CAT_COLOR: Record<string, string> = { 'eat-drink': '#3A4868', 'wellness': '#1F8A5B', 'work': '#1F8A5B', 'move-around': '#3A4868' };
const placePins = places.filter((p) => p.show_on_map && p.lat != null && p.lng != null).map((p) => ({
  slug: 'g-' + p.slug, title: p.title || p.name, lat: p.lat, lng: p.lng,
  photo: (p.photos && p.photos[0]) || '', href: '/georgia/batumi/guide/' + p.slug,
  sub: String(p.category).replace('-', ' '), cta: p.price || 'see place →',
  color: CAT_COLOR[p.category] || '#3A4868', ring: '#ffffff', outline: (p.category === 'move-around' || p.category === 'work'),
  hours: Array.isArray(p.hours) ? p.hours : [],
}));
const aptPins = (apts || []).filter((a) => a.lat != null && a.lng != null).map((a) => ({
  slug: 'a-' + a.slug, title: a.title, lat: a.lat, lng: a.lng,
  photo: (a.photos && a.photos[0]) || '', href: '/georgia/batumi/stays/' + a.slug,
  sub: 'flat', cta: priceFrom(a, 'en'),
  color: '#ff5e1a', ring: '#0a0908', flat: true,
}));
const mapData = placePins.concat(aptPins);

const esc = (s: any) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const goArrow = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

// category tiles — real worlds wired + counts; future worlds kept as placeholders (— / coming)
const ICO = {
  eat: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 1V8M4 8C3 8 2.5 8 2.5 9V15M4 8C5 8 5.5 8 5.5 9V15M11 1C9.5 1 9 2 9 3.5C9 5 9.5 6 11 6.5V14.5C11 14.7 11.2 15 11.5 15S12 14.7 12 14.5V6.5C13.5 6 14 5 14 3.5C14 2 13.5 1 12 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  wellness: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2C7 5 5 6 4 7C2.5 8 3 10 5 10.5C7 11 8.5 9.5 8 7M8 7C7.5 5 9 4 11 4.5C13 5 13.5 7 12 8.5C11 9.5 9 9 8 7Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  nightlife: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 2L8 8L12 2M8 8V14M5 14H11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  experiences: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M8 4V8L10.5 9.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  move: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="5" cy="11" r="2" stroke="currentColor" stroke-width="1.3"/><circle cx="11" cy="11" r="2" stroke="currentColor" stroke-width="1.3"/><path d="M5 9L7 4H10L12 8M3 4H6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  work: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="9" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M5 14H11M8 12V14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  explore: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1L9.5 6.5L15 8L9.5 9.5L8 15L6.5 9.5L1 8L6.5 6.5L8 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>',
};
const CATS = [
  { cls: 'stay primary featured', href: '/georgia/batumi/stays', n: aptCount || '', h: 'stay &amp; live', sub: 'flats · hotels · long-term', desc: 'our flats, hotels we send guests to, neighbourhoods we live in.', featured: true },
  { cls: 'eat primary', href: '/georgia/batumi/guide/eat-drink', n: counts['eat-drink'] || 0, ico: ICO.eat, h: 'eat &amp; drink', sub: 'cafés · restaurants · bars', desc: 'our favourite cafés, brunch spots, restaurants, cocktail bars and bakeries.' },
  { cls: 'wellness primary', href: '/georgia/batumi/guide/wellness', n: counts['wellness'] || 0, ico: ICO.wellness, h: 'wellness', sub: 'spa · baths · yoga · massage', desc: 'slow living done right: sulphur baths, massage rooms, spa days.' },
  { cls: 'nightlife secondary', href: '#', n: '—', ico: ICO.nightlife, h: 'nightlife', sub: 'wine bars · clubs · late spots', desc: 'where to drink late, dance properly, or find a wine bar with vinyl.', soon: true },
  { cls: 'experiences secondary', href: '#', n: '—', ico: ICO.experiences, h: 'experiences', sub: 'tours · classes · day trips', desc: 'wine tastings, cooking classes, boat trips, day trips we\'d go on again.', soon: true },
  { cls: 'move secondary', href: '/georgia/batumi/guide/move-around', n: counts['move-around'] || 0, ico: ICO.move, h: 'move around', sub: 'taxi · scooter · car', desc: 'how locals actually get around. apps, rentals, the ones we use.' },
  { cls: 'work secondary', href: '/georgia/batumi/guide/work', n: counts['work'] || 0, ico: ICO.work, h: 'work &amp; remote', sub: 'co-workings · cafes with wifi', desc: 'cafés with reliable wifi, co-workings, and quiet corners for deep work.' },
  { cls: 'explore secondary', href: '#', n: '—', ico: ICO.explore, h: 'explore', sub: 'beaches · old town · parks', desc: 'batumi\'s neighbourhoods, beaches, parks and viewpoints worth a walk.', soon: true },
];
const tile = (c: any) => {
  const top = '<div class="top"><span class="num">' + c.n + '</span>' +
    (c.featured ? '<span class="badge"><span class="pulse"></span>start here</span>'
      : (c.soon ? '<span class="badge" style="opacity:.6">soon</span>' : '<span class="ico">' + c.ico + '</span>')) + '</div>';
  const foot = c.featured ? '<span class="cta">book a stay' + goArrow + '</span>' : (c.soon ? '' : '<span class="go">' + goArrow + '</span>');
  const _cls = 'cat-tile ' + c.cls + (c.soon ? ' is-soon' : '');
  const _inner = top + '<h3>' + c.h + '</h3><div class="sub">' + c.sub + '</div><p class="desc">' + c.desc + '</p>' + foot;
  return c.soon
    ? '<div class="' + _cls + '" data-cat="' + esc(c.h) + '">' + _inner + '</div>'
    : '<a class="' + _cls + '" href="' + c.href + '" data-cat="' + esc(c.h) + '">' + _inner + '</a>';
};
const catsHtml = CATS.map(tile).join('');

// latest-news cover plate (restored) — top news item from tilda
const fmtDate = (d: string) => { const m = (d || '').match(/(\d{4})-(\d{2})-(\d{2})/); if (!m) return 'this week'; const mo = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'][+m[2] - 1]; return (+m[3]) + ' ' + mo; };
const newsArr = news as any[];
const mdEm = (raw: string) => esc(raw).replace(/\*([^*]+)\*/g, '<em>$1</em>');
const slidesHtml = [...newsArr].sort((a,b)=>String(b.date||'').localeCompare(String(a.date||''))).filter((nx: any)=>nx.on_guide!==false).slice(0,6).map((nx, i) =>
  '<a class="cover-slide' + (i === 0 ? ' active' : '') + '" href="/georgia/batumi/guide/news/' + nx.slug + '">' +
  '<img class="cs-bg" src="' + esc(nx.image || (nx.photos && nx.photos[0]) || '') + '" alt=""><span class="cs-tint"></span><span class="cs-shade"></span>' +
  '<div class="body"><h3>' + mdEm(nx.headline || nx.title) + '</h3>' +
  '<span class="read">read the issue</span></div></a>'
).join('');
const coverHtml = newsArr.length ? (
  '<div class="masthead-cover rotator"><div class="kicker-top">the batumi guide · this week</div>' +
  '<div class="slides">' + slidesHtml + '</div></div>'
) : '';

// longreads (stories) — templates kept; articles to be written
const storiesHtml = (
  '<a class="story" href="/georgia/batumi/guide/day-in-old-batumi"><div class="ph"><img src="/img/old-batumi.jpg" alt=""><span class="nr">routine · 02</span></div><span class="kicker">routine</span><h4>a day in <em>old batumi</em>.</h4><p class="summary">coffee in the old town, two squares, four faiths, khinkali, and an afternoon down to the sea.</p><span class="read">read routine →</span></a>'
);

// news — real items from tilda
const newsHtml = (news as any[]).map((n) =>
  '<a class="news-card" href="/georgia/batumi/guide/news/' + n.slug + '"><div class="ph"><img src="' + esc(n.image) + '" alt=""></div>' +
  '<div class="body"><span class="date"><span class="pulse"></span>' + esc(fmtDate(n.date)) + '</span>' +
  '<h4>' + esc(String(n.title).slice(0, 80)) + '</h4>' +
  '<p class="summary">' + esc(n.descr) + '</p></div></a>'
).join('');

const content =
  '<section class="masthead">' +
    '<a class="masthead-photo" href="#cats"><img src="/img/hero-batumi.jpg" alt="batumi old town">' +
    '<div class="caption"><h1>the batumi<br/>we <em>actually</em><br/>recommend.</h1><span class="credit">— our own<br/>local journal</span></div></a>' +
    '<div class="masthead-side"><div class="masthead-intro"><div class="kicker">about the guide</div>' +
      '<p class="lede"><b>cafés, restaurants, wellness, work spots and how to get around</b> — places we send our guests to, and would <em>hand to a friend without thinking</em>. not from tripadvisor, not optimised for clicks.</p>' +
      '<div class="stats"><div><span class="num">' + total + '</span>places</div><div><span class="num">4</span>worlds</div><div><span class="num">100%</span>tried by us</div></div></div>' +
      coverHtml +
    '</div>' +
  '</section>' +

  '<section class="cats-section" id="cats"><div class="cats-head"><h2>our <em>worlds</em>,<br/>one batumi.</h2>' +
    '<div class="right">— pick a world to dive in. each is <b>a curated mini-guide</b> with its own places, sub-categories, and a map.</div></div>' +
    '<div class="cats-grid">' + catsHtml + '</div></section>' +

  '<section class="mapblock" id="map">' +
    '<div class="mapblock-head"><div class="mh-left"><span class="eyebrow">— the map</span>' +
      '<h3>everything near you,<br/><em>and near your stay</em>.</h3>' +
      '<p class="mh-sub">all ' + total + ' spots and every flat on one map — <b>find what\'s good around you right now</b>.</p></div>' +
      '<div class="right"><span class="legend">' +
        '<span class="dot"><span class="sw" style="background:#3A4868"></span>eat</span>' +
        '<span class="dot"><span class="sw" style="background:#1F8A5B"></span>wellness</span>' +
        '<span class="dot"><span class="sw" style="background:transparent;border:2px solid #1F8A5B"></span>work</span>' +
        '<span class="dot"><span class="sw" style="background:transparent;border:2px solid #3A4868"></span>move</span>' +
        '<span class="dot"><svg width="13" height="13" viewBox="0 0 100 100" style="display:block"><path fill-rule="evenodd" fill="#ff5e1a" d="M 50,50 m -50,0 a 50,50 0 1,1 100,0 a 50,50 0 1,1 -100,0 z M 62,62 m -16.5,0 a 16.5,16.5 0 1,1 33,0 a 16.5,16.5 0 1,1 -33,0 z"/></svg>flat</span>' +
      '</span></div></div>' +
    '<div class="map-controls"><div class="seg">' +
      '<button class="mc active" data-act="all">all · ' + total + '</button>' +
      '<button class="mc" data-act="opennow">open now</button></div>' +
      '<button class="mc near" data-act="near"><svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="2.6" fill="currentColor"/><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4"/><path d="M8 0.5v3M8 12.5v3M0.5 8h3M12.5 8h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg> near me</button>' +
    '</div>' +
    '<div class="map"><button class="map-expand" type="button" aria-label="expand map"><svg class="ic-exp" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 2H2v4M10 2h4v4M6 14H2v-4M10 14h4v-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg><svg class="ic-close" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg></button><div id="guideMap"></div></div></section>' +

  '<section class="stories-wrap"><div class="stories-head"><div><h3>longer <em>reads</em>.</h3></div>' +
    '<div class="right"><span>stories take time. we publish one every few weeks — <b>people we love</b>, <b>routines we keep</b>, <b>photo essays</b>.</span><span class="scroll-hint">scroll →</span></div></div>' +
    '<div class="stories">' + storiesHtml + '</div></section>' +

  '<section class="news-wrap" id="news"><div class="news-head"><div><h3>what\'s <em>happening</em>.</h3></div>' +
    '<div class="right"><span>news worth showing up for —<br/>fresh from batumi</span><span class="scroll-hint">scroll →</span></div></div>' +
    '<div class="news-scroll">' + newsHtml + '</div></section>' +

  '<section class="pull"><blockquote>we don\'t <span class="under"><em>rate</em></span>.<br/>we just <span class="under"><em>recommend</em></span>.</blockquote><div class="sig">— bre, batumi</div></section>' +

  '<a class="map-fab" href="#map" aria-label="open the map"><span class="mf-ico"><svg viewBox="0 0 48 48"><defs><clipPath id="mfc"><circle cx="24" cy="24" r="24"/></clipPath></defs><g clip-path="url(#mfc)"><rect width="48" height="48" fill="#f4f0e7"/><path d="M0 37 Q14 33 26 35 T48 29 L48 48 L0 48 Z" fill="#bfdaee" opacity="0.6"/><path d="M0 37 Q14 33 26 35 T48 29" stroke="#7bafd2" stroke-width="1.2" fill="none" opacity="0.7"/><line x1="0" y1="17" x2="48" y2="17" stroke="#00000010" stroke-width="2"/><line x1="17" y1="0" x2="17" y2="48" stroke="#00000010" stroke-width="2"/><line x1="34" y1="0" x2="34" y2="48" stroke="#00000010" stroke-width="2"/><circle cx="20" cy="19" r="3.4" fill="#ff5e1a" stroke="#fff" stroke-width="1.5"/><circle cx="33" cy="26" r="2.6" fill="#1F8A5B" stroke="#fff" stroke-width="1.3"/></g></svg></span><span class="mf-txt">map</span></a>';
---
<Site title={"the batumi guide — rega rega"}>
<link rel="stylesheet" href="/rega-personal.css?v=3" />
<div id="rr-personal" hidden></div>
<Fragment set:html={content} />
<style is:inline set:html={"#guideMap{position:absolute;inset:0;width:100%;height:100%}\n.masthead-cover.rotator{position:relative}\n.masthead-cover.rotator .slides{position:absolute;inset:0;overflow:hidden;z-index:1}\n.masthead-cover .cover-slide{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;color:#FAF7F0;transform:translateY(100%);opacity:0;transition:transform .6s cubic-bezier(.2,.7,.2,1),opacity .5s ease;pointer-events:none;overflow:hidden}\n.masthead-cover .cover-slide.active{transform:translateY(0);opacity:1;pointer-events:auto}\n.masthead-cover .cover-slide.leaving{transform:translateY(-100%);opacity:0}\n.masthead-cover .cs-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;filter:grayscale(1) brightness(1.55) contrast(.9)}\n.masthead-cover .cs-tint{position:absolute;inset:0;z-index:1;background:#ff5e1a;mix-blend-mode:multiply}\n.masthead-cover .cs-shade{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(120,38,8,.28) 0%,rgba(120,38,8,0) 34%,rgba(90,28,6,.42) 100%)}\n.masthead-cover .cover-slide .body{position:relative;z-index:2;flex:1;width:100%;box-sizing:border-box;display:flex;flex-direction:column;justify-content:space-between;padding:64px 28px 26px}\n.masthead-cover .cover-slide h3{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(28px,2.9vw,42px);line-height:1.03;letter-spacing:-.035em;text-transform:lowercase;color:#FAF7F0;margin:0}\n.masthead-cover .cover-slide h3 em{font-style:italic;color:#FAF7F0}\n.masthead-cover .cover-slide .read{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.24em;text-transform:uppercase;font-weight:700;color:#FAF7F0;opacity:.92}\n.masthead-cover .kicker-top{position:absolute;top:26px;left:28px;z-index:3;display:flex;align-items:center;gap:11px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;color:#FAF7F0}\n.masthead-cover .kicker-top::before{content:'';width:22px;height:1px;background:#FAF7F0;display:inline-block}\n.masthead-cover .rot-dots{position:absolute;bottom:14px;right:18px;z-index:5;display:flex;gap:6px}\n.masthead-cover .rot-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.4);border:0;cursor:pointer;padding:0;transition:background .2s ease}\n.masthead-cover .rot-dot.active{background:#FAF7F0}\n.mapblock .mapblock-head .mh-left{max-width:560px}\n.mapblock .eyebrow{display:inline-flex;align-items:center;gap:10px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:600;color:var(--accent-deep);background:var(--accent-soft);padding:5px 11px;border-radius:999px;width:fit-content;margin-bottom:14px}\n.mapblock .mh-sub{margin-top:12px;font-size:15px;line-height:1.5;color:var(--ink-soft);max-width:470px}\n.mapblock .mh-sub b{color:var(--ink);font-weight:600}\n.map-controls{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin:24px 0 16px}\n.map-controls .seg{display:inline-flex;background:var(--paper);border:1px solid var(--line);border-radius:999px;padding:3px}\n.map-controls .mc{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:600;color:var(--ink-soft);padding:9px 16px;border-radius:999px;cursor:pointer;display:inline-flex;align-items:center;gap:7px;border:0;background:transparent;transition:all .18s ease}\n.map-controls .seg .mc.active{background:var(--ink);color:#FAF7F0}\n.map-controls .mc.near{border:1px solid var(--line);background:var(--paper);color:var(--ink)}\n.map-controls .mc.near:hover{border-color:var(--accent);color:var(--accent)}\n.map-controls .mc.near.loading{opacity:.55;pointer-events:none}\n.map-controls .mc.near.err{border-color:#d9402a;color:#d9402a}\n.map-fab{position:fixed;right:20px;bottom:20px;z-index:60;display:inline-flex;align-items:center;gap:9px;height:52px;padding:0 18px 0 7px;border-radius:999px;background:var(--ink);border:2px solid var(--ink);box-shadow:0 8px 24px rgba(0,0,0,.3);transition:transform .2s ease,box-shadow .2s ease}\n.map-fab:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(0,0,0,.36)}\n.map-fab .mf-ico{width:38px;height:38px;border-radius:50%;overflow:hidden;flex:none;border:1.5px solid rgba(255,255,255,.5)}\n.map-fab .mf-ico svg{width:100%;height:100%;display:block}\n.map-fab .mf-txt{font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;color:#FAF7F0}"}></style>
<script is:inline>
(function(){
  var rot=document.querySelector('.masthead-cover.rotator'); if(!rot) return;
  var slides=rot.querySelectorAll('.cover-slide'), dots=rot.querySelectorAll('.rot-dot');
  if(slides.length<2) return;
  var i=0, t;
  function go(n){ var prev=i; i=(n+slides.length)%slides.length; if(prev!==i){ slides[prev].classList.add('leaving'); slides[prev].classList.remove('active'); (function(p){ setTimeout(function(){ slides[p].classList.remove('leaving'); },650); })(prev); } if(dots[prev])dots[prev].classList.remove('active'); slides[i].classList.add('active'); if(dots[i])dots[i].classList.add('active'); }
  function start(){ t=setInterval(function(){ go(i+1); },5000); }
  dots.forEach(function(d){ d.addEventListener('click',function(e){ e.preventDefault(); clearInterval(t); go(+d.getAttribute('data-i')); start(); }); });
  start();
})();
</script>
<script is:inline src="https://unpkg.com/@googlemaps/markerclusterer@2.5.3/dist/index.min.js"></script>
<script is:inline src="/rega-map.js"></script>
<script is:inline>
(function(){
  var mapEl = document.querySelector('.mapblock .map');
  var expBtn = document.querySelector('.mapblock .map-expand');
  if (!mapEl || !expBtn) return;
  function setExp(on){
    mapEl.classList.toggle('expanded', on);
    document.documentElement.classList.toggle('map-locked', on);
    document.body.classList.toggle('map-locked', on);
    setTimeout(function(){ window.dispatchEvent(new Event('resize')); }, 90);
  }
  expBtn.addEventListener('click', function(){ setExp(!mapEl.classList.contains('expanded')); });
  document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && mapEl.classList.contains('expanded')) setExp(false); });
})();
</script>
<script is:inline>
(function(){
  // #map deep link: the native anchor jump fires before the images above the map
  // finish loading, so the page ends up short of the map (Safari never corrects).
  // Re-snap to the map block as the layout settles; stop as soon as the user acts.
  if (location.hash !== '#map') return;
  var mb = document.querySelector('.mapblock'); if (!mb) return;
  var stop = false;
  ['wheel','touchstart','keydown','pointerdown'].forEach(function(ev){
    window.addEventListener(ev, function(){ stop = true; }, { capture: true, passive: true, once: true });
  });
