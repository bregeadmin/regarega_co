---
import Site from '../../../layouts/Site.astro';
---
<Site title={'rega rega — page not found'}>
<Fragment set:html={'<div class="wrap">\n    <div class="stamp"><span class="dot"></span>404 · page not found</div>\n    <h1>this page <em>doesn\'t</em> exist.</h1>\n    <p>maybe it moved, maybe we haven\'t built it yet, maybe you mistyped the address. no worries — try one of the doors below.</p>\n    <div class="links">\n      <a class="btn" href="/georgia/batumi">← home</a>\n      <a class="btn alt" href="/georgia/batumi/guide">the guide</a>\n      <a class="btn alt" href="https://t.me/bre_ge">↗ telegram</a>\n    </div>\n  </div>'} />
<style is:global set:html={'.wrap{max-width:640px;text-align:left}\n.stamp{\n    display:inline-flex;align-items:center;gap:10px;\n    font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;\n    text-transform:uppercase;font-weight:600;color:var(--page-deep);background:var(--accent-soft);padding:5px 11px;border-radius:999px;\n    margin-bottom:24px;\n  }\n.stamp .dot{width:7px;height:7px;border-radius:50%;background:var(--accent)}\n.links{margin-top:36px;display:flex;flex-wrap:wrap;gap:10px}'}></style>
</Site>
