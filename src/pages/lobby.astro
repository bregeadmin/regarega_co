---
// Home — Rega Rega Batumi edition (lobby + city edition merged while one city is live).
// Ported from the locked prototype regarega.co.html. Componentise progressively.
import Base from '../layouts/Base.astro';
---
<Base>
<style is:global>
/* ══ STICKY STACK — each block flies up over the previous ══ */
.blk{position:sticky;top:0;height:100vh;overflow:hidden}
.b1{z-index:1;background:var(--ink)}
.b2{
  z-index:2;background:var(--bg);
  border-radius:30px 30px 0 0;
  box-shadow:0 -20px 60px rgba(0,0,0,.22)
}
/* dwell track: keeps block 2 fully on screen a bit longer before stays rises */
.b2-spacer{height:55vh;background:var(--bg)}
.b3{
  z-index:3;background:var(--ink);
  border-radius:30px 30px 0 0;
  box-shadow:0 -20px 60px rgba(0,0,0,.30)
}
.b4{
  position:relative;z-index:4;
  background:var(--bg);
  border-radius:30px 30px 0 0;
  box-shadow:0 -20px 60px rgba(0,0,0,.40);
  overflow:hidden;display:flex;flex-direction:column
}

.b3-right img{display:block;width:100%;height:100%;object-fit:cover}

/* ══════════════════════════
   BLOCK 1 — ink, centered mark
   ══════════════════════════ */
.b1{display:flex;align-items:center;justify-content:center}
.h-mark{
  display:inline-flex;align-items:flex-end;
  font-weight:800;font-size:clamp(80px,14vw,212px);
  letter-spacing:-.055em;line-height:.78;text-transform:lowercase;color:#FAF7F0
}
.h-mark .lead{display:inline-block;opacity:0;transform:translateY(28px);animation:hlead .7s cubic-bezier(.22,1,.36,1) .12s forwards}
.h-mark .d{
  border-radius:50%;background:var(--acc);flex:none;
  width:.12em;height:.12em;margin-left:.06em;margin-bottom:-.09em;
  opacity:0;transform:scale(.2);animation:hdot .5s cubic-bezier(.34,1.56,.64,1) .62s forwards
}
.h-mark .twin{display:inline-block;opacity:0;margin-left:.26em;transform:translateY(28px);animation:htwin .7s cubic-bezier(.22,1,.36,1) .46s forwards}
@keyframes hlead{to{opacity:1;transform:none}}
@keyframes hdot{to{opacity:1;transform:none}}
@keyframes htwin{to{opacity:.34;transform:none}}
@media(prefers-reduced-motion:reduce){
  .h-mark .lead,.h-mark .d,.h-mark .twin{animation:none;opacity:1;transform:none}
  .h-mark .twin{opacity:.34}
}

/* ══════════════════════════
   BLOCK 2 — city + four doors
   ══════════════════════════ */
.b2-nav{
  position:absolute;top:0;left:0;right:0;z-index:10;
  height:54px;display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;background:var(--bg);border-bottom:1px solid var(--ink)
}
.tb-mark{
  display:inline-flex;align-items:flex-end;font-weight:800;
  font-size:19px;letter-spacing:-.055em;line-height:.78;text-transform:lowercase
}
.tb-mark .d{
  border-radius:50%;background:var(--acc);flex:none;
  width:.075em;height:.075em;margin-left:.057em;margin-bottom:-.076em
}
.tb-mark .twin{opacity:.38;margin-left:.26em}
.tb-nav{display:flex}
.tb-link{
  display:inline-flex;align-items:center;gap:6px;
  font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.2em;
  text-transform:uppercase;font-weight:700;color:var(--soft);
  padding:6px 14px;transition:color .15s
}
.tb-link .dot{
  width:5px;height:5px;border-radius:50%;background:var(--acc);
  opacity:0;transform:scale(.3);transition:all .2s;flex:none
}
.tb-link:hover .dot{opacity:1;transform:scale(1)}
.tb-link:hover{color:var(--ink)}
.tb-r{font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;font-weight:600;color:var(--soft)}

/* ── city selector ("your city" → dropdown), overlaid on the tiles ── */
.b2-cities{
  position:absolute;top:0;left:0;right:0;z-index:6;
  padding:30px 28px 64px;pointer-events:none;
  background:linear-gradient(to bottom,var(--bg) 55%,rgba(251,248,241,.6) 80%,rgba(251,248,241,0))
}
.lang{
  position:absolute;top:20px;right:26px;z-index:8;
  font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.2em;
  text-transform:uppercase;font-weight:600;color:var(--soft);transition:color .15s
}
.lang:hover{color:var(--ink)}
.b2-cities-label{
  font-family:"JetBrains Mono",monospace;font-size:9.5px;letter-spacing:.26em;
  text-transform:uppercase;font-weight:700;color:var(--faint);margin-bottom:4px
}
.city-select{position:relative;display:inline-block;pointer-events:auto}
.city-current{
  display:inline-flex;align-items:flex-end;gap:.14em;
  font-weight:800;font-size:clamp(48px,8.5vw,116px);
  letter-spacing:-.055em;line-height:.82;text-transform:lowercase;color:var(--ink)
}
.city-current .caret{
  display:inline-flex;width:.32em;height:.32em;margin-bottom:.2em;
  transition:transform .25s cubic-bezier(.22,1,.36,1)
}
.city-current .caret svg{width:100%;height:100%;fill:none;stroke:var(--acc);stroke-width:3.2;stroke-linecap:round;stroke-linejoin:round}
.city-current[aria-expanded="true"] .caret{transform:rotate(180deg)}
.city-menu{
  position:absolute;top:calc(100% + 12px);left:0;z-index:50;
  min-width:272px;background:#fdfbf6;
  border:1px solid var(--ink);border-radius:14px;
  box-shadow:0 16px 44px rgba(0,0,0,.18);overflow:hidden
}
.city-menu[hidden]{display:none}
.city-opt{
  display:flex;align-items:center;justify-content:space-between;gap:20px;width:100%;
  padding:14px 18px;font-weight:800;font-size:20px;letter-spacing:-.03em;
  text-transform:lowercase;color:var(--ink);text-align:left;
  border-bottom:1px solid var(--line);transition:background .15s
}
.city-opt:last-child{border-bottom:0}
.city-opt:not(:disabled){cursor:pointer}
.city-opt:not(:disabled):hover{background:var(--bg2)}
.city-opt:disabled{color:var(--faint)}
.opt-tag{
  font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.2em;
  text-transform:uppercase;font-weight:700;color:var(--faint)
}
.opt-tag.live{color:var(--acc)}

/* ── FOUR DOORS (photo + colour plate, expand on hover) ── */
.b2-tiles{
  position:absolute;top:0;left:0;right:0;bottom:0;
  display:grid;grid-template-columns:2.6fr .8fr .8fr .8fr;
  transition:grid-template-columns .45s cubic-bezier(.22,1,.36,1)
}
.b2-tiles:has(.gt:nth-child(1):hover){grid-template-columns:2.6fr .8fr .8fr .8fr}
.b2-tiles:has(.gt:nth-child(2):hover){grid-template-columns:.8fr 2.6fr .8fr .8fr}
.b2-tiles:has(.gt:nth-child(3):hover){grid-template-columns:.8fr .8fr 2.6fr .8fr}
.b2-tiles:has(.gt:nth-child(4):hover){grid-template-columns:.8fr .8fr .8fr 2.6fr}

.gt{position:relative;overflow:hidden;cursor:pointer;border-right:1px solid rgba(255,255,255,.14)}
.gt:last-child{border-right:0}

/* photo always visible */
.gt-photo{position:absolute;inset:0}
.gt-photo img,.gt-photo video{width:100%;height:100%;object-fit:cover;display:block;transition:transform .6s cubic-bezier(.22,1,.36,1)}
.gt:hover .gt-photo img,.gt:hover .gt-photo video{transform:scale(1.05)}

/* colour plate overlaid on the photo, holding the text */
.gt-plate{
  position:absolute;left:0;right:0;bottom:0;
  padding:20px 20px 26px;display:flex;flex-direction:column;gap:8px;color:#FAF7F0;
  transition:padding .35s cubic-bezier(.22,1,.36,1),gap .35s
}
.gt:nth-child(1) .gt-plate{background:var(--acc)}    /* guide   — orange */
.gt:nth-child(2) .gt-plate{background:var(--blue)}   /* stays   — blue */
.gt:nth-child(3) .gt-plate{background:var(--purple)} /* stories — purple */
.gt:nth-child(4) .gt-plate{background:var(--teal)}   /* areas   — teal */

/* on open/hover: bigger colour zone + raised text so the link is easy to reach */
.gt:hover .gt-plate,
.b2-tiles:not(:has(.gt:hover)) .gt:nth-child(1) .gt-plate{padding:96px 22px 42px;gap:11px}

.gt-label{
  font-family:"JetBrains Mono",monospace;font-size:9.5px;letter-spacing:.24em;
  text-transform:uppercase;font-weight:700;color:rgba(255,255,255,.72)
}
.gt-head{
  display:inline-flex;align-items:flex-end;font-weight:800;
  font-size:clamp(26px,3.2vw,48px);letter-spacing:-.045em;
  line-height:.82;text-transform:lowercase;color:#FAF7F0;
  transition:transform .35s cubic-bezier(.22,1,.36,1)
}
.gt-head .d{
  border-radius:50%;background:#FAF7F0;flex:none;
  width:.12em;height:.12em;margin-left:.06em;margin-bottom:-.09em
}
.gt:hover .gt-head{transform:translateY(-2px)}
.gt-desc{
  font-size:14px;line-height:1.5;color:rgba(255,255,255,.9);max-width:32ch;
  opacity:0;max-height:0;transform:translateY(8px);overflow:hidden;
  transition:opacity .3s,transform .35s .05s cubic-bezier(.22,1,.36,1),max-height .4s
}
.gt:hover .gt-desc{opacity:1;max-height:120px;transform:none}
.gt-link{
  font-family:"JetBrains Mono",monospace;font-size:9.5px;letter-spacing:.2em;
  text-transform:uppercase;font-weight:700;color:#FAF7F0;
  opacity:0;transform:translateY(6px);
  transition:opacity .3s .1s,transform .35s .1s cubic-bezier(.22,1,.36,1);
  display:inline-flex;align-items:center;gap:6px;width:fit-content;
  border-bottom:1.5px solid #fff;padding-bottom:1px;margin-top:2px
}
.gt:hover .gt-link{opacity:1;transform:none}

/* guide tile open by default (until another tile is hovered) */
.b2-tiles:not(:has(.gt:hover)) .gt:nth-child(1) .gt-head{transform:translateY(-2px)}
.b2-tiles:not(:has(.gt:hover)) .gt:nth-child(1) .gt-desc{opacity:1;max-height:120px;transform:none}
.b2-tiles:not(:has(.gt:hover)) .gt:nth-child(1) .gt-link{opacity:1;transform:none}

/* ══════════════════════════
   BLOCK 3 — ink, stays + booking
   ══════════════════════════ */
.b3{display:grid;grid-template-columns:1fr 1fr}
.b3-left{
  padding:44px 32px 40px 36px;
  display:flex;flex-direction:column;justify-content:space-between;
  border-right:1px solid rgba(255,255,255,.08)
}
.b3-right{height:100vh;overflow:hidden}

.b3-prod{
  display:inline-flex;align-items:flex-end;font-weight:800;
  font-size:clamp(52px,7vw,100px);letter-spacing:-.055em;line-height:.78;text-transform:lowercase;color:#FAF7F0
}
.b3-prod .d{
  border-radius:50%;background:var(--acc);flex:none;
  width:.12em;height:.12em;margin-left:.06em;margin-bottom:-.09em
}
.b3-city{
  display:inline-flex;align-items:flex-end;font-weight:800;
  font-size:clamp(64px,16vw,220px);letter-spacing:-.055em;line-height:.78;text-transform:lowercase;color:#FAF7F0;
  margin-top:8px
}
.b3-city .d{
  border-radius:50%;background:var(--acc);flex:none;
  width:.12em;height:.12em;margin-left:.06em;margin-bottom:-.09em
}
.b3-line{
  font-size:clamp(18px,2.2vw,30px);font-weight:800;letter-spacing:-.03em;
  line-height:1.15;text-transform:lowercase;color:#FAF7F0
}
.b3-byline{
  font-size:15px;line-height:1.5;color:rgba(255,255,255,.45);
  font-weight:400;margin-top:6px
}
.b3-byline em{color:rgba(255,94,26,.85);font-style:italic}

.b3-book{
  background:rgba(255,255,255,.06);border-radius:14px;
  padding:20px 22px;display:flex;align-items:center;gap:0;flex-wrap:wrap
}
.book-city{
  font-weight:800;font-size:20px;letter-spacing:-.025em;color:var(--acc);
  padding-right:16px;white-space:nowrap;border-right:1px solid rgba(255,255,255,.12)
}
.book-field{
  display:flex;flex-direction:column;gap:3px;padding:0 16px;flex:1;min-width:80px
}
.book-field label{
  font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.22em;
  text-transform:uppercase;font-weight:700;color:rgba(255,255,255,.35)
}
.book-field input{
  font-size:17px;font-weight:500;letter-spacing:-.015em;color:#FAF7F0;
  border-bottom:1px solid rgba(255,255,255,.15);padding-bottom:4px;
  transition:border-color .2s;width:100%
}
.book-field input:focus{border-bottom-color:var(--acc)}
.book-field input::placeholder{color:rgba(255,255,255,.3)}
.book-sep{width:1px;height:36px;background:rgba(255,255,255,.12);flex:none}
.book-submit{
  margin-left:16px;flex:none;
  background:var(--acc);color:#FAF7F0;font-weight:800;font-size:16px;
  letter-spacing:-.01em;padding:12px 20px;border-radius:999px;
  transition:transform .15s,box-shadow .15s;white-space:nowrap
}
.book-submit:hover{transform:scale(1.03);box-shadow:0 4px 16px rgba(255,94,26,.4)}

.b3-guide-link{
  font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.2em;
  text-transform:uppercase;font-weight:700;color:rgba(255,255,255,.35);
  transition:color .15s;display:inline-flex;align-items:center;gap:7px
}
.b3-guide-link:hover{color:var(--acc)}

/* ══════════════════════════
   BLOCK 4 — cream card, footer
   ══════════════════════════ */
.bf{flex:1;padding:56px 36px 48px;overflow-y:auto}
.bf-grid{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr)}
.bf-block{
  padding:28px 32px 28px 0;border-right:1px solid var(--line);
  display:flex;flex-direction:column;gap:14px
}
.bf-block:last-child{border-right:0;padding-right:0;padding-left:32px}
.bf-block:nth-child(2){padding-left:32px}
.bf-lbl{
  font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.24em;
  text-transform:uppercase;font-weight:700;color:var(--soft)
}
.bf-ph{
  font-weight:800;font-size:clamp(17px,1.7vw,24px);
  letter-spacing:-.03em;line-height:1.15;text-transform:lowercase;flex:1
}
.bf-lk{
  font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.2em;
  text-transform:uppercase;font-weight:700;width:fit-content;
  border-bottom:1.5px solid var(--acc);padding-bottom:1px;transition:color .15s
}
.bf-lk:hover{color:var(--acc)}

.ft{border-top:1px solid var(--ink);padding:16px 36px 14px}
.ft-main{
  display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;
  font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.18em;
  text-transform:uppercase;font-weight:600;color:var(--soft)
}
.ft-sub{
  margin-top:8px;font-family:"JetBrains Mono",monospace;font-size:9px;
  letter-spacing:.18em;text-transform:uppercase;font-weight:500;color:var(--faint)
}

/* ══ RESPONSIVE ══ */
@media(max-width:768px){
  /* ── MOBILE = TOUR: sticky slides fly up over each other (clean, no overlap) ── */
  .blk{height:100svh}                /* b1, b3 stay sticky (base); refine to small-vh */
  .b2-spacer{display:none}           /* drop the desktop dwell gap that caused the bleed */
  .b2{position:relative;height:auto;min-height:0;overflow:visible;border-radius:0;box-shadow:none;background:transparent;z-index:2}
  .b2-tiles{position:static;display:block}
  .gt{
    position:sticky;top:0;height:100svh;border-right:0;
    border-radius:30px 30px 0 0;box-shadow:0 -22px 60px rgba(0,0,0,.45)
  }
  /* each door covers the previous one as it rises */
  .gt:nth-child(1){z-index:1}
  .gt:nth-child(2){z-index:2}
  .gt:nth-child(3){z-index:3}
  .gt:nth-child(4){z-index:4}
  .gt:first-child{border-radius:0;box-shadow:none}
  /* full text shown on every slide (no hover on touch) */
  .gt-plate{padding:40px 22px 52px!important;gap:12px}
  .gt-label{font-size:11px}
  .gt-head{font-size:clamp(52px,16vw,96px)}
  .gt-desc{opacity:1;max-height:240px;transform:none;font-size:16px;max-width:34ch}
  .gt-link{opacity:1;transform:none;font-size:11px}
  .gt:hover .gt-plate,
  .b2-tiles:not(:has(.gt:hover)) .gt:nth-child(1) .gt-plate{padding:40px 22px 52px!important}

  /* city selector sits over the first slide, white on a soft scrim */
  .b2-cities{padding:64px 20px 18px;background:linear-gradient(to bottom,rgba(0,0,0,.5),rgba(0,0,0,0))}
  .b2-cities-label{color:rgba(255,255,255,.72)}
  .city-current{color:#FAF7F0;font-size:clamp(40px,12vw,66px)}
  .lang{color:#FAF7F0}

  .b3{grid-template-columns:1fr}
  .b3-right{display:none}
  .b3-left{padding:28px 16px;min-height:100vh;min-height:100svh;justify-content:space-between}
  .book-city{display:none}
  .b3-book{padding:14px 16px;gap:6px}
  .book-field{min-width:60px;padding:0 10px}
  .book-submit{padding:10px 14px;font-size:14px}

  .bf-grid{grid-template-columns:1fr}
  .bf-block{border-right:0;padding:20px 0;border-bottom:1px solid var(--line)}
  .bf-block:nth-child(2){padding-left:0}
  .bf-block:last-child{padding-left:0}
  .bf{padding:40px 16px 36px}
  .ft{padding:14px 16px}
  .ft-main{flex-direction:column}
}
</style>

<!-- ══ BLOCK 1 — INK ══ -->
<section class="blk b1" id="b1">
  <div class="h-mark"><span class="lead">rega</span><span class="d"></span><span class="twin">rega</span></div>
</section>

<!-- ══ BLOCK 2 — CITY + FOUR DOORS ══ -->
<section class="blk b2" id="b2">

  <button class="lang" type="button">en</button>

  <!-- four big doors fill the screen -->
  <div class="b2-tiles">

      <div class="gt">
        <div class="gt-photo"><img alt="batumi guide" src="https://qkzinjawtumhjbezlyog.supabase.co/storage/v1/object/public/guide/botanico-cafe/01.png" loading="lazy"/></div>
        <div class="gt-plate">
          <span class="gt-label">01 · GUIDE</span>
          <div class="gt-head">guide<span class="d"></span></div>
          <p class="gt-desc">where to eat, swim, wander. checked by people who live here, not visit.</p>
          <a href="/georgia/batumi/guide" class="gt-link">open the guide →</a>
        </div>
      </div>

      <div class="gt">
        <div class="gt-photo"><video autoplay muted loop playsinline poster="/video/batumi-1.jpg"><source src="/video/batumi-1.webm" type="video/webm"><source src="/video/batumi-1.mp4" type="video/mp4"></video></div>
        <div class="gt-plate">
          <span class="gt-label">02 · STAYS</span>
          <div class="gt-head">stays<span class="d"></span></div>
          <p class="gt-desc">checked flats. honestly photographed. book direct.</p>
          <a href="#b3" data-scrollto="b3" class="gt-link">open stays →</a>
        </div>
      </div>

      <div class="gt">
        <div class="gt-photo"><img alt="batumi stories" src="https://qkzinjawtumhjbezlyog.supabase.co/storage/v1/object/public/guide/gimlet-bar/01.png" loading="lazy"/></div>
        <div class="gt-plate">
          <span class="gt-label">03 · STORIES</span>
          <div class="gt-head">stories<span class="d"></span></div>
          <p class="gt-desc">long reads about the city. a morning in the old town, the coast done right.</p>
          <a href="/georgia/batumi/guide#news" class="gt-link">read →</a>
        </div>
      </div>

      <div class="gt">
        <div class="gt-photo"><img alt="batumi neighbourhoods" src="https://qkzinjawtumhjbezlyog.supabase.co/storage/v1/object/public/apartments/sunset-apartment/01.jpg" loading="lazy"/></div>
        <div class="gt-plate">
          <span class="gt-label">04 · NEIGHBOURHOODS</span>
          <div class="gt-head">areas<span class="d"></span></div>
          <p class="gt-desc">the city by area. find the part you'd want to wake up in.</p>
          <a href="/georgia/batumi/stays" class="gt-link">explore areas →</a>
        </div>
      </div>

  </div>

  <!-- city selector overlaid on top of the tiles -->
  <div class="b2-cities">
    <div class="b2-cities-label">your city</div>
    <div class="city-select">
      <button class="city-current" id="cityBtn" type="button" aria-haspopup="listbox" aria-expanded="false">
        <span id="cityName">batumi</span>
        <span class="caret" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg></span>
      </button>
      <div class="city-menu" id="cityMenu" role="listbox" hidden>
        <button class="city-opt" type="button" role="option" data-city="batumi" data-slug="batumi"><span>batumi</span><span class="opt-tag live">live</span></button>
        <button class="city-opt" type="button" role="option" disabled><span>tbilisi</span><span class="opt-tag">soon</span></button>
        <button class="city-opt" type="button" role="option" disabled><span>+ more cities</span><span class="opt-tag">on the way</span></button>
      </div>
    </div>
  </div>

</section>

<div class="b2-spacer"></div>

<!-- ══ BLOCK 3 — STAYS + BOOKING ══ -->
<section class="blk b3" id="b3">

  <div class="b3-left">
    <div>
      <div class="b3-prod">stays</div>
      <div class="b3-city"><span id="b3CityName">batumi</span><span class="d"></span></div>
    </div>

    <div>
      <p class="b3-line">vetted flats. honestly photographed.</p>
      <p class="b3-byline">by <em>bre</em> — operator 01. stocked, checked, ready.</p>
    </div>

