<script is:inline>
(function(){
  // remember scroll position across reloads
  var KEY='rr-v7';
  var saved=parseInt(localStorage.getItem(KEY)||'0',10);
  if(saved>60){window.scrollTo(0,saved);}
  window.addEventListener('scroll',function(){
    localStorage.setItem(KEY,Math.round(window.scrollY));
  },{passive:true});

  // gently leave the intro after 2s if user hasn't scrolled
  var timer=setTimeout(function(){
    if(window.scrollY<40){
      window.scrollTo({top:document.getElementById('b2').offsetTop,behavior:'smooth'});
    }
  },1500);
  window.addEventListener('scroll',function(){
    if(window.scrollY>40)clearTimeout(timer);
  },{passive:true,once:true});
})();

/* ── city selector: drives the whole page ── */
(function(){
  var btn=document.getElementById('cityBtn');
  var menu=document.getElementById('cityMenu');
  if(!btn||!menu)return;
  function close(){menu.setAttribute('hidden','');btn.setAttribute('aria-expanded','false');}
  function open(){menu.removeAttribute('hidden');btn.setAttribute('aria-expanded','true');}
  btn.addEventListener('click',function(e){
    e.stopPropagation();
    if(menu.hasAttribute('hidden'))open();else close();
  });
  menu.addEventListener('click',function(e){e.stopPropagation();});
  document.addEventListener('click',close);
  document.addEventListener('keydown',function(e){if(e.key==='Escape')close();});

  function selectCity(name,slug){
    var nm=document.getElementById('cityName'); if(nm)nm.textContent=name;
    var b3=document.getElementById('b3CityName'); if(b3)b3.textContent=name;
    var bc=document.getElementById('bookCity'); if(bc)bc.textContent=name;
    var bf=document.getElementById('bookForm'); if(bf)bf.setAttribute('action','/georgia/batumi/stays');
    document.querySelectorAll('[data-citylink]').forEach(function(a){
      a.setAttribute('href',a.getAttribute('data-citylink')+'/'+slug);
    });
  }
  document.querySelectorAll('.city-opt:not(:disabled)').forEach(function(opt){
    opt.addEventListener('click',function(e){
      e.stopPropagation();
      selectCity(opt.getAttribute('data-city'),opt.getAttribute('data-slug'));
      close();
    });
  });
})();

/* ── stays door: smooth-scroll down to the stays block ── */
(function(){
  document.querySelectorAll('[data-scrollto]').forEach(function(el){
    el.addEventListener('click',function(e){
      var t=document.getElementById(el.getAttribute('data-scrollto'));
      if(t){e.preventDefault();window.scrollTo({top:t.offsetTop,behavior:'smooth'});}
    });
  });
})();

/* ── whole card clickable: doors + editorial cards follow their inner link ── */
(function(){
  document.querySelectorAll('.gt, .bf-block').forEach(function(card){
    var link=card.querySelector('a[href]');
    if(!link) return;
    card.style.cursor='pointer';
    card.addEventListener('click',function(e){
      if(e.target.closest('a,button,input,select,label,.city-select')) return;
      if(link.hasAttribute('data-scrollto')){
        var t=document.getElementById(link.getAttribute('data-scrollto'));
        if(t){e.preventDefault();window.scrollTo({top:t.offsetTop,behavior:'smooth'});return;}
      }
      var href=link.getAttribute('href'); if(href) window.location.href=href;
    });
  });
})();
</script>
