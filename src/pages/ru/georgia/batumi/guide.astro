<script is:inline>
(function(){
  var mapEl = document.querySelector('.mapblock .map');
  var expBtn = document.querySelector('.mapblock .map-expand');
  if (!mapEl || !expBtn) return;
  function setExp(on){
    mapEl.classList.toggle('expanded', on);
    document.documentElement.classList.toggle('map-locked', on);
    document.body.classList.toggle('map-locked', on);
    setTimeout(function(){ window.dispatchEvent(new Event('resize')); }, 90);
  }
  expBtn.addEventListener('click', function(){ setExp(!mapEl.classList.contains('expanded')); });
  document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && mapEl.classList.contains('expanded')) setExp(false); });
})();
</script>
<script is:inline>
(function(){
  // диплинк #map: нативный якорь срабатывает до загрузки картинок выше карты,
  // и страница останавливается выше (Safari сам не доводит). Доводим скролл по
  // мере загрузки; при первом действии пользователя — перестаём.
  if (location.hash !== '#map') return;
  var mb = document.querySelector('.mapblock'); if (!mb) return;
  var stop = false;
  ['wheel','touchstart','keydown','pointerdown'].forEach(function(ev){
    window.addEventListener(ev, function(){ stop = true; }, { capture: true, passive: true, once: true });
  });
  function snap(){
    if (stop) return;
    var sm = parseFloat(getComputedStyle(mb).scrollMarginTop) || 0;
    var off = mb.getBoundingClientRect().top - sm;
    if (Math.abs(off) > 6) window.scrollBy(0, off);
  }
  window.addEventListener('load', snap);
  [300, 800, 1500, 2500].forEach(function(t){ setTimeout(snap, t); });
})();
</script>
<script is:inline define:vars={{ MAP_DATA: mapData, GMAPS_KEY }}>
(function () {
  window.__initGuideMap = function () {
    // мобилка: greedy (карта маленькая → сразу тапается/двигается одним пальцем); десктоп: cooperative (скролл страницы не зумит карту, cmd+scroll зумит)
    // frameFlats: open framed on the flats at zoom 15, dots stay individual until zoomed out
    var mob = window.matchMedia('(max-width: 768px)').matches;
    var api = RegaMap.stays("guideMap", MAP_DATA, { cardSel: ".__no-list", cluster: true, gesture: mob ? "greedy" : "cooperative", frameFlats: true, clusterMaxZoom: 14 });
    if (!api) return;
    var bar = document.querySelector(".map-controls");
    if (bar) {
      var bAll = bar.querySelector('[data-act="all"]');
      var bOpen = bar.querySelector('[data-act="opennow"]');
      var bNear = bar.querySelector('[data-act="near"]');
      function seg(a) { if (bAll) bAll.classList.toggle("active", a === "all"); if (bOpen) bOpen.classList.toggle("active", a === "opennow"); }
      if (bAll) bAll.addEventListener("click", function () { seg("all"); api.clearFilter(); });
      if (bOpen) bOpen.addEventListener("click", function () { seg("opennow"); api.setFilter(function (it) { return RegaMap.isOpenNow(it.hours) !== false; }); });
      if (bNear) bNear.addEventListener("click", function () {
        var b = this; b.classList.add("loading");
        api.locate(function (u) { b.classList.remove("loading"); if (!u) { b.classList.add("err"); setTimeout(function () { b.classList.remove("err"); }, 2200); } });
      });
    }
  };

  // §8 — load the Google Maps SDK lazily, only as the map section nears the viewport.
  var loaded = false;
  function loadSDK() {
    if (loaded) return; loaded = true;
    var s = document.createElement("script");
    s.async = true;
    s.src = "https://maps.googleapis.com/maps/api/js?key=" + GMAPS_KEY + "&callback=__initGuideMap&loading=async&language=ru&region=GE";
    document.head.appendChild(s);
  }
  var target = document.querySelector(".mapblock") || document.getElementById("guideMap");
  if (!target || !("IntersectionObserver" in window)) { loadSDK(); }
  else {
    var io = new IntersectionObserver(function (es) {
      es.forEach(function (e) { if (e.isIntersecting) { io.disconnect(); loadSDK(); } });
    }, { rootMargin: "600px 0px" });
    io.observe(target);
  }
})();
</script>
