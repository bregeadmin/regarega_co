---
<SiteRu title="\u043a\u043e\u043d\u0442\u0430\u043a\u0442\u044b \u2014 rega rega">
<Fragment set:html={"<section class=\"hero\">\n  <div class=\"meta-line\"><span class=\"dot\"></span>\u2014 \u043a\u043e\u043d\u0442\u0430\u043a\u0442\u044b \u0438 \u043f\u043e\u043c\u043e\u0449\u044c</div>\n  <h1>\u041d\u0430\u043f\u0438\u0448\u0438 <em>\u043d\u0430\u043c</em>.</h1>\n  <p>\u0411\u044b\u0441\u0442\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043e \u043e\u0442\u0432\u0435\u0442\u0438\u043c \u0432 <b>Telegram</b> \u2014 \u0447\u0438\u0442\u0430\u0435\u043c \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u0438\u0445 \u043c\u0438\u043d\u0443\u0442, \u043f\u043e\u043a\u0430 \u043d\u0435 \u0441\u043f\u0438\u043c. Email \u0438 WhatsApp \u0442\u043e\u0436\u0435 \u0440\u0430\u0431\u043e\u0442\u0430\u044e\u0442. \u041e\u0442\u0432\u0435\u0447\u0430\u0435\u043c \u043f\u043e-\u0440\u0443\u0441\u0441\u043a\u0438, \u043f\u043e-\u0430\u043d\u0433\u043b\u0438\u0439\u0441\u043a\u0438 \u0438 \u043f\u043e-\u0433\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u0438.</p>\n</section>\n\n<section class=\"channels\">\n  <a class=\"channel-card\" href=\"https://t.me/bre_ge\">\n    <div class=\"ch-top\">\n      <h3>Telegram</h3>\n      <span class=\"ch-icon primary\">\u043e\u0441\u043d\u043e\u0432\u043d\u043e\u0439</span>\n    </div>\n    <p><b>@bre_ge</b> \u2014 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b, \u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435, \u0432\u043e\u043f\u0440\u043e\u0441\u044b \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a\u043e\u0432. \u041e\u0431\u044b\u0447\u043d\u043e \u043e\u0442\u0432\u0435\u0447\u0430\u0435\u043c \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 30 \u043c\u0438\u043d\u0443\u0442.</p>\n    <span class=\"ch-action\">\u2197 \u043e\u0442\u043a\u0440\u044b\u0442\u044c \u0432 telegram</span>\n  </a>\n\n  <a class=\"channel-card\" href=\"https://wa.me/995585889601\">\n    <div class=\"ch-top\">\n      <h3>WhatsApp</h3>\n      <span class=\"ch-icon\">\u0442\u043e\u0436\u0435 \u0445\u043e\u0440\u043e\u0448\u043e</span>\n    </div>\n    <p><b>+995 585 889 601</b> \u2014 \u0443\u0434\u043e\u0431\u043d\u043e \u043f\u0440\u0438\u0441\u043b\u0430\u0442\u044c \u0433\u043e\u043b\u043e\u0441 \u0438\u043b\u0438 \u0444\u043e\u0442\u043e. \u0422\u043e\u0442 \u0436\u0435 \u043d\u043e\u043c\u0435\u0440 \u0447\u0442\u043e \u0438 \u0442\u0435\u043b\u0435\u0444\u043e\u043d.</p>\n    <span class=\"ch-action\">\u2197 \u043e\u0442\u043a\u0440\u044b\u0442\u044c \u0432 whatsapp</span>\n  </a>\n\n  <a class=\"channel-card\" href=\"mailto:hello@bre.ge\">\n    <div class=\"ch-top\">\n      <h3>Email</h3>\n      <span class=\"ch-icon\">\u0434\u043b\u044f \u0434\u043b\u0438\u043d\u043d\u043e\u0433\u043e</span>\n    </div>\n    <p><b>hello@bre.ge</b> \u2014 \u0434\u043e\u0433\u043e\u0432\u043e\u0440\u044b, \u0432\u043b\u043e\u0436\u0435\u043d\u0438\u044f, \u0432\u0441\u0451 \u0447\u0442\u043e \u0434\u043e\u043b\u0436\u043d\u043e \u043e\u0441\u0442\u0430\u0442\u044c\u0441\u044f \u0432 \u043f\u043e\u0447\u0442\u0435. \u041e\u0442\u0432\u0435\u0447\u0430\u0435\u043c \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u0434\u043d\u044f.</p>\n    <span class=\"ch-action\">\u2197 \u043d\u0430\u043f\u0438\u0441\u0430\u0442\u044c \u043f\u0438\u0441\u044c\u043c\u043e</span>\n  </a>\n\n  <a class=\"channel-card\" href=\"tel:+995585889601\">\n    <div class=\"ch-top\">\n      <h3>\u0422\u0435\u043b\u0435\u0444\u043e\u043d</h3>\n      <span class=\"ch-icon\">\u0435\u0441\u043b\u0438 \u0441\u0440\u043e\u0447\u043d\u043e</span>\n    </div>\n    <p><b>+995 585 889 601</b> \u2014 \u0437\u0432\u043e\u043d\u0438 \u0435\u0441\u043b\u0438 \u043f\u0440\u0430\u0432\u0434\u0430 \u0441\u0440\u043e\u0447\u043d\u043e. \u041d\u0435 \u0432\u0441\u0435\u0433\u0434\u0430 \u0431\u0435\u0440\u0451\u043c \u0442\u0440\u0443\u0431\u043a\u0443 \u2014 \u043d\u043e \u043f\u0435\u0440\u0435\u0437\u0432\u0430\u043d\u0438\u0432\u0430\u0435\u043c.</p>\n    <span class=\"ch-action\">\u2197 \u043f\u043e\u0437\u0432\u043e\u043d\u0438\u0442\u044c</span>\n  </a>\n</section>\n\n<section class=\"form-wrap\">\n  <div class=\"form-intro\">\n    <div class=\"meta-line\"><span class=\"dot\"></span>\u2014 \u0438\u043b\u0438 \u043d\u0430\u043f\u0440\u044f\u043c\u0443\u044e</div>\n    <h2>\u0438\u043b\u0438 <em>\u043d\u0430\u043f\u0438\u0448\u0438</em> \u043f\u0440\u044f\u043c\u043e \u0437\u0434\u0435\u0441\u044c.</h2>\n    <p>\u0415\u0441\u043b\u0438 \u043d\u0435\u0442 \u0442\u0435\u043b\u0435\u0433\u0440\u0430\u043c\u0430 \u0438\u043b\u0438 \u043f\u0440\u043e\u0441\u0442\u043e \u0443\u0434\u043e\u0431\u043d\u0435\u0435 \u0444\u043e\u0440\u043c\u0430 \u2014 \u0442\u043e\u0436\u0435 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442. \u041f\u0438\u0441\u044c\u043c\u043e \u0443\u043f\u0430\u0434\u0451\u0442 \u043d\u0430\u043c \u043d\u0430 \u043f\u043e\u0447\u0442\u0443.</p>\n  </div>\n  <form class=\"form\" onsubmit=\"event.preventDefault();this.querySelector('.submit').textContent='\u0441\u043f\u0430\u0441\u0438\u0431\u043e \u2014 \u0441\u043a\u043e\u0440\u043e \u043e\u0442\u0432\u0435\u0442\u0438\u043c';this.querySelector('.submit').disabled=true;\">\n    <div class=\"row\">\n      <div class=\"field\">\n        <label>\u2014 \u043a\u0430\u043a \u0442\u0435\u0431\u044f \u0437\u043e\u0432\u0443\u0442</label>\n        <input type=\"text\" placeholder=\"\u041c\u0438\u0445\u0430\u0438\u043b\" required>\n      </div>\n      <div class=\"field\">\n        <label>\u2014 \u043a\u0430\u043a \u0441 \u0442\u043e\u0431\u043e\u0439 \u0441\u0432\u044f\u0437\u0430\u0442\u044c\u0441\u044f</label>\n        <input type=\"text\" placeholder=\"email \u0438\u043b\u0438 @telegram\" required>\n      </div>\n    </div>\n    <div class=\"field\">\n      <label>\u2014 \u043f\u043e \u043a\u0430\u043a\u043e\u043c\u0443 \u043f\u043e\u0432\u043e\u0434\u0443</label>\n      <select>\n        <option>\u0425\u043e\u0447\u0443 \u0437\u0430\u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0443</option>\n        <option>\u042f \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a \u2014 \u0443\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435</option>\n        <option>\u0425\u043e\u0447\u0443 \u0438\u043d\u0432\u0435\u0441\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0432 \u0411\u0430\u0442\u0443\u043c\u0438</option>\n        <option>\u041f\u0440\u0435\u0441\u0441\u0430 / \u043f\u0430\u0440\u0442\u043d\u0451\u0440\u0441\u0442\u0432\u043e</option>\n        <option>\u0427\u0442\u043e-\u0442\u043e \u0435\u0449\u0451</option>\n      </select>\n    </div>\n    <div class=\"field\">\n      <label>\u2014 \u0440\u0430\u0441\u0441\u043a\u0430\u0436\u0438 \u043e \u0447\u0451\u043c</label>\n      <textarea placeholder=\"\u0420\u0430\u0441\u0441\u043a\u0430\u0436\u0438 \u0447\u0442\u043e \u043d\u0443\u0436\u043d\u043e. \u041c\u043e\u0436\u043d\u043e \u0447\u0435\u0440\u043d\u043e\u0432\u0438\u043a\u043e\u043c \u2014 \u0440\u0430\u0437\u0431\u0435\u0440\u0451\u043c\u0441\u044f \u0432\u043c\u0435\u0441\u0442\u0435.\" required></textarea>\n    </div>\n    <button type=\"submit\" class=\"submit\">\u041e\u0442\u043f\u0440\u0430\u0432\u0438\u0442\u044c \u2192</button>\n    <p class=\"note\">\u041a\u0430\u0436\u0434\u043e\u0435 \u0441\u043e\u043e\u0431\u0449\u0435\u043d\u0438\u0435 \u0447\u0438\u0442\u0430\u0435\u043c \u0441\u0430\u043c\u0438. <b>\u0411\u0435\u0437 \u0431\u043e\u0442\u043e\u0432 \u0438 \u0430\u0432\u0442\u043e\u043e\u0442\u0432\u0435\u0442\u0447\u0438\u043a\u043e\u0432.</b> \u041e\u0442\u0432\u0435\u0447\u0430\u0435\u0442 \u0436\u0438\u0432\u043e\u0439 \u0447\u0435\u043b\u043e\u0432\u0435\u043a, \u043e\u0431\u044b\u0447\u043d\u043e \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u0434\u043d\u044f.</p>\n  </form>\n</section>\n\n<section class=\"faq-pointer\">\n  <div class=\"inner\">\n    <h3>\u0427\u0442\u043e-\u0442\u043e \u0441\u0440\u043e\u0447\u043d\u043e\u0435?</h3>\n    <p>\u0415\u0441\u043b\u0438 \u0432\u0440\u0435\u043c\u044f \u043f\u043e\u0434\u0436\u0438\u043c\u0430\u0435\u0442 \u2014 \u0442\u044b \u0443\u0436\u0435 \u0432 \u0434\u043e\u0440\u043e\u0433\u0435, \u0432 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0435 \u0438\u043b\u0438 \u043d\u0443\u0436\u043d\u043e \u0441\u0440\u043e\u0447\u043d\u043e \u0447\u0442\u043e-\u0442\u043e \u043f\u043e\u043c\u0435\u043d\u044f\u0442\u044c \u2014 \u043f\u0438\u0448\u0438 \u0432 Telegram. \u041c\u044b \u0436\u0438\u0432\u044b\u0435 \u043b\u044e\u0434\u0438 \u0441 \u0436\u0438\u0432\u044b\u043c\u0438 \u0443\u0432\u0435\u0434\u043e\u043c\u043b\u0435\u043d\u0438\u044f\u043c\u0438.</p>\n    <a href=\"https://t.me/bre_ge\" class=\"tg-btn\">\u2197 \u043e\u0442\u043a\u0440\u044b\u0442\u044c telegram</a>\n  </div>\n</section>" } />
<style is:global set:html={".hero{padding:160px 28px 80px;text-align:left;max-width:1400px;margin:0 auto}\n.meta-line{font-family:\"JetBrains Mono\",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--page-deep);font-weight:600;display:inline-flex;align-items:center;gap:8px;background:var(--accent-soft);padding:5px 11px;border-radius:999px;width:fit-content;margin-bottom:24px}\n.meta-line .dot{display:none}\n.hero p{font-size:17px;line-height:1.55;color:var(--ink-soft);max-width:48ch;margin-top:24px}\n.hero p b{color:var(--ink);font-weight:600}\n.channels{padding:0 28px 80px;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:repeat(2,1fr);gap:18px}\n.channel-card{display:flex;flex-direction:column;justify-content:space-between;gap:18px;padding:28px 32px;background:var(--paper);border:1px solid var(--line);border-radius:14px;min-height:200px;transition:border-color .25s ease,transform .25s ease}\n.channel-card:hover{border-color:var(--page);transform:translateY(-2px)}\n.channel-card .ch-top{display:flex;justify-content:space-between;align-items:flex-start;gap:14px}\n.channel-card h3{font-family:\"Bricolage Grotesque\",sans-serif;font-weight:700;font-size:28px;letter-spacing:-.025em;line-height:1.05}\n.channel-card .ch-icon{font-family:\"JetBrains Mono\",monospace;font-size:9px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;color:var(--ink-soft);padding:5px 10px;border:1px solid var(--line-strong);border-radius:999px}\n.channel-card .ch-icon.primary{background:var(--page);color:#fff;border-color:var(--page)}\n.channel-card p{font-size:14.5px;line-height:1.55;color:var(--ink-soft)}\n.channel-card p b{color:var(--ink);font-weight:600}\n.channel-card .ch-action{font-family:\"JetBrains Mono\",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;color:var(--page);display:inline-flex;align-items:center;gap:6px}\n.form-wrap{padding:0 28px 100px;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1fr 1.4fr;gap:60px;align-items:start}\n.form-intro h2{font-family:\"Bricolage Grotesque\",sans-serif;font-weight:800;font-size:clamp(36px,5vw,56px);line-height:.95;letter-spacing:-.035em}\n.form-intro h2 em{font-style:italic;color:var(--page)}\n.form-intro p{margin-top:20px;font-size:15px;line-height:1.6;color:var(--ink-soft);max-width:36ch}\n.form-intro .meta-line{margin-bottom:18px}\n.form{display:flex;flex-direction:column;gap:14px;padding:32px;background:var(--paper);border:1px solid var(--line);border-radius:14px}\n.form .field{display:flex;flex-direction:column;gap:5px}\n.form label{font-family:\"JetBrains Mono\",monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);font-weight:600}\n.form input,.form select,.form textarea{font-family:\"Bricolage Grotesque\",sans-serif;font-weight:500;font-size:15px;padding:12px 14px;border:1px solid var(--line-strong);border-radius:8px;background:#fff;color:var(--ink);outline:0;transition:border-color .2s ease}\n.form input:focus,.form select:focus,.form textarea:focus{border-color:var(--page)}\n.form textarea{min-height:120px;resize:vertical;line-height:1.5}\n.form .row{display:grid;grid-template-columns:1fr 1fr;gap:14px}\n.form .submit{padding:16px 24px;background:var(--ink);color:#fff;border:0;border-radius:999px;font-family:\"JetBrains Mono\",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;cursor:pointer;transition:background .2s ease;margin-top:4px}\n.form .submit:hover{background:var(--page)}\n.form .note{font-size:12px;color:var(--ink-soft);line-height:1.5}\n.form .note b{color:var(--ink)}\n.faq-pointer{padding:60px 28px;background:var(--bg-2);text-align:center}\n.faq-pointer .inner{max-width:680px;margin:0 auto}\n.faq-pointer h3{font-family:\"Bricolage Grotesque\",sans-serif;font-weight:700;font-size:28px;letter-spacing:-.025em;margin-bottom:14px}\n.faq-pointer p{font-size:15px;line-height:1.6;color:var(--ink-soft);margin-bottom:24px}\n.faq-pointer .tg-btn{display:inline-flex;align-items:center;gap:8px;padding:14px 24px;background:var(--ink);color:#fff;border-radius:999px;font-family:\"JetBrains Mono\",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;transition:background .2s ease}\n.faq-pointer .tg-btn:hover{background:var(--page)}\n@media (max-width:880px){\n.hero{padding:100px 14px 40px}\n.channels{padding:0 14px 48px;grid-template-columns:1fr;gap:12px}\n.channel-card{padding:22px 24px;min-height:auto}\n.form-wrap{padding:0 14px 64px;grid-template-columns:1fr;gap:32px}\n.form{padding:22px}\n.form .row{grid-template-columns:1fr;gap:14px}\n.faq-pointer{padding:48px 14px}\n}" }></style>
