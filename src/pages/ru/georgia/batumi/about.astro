<SiteRu title="\u041e \u043d\u0430\u0441 \u2014 rega rega">
<Fragment set:html={"<div class=\"meta-top\">\n  <div class=\"crumbs\">\n    <span class=\"cur\"><span class=\"dot\"></span>\u041e \u043d\u0430\u0441</span>\n  </div>\n</div>\n\n<section class=\"head\">\n  <div class=\"inner\">\n    <h1>\u0414\u0432\u0430 \u043f\u0443\u0442\u0438,<br/>\u043a\u043e\u0442\u043e\u0440\u044b\u0435 <em>\u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043b\u0438\u0441\u044c</em>.</h1>\n    <p class=\"lede\"><b>\u0414\u0432\u0430 \u043f\u0443\u0442\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043b\u0438\u0441\u044c \u0432 \u0411\u0430\u0442\u0443\u043c\u0438.</b> \u041e\u0434\u0438\u043d \u043d\u0430\u0447\u0430\u043b \u0443\u043f\u0440\u0430\u0432\u043b\u044f\u0442\u044c \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430\u043c\u0438 \u0441\u043b\u0443\u0447\u0430\u0439\u043d\u043e. \u0414\u0440\u0443\u0433\u043e\u0439 \u0438\u0441\u043a\u0430\u043b \u0438\u043c\u0435\u043d\u043d\u043e \u0442\u0430\u043a\u043e\u0439 \u0440\u044b\u043d\u043e\u043a, \u0447\u0442\u043e\u0431\u044b \u043f\u043e\u0441\u0442\u0440\u043e\u0438\u0442\u044c \u0447\u0442\u043e-\u0442\u043e \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e.</p>\n  </div>\n</section>\n\n<section class=\"story\">\n  <div class=\"inner\">\n    <p><span class=\"drop\">\u041e</span>\u043b\u0433\u0430 \u043f\u0440\u0438\u0435\u0445\u0430\u043b\u0430 \u0432 \u0411\u0430\u0442\u0443\u043c\u0438 \u0432 \u0441\u0430\u043c\u043e\u043c \u043d\u0430\u0447\u0430\u043b\u0435 2022 \u0433\u043e\u0434\u0430. \u0414\u043e \u044d\u0442\u043e\u0433\u043e \u0440\u0430\u0431\u043e\u0442\u0430\u043b\u0430 \u043f\u0440\u043e\u0434\u0436\u0435\u043a\u0442-\u043c\u0435\u043d\u0435\u0434\u0436\u0435\u0440\u043e\u043c \u0432 \u043c\u043e\u0441\u043a\u043e\u0432\u0441\u043a\u043e\u043c \u0441\u0442\u0430\u0440\u0442\u0430\u043f\u0435 <b>\u00ab\u0421\u0434\u0435\u043b\u0430\u043d\u043e\u00bb</b> \u2014 \u0438 \u043f\u043e\u043f\u0443\u0442\u043d\u043e \u043d\u0430\u043a\u043e\u043f\u0438\u043b\u0430 \u0440\u0435\u0434\u043a\u0443\u044e \u0432\u0435\u0449\u044c: \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0439, \u0440\u0443\u043a\u0430\u043c\u0438 \u0441\u0434\u0435\u043b\u0430\u043d\u043d\u044b\u0439 \u043e\u043f\u044b\u0442 \u043e\u0431\u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0430 \u043a\u0432\u0430\u0440\u0442\u0438\u0440 \u0432 \u043f\u043e\u043b\u0443\u0434\u044e\u0436\u0438\u043d\u0435 \u0433\u043e\u0440\u043e\u0434\u043e\u0432, \u0433\u0434\u0435 \u0436\u0438\u043b\u0430. \u0417\u043d\u0430\u0435\u0442 \u0437\u0430\u043f\u0430\u0445 \u043d\u043e\u0432\u044b\u0445 \u043f\u0440\u043e\u0441\u0442\u044b\u043d\u0435\u0439, \u0432\u0435\u0441 \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e \u043f\u043e\u0434\u0448\u0438\u0442\u043e\u0439 \u0448\u0442\u043e\u0440\u044b, \u0440\u0430\u0437\u043d\u0438\u0446\u0443 \u043c\u0435\u0436\u0434\u0443 \u043a\u0443\u0445\u043d\u0435\u0439, \u043a\u043e\u0442\u043e\u0440\u0430\u044f \u0445\u043e\u0440\u043e\u0448\u043e \u0441\u043d\u0438\u043c\u0430\u0435\u0442\u0441\u044f, \u0438 \u043a\u0443\u0445\u043d\u0435\u0439, \u0432 \u043a\u043e\u0442\u043e\u0440\u043e\u0439 \u0445\u043e\u0440\u043e\u0448\u043e \u0436\u0438\u0432\u0451\u0442\u0441\u044f.</p>\n    <p>\u0412 \u0411\u0430\u0442\u0443\u043c\u0438 \u043f\u0440\u0438\u0435\u0445\u0430\u043b\u0430 \u043f\u043e\u043c\u043e\u0447\u044c \u0441 \u0446\u0432\u0435\u0442\u0430\u043c\u0438 \u2014 \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0435 \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0435\u043d\u0438\u0435 <b>Plant Me</b>, \u0435\u0451 \u0441\u0442\u0443\u0434\u0438\u0438 \u0440\u0430\u0441\u0442\u0435\u043d\u0438\u0439 \u0432 \u041c\u043e\u0441\u043a\u0432\u0435. \u041d\u043e \u0447\u0435\u0440\u0435\u0437 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043c\u0435\u0441\u044f\u0446\u0435\u0432 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b \u043f\u0440\u0435\u0434\u043b\u043e\u0436\u0438\u043b \u0435\u0439 \u0443\u043f\u0440\u0430\u0432\u043b\u044f\u0442\u044c \u0435\u0433\u043e \u0436\u0438\u043b\u044c\u0451\u043c. \u041f\u043e\u0442\u043e\u043c \u0435\u0433\u043e \u0434\u0440\u0443\u0433 \u043f\u043e\u043f\u0440\u043e\u0441\u0438\u043b. \u041f\u043e\u0442\u043e\u043c \u0441\u043e\u0441\u0435\u0434. \u0422\u043e, \u0447\u0442\u043e \u043e\u043d\u0430 \u0434\u0435\u043b\u0430\u043b\u0430 \u043a\u0430\u043a \u0445\u043e\u0431\u0431\u0438 \u0432 \u0441\u0432\u043e\u0438\u0445 \u0434\u043e\u043c\u0430\u0445, \u043e\u043a\u0430\u0437\u0430\u043b\u043e\u0441\u044c \u0440\u043e\u0432\u043d\u043e \u0442\u0435\u043c, \u0447\u0435\u0433\u043e \u043d\u0435 \u0445\u0432\u0430\u0442\u0430\u043b\u043e \u0432 \u0411\u0430\u0442\u0443\u043c\u0438 \u2014 \u0438 \u043d\u0438\u043a\u0442\u043e \u043d\u0435 \u0434\u0435\u043b\u0430\u043b \u043d\u043e\u0440\u043c\u0430\u043b\u044c\u043d\u043e.</p>\n\n    <h3>\u041f\u043e\u0442\u043e\u043c <em>\u0410\u0440\u0442\u0451\u043c</em>.</h3>\n\n    <p><span class=\"drop\">\u0410</span>\u0440\u0442\u0451\u043c \u043f\u043e\u044f\u0432\u0438\u043b\u0441\u044f \u043f\u043e\u0437\u0436\u0435. \u0413\u043e\u0434\u0430\u043c\u0438 \u0436\u0438\u043b \u043c\u0435\u0436\u0434\u0443 \u0433\u043e\u0440\u043e\u0434\u0430\u043c\u0438 \u2014 <b>\u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c, \u0437\u0430\u043f\u0443\u0441\u043a\u0438 \u0431\u0440\u0435\u043d\u0434\u043e\u0432, \u0438\u043d\u0432\u0435\u0441\u0442\u0438\u0446\u0438\u0438</b>, \u0442\u043e\u0442 \u0440\u0435\u0436\u0438\u043c, \u043a\u043e\u0433\u0434\u0430 \u0442\u044b \u043f\u043e\u0447\u0442\u0438 \u043a\u0430\u0436\u0434\u0443\u044e \u043d\u0435\u0434\u0435\u043b\u044e \u0432 \u043d\u043e\u0432\u043e\u043c \u043e\u0442\u0435\u043b\u0435. \u041f\u043e\u0441\u043b\u0435 \u0434\u043e\u0441\u0442\u0430\u0442\u043e\u0447\u043d\u043e\u0433\u043e \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0430 \u0442\u0430\u043a\u0438\u0445 \u043d\u043e\u0447\u0435\u0439 \u0442\u044b \u043f\u0435\u0440\u0435\u0441\u0442\u0430\u0451\u0448\u044c \u0431\u044b\u0442\u044c \u0433\u043e\u0441\u0442\u0435\u043c \u0438 \u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0448\u044c\u0441\u044f \u043a\u0440\u0438\u0442\u0438\u043a\u043e\u043c: \u0432\u0435\u0441 \u043f\u043e\u043b\u043e\u0442\u0435\u043d\u0446\u0430, \u0442\u0435\u043c\u043f\u0435\u0440\u0430\u0442\u0443\u0440\u0430 \u0441\u0432\u0435\u0442\u0430, \u0447\u0435\u043a \u043d\u0430 \u0447\u0435\u043a\u0430\u0443\u0442\u0435, \u043c\u0435\u043b\u043e\u0447\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043e\u0442\u0434\u0435\u043b\u044f\u044e\u0442 \u0445\u043e\u0440\u043e\u0448\u0435\u0433\u043e \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0430 \u043e\u0442 \u043f\u043b\u043e\u0445\u043e\u0433\u043e. \u042d\u0442\u043e\u0442 \u044f\u0437\u044b\u043a \u043e\u043d \u0437\u043d\u0430\u0435\u0442 \u0441\u0432\u043e\u0431\u043e\u0434\u043d\u043e \u2014 \u0441\u043e \u0441\u0442\u043e\u0440\u043e\u043d\u044b \u043a\u043b\u0438\u0435\u043d\u0442\u0430.</p>\n    <p>\u041e\u043d \u0438\u0441\u043a\u0430\u043b, \u0441 \u043a\u0435\u043c \u044d\u0442\u043e \u043f\u043e\u0441\u0442\u0440\u043e\u0438\u0442\u044c. \u0420\u044b\u043d\u043e\u043a, \u0433\u0434\u0435 \u0441\u043f\u0440\u043e\u0441 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0439, \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u044b \u043d\u0438\u0437\u043a\u0438\u0435, \u0430 \u043a\u043e\u043c\u0430\u043d\u0434\u0430 \u2014 \u0443\u0437\u043a\u043e\u0435 \u043c\u0435\u0441\u0442\u043e. \u041a\u043e\u0433\u0434\u0430 \u043e\u043d \u043d\u0430\u0448\u0451\u043b \u041e\u043b\u0433\u0443, \u0443\u0436\u0435 \u0443\u043f\u0440\u0430\u0432\u043b\u044f\u044e\u0449\u0443\u044e \u0434\u0435\u0441\u044f\u0442\u044c\u044e \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430\u043c\u0438 \u0432 \u043e\u0434\u0438\u043d\u043e\u0447\u043a\u0443, \u0440\u0430\u0437\u0433\u043e\u0432\u043e\u0440 \u0431\u044b\u043b \u043a\u043e\u0440\u043e\u0442\u043a\u0438\u043c.</p>\n\n    <h3>\u0414\u0432\u0435 \u043f\u043e\u043b\u043e\u0432\u0438\u043d\u044b, <em>\u043e\u0434\u0438\u043d \u043f\u0440\u043e\u0434\u0443\u043a\u0442</em>.</h3>\n\n    <p>\u0418\u043d\u0442\u0435\u0440\u0435\u0441\u043d\u043e\u0435 \u0437\u0434\u0435\u0441\u044c \u043d\u0435 \u0432 \u0442\u043e\u043c, \u0447\u0442\u043e \u043c\u044b \u043f\u0430\u0440\u0442\u043d\u0451\u0440\u044b. \u0410 \u0432 \u0442\u043e\u043c, \u0447\u0442\u043e \u043c\u044b \u043f\u0440\u0438\u0448\u043b\u0438 <em>\u0441 \u043f\u0440\u043e\u0442\u0438\u0432\u043e\u043f\u043e\u043b\u043e\u0436\u043d\u044b\u0445 \u0441\u0442\u043e\u0440\u043e\u043d \u043a\u043e\u043c\u043d\u0430\u0442\u044b</em> \u2014 \u041e\u043b\u044f \u0438\u0437 \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u0439, \u0438\u0437\u043d\u0443\u0442\u0440\u0438 \u0434\u043e\u043c\u0430. \u0410\u0440\u0442\u0451\u043c \u0438\u0437 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0438 \u0438 \u0441\u043e \u0432\u043d\u0435\u0448\u043d\u0435\u0433\u043e \u0432\u0437\u0433\u043b\u044f\u0434\u0430 \u043d\u0430 \u0442\u043e, \u043a\u0430\u043a \u0432\u0435\u0434\u0443\u0442 \u0441\u0435\u0431\u044f \u0441\u0438\u0441\u0442\u0435\u043c\u044b. \u041e\u0434\u043d\u0430 \u0434\u0435\u0441\u044f\u0442\u044c \u043b\u0435\u0442 \u0441\u0442\u0440\u043e\u0438\u043b\u0430 \u0432\u0435\u0449\u0438 \u0440\u0443\u043a\u0430\u043c\u0438. \u0414\u0440\u0443\u0433\u043e\u0439 \u043d\u0430\u0431\u043b\u044e\u0434\u0430\u043b, \u043a\u0430\u043a \u0441\u0442\u0440\u043e\u044f\u0442, \u0438 \u0432\u0438\u0434\u0435\u043b, \u0447\u0435\u0433\u043e \u043d\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442.</p>\n    <p>\u0412\u043c\u0435\u0441\u0442\u0435 \u043c\u044b \u0441\u0442\u0440\u043e\u0438\u043c \u0442\u043e, \u0447\u0435\u0433\u043e, \u043a\u0430\u043a \u043d\u0430\u043c \u043a\u0430\u0436\u0435\u0442\u0441\u044f, \u043d\u0435 \u0445\u0432\u0430\u0442\u0430\u043b\u043e \u0440\u0435\u0433\u0438\u043e\u043d\u0443: <b>\u043b\u0443\u0447\u0448\u0435\u0433\u043e \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0430 \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u0438 \u0432 \u0411\u0430\u0442\u0443\u043c\u0438</b>. \u0427\u0435\u0441\u0442\u043d\u043e\u0433\u043e \u0432 \u0434\u0435\u043d\u044c\u0433\u0430\u0445, \u0431\u0435\u0441\u043a\u043e\u043c\u043f\u0440\u043e\u043c\u0438\u0441\u0441\u043d\u043e\u0433\u043e \u0432 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0435, \u043c\u0430\u043b\u0435\u043d\u044c\u043a\u043e\u0433\u043e \u043d\u0430\u043c\u0435\u0440\u0435\u043d\u043d\u043e. \u0421\u043e\u0431\u0438\u0440\u0430\u0435\u0442\u0441\u044f \u043f\u043e \u043e\u0434\u043d\u043e\u0439 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0435, \u043f\u043e \u043e\u0434\u043d\u043e\u043c\u0443 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a\u0443. \u041c\u0435\u0434\u043b\u0435\u043d\u043d\u043e \u2014 \u043d\u0430\u043c\u0435\u0440\u0435\u043d\u043d\u043e. \u041f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u043e \u2014 \u043f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e.</p>\n  </div>\n</section>\n\n<section class=\"people\">\n  <div class=\"container\">\n    <div class=\"people-head\">\n      <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u043a\u0442\u043e \u0437\u0430 \u044d\u0442\u0438\u043c \u0441\u0442\u043e\u0438\u0442</div>\n      <h2>\u0414\u0432\u0435 <em>\u043f\u043e\u043b\u043e\u0432\u0438\u043d\u044b</em>,<br/>\u043e\u0434\u043d\u0430 \u043a\u043e\u043c\u0430\u043d\u0434\u0430.</h2>\n    </div>\n\n    <div class=\"profiles\">\n      <div class=\"profile\">\n        <div class=\"ph\">\n          <img src=\"https://static.tildacdn.one/tild3861-3030-4661-a262-316335653632/photo_2024-06-13_121.jpeg\" alt=\"\u041e\u043b\u044f, \u0441\u043e\u043e\u0441\u043d\u043e\u0432\u0430\u0442\u0435\u043b\u044c bre\" onerror=\"this.src='https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=900&q=80'\">\n        </div>\n        <div class=\"role\"><span class=\"sw\"></span>\u0441\u043e\u043e\u0441\u043d\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u00b7 \u043b\u044e\u0434\u0438 \u0438 \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u0438</div>\n        <h3><em>\u041e\u043b\u044f</em></h3>\n        <p class=\"bio\">\u041e\u0441\u043d\u043e\u0432\u0430\u043b\u0430 <b>Plant Me</b> \u2014 \u043c\u043e\u0441\u043a\u043e\u0432\u0441\u043a\u0443\u044e \u0441\u0442\u0443\u0434\u0438\u044e \u0440\u0430\u0441\u0442\u0435\u043d\u0438\u0439. \u0413\u043e\u0434\u044b \u043e\u043f\u044b\u0442\u0430 \u043e\u0431\u0443\u0441\u0442\u0440\u043e\u0439\u0441\u0442\u0432\u0430 \u043a\u0432\u0430\u0440\u0442\u0438\u0440 \u0432 \u0440\u0430\u0437\u043d\u044b\u0445 \u0433\u043e\u0440\u043e\u0434\u0430\u0445 \u2014 \u0437\u043d\u0430\u0435\u0442 \u0442\u0435\u043a\u0441\u0442\u0438\u043b\u044c, \u0441\u0432\u0435\u0442, \u0440\u0438\u0442\u043c \u0434\u043e\u043c\u0430.</p>\n        <p class=\"bio\">\u0412 bre \u043e\u0442\u0432\u0435\u0447\u0430\u0435\u0442 \u0437\u0430 <b>\u0433\u043e\u0441\u0442\u0435\u0439, \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u044b \u0438 \u043f\u043b\u0430\u043d\u043a\u0443 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430</b>. \u041a\u0430\u0436\u0434\u0430\u044f \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430, \u043a\u043e\u0442\u043e\u0440\u0443\u044e \u043c\u044b \u0431\u0435\u0440\u0451\u043c, \u043f\u0440\u043e\u0445\u043e\u0434\u0438\u0442 \u0447\u0435\u0440\u0435\u0437 \u0435\u0451 \u0440\u0443\u043a\u0438.</p>\n        <div class=\"does\">\n          <div class=\"row\">\u0432\u0441\u0442\u0440\u0435\u0447\u0430 \u0433\u043e\u0441\u0442\u0435\u0439</div>\n          <div class=\"row\">\u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442 bre</div>\n          <div class=\"row\">\u0443\u0431\u043e\u0440\u043a\u0430 \u0438 \u043a\u043e\u043d\u0442\u0440\u043e\u043b\u044c \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430</div>\n          <div class=\"row\">\u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u044f \u0441 \u043f\u043e\u0441\u0442\u0430\u0432\u0449\u0438\u043a\u0430\u043c\u0438</div>\n        </div>\n        <div class=\"links\">\n          <a href=\"https://t.me/bre_ge\">\u2197 telegram</a>\n        </div>\n      </div>\n\n      <div class=\"profile\">\n        <div class=\"ph\">\n          <img src=\"https://www.grinbergart.com/assets/artem-hero-clean.png\" alt=\"\u0410\u0440\u0442\u0451\u043c, \u0441\u043e\u043e\u0441\u043d\u043e\u0432\u0430\u0442\u0435\u043b\u044c bre\">\n        </div>\n        <div class=\"role\"><span class=\"sw\"></span>\u0441\u043e\u043e\u0441\u043d\u043e\u0432\u0430\u0442\u0435\u043b\u044c \u00b7 \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044f \u0438 \u0438\u043d\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430</div>\n        <h3><em>\u0410\u0440\u0442\u0451\u043c</em></h3>\n        <p class=\"bio\">\u0413\u043e\u0434\u044b <b>\u0437\u0430\u043f\u0443\u0441\u043a\u0430 \u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0447\u043d\u044b\u0445 \u0431\u0438\u0437\u043d\u0435\u0441\u043e\u0432 \u0438 \u0440\u0430\u0431\u043e\u0442\u044b \u0441 \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c\u044e</b>. \u0416\u0438\u0432\u0451\u0442 \u043c\u0435\u0436\u0434\u0443 \u0433\u043e\u0440\u043e\u0434\u0430\u043c\u0438 \u2014 \u0437\u043d\u0430\u0435\u0442 \u0433\u043e\u0441\u0442\u0435\u043f\u0440\u0438\u0438\u043c\u0441\u0442\u0432\u043e \u0441\u043e \u0441\u0442\u043e\u0440\u043e\u043d\u044b \u043a\u043b\u0438\u0435\u043d\u0442\u0430 \u043f\u043e\u0441\u043b\u0435 \u0441\u043b\u0438\u0448\u043a\u043e\u043c \u043c\u043d\u043e\u0433\u0438\u0445 \u043e\u0442\u0435\u043b\u044c\u043d\u044b\u0445 \u043d\u043e\u0447\u0435\u0439, \u0447\u0442\u043e\u0431\u044b \u043b\u0435\u0433\u043a\u043e \u0443\u0434\u0438\u0432\u043b\u044f\u0442\u044c\u0441\u044f.</p>\n        <p class=\"bio\">\u0412 bre \u043e\u0442\u0432\u0435\u0447\u0430\u0435\u0442 \u0437\u0430 <b>\u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044e, \u043e\u0442\u043d\u043e\u0448\u0435\u043d\u0438\u044f \u0441 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a\u0430\u043c\u0438, \u043f\u0440\u043e\u0434\u0430\u0436\u0438 \u0438 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0443 \u043f\u043e\u0434 \u043a\u0430\u043f\u043e\u0442\u043e\u043c</b>: \u0441\u0438\u0441\u0442\u0435\u043c\u0443 \u0443\u0447\u0451\u0442\u0430, \u043d\u043e\u0432\u044b\u0435 \u043f\u0440\u043e\u0434\u0443\u043a\u0442\u043e\u0432\u044b\u0435 \u0438\u0434\u0435\u0438.</p>\n        <div class=\"does\">\n          <div class=\"row\">\u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u044f \u0438 \u043f\u043e\u0437\u0438\u0446\u0438\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435</div>\n          <div class=\"row\">\u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a\u0438 \u0438 \u0438\u043d\u0432\u0435\u0441\u0442\u043e\u0440\u044b</div>\n          <div class=\"row\">\u0438\u043d\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u0430 \u0438 \u0438\u043d\u0441\u0442\u0440\u0443\u043c\u0435\u043d\u0442\u044b</div>\n          <div class=\"row\">\u043f\u0440\u043e\u0434\u0430\u0436\u0438 \u0438 \u043f\u043e\u0438\u0441\u043a \u0441\u0434\u0435\u043b\u043e\u043a</div>\n        </div>\n        <div class=\"links\">\n          <a href=\"https://grinbergart.com\">\u2197 grinbergart.com</a>\n          <a href=\"https://t.me/grinbergart\">\u2197 telegram</a>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"mission\">\n  <blockquote>\u0425\u043e\u0442\u0438\u043c \u043f\u043e\u0441\u0442\u0440\u043e\u0438\u0442\u044c<br/><em>\u043b\u0443\u0447\u0448\u0435\u0433\u043e \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0430 \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u0438</em><br/>\u0432 \u0440\u0435\u0433\u0438\u043e\u043d\u0435.</blockquote>\n  <div class=\"signoff\">\u2014 \u043d\u0430\u0448 \u043e\u0440\u0438\u0435\u043d\u0442\u0438\u0440, \u0441 2022</div>\n</section>\n\n<section class=\"cta-wrap\">\n  <h2>\u0422\u0435\u043f\u0435\u0440\u044c \u0442\u044b <em>\u043d\u0430\u0441 \u0437\u043d\u0430\u0435\u0448\u044c</em>.<br/>\u041d\u0430\u043f\u0438\u0448\u0438.</h2>\n  <p>\u0417\u0430\u0431\u0440\u043e\u043d\u0438\u0440\u0443\u0439 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0443, \u043e\u0442\u0434\u0430\u0439 \u043d\u0430\u043c \u0441\u0432\u043e\u044e, \u0437\u0430\u0434\u0430\u0439 \u0432\u043e\u043f\u0440\u043e\u0441. \u041c\u044b \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u043c \u0438\u0437 \u043c\u0430\u043b\u0435\u043d\u044c\u043a\u043e\u0433\u043e \u043e\u0444\u0438\u0441\u0430 \u0432 \u0421\u0442\u0430\u0440\u043e\u043c \u0433\u043e\u0440\u043e\u0434\u0435 \u0438 \u043b\u044e\u0431\u0438\u043c \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0442\u044c\u0441\u044f \u0432\u0436\u0438\u0432\u0443\u044e.</p>\n  <div class=\"row\">\n    <a class=\"btn primary\" href=\"https://t.me/bre_ge\">\u2197 \u041d\u0430\u043f\u0438\u0441\u0430\u0442\u044c \u0432 \u0442\u0435\u043b\u0435\u0433\u0440\u0430\u043c</a>\n    <a class=\"btn alt\" href=\"tel:+995585889601\">+995 585 889 601</a>\n  </div>\n</section>" } />
