---
import SiteRu from '../../../../../layouts/SiteRu.astro';
import '../../../../../styles/apt.css';
import { supabase, applyNames, type Apartment } from '../../../../../lib/supabase';
import { template, pageScript } from '../../../../../lib/aptDetailRu';
import { stripEmoji } from '../../../../../lib/text';
import { GMAPS_KEY } from '../../../../../lib/maps';
import { tRoom, tAmenity } from '../../../../../lib/roomsRu';
import { priceFrom, priceSym } from '../../../../../lib/price';

export async function getStaticPaths() {
  const { data } = await supabase
    .from('apartments_public')
    .select('id,slug,title,title_ru,summary,summary_ru,neighborhood,bedrooms,max_guests,price_from,price_currency,photos,rooms,amenities,lat,lng');
  const apartments = ((data as Apartment[]) || []).map(applyNames);
  const { data: gpData } = await supabase.from('guide_places')
    .select('slug,title,name,category,tags,lat,lng,photos,image').eq('status', 'published');
  const guides = ((gpData as any[]) || []).filter((g) => g.lat != null && g.lng != null);
  const havKm = (a: any, b: any) => {
    const R = 6371, r = (x: number) => (x * Math.PI) / 180;
    const dLat = r(b.lat - a.lat), dLng = r(b.lng - a.lng);
    const s = Math.sin(dLat / 2) ** 2 + Math.cos(r(a.lat)) * Math.cos(r(b.lat)) * Math.sin(dLng / 2) ** 2;
    return 2 * R * Math.asin(Math.sqrt(s));
  };
  const hav = (a: Apartment, b: Apartment) => {
    const R = 6371, toRad = (x: number) => (x * Math.PI) / 180;
    const dLat = toRad((b.lat as number) - (a.lat as number));
    const dLng = toRad((b.lng as number) - (a.lng as number));
    const s = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(a.lat as number)) * Math.cos(toRad(b.lat as number)) * Math.sin(dLng / 2) ** 2;
    return 2 * R * Math.asin(Math.sqrt(s));
  };
  return apartments.map((apt) => {
    const others = apartments.filter((x) => x.slug !== apt.slug);
    const similar = (apt.lat != null && apt.lng != null
      ? others.filter((x) => x.lat != null && x.lng != null).sort((p, q) => hav(apt, p) - hav(apt, q))
      : others
    ).slice(0, 3);
    const near = (apt.lat != null && apt.lng != null)
      ? guides.map((g) => ({ g, d: havKm(apt, g) })).sort((x, y) => x.d - y.d).slice(0, 8)
      : [];
    return { params: { slug: apt.slug }, props: { apt, similar, near } };
  });
}

const { apt, similar, near } = Astro.props as { apt: Apartment; similar: Apartment[]; near: any[] };
const photos = (apt.photos && apt.photos.length)
  ? apt.photos
  : ['https://picsum.photos/seed/' + apt.slug + '/1600/1000'];

const plural = (n: number, one: string, few: string, many: string) => { const m = n % 100, d = n % 10; if (m >= 11 && m <= 14) return many; if (d === 1) return one; if (d >= 2 && d <= 4) return few; return many; };
const bedsW = (n: number) => plural(n, 'спальня', 'спальни', 'спален');
const guestsW = (n: number) => plural(n, 'гость', 'гостя', 'гостей');

const gallery =
  photos.slice(0, 5).map((p, i) =>
    `<div class="${i === 0 ? 'ph main' : 'ph'}" data-idx="${i}"><img src="${p}" alt="${apt.title}"></div>`
  ).join('\n') +
  `\n<button class="gallery-all" id="galleryAll" type="button">↗ смотреть все ${photos.length} фото</button>`;

const meta =
  (apt.bedrooms === 0 ? `<span><b>студия</b></span>` : `<span><b>${apt.bedrooms ?? 1}</b> ${bedsW(apt.bedrooms ?? 1)}</span>`) +
  `<span class="sep">·</span><span>вмещает <b>${apt.max_guests ?? 2}</b> ${guestsW(apt.max_guests ?? 2)}</span>` +
  (apt.neighborhood ? `<span class="sep">·</span><span>${apt.neighborhood}</span>` : '');

// Airbnb section labels glued into the text → lift to sub-headings (EN labels,
// since RU summaries fall back to the EN source where these appear).
const ABNB_HEAD = /^(the space|guest access|other things to note|other details to note|the neighbou?rhood|getting around|getting there|interaction with guests|during your stay|registration number)\.?:?$/i;
const renderAbout = (raw) => {
  const out = []; let para = [];
  const flush = () => { if (para.length) { out.push(`<p>${para.join(' ')}</p>`); para = []; } };
  stripEmoji(raw).split(/\n/).map((l) => l.trim()).forEach((l) => {
    if (!l) { flush(); return; }
    if (ABNB_HEAD.test(l)) { flush(); out.push(`<h5 class="ab-head">${l.replace(/[:.]$/, '')}</h5>`); return; }
    para.push(l);
  });
  flush();
  return out.join('');
};
const about =
  `<h2>проверена, укомплектована, <em>готова</em>.</h2>` +
  ((apt.summary_ru || apt.summary) ? renderAbout(apt.summary_ru || apt.summary) : '') +
  `<p>локальные операции — <b>bre</b>: настоящий заезд, настоящая поддержка, местный человек на расстоянии одного сообщения. на фото — та самая квартира.</p>`;

const ROOM_SKIP = new Set(['Additional photos']);
const inside = (apt.rooms || [])
  .filter((r) => r && r.amenities && r.amenities.length && !ROOM_SKIP.has(r.room))
  .map((r) => `<div class="item"><h5>${tRoom(r.room)}</h5><p>${r.amenities.map(tAmenity).join(', ')}.</p></div>`)
  .join('\n');
const amenities = (apt.amenities || [])
  .map((a) => `<div class="am"><span class="ic">✓</span> ${tAmenity(a)}</div>`)
  .join('\n');

const simPhoto = (s: Apartment) => (s.photos && s.photos[0]) || `https://picsum.photos/seed/${s.slug}/900/700`;
const similarHtml = similar
  .map((s) => {
    const nm = s.title_ru || s.title;
    const beds = s.bedrooms === 0 ? 'студия' : (s.bedrooms ?? 1) + ' ' + bedsW(s.bedrooms ?? 1);
    const price = priceFrom(s, 'ru');
    return `<a class="sim" href="/ru/georgia/batumi/stays/${s.slug}"><div class="ph"><img src="${simPhoto(s)}" alt="${nm}"></div><div class="body"><h5>${nm}</h5><div class="meta">${beds} · ${s.max_guests ?? 2} ${guestsW(s.max_guests ?? 2)}</div><div class="price">${price}</div></div></a>`;
  })
  .join('');

let content = template
  .replaceAll('%%TITLE%%', apt.title_ru || apt.title)
  .replaceAll('%%GUESTS%%', `${apt.max_guests ?? 2} ${guestsW(apt.max_guests ?? 2)}`)
  .replaceAll('%%PHOTOCOUNT%%', String(photos.length))
  .replace('%%GALLERY%%', gallery)
  .replace('%%META%%', meta)
  .replace('%%ABOUT%%', about)
  .replace('%%INSIDE%%', inside)
  .replace('%%AMENITIES%%', amenities)
  .replace('%%SIMILAR%%', similarHtml);
// Цена при сборке — лишь запасной вариант; скрипт панели подставит живое «от $X»
// (мин. доступная ставка ×1.1) когда загрузится. Токен %%PRICE%% не оставляем.
content = apt.price_from
  ? content.replaceAll('%%PRICE%%', priceSym(apt.price_currency) + apt.price_from)
  : content.replace('<em id="abFrom">от %%PRICE%%</em> <span class="per" id="abPer">/ ночь</span>', '<em id="abFrom">по запросу</em> <span class="per" id="abPer" hidden>/ ночь</span>');

// «что рядом» — реальные ближайшие места из гида (Haversine)
const escG = (s: any) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const CATRU: Record<string, string> = { 'eat-drink': 'еда и напитки', 'wellness': 'велнес', 'work': 'работа', 'move-around': 'транспорт' };
const walkMin = (km: number) => Math.max(1, Math.round(km * 12));
const gPhoto = (g: any) => (g && ((g.photos && g.photos[0]) || g.image)) || '';
const picksWithPhoto = (near || []).filter(({ g }: any) => gPhoto(g)).slice(0, 3);
const guidePicksHtml = picksWithPhoto.length
  ? picksWithPhoto.map(({ g, d }: any) => {
      const kick = (CATRU[g.category] || g.category) + ' · ' + walkMin(d) + ' мин пешком';
      return '<a class="pick" href="/georgia/batumi/guide/' + g.slug + '"><div class="ph"><img src="' + escG(gPhoto(g)) + '" alt="" loading="lazy"></div><span class="kicker">' + escG(kick) + '</span><h5>' + escG(g.title || g.name) + '</h5></a>';
    }).join('')
  : '<p style="color:var(--ink-soft)">скоро добавим.</p>';
const locNearHtml = (near && near.length)
  ? '<div class="loc-near">' + near.slice(0, 4).map(({ g, d }: any) => '<div class="ln"><a class="nm" href="/georgia/batumi/guide/' + g.slug + '">' + escG(g.title || g.name) + '</a><span class="ds">' + walkMin(d) + ' мин пешком</span></div>').join('') + '</div>'
  : '';
content = content
  .replace(/<div class="guide-picks">[\s\S]*?<\/div>\s*<\/div>\s*<!-- RULES -->/, '<div class="guide-picks">' + guidePicksHtml + '</div>\n    </div>\n\n    <!-- RULES -->')
  .replace(/<div class="loc-near pending">[\s\S]*?<\/div>\s*<\/div>/, locNearHtml);

content = content.replace('%%STORY%%', '');
const photosJson = JSON.stringify(photos.map((p) => ({ src: p, alt: apt.title })));
const script = pageScript.replaceAll('%%TITLE%%', apt.title).replace('%%PHOTOS%%', photosJson);
const aptMapInit = "window.__initAptMap=function(){RegaMap.single('aptMap',APT_GEO,{routeLabel:'↗ проложить маршрут'});};";
// Панель брони: id квартиры + публичный доступ к базе + русские подписи.
const SB_URL = import.meta.env.PUBLIC_SUPABASE_URL || 'https://qkzinjawtumhjbezlyog.supabase.co';
const SB_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY || 'sb_publishable_R0NeSmTwX9qt0bxlHYj1AA_JIVRqsqU';
const aptBookCfg = JSON.stringify({
  id: apt.id, title: apt.title_ru || apt.title, maxGuests: apt.max_guests ?? 2, url: SB_URL, key: SB_KEY,
  lang: 'ru',
  t: {
    months: ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'],
    week: ['Пн','Вт','Ср','Чт','Пт','Сб','Вс'],
    from: 'от', addDates: 'выбрать даты', minNights: 'минимум 2 ночи', minStay: 'минимум',
    nightsForms: ['ночь','ночи','ночей'],
    pickIn: '→ выберите заезд', pickOut: '→ теперь выезд',
    cleaning: 'уборка', total: 'итого', onRequest: 'по запросу',
    errDates: 'сначала выберите даты', errName: 'укажите имя', errContact: 'укажите контакт',
    errSend: 'не отправилось — напишите в telegram', send: '↗ отправить заявку', sending: 'отправляем…',
    placeholders: { telegram: '@username', whatsapp: '+995 …', email: 'name@email.com' },
  },
});
---
<SiteRu title={(apt.title_ru || apt.title) + ' — rega rega batumi'} description={stripEmoji(apt.summary_ru || apt.summary) || 'проверенная квартира в батуми.'} ogTitle={String(apt.title_ru || apt.title).toLowerCase() + ' — rega rega batumi'} ogDescription="" image={(apt.photos && apt.photos[0]) ? '/og/stay-' + apt.slug + '-ru.png' : undefined} accent='#3A4868' accentDeep='#2C3850'>
<Fragment set:html={content} />
<script is:inline set:html={'window.APT_BOOK=' + aptBookCfg + ';'}></script>
<script is:inline set:html={script}></script>
<script is:inline src="/apt-booking.js"></script>
<script is:inline src="/rega-map.js"></script>
<script is:inline set:html={'const APT_GEO=' + JSON.stringify({lat:apt.lat,lng:apt.lng,title:apt.title}) + ';' + aptMapInit}></script>
<script is:inline async src={'https://maps.googleapis.com/maps/api/js?key=' + GMAPS_KEY + '&callback=__initAptMap&loading=async&language=ru&region=GE'}></script>
</SiteRu>
