<SiteRu title="\u0440\u0438\u0435\u043b\u0442\u043e\u0440\u0430\u043c \u2014 rega rega">
<Fragment set:html={"<section class=\"doc-wrap\">\n  <div class=\"meta-line\"><span class=\"dot\"></span>\u2014 \u0430\u0433\u0435\u043d\u0442\u0430\u043c \u0438 \u043f\u0430\u0440\u0442\u043d\u0451\u0440\u0430\u043c</div>\n  <h1>\u0440\u0430\u0431\u043e\u0442\u0430\u0439 \u0441 \u043d\u0430\u043c\u0438 \u043a\u0430\u043a <em>\u0430\u0433\u0435\u043d\u0442</em>.</h1>\n  <div class=\"updated\">\u2014 \u043a\u043e\u043c\u0438\u0441\u0441\u0438\u044f 10% \u00b7 \u0433\u0440\u0443\u0437\u0438\u044f</div>\n\n  <p class=\"lede\">\u0415\u0441\u043b\u0438 \u0442\u044b \u0430\u0433\u0435\u043d\u0442 \u0438 \u0443 \u0442\u0435\u0431\u044f \u043a\u043b\u0438\u0435\u043d\u0442 \u0445\u043e\u0447\u0435\u0442 <b>\u043a\u0443\u043f\u0438\u0442\u044c \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c \u0432 \u0411\u0430\u0442\u0443\u043c\u0438</b>, <b>\u0441\u0434\u0430\u0432\u0430\u0442\u044c \u0435\u0451</b> \u0438\u043b\u0438 <b>\u043f\u0435\u0440\u0435\u0434\u0430\u0442\u044c \u043e\u043f\u0435\u0440\u0430\u0442\u043e\u0440\u0443 \u0432 \u0443\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435</b> \u2014 \u043f\u0440\u0438\u0432\u0435\u0434\u0438 \u0435\u0433\u043e \u043a \u043d\u0430\u043c. \u0417\u0430\u043a\u0440\u043e\u0435\u043c \u0441\u0434\u0435\u043b\u043a\u0443 \u0432\u043c\u0435\u0441\u0442\u0435 \u0438 \u0437\u0430\u043f\u043b\u0430\u0442\u0438\u043c \u043a\u043e\u043c\u0438\u0441\u0441\u0438\u044e.</p>\n\n  <h2>\u0447\u0442\u043e \u043c\u044b \u0434\u0435\u043b\u0430\u0435\u043c</h2>\n  <p>bre \u0443\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u043f\u043e\u0441\u0443\u0442\u043e\u0447\u043d\u043e\u0439 \u0438 \u0441\u0440\u0435\u0434\u043d\u0435\u0441\u0440\u043e\u0447\u043d\u043e\u0439 \u0430\u0440\u0435\u043d\u0434\u043e\u0439 \u0432 \u0411\u0430\u0442\u0443\u043c\u0438. \u041f\u043e\u043c\u043e\u0433\u0430\u0435\u043c \u0438\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u043c \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a\u0430\u043c \u043f\u043e\u043a\u0443\u043f\u0430\u0442\u044c \u0438 \u0443\u043f\u0440\u0430\u0432\u043b\u044f\u0442\u044c \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430\u043c\u0438 \u2014 \u043e\u0442 \u0432\u044b\u0431\u043e\u0440\u0430 \u0434\u043e\u043c\u0430 \u0434\u043e \u0440\u0435\u043c\u043e\u043d\u0442\u0430, \u043c\u0435\u0431\u043b\u0438\u0440\u043e\u0432\u043a\u0438 \u0438 \u0437\u0430\u043f\u0443\u0441\u043a\u0430 \u043a\u0430\u043a \u0440\u0430\u0431\u043e\u0442\u0430\u044e\u0449\u0435\u0433\u043e \u0430\u043a\u0442\u0438\u0432\u0430. \u0418 \u0432\u0435\u0434\u0451\u043c \u0433\u043e\u0440\u043e\u0434\u0441\u043a\u043e\u0439 \u0433\u0430\u0439\u0434 \u043a\u0443\u0434\u0430 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u043c \u0433\u043e\u0441\u0442\u0435\u0439.</p>\n\n  <h2>\u0441 \u043a\u0435\u043c \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u043c</h2>\n  <ul>\n    <li>\u043d\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043c\u044b\u0435 \u0440\u0438\u0435\u043b\u0442\u043e\u0440\u044b \u0432 \u0413\u0440\u0443\u0437\u0438\u0438 \u0438 \u0437\u0430 \u0435\u0451 \u043f\u0440\u0435\u0434\u0435\u043b\u0430\u043c\u0438</li>\n    <li>\u0441\u043f\u0435\u0446\u0438\u0430\u043b\u0438\u0441\u0442\u044b \u043f\u043e \u0440\u0435\u043b\u043e\u043a\u0430\u0446\u0438\u0438, family office</li>\n    <li>\u043a\u043e\u043d\u0441\u044c\u0435\u0440\u0436-\u0441\u0435\u0440\u0432\u0438\u0441\u044b \u0438 lifestyle-\u043c\u0435\u043d\u0435\u0434\u0436\u0435\u0440\u044b</li>\n    <li>\u0431\u0440\u043e\u043a\u0435\u0440\u044b \u0443 \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0435\u0441\u0442\u044c \u043a\u043b\u0438\u0435\u043d\u0442 \u0441\u0435\u0440\u044c\u0451\u0437\u043d\u043e \u0441\u043c\u043e\u0442\u0440\u044f\u0449\u0438\u0439 \u043d\u0430 \u0411\u0430\u0442\u0443\u043c\u0438</li>\n  </ul>\n\n  <h2>\u043a\u043e\u043c\u0438\u0441\u0441\u0438\u044f</h2>\n  <p><b>10% \u043e\u0442 \u043d\u0430\u0448\u0435\u0433\u043e \u0433\u043e\u043d\u043e\u0440\u0430\u0440\u0430</b>, \u0432\u044b\u043f\u043b\u0430\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044f \u043f\u043e\u0441\u043b\u0435 \u0437\u0430\u043a\u0440\u044b\u0442\u0438\u044f \u0441\u0434\u0435\u043b\u043a\u0438 \u0438 \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u0438\u044f \u043d\u0430\u0448\u0435\u0439 \u0441\u0442\u043e\u0440\u043e\u043d\u044b. \u041f\u043b\u0430\u0442\u0438\u043c \u0431\u0430\u043d\u043a\u043e\u0432\u0441\u043a\u0438\u043c \u043f\u0435\u0440\u0435\u0432\u043e\u0434\u043e\u043c \u0432 USD \u0438\u043b\u0438 \u043c\u0435\u0441\u0442\u043d\u043e\u0439 \u0432\u0430\u043b\u044e\u0442\u0435. \u041d\u0430 \u043f\u0435\u0440\u0432\u043e\u0439 \u0441\u0434\u0435\u043b\u043a\u0435 \u2014 \u043e\u0434\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u0438\u0447\u043d\u043e\u0435 \u0441\u043e\u0433\u043b\u0430\u0448\u0435\u043d\u0438\u0435. \u041f\u043e\u0432\u0442\u043e\u0440\u043d\u044b\u0435 \u043e\u0431\u0440\u0430\u0449\u0435\u043d\u0438\u044f \u2014 \u0435\u0449\u0451 \u043f\u0440\u043e\u0449\u0435.</p>\n\n  <h2>\u0447\u0442\u043e \u0434\u0435\u043b\u0430\u0435\u0448\u044c \u0442\u044b</h2>\n  <ul>\n    <li>\u0437\u043d\u0430\u043a\u043e\u043c\u0438\u0448\u044c \u043a\u043b\u0438\u0435\u043d\u0442\u0430 \u0441 \u043d\u0430\u043c\u0438 \u0432 \u043f\u043e\u0447\u0442\u0435 \u0438\u043b\u0438 \u0442\u0435\u043b\u0435\u0433\u0440\u0430\u043c\u0435 \u2014 \u043a\u043e\u0440\u043e\u0442\u043a\u043e\u0435 intro, \u0447\u0442\u043e \u0438\u0449\u0435\u0442, \u0431\u044e\u0434\u0436\u0435\u0442</li>\n    <li>\u043e\u0441\u0442\u0430\u0451\u0448\u044c\u0441\u044f \u0432 \u043a\u0443\u0440\u0441\u0435 \u0438\u043b\u0438 \u043e\u0442\u0445\u043e\u0434\u0438\u0448\u044c \u0432 \u0441\u0442\u043e\u0440\u043e\u043d\u0443 \u2014 \u043d\u0430 \u0442\u0432\u043e\u0439 \u0432\u044b\u0431\u043e\u0440</li>\n    <li>\u043c\u044b \u0434\u0435\u0440\u0436\u0438\u043c \u0442\u0435\u0431\u044f \u0432 \u043a\u0443\u0440\u0441\u0435 \u043f\u043e \u0441\u0442\u0430\u0442\u0443\u0441\u0443 \u0441\u0434\u0435\u043b\u043a\u0438</li>\n  </ul>\n\n  <h2>\u0447\u0442\u043e \u0434\u0435\u043b\u0430\u0435\u043c \u043c\u044b</h2>\n  <ul>\n    <li>\u043f\u043e\u043b\u043d\u043e\u0435 \u0443\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435: \u0432\u044b\u0431\u043e\u0440 \u0434\u043e\u043c\u0430, due diligence, \u043f\u043e\u043a\u0443\u043f\u043a\u0430, \u0440\u0435\u043c\u043e\u043d\u0442, \u043c\u0435\u0431\u043b\u0438\u0440\u043e\u0432\u043a\u0430</li>\n    <li>\u043e\u043f\u0435\u0440\u0430\u0446\u0438\u043e\u043d\u043a\u0430 \u043f\u043e \u0430\u0440\u0435\u043d\u0434\u0435 \u043a\u043e\u0433\u0434\u0430 \u0432\u0441\u0451 \u0433\u043e\u0442\u043e\u0432\u043e (Airbnb, Booking, \u043f\u0440\u044f\u043c\u044b\u0435 \u0431\u0440\u043e\u043d\u0438)</li>\n    <li>\u0435\u0436\u0435\u043c\u0435\u0441\u044f\u0447\u043d\u0430\u044f \u043e\u0442\u0447\u0451\u0442\u043d\u043e\u0441\u0442\u044c \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a\u0443</li>\n    <li>\u043f\u0440\u043e\u0437\u0440\u0430\u0447\u043d\u044b\u0435 \u043a\u043e\u043c\u0438\u0441\u0441\u0438\u0438: 20% \u043e\u0442 \u0447\u0438\u0441\u0442\u043e\u0433\u043e \u0434\u043e\u0445\u043e\u0434\u0430 \u0441 \u0430\u0440\u0435\u043d\u0434\u044b, \u0431\u0435\u0437 \u0441\u044e\u0440\u043f\u0440\u0438\u0437\u043e\u0432</li>\n  </ul>\n\n  <h2>\u043a\u0430\u043a \u043d\u0430\u0447\u0430\u0442\u044c</h2>\n  <p>\u041f\u0440\u0438\u0448\u043b\u0438 intro \u2014 \u0438\u043c\u044f, \u043a\u043e\u043d\u0442\u0430\u043a\u0442, \u0447\u0442\u043e \u043d\u0443\u0436\u043d\u043e \u0438 \u043b\u044e\u0431\u043e\u0439 \u043a\u043e\u043d\u0442\u0435\u043a\u0441\u0442 \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043f\u043e\u043c\u043e\u0436\u0435\u0442. \u041e\u0442\u0432\u0435\u0442\u0438\u043c \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u0434\u043d\u044f, \u0441\u043e\u0437\u0432\u043e\u043d\u0438\u043c\u0441\u044f, \u0434\u0430\u043b\u044c\u0448\u0435 \u2014 \u043d\u0430\u0448\u0430 \u0440\u0430\u0431\u043e\u0442\u0430. \u041a\u043e\u043d\u0444\u0438\u0434\u0435\u043d\u0446\u0438\u0430\u043b\u044c\u043d\u043e\u0441\u0442\u044c \u043f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e.</p>\n\n  <div class=\"end\">\u0413\u043e\u0442\u043e\u0432 \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u0447\u0430\u0442\u044c? \u041f\u0438\u0448\u0438 \u043d\u0430 <a href=\"mailto:hello@bre.ge\">hello@bre.ge</a> \u0438\u043b\u0438 \u0432 <a href=\"https://t.me/bre_ge\">Telegram</a>. \u041f\u043e\u0433\u043e\u0432\u043e\u0440\u0438\u043c.</div>\n</section>" } />
