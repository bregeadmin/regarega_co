<SiteRu title="\u0418\u043d\u0432\u0435\u0441\u0442\u043e\u0440\u0430\u043c \u2014 rega rega" accent="#1F8A5B" accentDeep="#176E48">
<Fragment set:html={"<!-- HEADER -->\n<section class=\"head\">\n  <div class=\"inner\">\n    <div>\n      <div class=\"crumbs\">\n        <span class=\"current\"><span class=\"dot\"></span>\u0418\u043d\u0432\u0435\u0441\u0442\u043e\u0440\u0430\u043c</span>\n      </div>\n      <h1>\u041a\u0443\u043f\u0438 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0443<br/>\u0432 <em>\u0411\u0430\u0442\u0443\u043c\u0438</em>.</h1>\n    </div>\n    <p class=\"lede\">\u041c\u044b \u043f\u043e\u043c\u043e\u0436\u0435\u043c <b>\u043d\u0430\u0439\u0442\u0438, \u043e\u0442\u0440\u0435\u043c\u043e\u043d\u0442\u0438\u0440\u043e\u0432\u0430\u0442\u044c \u0438 \u0441\u0434\u0430\u0432\u0430\u0442\u044c</b>. \u0412\u0441\u0435 \u0442\u0440\u0438 \u044d\u0442\u0430\u043f\u0430 \u0438\u043b\u0438 \u043e\u0434\u0438\u043d \u043d\u0430 \u0432\u044b\u0431\u043e\u0440. <b>\u0421 2022 \u0433\u043e\u0434\u0430</b>, \u0441\u0432\u043e\u0438\u043c\u0438 \u0440\u0443\u043a\u0430\u043c\u0438.</p>\n  </div>\n</section>\n\n<!-- THE THREE STEPS -->\n<section class=\"steps3-wrap\">\n  <div class=\"steps3-head\">\n    <div>\n      <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u0442\u0440\u0438 \u044d\u0442\u0430\u043f\u0430</div>\n      <h2>\u041d\u0430\u0439\u0434\u0438. <em>\u041e\u0442\u0440\u0435\u043c\u043e\u043d\u0442\u0438\u0440\u0443\u0439</em>.<br/>\u0421\u0434\u0430\u0432\u0430\u0439.</h2>\n    </div>\n    <div class=\"right\">\u0414\u0435\u043b\u0430\u0435\u043c \u0432\u0441\u0435 \u0442\u0440\u0438 \u044d\u0442\u0430\u043f\u0430, \u043e\u0442 \u043d\u0430\u0447\u0430\u043b\u0430 \u0434\u043e \u043a\u043e\u043d\u0446\u0430, \u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e \u0437\u0430 <b>90 \u0434\u043d\u0435\u0439</b> \u0434\u043b\u044f \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b \u0432 50\u043c\u00b2. \u0418\u043b\u0438 \u0432\u044b\u0431\u0435\u0440\u0438 \u043d\u0443\u0436\u043d\u044b\u0439 \u044d\u0442\u0430\u043f \u2014 <b>\u043a\u0430\u0436\u0434\u044b\u0439 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u043e</b>.</div>\n  </div>\n\n  <div class=\"steps3\">\n    <a class=\"step3\" href=\"#find\">\n      <span class=\"nr\">01</span>\n      <h3>\u041d\u0430\u0439\u0434\u0438</h3>\n      <p>\u0417\u043d\u0430\u0435\u043c <b>\u0440\u0430\u0439\u043e\u043d\u044b, \u0437\u0430\u0441\u0442\u0440\u043e\u0439\u0449\u0438\u043a\u043e\u0432, \u0434\u043e\u0433\u043e\u0432\u043e\u0440\u044b</b>. \u0420\u0430\u0441\u0441\u043a\u0430\u0436\u0435\u043c, \u0447\u0442\u043e \u0441\u0442\u043e\u0438\u0442 \u043f\u043e\u043a\u0443\u043f\u0430\u0442\u044c, \u0433\u0434\u0435, \u043f\u043e \u043a\u0430\u043a\u043e\u0439 \u0446\u0435\u043d\u0435 \u2014 \u0438 \u043e\u0442 \u0447\u0435\u0433\u043e \u0434\u0435\u0440\u0436\u0430\u0442\u044c\u0441\u044f \u043f\u043e\u0434\u0430\u043b\u044c\u0448\u0435.</p>\n      <span class=\"more\">\u043f\u043e\u0434\u0440\u043e\u0431\u043d\u0435\u0435 \u2198</span>\n    </a>\n    <a class=\"step3\" href=\"#renovate\">\n      <span class=\"nr\">02</span>\n      <h3><em>\u041e\u0442\u0440\u0435\u043c\u043e\u043d\u0442\u0438\u0440\u0443\u0439</em></h3>\n      <p>\u041e\u0442 \u0447\u0451\u0440\u043d\u043e\u0433\u043e \u0438\u043b\u0438 \u0431\u0435\u043b\u043e\u0433\u043e \u043a\u0430\u0440\u043a\u0430\u0441\u0430 \u0434\u043e \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u043e\u0431\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u043d\u043e\u0439 \u2014 <b>\u043f\u043e\u0434 \u043a\u043b\u044e\u0447</b>. \u0424\u0438\u043a\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u0430\u044f \u0446\u0435\u043d\u0430, \u0444\u0438\u043a\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0435 \u0441\u0440\u043e\u043a\u0438, \u0435\u0436\u0435\u043d\u0435\u0434\u0435\u043b\u044c\u043d\u044b\u0439 \u0444\u043e\u0442\u043e\u043e\u0442\u0447\u0451\u0442. <b>\u2248 $600/\u043c\u00b2</b> \u0432\u0441\u0451 \u0432\u043a\u043b\u044e\u0447\u0435\u043d\u043e.</p>\n      <span class=\"more\">\u043f\u043e\u0434\u0440\u043e\u0431\u043d\u0435\u0435 \u2198</span>\n    </a>\n    <a class=\"step3\" href=\"#rent\">\n      <span class=\"nr\">03</span>\n      <h3>\u0421\u0434\u0430\u0432\u0430\u0439</h3>\n      <p>\u0420\u0430\u0437\u043c\u0435\u0449\u0430\u0435\u043c, \u0444\u043e\u0442\u043e\u0433\u0440\u0430\u0444\u0438\u0440\u0443\u0435\u043c, \u0441\u0442\u0430\u0432\u0438\u043c \u0446\u0435\u043d\u044b, \u043e\u0431\u0449\u0430\u0435\u043c\u0441\u044f \u0441 \u0433\u043e\u0441\u0442\u044f\u043c\u0438, \u0443\u0431\u0438\u0440\u0430\u0435\u043c. <b>30 / 70</b>. \u041c\u0435\u0441\u044f\u0447\u043d\u044b\u0439 \u043e\u0442\u0447\u0451\u0442. \u0422\u044b \u0432\u043b\u0430\u0434\u0435\u0435\u0448\u044c \u0434\u0432\u0435\u0440\u044c\u044e \u2014 \u043c\u044b \u0435\u0451 \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u043c.</p>\n      <span class=\"more\">\u043f\u043e\u0434\u0440\u043e\u0431\u043d\u0435\u0435 \u043d\u0430 /own \u2198</span>\n    </a>\n  </div>\n\n  <div class=\"flex-note\">\n    <div class=\"l\">\n      <span class=\"badge\">\u2014 \u0432\u0430\u0436\u043d\u043e</span>\n      <div class=\"text\"><em>\u041c\u043e\u0436\u0435\u0448\u044c \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0442\u043e\u043b\u044c\u043a\u043e \u043e\u0434\u0438\u043d \u044d\u0442\u0430\u043f.</em> \u0423\u0436\u0435 \u0435\u0441\u0442\u044c \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430? \u041f\u0435\u0440\u0435\u0445\u043e\u0434\u0438 \u0441\u0440\u0430\u0437\u0443 \u043a <b>\u0448\u0430\u0433\u0443 2</b> \u0438\u043b\u0438 <b>\u0448\u0430\u0433\u0443 3</b>.</div>\n    </div>\n  </div>\n</section>\n\n<!-- FIND -->\n<section class=\"pad\" id=\"find\">\n  <div class=\"container\">\n    <div class=\"section-head\">\n      <div class=\"left\">\n        <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u0448\u0430\u0433 01 / \u043d\u0430\u0439\u0434\u0438</div>\n        <h2>\u0427\u0442\u043e \u043c\u044b \u0437\u043d\u0430\u0435\u043c<br/>\u043f\u0440\u043e <em>\u0440\u044b\u043d\u043e\u043a</em>.</h2>\n      </div>\n      <div class=\"right\">\u041d\u0435 \u0431\u0435\u0440\u0451\u043c \u043a\u043e\u043c\u0438\u0441\u0441\u0438\u044e \u0441 \u043f\u0440\u043e\u0434\u0430\u0432\u0446\u043e\u0432. \u0420\u0430\u0431\u043e\u0442\u0430\u0435\u043c \u043d\u0430 <b>\u0442\u0435\u0431\u044f</b>, \u0430 \u043d\u0435 \u043d\u0430 \u0437\u0430\u0441\u0442\u0440\u043e\u0439\u0449\u0438\u043a\u0430. \u041c\u043e\u0436\u0435\u043c \u0441\u0434\u0435\u043b\u0430\u0442\u044c \u0442\u043e\u043b\u044c\u043a\u043e \u043a\u043e\u043d\u0441\u0443\u043b\u044c\u0442\u0430\u0446\u0438\u044e \u043d\u0430 \u044d\u0442\u043e\u043c \u044d\u0442\u0430\u043f\u0435.</div>\n    </div>\n\n    <div class=\"find\">\n      <div class=\"find-text\">\n        <p>\u0412 \u0411\u0430\u0442\u0443\u043c\u0438 \u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e <b>\u0442\u0440\u0438 \u0441\u043b\u043e\u044f</b> \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u0438 \u2014 \u0441\u0442\u0430\u0440\u044b\u0439 \u0441\u043e\u0432\u0435\u0442\u0441\u043a\u0438\u0439 \u0444\u043e\u043d\u0434 \u0432 \u0446\u0435\u043d\u0442\u0440\u0435, \u0441\u0440\u0435\u0434\u043d\u0438\u0435 \u043d\u043e\u0432\u043e\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u043d\u0430 \u0411\u0443\u043b\u044c\u0432\u0430\u0440\u0435 \u0438 \u0427\u0430\u0432\u0447\u0430\u0432\u0430\u0434\u0437\u0435, \u0438 \u0431\u0430\u0448\u043d\u0438 (Orbi, Panorama, Arena) \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0437\u0430\u0434\u0430\u044e\u0442 \u0441\u0438\u043b\u0443\u044d\u0442 \u0433\u043e\u0440\u043e\u0434\u0430. \u041a\u0430\u0436\u0434\u044b\u0439 \u0441\u043b\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442 \u043f\u043e-\u0441\u0432\u043e\u0435\u043c\u0443 \u043f\u043e\u0434 \u043f\u043e\u0441\u0443\u0442\u043e\u0447\u043d\u0443\u044e \u0430\u0440\u0435\u043d\u0434\u0443.</p>\n        <p>\u0420\u0430\u0441\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u043c \u0447\u0442\u043e <b>\u0441\u0442\u043e\u0438\u0442 \u043f\u043e\u043a\u0443\u043f\u0430\u0442\u044c</b>, \u0433\u0434\u0435, \u043f\u043e \u043a\u0430\u043a\u043e\u0439 \u0446\u0435\u043d\u0435 \u2014 \u0438 \u0447\u0435\u0433\u043e \u0438\u0437\u0431\u0435\u0433\u0430\u0442\u044c: \u0434\u043e\u043c\u0430 \u0441\u043e \u0441\u043b\u0430\u0431\u044b\u043c \u0443\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435\u043c, \u0437\u0430\u0441\u0442\u0440\u043e\u0439\u0449\u0438\u043a\u043e\u0432 \u0441 \u0437\u0430\u0434\u0435\u0440\u0436\u043a\u0430\u043c\u0438 \u0441\u0434\u0430\u0447\u0438, \u0440\u0430\u0439\u043e\u043d\u044b \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043e\u0442\u043b\u0438\u0447\u043d\u043e \u0441\u043c\u043e\u0442\u0440\u044f\u0442\u0441\u044f \u043d\u0430 \u0440\u0435\u043d\u0434\u0435\u0440\u0435 \u043d\u043e \u043d\u0435 \u0441\u0434\u0430\u044e\u0442\u0441\u044f \u0432 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0439 \u0436\u0438\u0437\u043d\u0438.</p>\n        <p>\u041f\u043e\u043c\u043e\u0433\u0430\u0435\u043c \u0438 \u0441\u043e \u0441\u043a\u0443\u0447\u043d\u044b\u043c-\u043d\u043e-\u0432\u0430\u0436\u043d\u044b\u043c: <b>\u0434\u043e\u0433\u043e\u0432\u043e\u0440\u044b, \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0430 \u043a\u0430\u0434\u0430\u0441\u0442\u0440\u0430, \u0412\u041d\u0416, \u043d\u0430\u043b\u043e\u0433\u043e\u0432\u0430\u044f \u0440\u0435\u0433\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u044f</b>. \u0413\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u043e\u0435 \u043f\u0440\u0430\u0432\u043e \u043e \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u0438 \u0434\u0440\u0443\u0436\u0435\u043b\u044e\u0431\u043d\u0435\u0435 \u0447\u0435\u043c \u043a\u0430\u0436\u0435\u0442\u0441\u044f \u2014 \u043d\u043e \u0442\u043e\u043b\u044c\u043a\u043e \u0435\u0441\u043b\u0438 \u0437\u043d\u0430\u0435\u0448\u044c \u043f\u0440\u0430\u0432\u0438\u043b\u044c\u043d\u044b\u0435 \u0445\u043e\u0434\u044b.</p>\n      </div>\n\n      <div class=\"find-cards\">\n        <div class=\"find-card\">\n          <span class=\"lbl\">\u0441\u0440\u0435\u0434\u043d\u044f\u044f \u0434\u043e\u0445\u043e\u0434\u043d\u043e\u0441\u0442\u044c</span>\n          <span class=\"val\"><em>~11%</em></span>\n          <span class=\"note\">\u0447\u0438\u0441\u0442\u0430\u044f \u0433\u043e\u0434\u043e\u0432\u0430\u044f \u0434\u043e\u0445\u043e\u0434\u043d\u043e\u0441\u0442\u044c \u043f\u043e \u043d\u0430\u0448\u0435\u043c\u0443 \u043f\u043e\u0440\u0442\u0444\u0435\u043b\u044e. \u041e\u0431\u043d\u043e\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u0435\u0436\u0435\u043a\u0432\u0430\u0440\u0442\u0430\u043b\u044c\u043d\u043e.</span>\n        </div>\n        <div class=\"find-card\">\n          <span class=\"lbl\">\u043d\u0430\u043b\u043e\u0433</span>\n          <span class=\"val\"><em>5%</em></span>\n          <span class=\"note\">\u0444\u0438\u043a\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0439 \u043d\u0430\u043b\u043e\u0433 \u043d\u0430 \u0434\u043e\u0445\u043e\u0434 \u0441 \u0430\u0440\u0435\u043d\u0434\u044b \u0432 \u0413\u0440\u0443\u0437\u0438\u0438. \u0420\u0435\u0433\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u044f \u2014 1 \u0434\u0435\u043d\u044c.</span>\n        </div>\n        <div class=\"find-card\">\n          <span class=\"lbl\">\u0431\u0435\u0437\u0432\u0438\u0437</span>\n          <span class=\"val\"><em>95+</em></span>\n          <span class=\"note\">\u0441\u0442\u0440\u0430\u043d. \u0412\u043b\u0430\u0434\u0435\u043d\u0438\u0435 \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c\u044e \u043d\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0412\u041d\u0416. \u041b\u0435\u0433\u043a\u043e \u043f\u0440\u0438\u0435\u0445\u0430\u0442\u044c, \u043b\u0435\u0433\u043a\u043e \u0443\u0435\u0445\u0430\u0442\u044c.</span>\n        </div>\n        <div class=\"find-card\">\n          <span class=\"lbl\">\u043d\u0430\u0448 \u043e\u043f\u044b\u0442</span>\n          <span class=\"val\">\u043d\u0430 \u0437\u0435\u043c\u043b\u0435</span>\n          <span class=\"note\">\u043c\u044b \u0443\u0436\u0435 <b>\u0441\u0434\u0430\u0451\u043c \u0438 \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u043e\u043d\u043d\u043e \u0432\u0435\u0434\u0451\u043c</b> \u0432 \u0448\u0435\u0441\u0442\u0438 \u0440\u0430\u0439\u043e\u043d\u0430\u0445. \u0417\u043d\u0430\u0435\u043c \u0433\u0434\u0435 \u043f\u043e\u043a\u0443\u043f\u0430\u0442\u044c, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e <b>\u0441\u0430\u043c\u0438 \u0436\u0438\u0432\u0451\u043c \u0438 \u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u0435\u043c \u0437\u0434\u0435\u0441\u044c</b>.</span>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- RENOVATE -->\n<section class=\"reno-wrap\" id=\"renovate\">\n  <div class=\"container\">\n    <div class=\"section-head\">\n      <div class=\"left\">\n        <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u0448\u0430\u0433 02 / \u043e\u0442\u0440\u0435\u043c\u043e\u043d\u0442\u0438\u0440\u0443\u0439</div>\n        <h2>\u041e\u0442 \u0447\u0451\u0440\u043d\u043e\u0433\u043e \u043a\u0430\u0440\u043a\u0430\u0441\u0430<br/>\u0434\u043e \u043f\u0435\u0440\u0432\u043e\u0433\u043e <em>\u0433\u043e\u0441\u0442\u044f</em>.</h2>\n      </div>\n      <div class=\"right\">\u0426\u0435\u043d\u0430 \u0441\u043e\u0433\u043b\u0430\u0441\u043e\u0432\u0430\u043d\u0430 \u0437\u0430\u0440\u0430\u043d\u0435\u0435, \u0431\u0435\u0437 \u0441\u044e\u0440\u043f\u0440\u0438\u0437\u043e\u0432. \u0415\u0436\u0435\u043d\u0435\u0434\u0435\u043b\u044c\u043d\u044b\u0439 \u0444\u043e\u0442\u043e + \u0432\u0438\u0434\u0435\u043e-\u043e\u0442\u0447\u0451\u0442. \u041e\u043a\u043e\u043b\u043e <b>60\u201490 \u0434\u043d\u0435\u0439</b> \u0434\u043b\u044f \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b \u0432 50\u043c\u00b2.</div>\n    </div>\n\n    <div class=\"reno\">\n      <div class=\"reno-text\">\n        <p>\u0411\u043e\u043b\u044c\u0448\u0438\u043d\u0441\u0442\u0432\u043e \u043f\u043e\u043a\u0443\u043f\u0430\u0442\u0435\u043b\u0435\u0439 \u0432 \u0411\u0430\u0442\u0443\u043c\u0438 \u043f\u043e\u043b\u0443\u0447\u0430\u044e\u0442 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0443 \u0432 <b>\u0447\u0451\u0440\u043d\u043e\u043c \u0438\u043b\u0438 \u0431\u0435\u043b\u043e\u043c \u043a\u0430\u0440\u043a\u0430\u0441\u0435</b> \u2014 \u0441\u0442\u0435\u043d\u044b, \u043e\u043a\u043d\u0430, \u0440\u0430\u0437\u0432\u043e\u0434\u043a\u0430 \u043a\u043e\u043c\u043c\u0443\u043d\u0438\u043a\u0430\u0446\u0438\u0439, \u0438 \u043d\u0435 \u0431\u043e\u043b\u0435\u0435. \u0416\u0438\u0442\u044c \u043d\u0435\u043b\u044c\u0437\u044f, \u0441\u0434\u0430\u0432\u0430\u0442\u044c \u043d\u0435\u043b\u044c\u0437\u044f. \u041d\u0443\u0436\u0435\u043d \u0440\u0435\u043c\u043e\u043d\u0442, <b>\u0441\u0434\u0435\u043b\u0430\u043d\u043d\u044b\u0439 \u043f\u043e\u0434 \u0430\u0440\u0435\u043d\u0434\u0443, \u0430 \u043d\u0435 \u043f\u043e\u0434 \u043b\u0438\u0447\u043d\u044b\u0439 \u0432\u043a\u0443\u0441</b>.</p>\n        <p>\u041c\u044b \u0434\u0435\u043b\u0430\u0435\u043c <b>\u043f\u043e\u0434 \u043a\u043b\u044e\u0447</b> \u2014 \u0434\u0438\u0437\u0430\u0439\u043d, \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044b, \u043f\u043e\u0434\u0440\u044f\u0434\u0447\u0438\u043a\u0438, \u043c\u0435\u0431\u0435\u043b\u044c, \u0442\u0435\u0445\u043d\u0438\u043a\u0430, \u0442\u0435\u043a\u0441\u0442\u0438\u043b\u044c, \u043a\u0430\u0440\u0442\u0438\u043d\u044b \u043d\u0430 \u0441\u0442\u0435\u043d\u0430\u0445. \u041e\u0434\u043d\u0430 \u043a\u043e\u043c\u0430\u043d\u0434\u0430, \u043e\u0434\u0438\u043d \u0441\u0440\u043e\u043a, \u043e\u0434\u043d\u0430 \u0446\u0435\u043d\u0430. \u0415\u0436\u0435\u043d\u0435\u0434\u0435\u043b\u044c\u043d\u044b\u0435 \u0444\u043e\u0442\u043e\u043e\u0442\u0447\u0451\u0442\u044b \u0438 \u0433\u043e\u0442\u043e\u0432\u0430\u044f \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430 \u0441 \u043a\u043b\u044e\u0447\u0430\u043c\u0438 \u0432 \u043d\u0430\u0448\u0438\u0445 \u0440\u0443\u043a\u0430\u0445 \u2014 \u0432\u0441\u0442\u0440\u0435\u0447\u0430\u0439 \u0433\u043e\u0441\u0442\u044f.</p>\n        <p>\u0426\u0438\u0444\u0440\u0430 \u0441\u043f\u0440\u0430\u0432\u0430 \u2014 \u044d\u0442\u043e <b>\u0432\u0441\u0451 \u0432\u043a\u043b\u044e\u0447\u0435\u043d\u043e</b>: \u0434\u0438\u0437\u0430\u0439\u043d, \u0440\u0430\u0431\u043e\u0442\u0430, \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044b, \u043c\u0435\u0431\u0435\u043b\u044c, \u043f\u043e\u043b\u043d\u0430\u044f \u043e\u0441\u043d\u0430\u0441\u0442\u043a\u0430, \u0434\u0435\u043a\u043e\u0440. \u041d\u0438\u0447\u0435\u0433\u043e \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u043e \u0434\u043e\u043a\u0443\u043f\u0430\u0442\u044c \u043d\u0435 \u043d\u0443\u0436\u043d\u043e. \u041d\u0438\u0447\u0435\u0433\u043e \u043d\u0435 \u0437\u0430\u0431\u044b\u0442\u043e. \u0413\u043e\u0442\u043e\u0432\u0430 \u043f\u043e\u0434 \u0433\u043e\u0441\u0442\u044f \u0432 \u0434\u0435\u043d\u044c \u043f\u0435\u0440\u0435\u0434\u0430\u0447\u0438.</p>\n        <p>\u0422\u0440\u0438 \u0443\u0440\u043e\u0432\u043d\u044f \u2014 <b>\u044d\u043a\u043e\u043d\u043e\u043c, \u043a\u043e\u043c\u0444\u043e\u0440\u0442, \u043b\u044e\u043a\u0441</b>. \u0426\u0438\u0444\u0440\u0430 \u0432\u044b\u0448\u0435 \u2014 \u0442\u0438\u043f\u0438\u0447\u043d\u044b\u0439 \u0441\u0440\u0435\u0434\u043d\u0438\u0439 \u043a\u043e\u043c\u0444\u043e\u0440\u0442. \u041d\u0430 \u043f\u0435\u0440\u0432\u043e\u043c \u0441\u043e\u0437\u0432\u043e\u043d\u0435 \u043e\u0431\u0441\u0443\u0434\u0438\u043c, \u043a\u0430\u043a\u043e\u0439 \u0443\u0440\u043e\u0432\u0435\u043d\u044c \u043f\u043e\u0434\u0445\u043e\u0434\u0438\u0442 \u043f\u043e\u0434 \u0442\u0432\u043e\u044e \u0446\u0435\u043b\u044c.</p>\n      </div>\n\n      <div class=\"reno-num\">\n        <span class=\"lbl\">\u2014 \u0442\u0438\u043f\u0438\u0447\u043d\u044b\u0439 all-in</span>\n        <span class=\"price\">\u2248 $600<span class=\"unit\">/m\u00b2</span></span>\n        <p class=\"desc\">\u0434\u0438\u0437\u0430\u0439\u043d, \u0440\u0430\u0431\u043e\u0442\u0430, \u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044b, <b>\u043c\u0435\u0431\u0435\u043b\u044c, \u0442\u0435\u0445\u043d\u0438\u043a\u0430, \u0442\u0435\u043a\u0441\u0442\u0438\u043b\u044c, \u0434\u0435\u043a\u043e\u0440</b> \u2014 \u0432\u0441\u0451, \u043a\u0440\u043e\u043c\u0435 \u0441\u0430\u043c\u043e\u0439 \u043a\u043e\u0440\u043e\u0431\u043a\u0438. \u041a\u0432\u0430\u0440\u0442\u0438\u0440\u0430 50\u043c\u00b2 \u043d\u0430 \u044d\u0442\u043e\u043c \u0443\u0440\u043e\u0432\u043d\u0435 \u2014 <b>\u2248 $30 000</b> \u043f\u043e\u0434 \u043a\u043b\u044e\u0447.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- HOME STAGING \u2014 buyable separately -->\n<section class=\"pad\">\n  <div class=\"container\">\n    <div class=\"section-head\">\n      <div class=\"left\">\n        <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u043d\u0430\u0448 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430</div>\n        <h2>C\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u044b <em>bre</em>.<br/><span style=\"font-size:.5em;letter-spacing:0;color:var(--ink-soft);font-weight:500;font-style:italic\">(\u043f\u043e\u043a\u0430 \u043d\u0430\u0437\u044b\u0432\u0430\u0435\u043c \u044d\u0442\u043e \u00abhome staging\u00bb)</span></h2>\n      </div>\n      <div class=\"right\">\u041a\u0432\u0430\u0440\u0442\u0438\u0440\u0430 \u0443\u0436\u0435 \u043e\u0442\u0440\u0435\u043c\u043e\u043d\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0430, \u043d\u043e \u043d\u0435 <i>\u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442</i>? \u041f\u043e\u0434\u0432\u0435\u0434\u0451\u043c \u0435\u0451 \u043f\u043e\u0434 <b>\u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442 bre</b> \u2014 \u0442\u043e\u0442 \u0436\u0435 \u0447\u0435\u043a-\u043b\u0438\u0441\u0442, \u0447\u0442\u043e \u043c\u044b \u043f\u0440\u0438\u043c\u0435\u043d\u044f\u0435\u043c \u043a\u043e \u0432\u0441\u0435\u043c\u0443, \u0447\u0442\u043e \u0443\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u043c. <b>\u041c\u043e\u0436\u043d\u043e \u0437\u0430\u043a\u0430\u0437\u0430\u0442\u044c \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u043e</b>.</div>\n    </div>\n\n    <div class=\"staging\">\n      <div class=\"l\">\n        <span class=\"badge\">\u2014 \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u0430\u044f \u0443\u0441\u043b\u0443\u0433\u0430</span>\n        <h3>\u041d\u0435 \u043f\u0440\u043e\u0441\u0442\u043e <em>\u0441\u0442\u0430\u0439\u043b\u0438\u043d\u0433</em>.<br/>\u041f\u043e\u043b\u043d\u044b\u0439 <em>\u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442</em>.</h3>\n        <p>\u041d\u0430\u0437\u044b\u0432\u0430\u0435\u043c \u044d\u0442\u043e home staging, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u044d\u0442\u043e \u043f\u043e\u043d\u044f\u0442\u043d\u043e\u0435 \u043c\u0438\u0440\u0443 \u0441\u043b\u043e\u0432\u043e. <b>\u041d\u043e \u044d\u0442\u043e \u043d\u0430\u0448 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442</b> \u2014 \u0447\u0435\u043a-\u043b\u0438\u0441\u0442 \u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e \u0438\u0437 70 \u043f\u0443\u043d\u043a\u0442\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043c\u044b \u0441\u043e\u0431\u0438\u0440\u0430\u043b\u0438 \u0447\u0435\u0442\u044b\u0440\u0435 \u0433\u043e\u0434\u0430 \u0440\u0435\u0430\u043b\u044c\u043d\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u044b \u0441 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430\u043c\u0438: \u043e\u0442 \u043f\u043b\u043e\u0442\u043d\u043e\u0441\u0442\u0438 \u0442\u0435\u043a\u0441\u0442\u0438\u043b\u044f \u0438 \u0442\u0435\u043c\u043f\u0435\u0440\u0430\u0442\u0443\u0440\u044b \u0441\u0432\u0435\u0442\u0430 \u0434\u043e welcome-\u043a\u0430\u0440\u0442\u043e\u0447\u0435\u043a, \u0431\u0440\u0435\u043d\u0434\u0430 \u0447\u0430\u0439\u043d\u0438\u043a\u0430 \u0438 \u0443\u043f\u043e\u0440\u043e\u0432 \u0448\u0442\u043e\u0440.</p>\n        <p>\u0422\u0430 \u0436\u0435 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430, \u0432 \u0434\u0432\u0430 \u0440\u0430\u0437\u0430 \u0431\u043e\u043b\u044c\u0448\u0435 \u0432\u044b\u0440\u0443\u0447\u043a\u0438 \u2014 \u0432\u043e\u0442 \u0447\u0442\u043e \u0434\u0435\u043b\u0430\u0435\u0442 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442. <b>\u0422\u0435\u043a\u0441\u0442\u0438\u043b\u044c, \u043a\u0430\u0440\u0442\u0438\u043d\u044b, \u0441\u0432\u0435\u0442, \u0440\u0430\u0441\u0442\u0435\u043d\u0438\u044f, \u0442\u043e\u0447\u0435\u0447\u043d\u044b\u0435 \u043c\u0435\u043b\u043a\u0438\u0435 \u043f\u043e\u043a\u0443\u043f\u043a\u0438</b>. \u0420\u0430\u0431\u043e\u0442\u0430\u0435\u043c \u0441 \u0442\u0435\u043c, \u0447\u0442\u043e \u0435\u0441\u0442\u044c, \u0434\u043e\u0431\u0430\u0432\u043b\u044f\u0435\u043c \u0442\u043e, \u0447\u0435\u0433\u043e \u043d\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442.</p>\n        <div class=\"pricing\">\n          <div>\n            <span class=\"k\">\u2014 \u0442\u0438\u043f\u0438\u0447\u043d\u044b\u0439 \u043f\u0440\u043e\u0435\u043a\u0442</span>\n            <span class=\"v\">2\u20145 \u0434\u043d\u0435\u0439</span>\n          </div>\n          <div>\n            <span class=\"k\">\u2014 \u0447\u0442\u043e \u0432\u0445\u043e\u0434\u0438\u0442</span>\n            <span class=\"v\">~70 \u043f\u0443\u043d\u043a\u0442\u043e\u0432 \u0441\u0442\u0430\u043d\u0434\u0430\u0440\u0442\u0430</span>\n          </div>\n          <div>\n            <span class=\"k\">\u2014 \u043d\u0430 \u0432\u044b\u0445\u043e\u0434\u0435</span>\n            <span class=\"v\">\u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430 \u043f\u043e\u0434 \u0441\u044a\u0451\u043c\u043a\u0443</span>\n          </div>\n        </div>\n      </div>\n      <div class=\"r\"></div>\n    </div>\n  </div>\n</section>\n\n<!-- RENT \u2014 short link to /own -->\n<section class=\"pad\" id=\"rent\" style=\"padding-top:0\">\n  <div class=\"container\">\n    <div class=\"section-head\">\n      <div class=\"left\">\n        <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u0448\u0430\u0433 03 / \u0441\u0434\u0430\u0432\u0430\u0439</div>\n        <h2>\u0422\u0435\u043f\u0435\u0440\u044c \u043e\u043d\u0430 <em>\u0437\u0430\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u0435\u0442</em>.</h2>\n      </div>\n      <div class=\"right\">\u041f\u043e\u0434\u0440\u043e\u0431\u043d\u043e \u2014 \u043d\u0430 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0435 <b>/own</b>. \u0422\u0430 \u0436\u0435 \u0443\u0441\u043b\u0443\u0433\u0430, \u043a\u0443\u043f\u0438\u043b \u0442\u044b \u0447\u0435\u0440\u0435\u0437 \u043d\u0430\u0441 \u0438\u043b\u0438 \u043f\u0440\u0438\u043d\u0451\u0441 \u0441\u0432\u043e\u044e \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0443.</div>\n    </div>\n\n    <div class=\"manage\">\n      <div class=\"manage-text\">\n        <p>\u041f\u043e\u0441\u043b\u0435 \u0440\u0435\u043c\u043e\u043d\u0442\u0430 \u0438 \u0441\u0442\u0430\u0439\u043b\u0438\u043d\u0433\u0430 \u043c\u044b \u0431\u0435\u0440\u0451\u043c \u0430\u0440\u0435\u043d\u0434\u0443 \u043d\u0430 \u0441\u0435\u0431\u044f. <b>\u041e\u0431\u044a\u044f\u0432\u043b\u0435\u043d\u0438\u044f, \u0444\u043e\u0442\u043e, \u0433\u0438\u0431\u043a\u043e\u0435 \u0446\u0435\u043d\u043e\u043e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u043d\u0438\u0435, \u043e\u0431\u0449\u0435\u043d\u0438\u0435 \u0441 \u0433\u043e\u0441\u0442\u044f\u043c\u0438, \u0443\u0431\u043e\u0440\u043a\u0430, \u0432\u0441\u0451 \u043e\u0441\u0442\u0430\u043b\u044c\u043d\u043e\u0435.</b></p>\n        <p>\u0422\u044b \u043f\u043e\u043b\u0443\u0447\u0430\u0435\u0448\u044c <b>70%</b> \u043e\u0442 \u0447\u0438\u0441\u0442\u043e\u0439 \u0432\u044b\u0440\u0443\u0447\u043a\u0438. \u041c\u044b \u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u043c <b>30%</b> \u0438 \u043f\u043e\u043a\u0440\u044b\u0432\u0430\u0435\u043c \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u0439 \u2014 welcome-\u043d\u0430\u0431\u043e\u0440\u044b, \u0441\u0442\u0438\u0440\u043a\u0430, \u043c\u0435\u043b\u043a\u0438\u0439 \u0440\u0435\u043c\u043e\u043d\u0442, \u043c\u0435\u0441\u044f\u0447\u043d\u044b\u0439 \u043e\u0442\u0447\u0451\u0442.</p>\n        <p>\u0422\u044b \u0432\u043b\u0430\u0434\u0435\u0435\u0448\u044c \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u043e\u0439, \u043e\u043f\u043b\u0430\u0447\u0438\u0432\u0430\u0435\u0448\u044c \u043a\u043e\u043c\u043c\u0443\u043d\u0430\u043b\u043a\u0443 \u0438 \u0440\u0430\u0437\u043e\u0432\u044b\u0435 \u043f\u043e\u043a\u0443\u043f\u043a\u0438. \u0412\u0441\u0451. <b>\u0422\u0435 \u0436\u0435 \u0443\u0441\u043b\u043e\u0432\u0438\u044f \u0434\u043b\u044f \u043a\u0430\u0436\u0434\u043e\u0433\u043e \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a\u0430</b>, \u043d\u0435\u0437\u0430\u0432\u0438\u0441\u0438\u043c\u043e \u043e\u0442 \u0442\u043e\u0433\u043e, \u0447\u0435\u0440\u0435\u0437 \u043d\u0430\u0441 \u043b\u0438 \u043f\u043e\u043a\u0443\u043f\u0430\u043b.</p>\n      </div>\n      <div class=\"manage-card\">\n        <span class=\"num\">30<span class=\"pc\">/70</span></span>\n        <h4>\u043d\u0430\u0448\u0430 \u0434\u043e\u043b\u044f \u00b7 \u0442\u0432\u043e\u044f \u0434\u043e\u043b\u044f</h4>\n        <p>\u041d\u0430\u0448\u0438 30% \u043f\u043e\u043a\u0440\u044b\u0432\u0430\u044e\u0442 \u0432\u0441\u044e \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u043e\u043d\u043a\u0443. \u0422\u0432\u043e\u0438 70% \u2014 \u0440\u0430\u0437 \u0432 \u043c\u0435\u0441\u044f\u0446 \u0441 \u043f\u0440\u043e\u0437\u0440\u0430\u0447\u043d\u044b\u043c \u043e\u0442\u0447\u0451\u0442\u043e\u043c.</p>\n        <a class=\"lnk\" href=\"/ru/georgia/batumi/own\">\u043f\u043e\u0434\u0440\u043e\u0431\u043d\u043e\u0441\u0442\u0438 \u043d\u0430 /own \u2192</a>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- WHY BATUMI -->\n<section class=\"pad\" style=\"background:var(--paper);padding-top:96px;padding-bottom:96px;border-top:1px solid var(--line);border-bottom:1px solid var(--line)\">\n  <div class=\"container\">\n    <div class=\"section-head\">\n      <div class=\"left\">\n        <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u043f\u043e\u0447\u0435\u043c\u0443 \u0411\u0430\u0442\u0443\u043c\u0438</div>\n        <h2>\u0426\u0438\u0444\u0440\u044b, \u043a\u043e\u0442\u043e\u0440\u044b\u0435<br/>\u043d\u0430\u043c <em>\u043d\u0440\u0430\u0432\u044f\u0442\u0441\u044f</em><br/>\u0432 \u044d\u0442\u043e\u043c \u0433\u043e\u0440\u043e\u0434\u0435.</h2>\n      </div>\n      <div class=\"right\">\u041a\u0440\u0430\u0442\u043a\u0430\u044f \u043a\u0430\u0440\u0442\u0430 \u043c\u0430\u043a\u0440\u043e. \u041d\u0430 \u0441\u043e\u0437\u0432\u043e\u043d\u0435 \u043c\u043e\u0436\u0435\u043c \u0433\u043b\u0443\u0431\u0436\u0435 \u043a\u043e\u043f\u043d\u0443\u0442\u044c \u043b\u044e\u0431\u0443\u044e \u0438\u0437 \u043d\u0438\u0445.</div>\n    </div>\n\n    <div class=\"why\">\n      <div class=\"why-tile\">\n        <span class=\"nr\">01</span>\n        <span class=\"num\"><em>5%</em></span>\n        <h5>\u0444\u0438\u043a\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0439 \u043d\u0430\u043b\u043e\u0433</h5>\n        <p>\u0444\u0438\u043a\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0439 \u043d\u0430\u043b\u043e\u0433 \u043d\u0430 \u0434\u043e\u0445\u043e\u0434 \u0441 \u0430\u0440\u0435\u043d\u0434\u044b \u0432 \u0413\u0440\u0443\u0437\u0438\u0438. \u041e\u0434\u0438\u043d \u0438\u0437 \u0441\u0430\u043c\u044b\u0445 \u043d\u0438\u0437\u043a\u0438\u0445 \u0432 \u0415\u0432\u0440\u043e\u043f\u0435.</p>\n      </div>\n      <div class=\"why-tile\">\n        <span class=\"nr\">02</span>\n        <span class=\"num\">~9<span style=\"font-size:.5em;letter-spacing:-.02em\">\u043c\u0435\u0441</span></span>\n        <h5>\u0442\u0451\u043f\u043b\u044b\u0439 \u0441\u0435\u0437\u043e\u043d</h5>\n        <p>\u041a\u043b\u0438\u043c\u0430\u0442 \u0427\u0451\u0440\u043d\u043e\u0433\u043e \u043c\u043e\u0440\u044f. \u0412\u044b\u0441\u043e\u043a\u0438\u0439 \u0441\u0435\u0437\u043e\u043d \u2014 \u043c\u0430\u0439\u2014\u043e\u043a\u0442\u044f\u0431\u0440\u044c, \u043d\u043e \u0432\u0435\u0441\u043d\u0430 \u0438 \u043e\u0441\u0435\u043d\u044c \u0442\u043e\u0436\u0435 \u0441\u0434\u0430\u044e\u0442\u0441\u044f \u043d\u0435\u043f\u043b\u043e\u0445\u043e.</p>\n      </div>\n      <div class=\"why-tile\">\n        <span class=\"nr\">03</span>\n        <span class=\"num\">95+<span style=\"font-size:.5em\">cn</span></span>\n        <h5>\u0431\u0435\u0437\u0432\u0438\u0437, ~95 \u0441\u0442\u0440\u0430\u043d</h5>\n        <p>\u0412\u043b\u0430\u0434\u0435\u043d\u0438\u0435 \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c\u044e \u043d\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0412\u041d\u0416. \u041b\u0435\u0433\u043a\u043e \u043f\u0440\u0438\u0435\u0445\u0430\u0442\u044c, \u043b\u0435\u0433\u043a\u043e \u0443\u0435\u0445\u0430\u0442\u044c.</p>\n      </div>\n      <div class=\"why-tile\">\n        <span class=\"nr\">04</span>\n        <span class=\"num\"><em>~70%</em></span>\n        <h5>\u0437\u0430\u0433\u0440\u0443\u0437\u043a\u0430 \u0432 \u0433\u043e\u0434</h5>\n        <p>\u0412 \u0441\u0440\u0435\u0434\u043d\u0435\u043c \u043f\u043e \u043d\u0430\u0448\u0435\u043c\u0443 \u043f\u043e\u0440\u0442\u0444\u0435\u043b\u044e. \u041f\u0438\u043a\u043e\u0432\u044b\u0435 \u043d\u0435\u0434\u0435\u043b\u0438 \u0431\u0440\u043e\u043d\u0438\u0440\u0443\u044e\u0442\u0441\u044f \u0437\u0430 \u043c\u0435\u0441\u044f\u0446\u044b \u0432\u043f\u0435\u0440\u0451\u0434, \u043c\u0435\u0436\u0441\u0435\u0437\u043e\u043d\u044c\u0435 \u043f\u043e\u0434\u0442\u044f\u0433\u0438\u0432\u0430\u0435\u0442\u0441\u044f.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- PULL QUOTE -->\n<section class=\"pull\">\n  <blockquote>\u041d\u0435 <em>\u043f\u0440\u043e\u0434\u0430\u0451\u043c</em>.<br/>\u041f\u0440\u043e\u0441\u0442\u043e <em>\u0441\u043e\u0432\u0435\u0442\u0443\u0435\u043c</em>.</blockquote>\n  <div class=\"signoff\">\u2014 bre \u00b7 \u0441 2022</div>\n</section>\n\n<!-- CTA -->\n<section class=\"cta-wrap\">\n  <h2>\u0414\u0430\u0432\u0430\u0439 <em>\u043f\u043e\u0433\u043e\u0432\u043e\u0440\u0438\u043c</em><br/>\u043e \u0442\u0432\u043e\u0435\u0439 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0435.</h2>\n  <p>30 \u043c\u0438\u043d\u0443\u0442 \u043a\u043e\u043d\u0441\u0443\u043b\u044c\u0442\u0430\u0446\u0438\u0438. \u0420\u0430\u0437\u0431\u0435\u0440\u0451\u043c \u0442\u0432\u043e\u0439 \u0431\u044e\u0434\u0436\u0435\u0442, \u0446\u0435\u043b\u044c \u0438 \u043a\u0430\u043a\u043e\u0439 \u0438\u0437 \u0442\u0440\u0451\u0445 \u044d\u0442\u0430\u043f\u043e\u0432 \u043d\u0443\u0436\u0435\u043d \u043d\u0430 \u0441\u0430\u043c\u043e\u043c \u0434\u0435\u043b\u0435. \u0427\u0435\u0441\u0442\u043d\u044b\u0439 \u0432\u0437\u0433\u043b\u044f\u0434 \u043d\u0430 \u0440\u044b\u043d\u043e\u043a, \u0431\u0435\u0437 \u043f\u0440\u0435\u0437\u0435\u043d\u0442\u0430\u0446\u0438\u0439.</p>\n  <div class=\"row\">\n    <a class=\"btn primary\" href=\"https://t.me/bre_ge\">\u2197 \u041d\u0430\u043f\u0438\u0441\u0430\u0442\u044c \u0432 \u0442\u0435\u043b\u0435\u0433\u0440\u0430\u043c</a>\n    <a class=\"btn alt\" href=\"tel:+995585889601\">+995 585 889 601</a>\n  </div>\n</section>" } />
