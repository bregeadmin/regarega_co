7\u0438\u044f</span>\n          <h5>\u041a\u043d\u0438\u0436\u043d\u044b\u0439 \u0431\u0435\u0437 \u0432\u044b\u0432\u0435\u0441\u043a\u0438</h5>\n          <div class=\"meta\"><span>\u0421\u0442\u0430\u0440\u044b\u0439 \u0433\u043e\u0440\u043e\u0434</span><span>\u00b7 \u0432\u0442 \u00b7 \u0447\u0442 \u00b7 \u0441\u0431</span><span>\u00b7 \u0442\u043e\u043b\u044c\u043a\u043e \u043d\u0430\u043b\u0438\u0447\u043d\u044b\u0435</span></div>\n        </a>\n        <a class=\"place\" href=\"/ru/georgia/batumi/guide/armenian-church-courtyard\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1602077429129-feb7f17e9712?w=900&q=80\" alt=\"\"></div>\n          <span class=\"kicker\"><span class=\"sw\"></span>\u043c\u0435\u0441\u0442\u043e \u00b7 \u0434\u0432\u043e\u0440</span>\n          <h5>\u0414\u0432\u043e\u0440 \u0430\u0440\u043c\u044f\u043d\u0441\u043a\u043e\u0439 \u0446\u0435\u0440\u043a\u0432\u0438</h5>\n          <div class=\"meta\"><span>\u0421\u0442\u0430\u0440\u044b\u0439 \u0433\u043e\u0440\u043e\u0434</span><span>\u00b7 \u0441\u0432\u0435\u0442\u043b\u043e\u0435 \u0432\u0440\u0435\u043c\u044f</span><span>\u00b7 \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u043e</span></div>\n        </a>\n        <a class=\"place\" href=\"/ru/georgia/batumi/guide/old-batumi-synagogue\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1591291621164-2c6367723315?w=900&q=80\" alt=\"\"></div>\n          <span class=\"kicker\"><span class=\"sw\"></span>\u0441\u0438\u043d\u0430\u0433\u043e\u0433\u0430</span>\n          <h5>\u0421\u0438\u043d\u0430\u0433\u043e\u0433\u0430 \u0421\u0442\u0430\u0440\u043e\u0433\u043e \u0411\u0430\u0442\u0443\u043c\u0438</h5>\n          <div class=\"meta\"><span>\u0421\u0442\u0430\u0440\u044b\u0439 \u0433\u043e\u0440\u043e\u0434</span><span>\u00b7 \u043f\u043e\u0437\u0432\u043e\u043d\u0438 \u0432 \u0437\u0432\u043e\u043d\u043e\u043a</span><span>\u00b7 \u0431\u0435\u0441\u043f\u043b\u0430\u0442\u043d\u043e</span></div>\n        </a>\n        <a class=\"place\" href=\"/ru/georgia/batumi/guide/dalis-place\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1565958011703-44f9829ba187?w=900&q=80\" alt=\"\"></div>\n          <span class=\"kicker\"><span class=\"sw\"></span>\u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d \u00b7 \u0433\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u0430\u044f</span>\n          <h5>\u0423 \u0414\u0430\u043b\u0438 (\u0431\u0435\u0437 \u0432\u044b\u0432\u0435\u0441\u043a\u0438)</h5>\n          <div class=\"meta\"><span>\u0421\u0442\u0430\u0440\u044b\u0439 \u0433\u043e\u0440\u043e\u0434</span><span>\u00b7 13\u201416, 19\u201422</span><span>\u00b7 \u224825\u201440 \u20be</span></div>\n        </a>\n      </div>\n    </div>\n  </section>\n\n  <!-- RELATED -->\n  <section class=\"related\">\n    <div class=\"inner\">\n      <div class=\"top\">\n        <h3>\u0415\u0449\u0451 <em>\u0438\u0441\u0442\u043e\u0440\u0438\u0438</em>.</h3>\n        <div class=\"right\">\u2014 \u0432\u044b\u0431\u0440\u0430\u043d\u043e \u0438\u0437 \u0433\u0430\u0439\u0434\u0430</div>\n      </div>\n      <div class=\"grid\">\n        <a class=\"story\" href=\"#\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1561758033-d89a9ad46330?w=900&q=80\" alt=\"\"></div>\n          <span class=\"nr\">\u043f\u043e\u0433\u0440\u0443\u0436\u0435\u043d\u0438\u0435 \u00b7 04</span>\n          <h4>\u041f\u043e\u0447\u0435\u043c\u0443 <em>\u0445\u0430\u0447\u0430\u043f\u0443\u0440\u0438</em><br/>\u043d\u0438\u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u043f\u0440\u043e\u0441\u0442\u043e \u0445\u043b\u0435\u0431.</h4>\n          <p>\u041f\u044f\u0442\u044c \u043c\u0435\u0441\u0442, \u043f\u044f\u0442\u044c \u0440\u0435\u0446\u0435\u043f\u0442\u043e\u0432, \u043f\u043e\u0447\u0435\u043c\u0443 \u0432\u0430\u0436\u0435\u043d \u0436\u0435\u043b\u0442\u043e\u043a, \u0433\u0434\u0435 \u043c\u044b \u043e\u0448\u0438\u0431\u0430\u043b\u0438\u0441\u044c.</p>\n          <span class=\"read\">\u0447\u0438\u0442\u0430\u0442\u044c \u044d\u0441\u0441\u0435 \u2192</span>\n        </a>\n        <a class=\"story\" href=\"#\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1502920514313-52581002a659?w=900&q=80\" alt=\"\"></div>\n          <span class=\"nr\">\u0444\u043e\u0442\u043e \u00b7 01</span>\n          <h4>\u0414\u0435\u043d\u044c<br/>\u0432 <em>\u0413\u043e\u043d\u0438\u043e</em>.</h4>\n          <p>\u041c\u044b\u0441, \u043a\u0440\u0435\u043f\u043e\u0441\u0442\u044c, \u0440\u044b\u0431\u043d\u044b\u0439 \u043e\u0431\u0435\u0434, \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0445\u043e\u0440\u043e\u0448\u0438\u0439 \u043f\u043b\u044f\u0436 \u043a \u044e\u0433\u0443 \u043e\u0442 \u0411\u0430\u0442\u0443\u043c\u0438.</p>\n          <span class=\"read\">\u043e\u0442\u043a\u0440\u044b\u0442\u044c \u044d\u0441\u0441\u0435 \u2192</span>\n        </a>\n        <a class=\"story\" href=\"#\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1493809842364-78817add7ffb?w=900&q=80\" alt=\"\"></div>\n          <span class=\"nr\">\u043c\u0430\u0440\u0448\u0440\u0443\u0442 \u00b7 06</span>\n          <h4>\u041c\u0435\u0434\u043b\u0435\u043d\u043d\u043e\u0435 <em>\u0432\u043e\u0441\u043a\u0440\u0435\u0441\u0435\u043d\u044c\u0435</em><br/>\u0432 \u0411\u0430\u0442\u0443\u043c\u0438.</h4>\n          <p>\u0411\u043b\u043e\u0448\u0438\u043d\u044b\u0439 \u0440\u044b\u043d\u043e\u043a, \u0441\u0435\u0440\u043d\u044b\u0435 \u0431\u0430\u043d\u0438, \u043e\u0431\u0435\u0434 \u0441 \u0434\u0440\u0443\u0437\u044c\u044f\u043c\u0438, \u0434\u0440\u0451\u043c\u0430. \u041d\u0430\u0448 \u043f\u0440\u043e\u0442\u043e\u043a\u043e\u043b \u0432\u044b\u0445\u043e\u0434\u043d\u043e\u0433\u043e.</p>\n          <span class=\"read\">\u0447\u0438\u0442\u0430\u0442\u044c \u043c\u0430\u0440\u0448\u0440\u0443\u0442 \u2192</span>\n        </a>\n      </div>\n    </div>\n  </section>\n\n  <!-- TELEGRAM CTA -->\n  <section class=\"tg-cta\">\n    <h3>\u041f\u0443\u0431\u043b\u0438\u043a\u0443\u0435\u043c \u0442\u0430\u043a\u0438\u0435<br/>\u0440\u0430\u0437 \u0432 <em>\u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043d\u0435\u0434\u0435\u043b\u044c</em>.</h3>\n    <p>\u041f\u043e\u0434\u043f\u0438\u0448\u0438\u0441\u044c \u043d\u0430 \u0442\u0435\u043b\u0435\u0433\u0440\u0430\u043c-\u043a\u0430\u043d\u0430\u043b \u2014 \u043d\u043e\u0432\u044b\u0435 \u0438\u0441\u0442\u043e\u0440\u0438\u0438, \u043d\u043e\u0432\u043e\u0441\u0442\u0438 \u0438\u0437 \u0411\u0430\u0442\u0443\u043c\u0438 \u0438 \u043c\u0435\u043b\u043e\u0447\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0441\u0442\u043e\u0438\u0442 \u0437\u043d\u0430\u0442\u044c \u043f\u0440\u043e \u0433\u043e\u0440\u043e\u0434.</p>\n    <a class=\"btn\" href=\"https://t.me/batumirealflats\">\u2197 \u043f\u043e\u0434\u043f\u0438\u0441\u0430\u0442\u044c\u0441\u044f \u0432 \u0442\u0435\u043b\u0435\u0433\u0440\u0430\u043c\u0435</a>\n  </section>\n\n</article>"} />
