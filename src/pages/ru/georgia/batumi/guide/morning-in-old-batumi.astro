<SiteRu title="\u0423\u0442\u0440\u043e \u0432 \u0421\u0442\u0430\u0440\u043e\u043c \u0411\u0430\u0442\u0443\u043c\u0438 \u2014 rega rega">
<Fragment set:html={"<article class=\"article\">\n\n  <!-- META TOP -->\n  <div class=\"meta-top\">\n    <div class=\"left\">\n      <span class=\"pill\"><span class=\"dot\"></span>\u043c\u0430\u0440\u0448\u0440\u0443\u0442 \u00b7 02</span>\n      <span>\u00b7 \u043e\u043f\u0443\u0431\u043b\u0438\u043a\u043e\u0432\u0430\u043d\u043e 28 \u0430\u043f\u0440\u0435\u043b\u044f 2026</span>\n      <span>\u00b7 8 \u043c\u0438\u043d \u0447\u0438\u0442\u0430\u0442\u044c</span>\n    </div>\n    <div class=\"right\">\n      <a href=\"#share\">\u043f\u043e\u0434\u0435\u043b\u0438\u0442\u044c\u0441\u044f \u2197</a>\n    </div>\n  </div>\n\n  <!-- HERO TITLE -->\n  <section class=\"hero\">\n    <div class=\"inner\">\n      <div class=\"crumbs\">\n        <a href=\"/ru/georgia/batumi/guide\">\u0413\u0430\u0439\u0434</a>\n        <span class=\"sep\">/</span>\n        <a href=\"/ru/georgia/batumi/guide#stories\">\u0438\u0441\u0442\u043e\u0440\u0438\u0438</a>\n        <span class=\"sep\">/</span>\n        <span class=\"current\"><span class=\"dot\"></span>\u043c\u0430\u0440\u0448\u0440\u0443\u0442 \u00b7 02</span>\n      </div>\n      <h1 class=\"title\">\u0423\u0442\u0440\u043e<br/>\u0432 <em>\u0421\u0442\u0430\u0440\u043e\u043c</em> \u0411\u0430\u0442\u0443\u043c\u0438.</h1>\n      <div class=\"by\">\n        <span class=\"av\"></span>\n        <span>\u0442\u0435\u043a\u0441\u0442 \u00b7 <b>\u043a\u043e\u043c\u0430\u043d\u0434\u0430 bre</b></span>\n        <span>\u00b7 \u0444\u043e\u0442\u043e \u00b7 \u043a\u043e\u043c\u0430\u043d\u0434\u0430 bre</span>\n      </div>\n    </div>\n  </section>\n\n  <!-- HERO PHOTO -->\n  <div class=\"hero-photo\">\n    <img src=\"https://images.unsplash.com/photo-1604542031658-5799ca5d7936?w=2400&q=80\" alt=\"batumi old town courtyard, morning light\">\n    <span class=\"cap\">\u2014 \u0421\u0442\u0430\u0440\u044b\u0439 \u0433\u043e\u0440\u043e\u0434, \u043e\u043a\u043e\u043b\u043e 9 \u0443\u0442\u0440\u0430</span>\n  </div>\n\n  <!-- LEDE -->\n  <section class=\"lede\">\n    <div class=\"inner\">\n      <p>\u0412\u044b\u0439\u0434\u0438 \u0438\u0437 <a href=\"/ru/georgia/batumi/stays/old-boulevard-loft\" style=\"color:var(--ink);border-bottom:2px solid var(--page);text-decoration:none\">\u043b\u043e\u0444\u0442\u0430 \u043d\u0430 \u0441\u0442\u0430\u0440\u043e\u043c \u0431\u0443\u043b\u044c\u0432\u0430\u0440\u0435</a>. \u041f\u043e\u0432\u0435\u0440\u043d\u0438 \u043d\u0430\u043b\u0435\u0432\u043e. <em>\u0422\u0440\u0438 \u043a\u043e\u0444\u0435</em>, \u043a\u043d\u0438\u0436\u043d\u044b\u0439, \u0434\u0432\u0435 \u0446\u0435\u0440\u043a\u0432\u0438, \u0441\u0438\u043d\u0430\u0433\u043e\u0433\u0430 \u0438 \u043e\u0431\u0435\u0434 \u0432 \u043c\u0435\u0441\u0442\u0435 \u0431\u0435\u0437 \u0432\u044b\u0432\u0435\u0441\u043a\u0438. \u0417\u0432\u0443\u0447\u0438\u0442 \u043a\u0430\u043a \u0441\u043f\u0438\u0441\u043e\u043a. \u042d\u0442\u043e \u043d\u0435 \u0441\u043f\u0438\u0441\u043e\u043a.</p>\n      <p>\u042d\u0442\u043e \u0441\u0430\u043c\u0430\u044f \u043c\u0435\u0434\u043b\u0435\u043d\u043d\u0430\u044f \u0447\u0430\u0441\u0442\u044c \u043d\u0430\u0448\u0435\u0439 \u043d\u0435\u0434\u0435\u043b\u0438. \u0422\u0435\u043b\u0435\u0444\u043e\u043d \u043d\u0435 \u0431\u0435\u0440\u0451\u043c \u2014 \u0431\u0435\u0440\u0451\u043c \u0442\u043e\u043b\u044c\u043a\u043e \u043a\u0430\u043c\u0435\u0440\u0443. \u0423 \u0443\u0442\u0440\u0430 \u0435\u0441\u0442\u044c \u0444\u043e\u0440\u043c\u0430, \u043a\u043e\u0442\u043e\u0440\u043e\u0439 \u0441\u043b\u0435\u0434\u0443\u0435\u043c \u043d\u0435\u0441\u0442\u0440\u043e\u0433\u043e \u2014 \u043a\u0430\u043a \u0441\u043b\u0435\u0434\u0443\u044e\u0442 \u0440\u0435\u0446\u0435\u043f\u0442\u0443, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0433\u043e\u0442\u043e\u0432\u0438\u043b\u0438 \u0434\u0432\u0430\u0434\u0446\u0430\u0442\u044c \u0440\u0430\u0437. \u0415\u0441\u043b\u0438 \u0442\u044b \u0443 \u043d\u0430\u0441 \u043e\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u043b\u0441\u044f \u2014 \u0434\u0432\u0435\u0440\u044c \u0443\u0436\u0435 \u0437\u043d\u0430\u0435\u0448\u044c, \u0438 \u0434\u043e \u043d\u0430\u0447\u0430\u043b\u0430 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u0430 \u0442\u0435\u0431\u0435 <b>\u0442\u0440\u0438 \u043c\u0438\u043d\u0443\u0442\u044b</b>.</p>\n    </div>\n  </section>\n\n  <!-- 09:30 \u2014 FIRST COFFEE -->\n  <section class=\"section\">\n    <div class=\"inner\">\n      <div class=\"time\">09:30 \u2014 \u043f\u0435\u0440\u0432\u044b\u0439 \u043a\u043e\u0444\u0435</div>\n      <h2>\u041d\u0430\u0447\u0438\u043d\u0430\u0435\u043c \u0432 <em>Nova</em>.</h2>\n      <p>\u0412 \u0421\u0442\u0430\u0440\u043e\u043c \u0433\u043e\u0440\u043e\u0434\u0435 \u0441 \u0434\u0435\u0441\u044f\u0442\u043e\u043a \u043c\u0435\u0441\u0442, \u0433\u0434\u0435 \u043c\u043e\u0436\u043d\u043e \u043d\u0430\u0447\u0430\u0442\u044c \u0443\u0442\u0440\u043e, \u2014 \u043c\u044b \u043f\u0435\u0440\u0435\u043f\u0440\u043e\u0431\u043e\u0432\u0430\u043b\u0438 \u0432\u0441\u0435. \u0412\u0441\u0451 \u0440\u0430\u0432\u043d\u043e \u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u043c\u0441\u044f \u0432 <b>Nova Coffee Bar</b> \u2014 \u043e\u0442\u043a\u0440\u044b\u043b\u0438 \u0431\u0435\u043b\u043e\u0440\u0443\u0441\u044b \u0432 \u043c\u0430\u0435 2022, \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0435 \u0443\u043b\u0438\u0446\u044b \u043e\u0442 \u0411\u0443\u043b\u044c\u0432\u0430\u0440\u0430. \u0411\u0430\u0440 \u043a\u043e\u0444\u0435 \u0442\u0440\u0435\u0442\u044c\u0435\u0439 \u0432\u043e\u043b\u043d\u044b \u0441 \u043c\u0435\u0434\u043d\u043e\u0439 \u043a\u043e\u0444\u0435\u043c\u043e\u043b\u043a\u043e\u0439, \u043e\u043a\u043d\u043e\u043c \u043d\u0430 \u0427\u0430\u0432\u0447\u0430\u0432\u0430\u0434\u0437\u0435 \u0438 \u0431\u0430\u0440\u0438\u0441\u0442\u043e\u0439, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0434\u0430\u0441\u0442 \u0442\u0435\u0431\u0435 \u043f\u043e\u0441\u0438\u0434\u0435\u0442\u044c \u0434\u0432\u0430 \u0447\u0430\u0441\u0430, \u0435\u0441\u043b\u0438 \u0437\u0430\u0445\u043e\u0447\u0435\u0448\u044c.</p>\n      <p>\u0423\u0442\u0440\u043e \u2014 \u044d\u0442\u043e <b>\u043f\u0443\u0440\u043e\u0432\u0435\u0440, \u043d\u0435 \u044d\u0441\u043f\u0440\u0435\u0441\u0441\u043e</b>. \u0423 \u043d\u0438\u0445 \u0435\u0441\u0442\u044c \u044d\u0444\u0438\u043e\u043f\u0438\u044f \u043c\u044b\u0442\u043e\u0439 \u043e\u0431\u0440\u0430\u0431\u043e\u0442\u043a\u0438, \u043d\u0430 \u043e\u0441\u0442\u044b\u0432\u0430\u043d\u0438\u0438 \u043f\u0430\u0445\u043d\u0435\u0442 \u0433\u0440\u0435\u0439\u043f\u0444\u0440\u0443\u0442\u043e\u043c. \u041c\u043e\u0436\u043d\u043e \u043f\u0438\u0442\u044c \u0441\u0442\u043e\u044f, \u043d\u043e \u0441\u043c\u044b\u0441\u043b \u2014 \u0432 \u0441\u043a\u0430\u043c\u0435\u0439\u043a\u0435. \u041b\u044e\u0434\u0438 \u0438\u0434\u0443\u0442 \u043d\u0430 \u0440\u0430\u0431\u043e\u0442\u0443, \u0441\u043e\u0431\u0430\u043a\u0438 \u043d\u044e\u0445\u0430\u044e\u0442 \u0442\u0432\u043e\u0438 \u043d\u043e\u0433\u0438, \u0432 \u0434\u0435\u0441\u044f\u0442\u044c \u0437\u0432\u043e\u043d\u044f\u0442 \u043a\u043e\u043b\u043e\u043a\u043e\u043b\u0430 \u043a\u0430\u0444\u0435\u0434\u0440\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0441\u043e\u0431\u043e\u0440\u0430.</p>\n      <p>\u041a\u0440\u0443\u0430\u0441\u0441\u0430\u043d \u0431\u0435\u0440\u0438 \u0442\u043e\u043b\u044c\u043a\u043e \u0435\u0441\u043b\u0438 \u043f\u044f\u0442\u043d\u0438\u0446\u0430. \u0418\u0445 \u043f\u0435\u043a\u0443\u0442 \u0441 \u0432\u0435\u0447\u0435\u0440\u0430. \u041a \u0441\u0443\u0431\u0431\u043e\u0442\u0435 \u043e\u043d\u0438 \u0441\u0442\u0430\u0440\u0430\u044e\u0442\u0441\u044f.</p>\n    </div>\n  </section>\n\n  <div class=\"inline-photo\">\n    <div class=\"inner\">\n      <img src=\"https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=2000&q=80\" alt=\"coffee on a wooden table\">\n      <div class=\"cap\">\u2014 \u043f\u0443\u0440\u043e\u0432\u0435\u0440 \u0432 Nova, \u043e\u0431\u044b\u0447\u043d\u044b\u0439 \u0432\u0442\u043e\u0440\u043d\u0438\u043a</div>\n    </div>\n  </div>\n\n  <div class=\"place-card\">\n    <div class=\"inner\">\n      <a class=\"card\" href=\"/ru/georgia/batumi/guide/nova-coffee\">\n        <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1559561853-08451507cbe7?w=600&q=80\" alt=\"\"></div>\n        <div class=\"body\">\n          <span class=\"kicker\"><span class=\"sw\"></span>\u043a\u0430\u0444\u0435 \u00b7 \u043f\u0443\u0440\u043e\u0432\u0435\u0440</span>\n          <h4>Nova Coffee</h4>\n          <p class=\"desc\">\u0431\u0430\u0440 \u043a\u043e\u0444\u0435 \u0442\u0440\u0435\u0442\u044c\u0435\u0439 \u0432\u043e\u043b\u043d\u044b \u0447\u0435\u0440\u0435\u0437 \u0434\u0432\u0435 \u0443\u043b\u0438\u0446\u044b \u043e\u0442 \u0411\u0443\u043b\u044c\u0432\u0430\u0440\u0430. \u042d\u0444\u0438\u043e\u043f\u0438\u044f, \u043a\u0440\u0443\u0430\u0441\u0441\u0430\u043d\u044b \u043f\u043e \u0432\u044b\u0445\u043e\u0434\u043d\u044b\u043c, \u0441\u0432\u0435\u0442\u043b\u044b\u0439 \u0437\u0430\u043b.</p>\n          <div class=\"meta\"><span>\u0440\u0430\u0439\u043e\u043d \u0427\u0430\u0432\u0447\u0430\u0432\u0430\u0434\u0437\u0435</span><span>\u00b7 9\u201422</span><span>\u00b7 \u224810\u201422 \u20be</span></div>\n        </div>\n      </a>\n    </div>\n  </div>\n\n  <!-- 10:30 \u2014 BOOKSTORE -->\n  <section class=\"section\">\n    <div class=\"inner\">\n      <div class=\"time\">10:30 \u2014 \u043a\u043d\u0438\u0436\u043d\u044b\u0439</div>\n      <h2>\u041f\u043e\u044d\u0437\u0438\u044f, \u043f\u043e\u0441\u0442\u0435\u0440\u044b, <em>\u0438 \u043d\u0438\u043a\u043e\u0433\u043e \u0431\u043e\u043b\u044c\u0448\u0435</em>.</h2>\n      <p>\u0427\u0435\u0440\u0435\u0437 \u0434\u0432\u0435 \u0443\u043b\u0438\u0446\u044b, \u0437\u0430 \u0434\u043e\u043c\u043e\u043c \u0441 \u0441\u0438\u043d\u0438\u043c \u0431\u0430\u043b\u043a\u043e\u043d\u043e\u043c, \u0435\u0441\u0442\u044c \u043a\u043d\u0438\u0436\u043d\u044b\u0439 \u0431\u0435\u0437 \u0432\u044b\u0432\u0435\u0441\u043a\u0438. \u041d\u0430\u0439\u0442\u0438 \u0435\u0433\u043e \u043c\u043e\u0436\u043d\u043e \u043f\u043e \u043e\u0442\u043a\u0440\u044b\u0442\u043a\u0430\u043c, \u043f\u0440\u0438\u043b\u0435\u043f\u043b\u0435\u043d\u043d\u044b\u043c \u0438\u0437\u043d\u0443\u0442\u0440\u0438 \u0432\u0438\u0442\u0440\u0438\u043d\u044b \u2014 \u0447\u0451\u0440\u043d\u043e-\u0431\u0435\u043b\u044b\u0435 \u0444\u043e\u0442\u043e\u0433\u0440\u0430\u0444\u0438\u0438 \u0411\u0430\u0442\u0443\u043c\u0438 \u0441\u0435\u043c\u0438\u0434\u0435\u0441\u044f\u0442\u044b\u0445, \u043a\u043e\u0433\u0434\u0430 \u0437\u0434\u0435\u0441\u044c \u043d\u0438\u043a\u043e\u0433\u043e \u043d\u0435 \u0431\u044b\u043b\u043e.</p>\n      <p>\u0425\u043e\u0437\u044f\u0438\u043d \u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442 \u0442\u0440\u0438 \u0434\u043d\u044f \u0432 \u043d\u0435\u0434\u0435\u043b\u044e. \u041f\u043e\u044d\u0437\u0438\u0438 \u0431\u043e\u043b\u044c\u0448\u0435, \u0447\u0435\u043c \u043f\u0440\u043e\u0437\u044b, \u0440\u0443\u0441\u0441\u043a\u043e\u0433\u043e \u0431\u043e\u043b\u044c\u0448\u0435, \u0447\u0435\u043c \u0430\u043d\u0433\u043b\u0438\u0439\u0441\u043a\u043e\u0433\u043e, \u0438 \u043d\u0435\u0431\u043e\u043b\u044c\u0448\u043e\u0439, \u043d\u043e \u0441\u0435\u0440\u044c\u0451\u0437\u043d\u044b\u0439 \u0433\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u0438\u0439 \u043e\u0442\u0434\u0435\u043b \u0441\u0437\u0430\u0434\u0438. \u0423 \u043d\u0435\u0433\u043e \u0435\u0441\u0442\u044c <b>\u0410\u043d\u043d\u0438 \u042d\u0440\u043d\u043e \u043d\u0430 \u0434\u0432\u0443\u0445 \u044f\u0437\u044b\u043a\u0430\u0445</b> \u0438 \u043f\u043e\u043b\u043d\u043e\u0435 \u0441\u043e\u0431\u0440\u0430\u043d\u0438\u0435 \u041e\u043a\u0443\u0434\u0436\u0430\u0432\u044b \u043d\u0430 \u043a\u0430\u0441\u0441\u0435\u0442\u0430\u0445.</p>\n      <p>\u0411\u0435\u0437 \u0447\u0435\u0433\u043e-\u0442\u043e \u043d\u0438\u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u0443\u0445\u043e\u0434\u0438\u043c. \u0412 \u043f\u0440\u043e\u0448\u043b\u044b\u0439 \u0440\u0430\u0437 \u2014 \u0441\u0431\u043e\u0440\u043d\u0438\u043a \u043d\u043e\u0432\u044b\u0445 \u0433\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u0438\u0445 \u043f\u043e\u044d\u0442\u043e\u0432 \u0432 \u043f\u0435\u0440\u0435\u0432\u043e\u0434\u0435 \u0447\u0435\u043b\u043e\u0432\u0435\u043a\u0430, \u043e \u043a\u043e\u0442\u043e\u0440\u043e\u043c \u043c\u044b \u043d\u0438\u043a\u043e\u0433\u0434\u0430 \u043d\u0435 \u0441\u043b\u044b\u0448\u0430\u043b\u0438, \u0442\u0438\u0440\u0430\u0436 400 \u044d\u043a\u0437\u0435\u043c\u043f\u043b\u044f\u0440\u043e\u0432. \u0422\u0430\u043a \u0442\u0443\u0442 \u0432\u0441\u0451 \u0443\u0441\u0442\u0440\u043e\u0435\u043d\u043e.</p>\n    </div>\n  </section>\n\n  <!-- 11:30 \u2014 CHURCHES -->\n  <section class=\"section\">\n    <div class=\"inner\">\n      <div class=\"time\">11:30 \u2014 \u0434\u0432\u0435 \u0446\u0435\u0440\u043a\u0432\u0438</div>\n      <h2>\u041f\u0440\u043e\u0445\u043b\u0430\u0434\u043d\u044b\u0439 \u043a\u0430\u043c\u0435\u043d\u044c,<br/>\u0431\u0435\u0437 <em>\u0442\u0443\u0440\u0438\u0441\u0442\u043e\u0432</em>.</h2>\n      <p>\u0412 \u0421\u0442\u0430\u0440\u043e\u043c \u0411\u0430\u0442\u0443\u043c\u0438 \u2014 \u043c\u0430\u043b\u0435\u043d\u044c\u043a\u043e\u0435 \u0447\u0443\u0434\u043e \u0440\u0435\u043b\u0438\u0433\u0438\u043e\u0437\u043d\u043e\u0439 \u0442\u0435\u0440\u043f\u0438\u043c\u043e\u0441\u0442\u0438. \u0427\u0435\u0442\u044b\u0440\u0435 \u043a\u043e\u043d\u0444\u0435\u0441\u0441\u0438\u0438 \u0432 \u043f\u044f\u0442\u0438 \u043c\u0438\u043d\u0443\u0442\u0430\u0445 \u0445\u043e\u0434\u044c\u0431\u044b. \u041a\u0430\u0442\u043e\u043b\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0441\u043e\u0431\u043e\u0440 \u043d\u0430 \u0427\u0430\u0432\u0447\u0430\u0432\u0430\u0434\u0437\u0435, \u0430\u0440\u043c\u044f\u043d\u0441\u043a\u0430\u044f \u0446\u0435\u0440\u043a\u043e\u0432\u044c \u0447\u0435\u0440\u0435\u0437 \u043a\u0432\u0430\u0440\u0442\u0430\u043b, \u043f\u0440\u0430\u0432\u043e\u0441\u043b\u0430\u0432\u043d\u044b\u0439 \u0445\u0440\u0430\u043c \u0441 \u0437\u0435\u043b\u0451\u043d\u044b\u043c \u043a\u0443\u043f\u043e\u043b\u043e\u043c \u0438 \u0441\u0438\u043d\u0430\u0433\u043e\u0433\u0430 \u0437\u0430 \u0443\u0433\u043b\u043e\u043c \u043e\u0442 \u0431\u0430\u0437\u0430\u0440\u0430.</p>\n      <p>\u041e\u0431\u044b\u0447\u043d\u043e \u0437\u0430\u0445\u043e\u0434\u0438\u043c \u0432 \u0434\u0432\u0435 \u2014 \u043a\u0430\u0442\u043e\u043b\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0440\u0430\u0434\u0438 \u0432\u0438\u0442\u0440\u0430\u0436\u0435\u0439, \u0430\u0440\u043c\u044f\u043d\u0441\u043a\u0438\u0439 \u0440\u0430\u0434\u0438 \u0434\u0432\u043e\u0440\u0430. \u0414\u0432\u043e\u0440 \u2014 \u044d\u0442\u043e \u0432\u0435\u0441\u044c \u0441\u043c\u044b\u0441\u043b. \u0418\u043d\u0436\u0438\u0440\u043d\u043e\u0435 \u0434\u0435\u0440\u0435\u0432\u043e, \u043d\u0438\u0437\u043a\u0430\u044f \u043a\u0430\u043c\u0435\u043d\u043d\u0430\u044f \u0441\u043a\u0430\u043c\u044c\u044f \u0438 \u043a\u043e\u0442, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0442\u0443\u0442 \u0436\u0438\u0432\u0451\u0442. <b>\u0422\u0435\u0431\u044f \u043d\u0438\u043a\u0442\u043e \u043d\u0435 \u0442\u0440\u043e\u0433\u0430\u0435\u0442.</b> \u0412 \u0430\u0432\u0433\u0443\u0441\u0442\u0435 \u044d\u0442\u043e \u0441\u0430\u043c\u043e\u0435 \u043f\u0440\u043e\u0445\u043b\u0430\u0434\u043d\u043e\u0435 \u043c\u0435\u0441\u0442\u043e \u0432 \u0411\u0430\u0442\u0443\u043c\u0438 \u2014 \u0438 \u043f\u043e \u0442\u0435\u043c\u043f\u0435\u0440\u0430\u0442\u0443\u0440\u0435, \u0438 \u043f\u043e \u043e\u0449\u0443\u0449\u0435\u043d\u0438\u044e.</p>\n    </div>\n  </section>\n\n  <div class=\"photo-row\">\n    <div class=\"inner\">\n      <img src=\"https://images.unsplash.com/photo-1604542031658-5799ca5d7936?w=900&q=80\" alt=\"\">\n      <img src=\"https://images.unsplash.com/photo-1502672023488-70e25813eb80?w=900&q=80\" alt=\"\">\n      <img src=\"https://images.unsplash.com/photo-1505691938895-1758d7feb511?w=900&q=80\" alt=\"\">\n    </div>\n  </div>\n\n  <!-- 12:00 \u2014 SYNAGOGUE -->\n  <section class=\"section\">\n    <div class=\"inner\">\n      <div class=\"time\">12:00 \u2014 \u0441\u0438\u043d\u0430\u0433\u043e\u0433\u0430</div>\n      <h2>\u0421\u0430\u043c\u0430\u044f \u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0430\u044f \u0432 <em>\u0413\u0440\u0443\u0437\u0438\u0438</em>.</h2>\n      <p>\u0412 \u043f\u044f\u0442\u0438 \u043c\u0438\u043d\u0443\u0442\u0430\u0445 \u043e\u0442 \u043f\u0440\u0430\u0432\u043e\u0441\u043b\u0430\u0432\u043d\u043e\u0439 \u0431\u0430\u0437\u0438\u043b\u0438\u043a\u0438, \u043d\u0430 \u0443\u043b\u0438\u0446\u0435, \u0447\u044c\u0451 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u0435 \u043c\u044b \u043a\u0430\u0436\u0434\u044b\u0439 \u0440\u0430\u0437 \u0437\u0430\u0431\u044b\u0432\u0430\u0435\u043c, \u0441\u0442\u043e\u0438\u0442 \u0441\u0430\u043c\u0430\u044f \u043c\u0430\u043b\u0435\u043d\u044c\u043a\u0430\u044f \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u044e\u0449\u0430\u044f \u0441\u0438\u043d\u0430\u0433\u043e\u0433\u0430 \u0432 \u0413\u0440\u0443\u0437\u0438\u0438. \u041e\u043d\u0430 \u043c\u0435\u043d\u044c\u0448\u0435, \u0447\u0435\u043c \u043d\u0430\u0448\u0430 \u0433\u043e\u0441\u0442\u0438\u043d\u0430\u044f. \u041d\u0443\u0436\u043d\u043e \u043f\u043e\u0437\u0432\u043e\u043d\u0438\u0442\u044c \u0432 \u0437\u0432\u043e\u043d\u043e\u043a.</p>\n      <p>\u0420\u0430\u0432\u0432\u0438\u043d \u043f\u0443\u0441\u0442\u0438\u0442, \u0435\u0441\u043b\u0438 \u043d\u0435 \u043d\u0430 \u043e\u0431\u0435\u0434\u0435. \u0414\u0435\u0440\u0435\u0432\u044f\u043d\u043d\u044b\u0435 \u0441\u043a\u0430\u043c\u044c\u0438, \u043f\u043e\u0442\u043e\u043b\u043e\u0447\u043d\u044b\u0435 \u0431\u0430\u043b\u043a\u0438, \u0432\u044b\u043a\u0440\u0430\u0448\u0435\u043d\u043d\u044b\u0435 \u0432 \u0441\u0438\u043d\u0438\u0439, \u0438 \u043a\u0440\u043e\u0448\u0435\u0447\u043d\u0430\u044f, \u043d\u043e \u0441\u0435\u0440\u044c\u0451\u0437\u043d\u0430\u044f \u0431\u0438\u0431\u043b\u0438\u043e\u0442\u0435\u043a\u0430. <b>\u0413\u043e\u0432\u043e\u0440\u0438\u0442 \u043d\u0430 \u0447\u0435\u0442\u044b\u0440\u0451\u0445 \u044f\u0437\u044b\u043a\u0430\u0445</b> \u0438 \u043f\u043e\u043c\u043d\u0438\u0442 \u0432\u0441\u0435\u0445, \u043a\u0442\u043e \u043a\u043e\u0433\u0434\u0430-\u043b\u0438\u0431\u043e \u0437\u0430\u0445\u043e\u0434\u0438\u043b. \u0415\u0441\u043b\u0438 \u0432 \u043f\u0440\u043e\u0448\u043b\u044b\u0439 \u0440\u0430\u0437 \u0442\u044b \u0431\u044b\u043b \u0441 \u0434\u0440\u0443\u0433\u043e\u043c \u2014 \u0441\u043f\u0440\u043e\u0441\u0438\u0442 \u043e \u043d\u0451\u043c.</p>\n    </div>\n  </section>\n\n  <!-- 13:00 \u2014 LUNCH -->\n  <section class=\"section\">\n    <div class=\"inner\">\n      <div class=\"time\">13:00 \u2014 \u043e\u0431\u0435\u0434</div>\n      <h2>\u041c\u0435\u0441\u0442\u043e <em>\u0431\u0435\u0437 \u0432\u044b\u0432\u0435\u0441\u043a\u0438</em>.</h2>\n      <p>\u0417\u0430 \u0443\u0433\u043b\u043e\u043c \u043e\u0442 \u0441\u0438\u043d\u0430\u0433\u043e\u0433\u0438, \u0432\u043e \u0434\u0432\u043e\u0440\u0435, \u0447\u0435\u0440\u0435\u0437 \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043d\u0430\u0434\u043e \u043f\u0440\u043e\u0439\u0442\u0438 \u043f\u043e\u0434 \u0447\u044c\u0438\u043c-\u0442\u043e \u0431\u0435\u043b\u044c\u0451\u043c \u043d\u0430 \u0432\u0435\u0440\u0451\u0432\u043a\u0435 \u2014 \u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d. \u0423 \u043d\u0435\u0433\u043e \u043d\u0435\u0442 \u043d\u0430\u0437\u0432\u0430\u043d\u0438\u044f. \u041d\u0435\u0442 \u0432\u044b\u0432\u0435\u0441\u043a\u0438. \u0415\u0441\u0442\u044c \u0437\u0435\u043b\u0451\u043d\u0430\u044f \u0434\u0432\u0435\u0440\u044c \u0438 \u043d\u0430\u0440\u0438\u0441\u043e\u0432\u0430\u043d\u043d\u0430\u044f \u043e\u0442 \u0440\u0443\u043a\u0438 \u0442\u0430\u0431\u043b\u0438\u0447\u043a\u0430 <i>\u00ab\u043e\u0442\u043a\u0440\u044b\u0442\u043e\u00bb</i>, \u043a\u043e\u0433\u0434\u0430 \u043e\u0442\u043a\u0440\u044b\u0442\u043e.</p>\n      <p>\u0422\u0440\u0438 \u0441\u0442\u043e\u043b\u0430 \u0432\u043d\u0443\u0442\u0440\u0438, \u0447\u0435\u0442\u044b\u0440\u0435 \u0441\u043d\u0430\u0440\u0443\u0436\u0438 \u043f\u043e\u0434 \u0432\u0438\u043d\u043e\u0433\u0440\u0430\u0434\u043d\u043e\u0439 \u0431\u0435\u0441\u0435\u0434\u043a\u043e\u0439. \u041c\u0435\u043d\u044e \u2014 \u0443\u0441\u0442\u043d\u043e\u0435. <b>\u041f\u043e\u0432\u0430\u0440 \u2014 \u043e\u043d\u0430 \u0436\u0435 \u0445\u043e\u0437\u044f\u0439\u043a\u0430, \u043e\u0444\u0438\u0446\u0438\u0430\u043d\u0442\u043a\u0430 \u0438 \u043a\u0430\u0441\u0441\u0438\u0440.</b> \u0415\u0451 \u0437\u043e\u0432\u0443\u0442 \u0414\u0430\u043b\u0438, \u0435\u0439 \u043e\u043a\u043e\u043b\u043e \u0441\u0435\u043c\u0438\u0434\u0435\u0441\u044f\u0442\u0438, \u0438 \u043e\u043d\u0430 \u0433\u043e\u0442\u043e\u0432\u0438\u0442 \u043e\u0434\u043d\u0443 \u0432\u0435\u0449\u044c \u0438\u0434\u0435\u0430\u043b\u044c\u043d\u043e: \u0447\u0430\u043a\u0430\u043f\u0443\u043b\u0438 \u0432\u0435\u0441\u043d\u043e\u0439, \u0447\u0430\u0448\u0443\u0448\u0443\u043b\u0438 \u043e\u0441\u0435\u043d\u044c\u044e \u0438 \u0430\u0434\u0436\u0430\u0440\u0441\u043a\u0438\u0439 \u0445\u0430\u0447\u0430\u043f\u0443\u0440\u0438 \u043a\u0440\u0443\u0433\u043b\u044b\u0439 \u0433\u043e\u0434.</p>\n      <p>\u0422\u043e\u043b\u044c\u043a\u043e \u043d\u0430\u043b\u0438\u0447\u043d\u044b\u0435. \u041d\u0435 \u0441\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0439 \u0432\u0430\u0439\u0444\u0430\u0439. \u0415\u0433\u043e \u043d\u0435\u0442. \u0412 \u044d\u0442\u043e\u043c \u0438 \u0441\u043c\u044b\u0441\u043b.</p>\n    </div>\n  </section>\n\n  <div class=\"inline-photo\">\n    <div class=\"inner\">\n      <img src=\"https://images.unsplash.com/photo-1561758033-d89a9ad46330?w=2000&q=80\" alt=\"adjarian khachapuri\">\n      <div class=\"cap\">\u2014 \u0445\u0430\u0447\u0430\u043f\u0443\u0440\u0438 \u0443 \u0414\u0430\u043b\u0438, \u0436\u0435\u043b\u0442\u043a\u0430 \u043f\u043e\u0447\u0442\u0438 \u0447\u0442\u043e \u0441\u043b\u0438\u0448\u043a\u043e\u043c</div>\n    </div>\n  </div>\n\n  <div class=\"place-card\">\n    <div class=\"inner\">\n      <a class=\"card\" href=\"/ru/georgia/batumi/guide/dalis-place\">\n        <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1565958011703-44f9829ba187?w=600&q=80\" alt=\"\"></div>\n        <div class=\"body\">\n          <span class=\"kicker\"><span class=\"sw\"></span>\u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d \u00b7 \u0433\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u0430\u044f</span>\n          <h4>\u0423 \u0414\u0430\u043b\u0438 (\u0431\u0435\u0437 \u0432\u044b\u0432\u0435\u0441\u043a\u0438)</h4>\n          <p class=\"desc\">\u0442\u0440\u0438 \u0441\u0442\u043e\u043b\u0430, \u043e\u0434\u0438\u043d \u043f\u043e\u0432\u0430\u0440, \u0443\u0441\u0442\u043d\u043e\u0435 \u043c\u0435\u043d\u044e. \u0425\u0430\u0447\u0430\u043f\u0443\u0440\u0438, \u0447\u0430\u043a\u0430\u043f\u0443\u043b\u0438, \u0447\u0430\u0448\u0443\u0448\u0443\u043b\u0438. \u0422\u043e\u043b\u044c\u043a\u043e \u043d\u0430\u043b\u0438\u0447\u043d\u044b\u0435.</p>\n          <div class=\"meta\"><span>\u0421\u0442\u0430\u0440\u044b\u0439 \u0433\u043e\u0440\u043e\u0434</span><span>\u00b7 13\u201416, 19\u201422</span><span>\u00b7 \u224825\u201440 \u20be</span></div>\n        </div>\n      </a>\n    </div>\n  </div>\n\n  <!-- MAP -->\n  <section class=\"map-wrap\">\n    <div class=\"inner\">\n      <div class=\"head-row\">\n        <h3>\u041c\u0430\u0440\u0448\u0440\u0443\u0442,<br/><em>\u043d\u0430 \u043a\u0430\u0440\u0442\u0435</em>.</h3>\n        <div class=\"right\">\u043f\u0440\u0438\u043c\u0435\u0440\u043d\u043e <b>1.6 \u043a\u043c \u043f\u0435\u0448\u043a\u043e\u043c</b>, \u043e\u0447\u0435\u043d\u044c \u043c\u0435\u0434\u043b\u0435\