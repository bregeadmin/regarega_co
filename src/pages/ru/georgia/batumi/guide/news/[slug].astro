---
import SiteRu from '../../../../../../layouts/SiteRu.astro';
import { supabase } from '../../../../../../lib/supabase';
import { GUIDE_CATS } from '../../../../../../lib/guideCats';

const CAT = Object.fromEntries(Object.entries(GUIDE_CATS).map(([k, v]) => [k, { color: v.color, label: v.label.ru }]));

export async function getStaticPaths() {
  const { data: gp } = await supabase
    .from('guide_places')
    .select('slug,title,name,category,photos,image')
    .eq('status', 'published');
  const { data: news } = await supabase
    .from('news').select('*').eq('status', 'published').order('date', { ascending: false });
  const pmap: Record<string, any> = {};
  (gp || []).forEach((p: any) => { pmap[p.slug] = p; });
  return (news || []).map((n: any) => ({
    params: { slug: n.slug },
    props: { n, place: n.place ? (pmap[n.place] || null) : null },
  }));
}

const { n, place } = Astro.props as { n: any; place: any };
// русский контент с откатом на английский, если RU-поля не заданы
const nt = n.title_ru || n.title;
const nd = n.descr_ru || n.descr;
const nb = n.body_ru || n.body;
const esc = (s: any) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const RUMO = ['янв', 'фев', 'мар', 'апр', 'мая', 'июн', 'июл', 'авг', 'сен', 'окт', 'ноя', 'дек'];
const fmtDate = (d: string) => { const m = (d || '').match(/(\d{4})-(\d{2})-(\d{2})/); if (!m) return ''; return (+m[3]) + ' ' + RUMO[+m[2] - 1] + ' ' + m[1]; };
const rawPhotos = (n.photos && n.photos.length) ? n.photos : (n.image ? [n.image] : []);
const _seen = new Set<string>();
const photos = rawPhotos.filter((src: string) => {
  if (/___12\.png/.test(src)) return false;
  const base = String(src).split('/').pop() || src;
  if (_seen.has(base)) return false;
  _seen.add(base); return true;
});
const mdInline = (raw: string) => esc(raw).replace(/\*\*([^*]+)\*\*/g, '<b>$1</b>').replace(/\*([^*]+)\*/g, '<em>$1</em>');
const bodyHtml = String(nb || nd || '').split(/\n+/).map((x: string) => x.trim()).filter(Boolean).map((x: string) => '<p>' + mdInline(x) + '</p>').join('');
const galleryHtml = photos.slice(1).map((src: string) => '<button class="g" type="button"><img src="' + esc(src) + '" alt="" loading="lazy"></button>').join('');

const words = String(nb || nd || '').split(/\s+/).filter(Boolean).length;
const mins = Math.max(1, Math.round(words / 90));

let placeHtml = '';
if (place) {
  const pc = CAT[place.category] || { color: '#ff5e1a', label: place.category };
  const pName = place.title || place.name || place.slug;
  const pPhoto = (place.photos && place.photos.length) ? place.photos[0] : (place.image || '');
  placeHtml =
    '<a class="place-card" href="/ru/georgia/batumi/guide/' + esc(place.slug) + '" style="--pc:' + pc.color + '">' +
      (pPhoto ? '<div class="pc-ph"><img src="' + esc(pPhoto) + '" alt="" loading="lazy"></div>' : '') +
      '<div class="pc-body">' +
        '<div class="pc-eyebrow">место · ' + esc(pc.label) + '</div>' +
        '<h4>' + esc(pName) + '</h4>' +
        '<span class="pc-go">открыть в гиде →</span>' +
      '</div>' +
    '</a>';
}

const content =
  '<article class="news-article">' +
    '<div class="crumbs"><a href="/ru/georgia/batumi/guide/">гид</a><span class="sep">/</span><a href="/ru/georgia/batumi/guide#news">новости</a><span class="sep">/</span><span class="cur">' + esc(String(nt).slice(0, 30)) + '…</span></div>' +
    '<div class="eyebrow"><span class="tag">● новости</span>' + (fmtDate(n.date) ? '<span class="when">' + esc(fmtDate(n.date)) + '</span>' : '') + '</div>' +
    '<h1>' + esc(nt) + '</h1>' +
    (nd ? '<p class="lead">' + mdInline(nd) + '</p>' : '') +
    '<div class="byline"><span>команда rega rega</span><span class="sep"></span><span>' + mins + ' мин чтения</span></div>' +
    (photos[0] ? '<div class="hero"><img src="' + esc(photos[0]) + '" alt=""></div>' : '') +
    '<div class="body">' + bodyHtml + '</div>' +
    placeHtml +
    (galleryHtml ? '<div class="gallery">' + galleryHtml + '</div>' : '') +
    '<a class="back" href="/ru/georgia/batumi/guide#news">← ещё из гида</a>' +
  '</article>';
---
<SiteRu title={String(nt).slice(0, 60) + ' — новости — rega rega batumi'} description={nd || ''} ogTitle={String(nt).toLowerCase() + ' — rega rega batumi'} ogDescription="" image={`/og/news-${n.slug}-ru.png`} ogType="article">
<style is:inline set:html={".news-article{max-width:780px;margin:0 auto;padding:120px 24px 96px}\n.news-article .crumbs{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-soft);font-weight:500;display:flex;gap:10px;align-items:center;margin-bottom:28px}\n.news-article .crumbs a:hover{color:var(--ink)}\n.news-article .crumbs .sep{opacity:.4}\n.news-article .crumbs .cur{color:var(--page-deep);font-weight:700;background:var(--accent-soft);padding:5px 11px;border-radius:999px;display:inline-flex;align-items:center}\n.news-article .eyebrow{display:flex;align-items:center;gap:14px;margin-bottom:18px}\n.news-article .eyebrow .tag{display:inline-flex;align-items:center;gap:7px;background:var(--accent);color:#FAF7F0;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;font-weight:700;padding:6px 13px;border-radius:999px}\n.news-article .eyebrow .when{font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-soft);font-weight:600}\n.news-article h1{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(30px,4.5vw,52px);line-height:1.04;letter-spacing:-.035em;text-transform:lowercase;margin-bottom:20px}\n.news-article .lead{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(19px,2.1vw,24px);line-height:1.4;font-weight:500;color:var(--ink);margin-bottom:22px}\n.news-article .lead em{font-style:italic;color:var(--accent)}\n.news-article .byline{display:flex;align-items:center;gap:12px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-soft);font-weight:600;margin-bottom:34px}\n.news-article .byline .sep{width:4px;height:4px;border-radius:50%;background:var(--ink-soft);opacity:.5}\n.news-article .hero{border-radius:16px;overflow:hidden;aspect-ratio:16/10;background:var(--bg-2);margin-bottom:32px;cursor:zoom-in}\n.news-article .hero img{width:100%;height:100%;object-fit:cover}\n.news-article .body p{font-size:19px;line-height:1.65;color:var(--ink);margin-bottom:18px}\n.news-article .body b{font-weight:700;color:var(--ink)}\n.news-article .body em{font-style:italic;color:var(--accent)}\n.news-article .place-card{display:flex;gap:18px;align-items:center;margin:40px 0 8px;padding:16px;border:1px solid var(--line);border-radius:16px;background:var(--paper);transition:border-color .2s ease,transform .2s ease,box-shadow .2s ease}\n.news-article .place-card:hover{border-color:var(--pc);transform:translateY(-2px);box-shadow:0 10px 28px rgba(10,9,8,.08)}\n.news-article .place-card .pc-ph{width:96px;height:96px;border-radius:12px;overflow:hidden;flex:none;background:var(--bg-2)}\n.news-article .place-card .pc-ph img{width:100%;height:100%;object-fit:cover}\n.news-article .place-card .pc-eyebrow{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;font-weight:700;color:var(--pc);margin-bottom:7px}\n.news-article .place-card h4{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(20px,2.4vw,26px);letter-spacing:-.02em;line-height:1.05;text-transform:lowercase;color:var(--ink);margin-bottom:9px}\n.news-article .place-card .pc-go{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;font-weight:600;color:var(--ink-soft)}\n.news-article .place-card:hover .pc-go{color:var(--pc)}\n.news-article .gallery{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:38px}\n.news-article .gallery .g{aspect-ratio:4/3;border:0;padding:0;border-radius:12px;overflow:hidden;background:var(--bg-2);cursor:zoom-in;transition:transform .2s ease}\n.news-article .gallery .g:first-child{grid-column:1 / -1;aspect-ratio:16/8}\n.news-article .gallery .g:hover{transform:translateY(-2px)}\n.news-article .gallery .g img{width:100%;height:100%;object-fit:cover;display:block}\n.news-article .back{display:inline-flex;margin-top:52px;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;font-weight:600;color:var(--ink);border-bottom:1px solid var(--ink);padding-bottom:4px}\n.news-article .back:hover{color:var(--accent);border-color:var(--accent)}\n.gx-lb{position:fixed;inset:0;z-index:200;background:rgba(10,9,8,.9);backdrop-filter:blur(6px);display:none;align-items:center;justify-content:center;touch-action:pan-y}\n.gx-lb.on{display:flex}\n.gx-stage{margin:0;display:flex;align-items:center;justify-content:center;max-width:92vw;max-height:88vh}\n.gx-img{max-width:92vw;max-height:88vh;border-radius:12px;box-shadow:0 24px 60px rgba(0,0,0,.5);user-select:none;-webkit-user-drag:none}\n.gx-nav{position:absolute;top:50%;transform:translateY(-50%);width:52px;height:52px;border-radius:50%;border:0;background:rgba(255,255,255,.14);color:#FAF7F0;font-size:30px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s ease}\n.gx-nav:hover{background:rgba(255,255,255,.28)}\n.gx-prev{left:18px}\n.gx-next{right:18px}\n.gx-close{position:absolute;top:18px;right:18px;width:44px;height:44px;border-radius:50%;border:0;background:rgba(255,255,255,.14);color:#FAF7F0;font-size:24px;cursor:pointer;z-index:2;display:flex;align-items:center;justify-content:center}\n.gx-close:hover{background:rgba(255,255,255,.28)}\n.gx-count{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);color:#FAF7F0;font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.18em;background:rgba(0,0,0,.4);padding:6px 14px;border-radius:999px}\n@media(max-width:880px){.gx-nav{width:44px;height:44px;font-size:26px}.gx-prev{left:8px}.gx-next{right:8px}}\n@media(max-width:880px){.news-article{padding:90px 16px 64px}.news-article .place-card{gap:14px;padding:13px}.news-article .place-card .pc-ph{width:76px;height:76px}}"}></style>
<Fragment set:html={content} />
<script is:inline>
(function () {
  var tiles = [].slice.call(document.querySelectorAll('.news-article .hero, .news-article .gallery .g'));
  var srcs = tiles.map(function (t) { var i = t.querySelector('img'); return i ? i.src : ''; }).filter(Boolean);
  if (!srcs.length) return;
  var ov = document.createElement('div'); ov.className = 'gx-lb';
  ov.innerHTML = '<button class="gx-close" type="button" aria-label="close">×</button>' +
    '<button class="gx-nav gx-prev" type="button" aria-label="previous">‹</button>' +
    '<figure class="gx-stage"><img class="gx-img" alt=""></figure>' +
    '<button class="gx-nav gx-next" type="button" aria-label="next">›</button>' +
    '<div class="gx-count"></div>';
  document.body.appendChild(ov);
  var im = ov.querySelector('.gx-img'), cnt = ov.querySelector('.gx-count'), i = 0;
  function show(n) { i = (n + srcs.length) % srcs.length; im.src = srcs[i]; cnt.textContent = (i + 1) + ' / ' + srcs.length; }
  function open(n) { show(n); ov.classList.add('on'); document.documentElement.style.overflow = 'hidden'; }
  function close() { ov.classList.remove('on'); document.documentElement.style.overflow = ''; }
  tiles.forEach(function (t, idx) { t.addEventListener('click', function (e) { e.preventDefault(); open(idx); }); });
  ov.querySelector('.gx-prev').addEventListener('click', function (e) { e.stopPropagation(); show(i - 1); });
  ov.querySelector('.gx-next').addEventListener('click', function (e) { e.stopPropagation(); show(i + 1); });
  ov.querySelector('.gx-close').addEventListener('click', close);
  ov.addEventListener('click', function (e) { if (e.target === ov || e.target.classList.contains('gx-stage')) close(); });
  document.addEventListener('keydown', function (e) { if (!ov.classList.contains('on')) return; if (e.key === 'Escape') close(); else if (e.key === 'ArrowLeft') show(i - 1); else if (e.key === 'ArrowRight') show(i + 1); });
  var x0 = null, y0 = 0, drag = false;
  ov.addEventListener('touchstart', function (e) { x0 = e.touches[0].clientX; y0 = e.touches[0].clientY; drag = false; im.style.transition = 'none'; }, { passive: true });
  ov.addEventListener('touchmove', function (e) {
    if (x0 === null) return;
    var dx = e.touches[0].clientX - x0, dy = e.touches[0].clientY - y0;
    if (!drag) { if (Math.abs(dx) < 6 && Math.abs(dy) < 6) return; if (Math.abs(dy) > Math.abs(dx)) { x0 = null; return; } drag = true; }
    e.preventDefault();
    im.style.transform = 'translateX(' + dx + 'px)';
    im.style.opacity = String(Math.max(0.35, 1 - Math.abs(dx) / 700));
  }, { passive: false });
  ov.addEventListener('touchend', function (e) {
    if (x0 === null) return;
    var dx = e.changedTouches[0].clientX - x0;
    if (Math.abs(dx) > Math.min(110, window.innerWidth * 0.16)) { im.style.transition = 'none'; im.style.transform = ''; im.style.opacity = '1'; show(i + (dx < 0 ? 1 : -1)); }
    else { im.style.transition = 'transform .2s ease, opacity .2s ease'; im.style.transform = 'translateX(0)'; im.style.opacity = '1'; }
    x0 = null;
  }, { passive: false });
})();
</script>
</SiteRu>
