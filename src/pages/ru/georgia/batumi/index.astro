---
import SiteRu from '../../../../layouts/SiteRu.astro';
import HomeIntro from '../../../../components/HomeIntro.astro';
import { mapTeaserHTML } from '../../../../lib/homeTeaser';
import { supabase, applyNames, type Apartment } from '../../../../lib/supabase';
const { data } = await supabase.from('apartments_public').select('id,slug,title,title_ru,bedrooms,max_guests,price_from,photos,neighborhood').limit(6);
const apts = ((data as Apartment[]) || []).map(applyNames);
const pl = (n: number, one: string, few: string, many: string) => { const m=n%100,d=n%10; if(m>=11&&m<=14) return many; if(d===1) return one; if(d>=2&&d<=4) return few; return many; };
const homeApts = apts.map((a) => {
  const photo = (a.photos && a.photos[0]) || `https://picsum.photos/seed/${a.slug}/1200/900`;
  const bedType = a.bedrooms === 0 ? 'студия' : `${a.bedrooms ?? 1} ${pl(a.bedrooms ?? 1,'спальня','спальни','спален')}`;
  const price = a.price_from ? `₾${a.price_from}<span class="u">/НОЧЬ</span>` : `<span style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.04em">по запросу</span>`;
  const dist = a.neighborhood ? `<span class="dist">${a.neighborhood}</span>` : '';
  return `<a class="apt reveal" href="/ru/georgia/batumi/stays/${a.slug}"><div class="ph"><img src="${photo}" alt="${a.title_ru || a.title}"/><button class="fav" type="button" aria-label="в избранное">♡</button></div><div class="info"><div class="top"><h4>${a.title_ru || a.title}</h4><div class="price">${price}</div></div><div class="sub"><span>${bedType} · ${a.max_guests ?? 2} ${pl(a.max_guests ?? 2,'гость','гостя','гостей')}</span>${dist}</div></div></a>`;
}).join('');
const mapTeaser = mapTeaserHTML({ href: '/ru/georgia/batumi/guide#map', label: 'карта · батуми', cta: 'открыть карту', aria: 'открыть карту-гид по батуми' });
---
<SiteRu title="rega rega \u2014 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b \u0438 \u0433\u0430\u0439\u0434 \u043f\u043e \u0431\u0430\u0442\u0443\u043c\u0438">
<HomeIntro />
<Fragment set:html={"<section class=\"hero\">\n  <a class=\"hero-main\" href=\"/ru/georgia/batumi/stays\" aria-label=\"\u0432\u0441\u0435 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b\">\n    <img src=\"https://images.unsplash.com/photo-1502672023488-70e25813eb80?w=2000&q=80\" alt=\"\u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430 bre\" onerror=\"this.src='https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=2000&q=80'\"/>\n    <h1 class=\"hero-h1\">\n      \u041d\u0430\u0439\u0434\u0438 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0443.<br/>\n      <span class=\"row2\"><em>\u0412\u043b\u044e\u0431\u0438\u0441\u044c</em> \u0432 \u0433\u043e\u0440\u043e\u0434.</span>\n    </h1>\n  </a>\n\n  <div class=\"hero-side\">\n    " + mapTeaser + "\n    <div class=\"hero-card edition\" id=\"heroEdition\">\n      <a class=\"ed-slide active\" href=\"/ru/georgia/batumi/guide/pure-bistro-oyster-weekend\"><img src=\"https://images.unsplash.com/photo-1559561853-08451507cbe7?w=900&q=80\" alt=\"\"/><div class=\"ed-no\">Гайд по Батуми · на этой неделе</div><h4>Устричный <em>уикенд</em><br/>в Pure Bistro, 08–10/05.</h4><div class=\"ed-foot\"><span><b>Читать →</b></span><span>↗</span></div></a>\n      <a class=\"ed-slide\" href=\"/ru/georgia/batumi/guide/kava-lova-popup\"><img src=\"https://images.unsplash.com/photo-1551782450-a2132b4ba21d?w=900&q=80\" alt=\"\"/><div class=\"ed-no\">Гайд по Батуми · на этой неделе</div><h4>Коктейльный <em>поп-ап</em><br/>в Kava Lova, 15/05.</h4><div class=\"ed-foot\"><span><b>Читать →</b></span><span>↗</span></div></a>\n    </div>\n  </div>\n</section>\n\n<section class=\"pad\" id=\"stays\">\n  <div class=\"section-head reveal\">\n    <div>\n      <div class=\"meta\"><span class=\"dot\"></span>\u2014 01 / \u0441\u0432\u043e\u0431\u043e\u0434\u043d\u043e \u0441\u0435\u0439\u0447\u0430\u0441</div>\n      <h2 style=\"margin-top:18px\">\u041e\u0441\u0442\u0430\u043d\u043e\u0432\u0438\u0441\u044c<br/>\u0443 <em>\u043d\u0430\u0441</em>.</h2>\n    </div>\n    <div class=\"right\"><b>\u041a\u0432\u0430\u0440\u0442\u0438\u0440\u044b \u043f\u043e \u0432\u0441\u0435\u043c\u0443 \u0411\u0430\u0442\u0443\u043c\u0438.</b> \u0427\u0435\u0441\u0442\u043d\u043e\u0435 \u0444\u043e\u0442\u043e, \u0447\u0435\u0441\u0442\u043d\u0430\u044f \u0446\u0435\u043d\u0430, \u0432\u0441\u0451 \u0447\u0442\u043e \u0437\u0430\u0431\u044b\u043b \u0432\u0437\u044f\u0442\u044c \u0441 \u0441\u043e\u0431\u043e\u0439 \u2014 \u0443\u0436\u0435 \u043d\u0430 \u043c\u0435\u0441\u0442\u0435. \u041a \u043a\u0430\u0436\u0434\u043e\u0439 \u2014 \u0441\u0432\u043e\u0439 \u043c\u0438\u043d\u0438-\u0433\u0430\u0439\u0434.</div>\n  </div>\n\n  <div class=\"apts\">" + homeApts + "</div>\n\n  <div class=\"more\"><a href=\"/ru/georgia/batumi/stays\">\u0412\u0441\u0435 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b \u2192</a></div>\n</section>\n\n<section class=\"spread\">\n  <img src=\"/img/hero-batumi.jpg\" alt=\"\u0441\u0442\u0430\u0440\u044b\u0439 \u0433\u043e\u0440\u043e\u0434 \u0431\u0430\u0442\u0443\u043c\u0438\"/>\n  <div class=\"inner\">\n    <h2>\u0422\u043e\u0442 \u0411\u0430\u0442\u0443\u043c\u0438,<br/>\u0447\u0442\u043e \u043c\u044b <em>\u043f\u0440\u0430\u0432\u0434\u0430</em><br/>\u0441\u043e\u0432\u0435\u0442\u0443\u0435\u043c.</h2>\n    <p class=\"lede\">\u041d\u0430\u0448 \u0433\u0438\u0434 \u043f\u043e \u0433\u043e\u0440\u043e\u0434\u0443 \u2014 \u043f\u0438\u0448\u0435\u043c \u0441\u0430\u043c\u0438, \u043d\u0435 \u0442\u0430\u0441\u043a\u0430\u0435\u043c \u0441 TripAdvisor. \u041a\u0430\u0444\u0435, \u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d\u044b, \u043f\u043b\u044f\u0436\u0438, \u0432\u0435\u043b\u043d\u0435\u0441, \u043d\u043e\u0447\u043d\u0430\u044f \u0436\u0438\u0437\u043d\u044c \u2014 \u0441\u043e\u0431\u0440\u0430\u043d\u043e \u043f\u043e \u0442\u043e\u043c\u0443, \u0433\u0434\u0435 \u043f\u0440\u0430\u0432\u0434\u0430 \u0445\u043e\u0447\u0435\u0442\u0441\u044f \u043f\u0440\u043e\u0432\u0435\u0441\u0442\u0438 \u0432\u0435\u0447\u0435\u0440.</p>\n    <div class=\"spread-cta\">\n      <a class=\"btn\" href=\"/ru/georgia/batumi/guide\">\u041e\u0442\u043a\u0440\u044b\u0442\u044c \u0433\u0430\u0439\u0434 \u2192</a>\n    </div>\n  </div>\n</section>\n\n<section class=\"guide-wrap\" id=\"guide\">\n  <div class=\"section-head reveal\">\n    <div>\n      <div class=\"meta\"><span class=\"dot\"></span>\u2014 \u0432 \u044d\u0442\u043e\u043c \u0432\u044b\u043f\u0443\u0441\u043a\u0435</div>\n    </div>\n    <div class=\"right\">\u041f\u043e\u0434\u0431\u043e\u0440\u043a\u0430 \u0438\u0437 <b>\u0432\u043e\u0441\u044c\u043c\u0438 \u0440\u0430\u0437\u0434\u0435\u043b\u043e\u0432</b>. \u0411\u043e\u043b\u044c\u0448\u0435 \u0441\u043e\u0442\u043d\u0438 \u043c\u0435\u0441\u0442, \u043e\u0442\u043e\u0431\u0440\u0430\u043d\u043d\u044b\u0445 \u0432\u0440\u0443\u0447\u043d\u0443\u044e.</div>\n  </div>\n\n  <div class=\"guide-categories\">\n    <div class=\"cat reveal\">\n      <div class=\"cat-head\">\n        <h3>\u0415\u0441\u0442\u044c \u0438 <em>\u043f\u0438\u0442\u044c</em></h3>\n        <span class=\"count\">42 \u043c\u0435\u0441\u0442\u0430</span>\n      </div>\n      <a class=\"feat\" href=\"/ru/georgia/batumi/guide/nova-coffee\">\n        <div class=\"ph\">\n          <img src=\"https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=1000&q=80\" alt=\"\"/>\n          <span class=\"tag\">\u043a\u043e\u0444\u0435</span>\n        </div>\n        <div class=\"body\">\n          <span class=\"kicker\">\u0435\u0441\u0442\u044c \u0438 \u043f\u0438\u0442\u044c \u00b7 3 \u043c\u0438\u043d \u0447\u0438\u0442\u0430\u0442\u044c</span>\n          <h4>Nova Coffee \u2014 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0430\u044f \u0441\u043f\u0435\u0448\u0435\u043b\u0442\u0438 \u0432 \u0433\u043e\u0440\u043e\u0434\u0435</h4>\n          <p>\u0421\u0432\u0435\u0442\u043b\u044b\u0439 \u0437\u0430\u043b, \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0430\u044f \u044d\u0441\u043f\u0440\u0435\u0441\u0441\u043e-\u043c\u0430\u0448\u0438\u043d\u0430, \u0437\u0451\u0440\u043d\u0430 \u0441\u0432\u0435\u0436\u0435\u0439 \u043e\u0431\u0436\u0430\u0440\u043a\u0438. \u041c\u043e\u0436\u043d\u043e \u0441\u0438\u0434\u0435\u0442\u044c \u0438 \u0447\u0438\u0442\u0430\u0442\u044c \u0447\u0430\u0441\u0430\u043c\u0438.</p>\n        </div>\n      </a>\n      <div class=\"cat-posts\">\n        <a class=\"post\" href=\"/ru/georgia/batumi/guide/milevski-coffee\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1559561853-08451507cbe7?w=400&q=80\" alt=\"\"/></div>\n          <div class=\"body\"><span class=\"kicker\">\u043a\u043e\u0444\u0435</span><h4>Milevski Coffee \u2014 \u043f\u0443\u0440\u043e\u0432\u0435\u0440 \u0438 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u044f</h4></div>\n        </a>\n        <a class=\"post\" href=\"/ru/georgia/batumi/guide/japan-33\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=400&q=80\" alt=\"\"/></div>\n          <div class=\"body\"><span class=\"kicker\">\u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d</span><h4>Japan 33 \u2014 \u0437\u0430\u043a\u0430\u0442\u043d\u044b\u0435 \u0443\u0436\u0438\u043d\u044b \u043d\u0430\u0434 \u043c\u043e\u0440\u0435\u043c</h4></div>\n        </a>\n      </div>\n    </div>\n\n    <div class=\"cat reveal\">\n      <div class=\"cat-head\">\n        <h3>\u041a\u0430\u043a <em>\u043f\u0435\u0440\u0435\u0434\u0432\u0438\u0433\u0430\u0442\u044c\u0441\u044f</em></h3>\n        <span class=\"count\">12 \u0442\u0435\u043a\u0441\u0442\u043e\u0432</span>\n      </div>\n      <a class=\"feat\" href=\"/ru/georgia/batumi/guide/bolt-taxi\">\n        <div class=\"ph\">\n          <img src=\"https://images.unsplash.com/photo-1502920514313-52581002a659?w=1000&q=80\" alt=\"\"/>\n          <span class=\"tag\">\u043a\u0430\u043a</span>\n        </div>\n        <div class=\"body\">\n          <span class=\"kicker\">\u043f\u0435\u0440\u0435\u0434\u0432\u0438\u0436\u0435\u043d\u0438\u0435 \u00b7 4 \u043c\u0438\u043d \u0447\u0438\u0442\u0430\u0442\u044c</span>\n          <h4>Bolt \u0442\u0430\u043a\u0441\u0438 \u2014 \u043a\u0430\u043a \u0438\u043c \u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c\u0441\u044f \u0432 \u0411\u0430\u0442\u0443\u043c\u0438</h4>\n          <p>\u041c\u0435\u0441\u0442\u043d\u044b\u0439 Uber. 3 \u0442\u0430\u043f\u0430, \u043e\u043f\u043b\u0430\u0442\u0430 \u043a\u0430\u0440\u0442\u043e\u0439, \u043e\u0442 \u0421\u0442\u0430\u0440\u043e\u0433\u043e \u0433\u043e\u0440\u043e\u0434\u0430 \u0434\u043e \u0413\u043e\u043d\u0438\u043e \u2014 \u043c\u0435\u043d\u044c\u0448\u0435 10 \u043b\u0430\u0440\u0438.</p>\n        </div>\n      </a>\n      <div class=\"cat-posts\">\n        <a class=\"post\" href=\"/ru/georgia/batumi/guide/airport-transfer\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=400&q=80\" alt=\"\"/></div>\n          <div class=\"body\"><span class=\"kicker\">\u043a\u0430\u043a</span><h4>\u0418\u0437 \u0430\u044d\u0440\u043e\u043f\u043e\u0440\u0442\u0430 \u2014 \u0442\u0440\u0438 \u0441\u043f\u043e\u0441\u043e\u0431\u0430, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0440\u0435\u0430\u043b\u044c\u043d\u043e \u0440\u0430\u0431\u043e\u0442\u0430\u044e\u0442</h4></div>\n        </a>\n        <a class=\"post\" href=\"/ru/georgia/batumi/guide/marshrutkas\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1473445730015-841f29a9490b?w=400&q=80\" alt=\"\"/></div>\n          <div class=\"body\"><span class=\"kicker\">\u043a\u0430\u043a</span><h4>\u041c\u0430\u0440\u0448\u0440\u0443\u0442\u043a\u0438 \u2014 \u043a\u0430\u043a \u0440\u0430\u0437\u043e\u0431\u0440\u0430\u0442\u044c\u0441\u044f \u0432 \u043c\u0435\u0441\u0442\u043d\u043e\u043c \u043c\u0438\u043d\u0438-\u0430\u0432\u0442\u043e\u0431\u0443\u0441\u0435</h4></div>\n        </a>\n      </div>\n    </div>\n\n    <div class=\"cat reveal\">\n      <div class=\"cat-head\">\n        <h3><em>\u0412\u0435\u043b\u043d\u0435\u0441</em></h3>\n        <span class=\"count\">18 \u043c\u0435\u0441\u0442</span>\n      </div>\n      <a class=\"feat\" href=\"/ru/georgia/batumi/guide/pure-bistro-oyster-weekend\">\n        <div class=\"ph\">\n          <img src=\"https://images.unsplash.com/photo-1559561853-08451507cbe7?w=1000&q=80\" alt=\"\"/>\n          <span class=\"tag news\">\u043d\u043e\u0432\u043e\u0441\u0442\u044c \u00b7 07/05</span>\n        </div>\n        <div class=\"body\">\n          <span class=\"kicker\">\u043d\u043e\u0432\u043e\u0441\u0442\u044c \u00b7 \u0432 \u044d\u0442\u0443 \u0441\u0443\u0431\u0431\u043e\u0442\u0443</span>\n          <h4>Pure Bistro \u2014 \u0443\u0441\u0442\u0440\u0438\u0447\u043d\u044b\u0439 \u0443\u0438\u043a\u0435\u043d\u0434, 08\u201310/05</h4>\n          <p>\u0421\u0432\u0435\u0436\u0438\u0435 \u0443\u0441\u0442\u0440\u0438\u0446\u044b, \u043a\u0430\u0432\u0430 \u0438 \u043a\u0440\u0435\u043c\u0430\u043d \u0432 \u043e\u0434\u043d\u043e\u043c \u0438\u0437 \u043d\u0430\u0448\u0438\u0445 \u043b\u044e\u0431\u0438\u043c\u044b\u0445 \u043c\u0435\u0441\u0442 \u0434\u043b\u044f \u0431\u0440\u0430\u043d\u0447\u0430 \u0438 \u0443\u0436\u0438\u043d\u0430 \u0432 \u0411\u0430\u0442\u0443\u043c\u0438.</p>\n        </div>\n      </a>\n      <div class=\"cat-posts\">\n        <a class=\"post\" href=\"/ru/georgia/batumi/guide/kava-lova-popup\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1551782450-a2132b4ba21d?w=400&q=80\" alt=\"\"/></div>\n          <div class=\"body\"><span class=\"kicker\">\u043d\u043e\u0432\u043e\u0441\u0442\u044c \u00b7 13/05</span><h4>15/05 \u043a\u043e\u043a\u0442\u0435\u0439\u043b\u044c\u043d\u044b\u0439 \u043f\u043e\u043f-\u0430\u043f \u0432 Kava Lova \u0441 \u0412\u0430\u043d\u0435\u0439</h4></div>\n        </a>\n        <a class=\"post\" href=\"/ru/georgia/batumi/guide/botanical-garden-may\">\n          <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1530631673369-bc20fdb32288?w=400&q=80\" alt=\"\"/></div>\n          <div class=\"body\"><span class=\"kicker\">\u0444\u043e\u0442\u043e-\u044d\u0441\u0441\u0435</span><h4>\u0411\u043e\u0442\u0430\u043d\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0441\u0430\u0434, \u0432 \u043c\u0430\u0435</h4></div>\n        </a>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"now\">\n  <div class=\"now-grid\">\n    <div>\n      <div class=\"now-label\"><span class=\"pulse\"></span>\u041f\u0440\u044f\u043c\u043e \u0441\u0435\u0439\u0447\u0430\u0441 \u0432 \u0411\u0430\u0442\u0443\u043c\u0438</div>\n      <div class=\"now-val\"><span id=\"nowDate\">\u0441\u0435\u0433\u043e\u0434\u043d\u044f</span><span class=\"small\" id=\"nowDesc\">\u0441\u043c\u043e\u0442\u0440\u0438\u043c \u0432 \u043d\u0435\u0431\u043e\u2026</span></div>\n    </div>\n    <div>\n      <div class=\"now-label\">\u0422\u0435\u043c\u043f\u0435\u0440\u0430\u0442\u0443\u0440\u0430</div>\n      <div class=\"now-val\"><span id=\"nowTemp\">\u2014</span><em>\u00b0</em>C<span class=\"small\" id=\"nowWind\">\u043b\u0451\u0433\u043a\u0438\u0439 \u0431\u0440\u0438\u0437 \u0441 \u043c\u043e\u0440\u044f</span></div>\n    </div>\n    <div>\n      <div class=\"now-label\">\u0417\u0430\u043a\u0430\u0442</div>\n      <div class=\"now-val\" id=\"nowSunset\">\u2014:\u2014<span class=\"small\">\u043d\u0430\u0434 \u0427\u0451\u0440\u043d\u044b\u043c \u043c\u043e\u0440\u0435\u043c</span></div>\n    </div>\n    <div>\n      <div class=\"now-label\">\u0418\u0437 \u0433\u0430\u0439\u0434\u0430</div>\n      <div class=\"now-val\"><a href=\"/ru/georgia/batumi/guide/pure-bistro-oyster-weekend\">\u0423\u0441\u0442\u0440\u0438\u0447\u043d\u044b\u0439 \u0443\u0438\u043a\u0435\u043d\u0434</a><span class=\"small\">\u2192 Pure Bistro, \u0441\u0431\u2013\u0432\u0441</span></div>\n    </div>\n  </div>\n</section>\n\n<section class=\"pull\">\n  <blockquote class=\"reveal\">\n    \u0421 \u043d\u0430\u0441 \u2014<br/><span class=\"underline\"><em>\u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430</em></span>.<br/>\u0421 \u0442\u0435\u0431\u044f \u2014<br/><span class=\"underline\"><em>\u0433\u043e\u0440\u043e\u0434</em></span>.\n  </blockquote>\n  <div class=\"sig\">\u2014 bre, \u0411\u0430\u0442\u0443\u043c\u0438</div>\n</section>\n\n<section class=\"doors-wrap\" id=\"own\">\n  <div class=\"section-head reveal\">\n    <div>\n      <div class=\"meta\"><span class=\"dot\"></span>\u2014 \u043d\u0435 \u0437\u0430 \u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435\u043c?</div>\n      <h2 style=\"margin-top:18px\">\u041f\u043e\u043c\u043e\u0433\u0430\u0435\u043c <em>\u043a\u0443\u043f\u0438\u0442\u044c</em><br/>\u0438 <em>\u0443\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u043c</em> \u043f\u043e\u0442\u043e\u043c.</h2>\n    </div>\n    <div class=\"right\">\u0415\u0441\u043b\u0438 \u0443 \u0442\u0435\u0431\u044f \u0435\u0441\u0442\u044c \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430 \u0432 \u0411\u0430\u0442\u0443\u043c\u0438 \u2014 \u0438\u043b\u0438 \u0442\u044b \u0442\u043e\u043b\u044c\u043a\u043e \u0434\u0443\u043c\u0430\u0435\u0448\u044c \u0435\u0451 \u043a\u0443\u043f\u0438\u0442\u044c \u2014 \u0440\u0430\u0441\u0441\u043a\u0430\u0436\u0438. \u041c\u044b \u0443\u0436\u0435 <b>120+ \u0440\u0430\u0437</b> \u0447\u0435\u0440\u0435\u0437 \u044d\u0442\u043e \u043f\u0440\u043e\u0448\u043b\u0438.</div>\n  </div>\n\n  <div class=\"doors\">\n    <a class=\"door reveal\" href=\"/ru/georgia/batumi/own\">\n      <div>\n        <div class=\"num\">i. \u0421\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a\u0430\u043c</div>\n        <h3>\u041f\u0440\u043e\u0441\u0442\u043e \u043f\u0435\u0440\u0435\u0434\u0430\u0439 \u043d\u0430\u043c<br/><em>\u043a\u043b\u044e\u0447\u0438</em>.</h3>\n        <p>\u041f\u043e\u043b\u043d\u044b\u0439 \u0441\u0435\u0440\u0432\u0438\u0441 \u043f\u043e\u0441\u0443\u0442\u043e\u0447\u043d\u043e\u0439 \u0438 \u0441\u0440\u0435\u0434\u043d\u0435\u0441\u0440\u043e\u0447\u043d\u043e\u0439 \u0430\u0440\u0435\u043d\u0434\u044b. 30% \u043a\u043e\u043c\u0438\u0441\u0441\u0438\u044f \u2014 \u0432\u0441\u0451 \u0432\u043a\u043b\u044e\u0447\u0435\u043d\u043e. \u0413\u043e\u0441\u0442\u0438 \u043d\u0430 5 \u044f\u0437\u044b\u043a\u0430\u0445, \u0444\u043e\u0442\u043e, \u0433\u0438\u0431\u043a\u0438\u0435 \u0446\u0435\u043d\u044b, \u0443\u0431\u043e\u0440\u043a\u0430, \u0432\u0441\u0451 \u043e\u0441\u0442\u0430\u043b\u044c\u043d\u043e\u0435.</p>\n      </div>\n      <div>\n        <div class=\"stat\"><b>30%</b><span>\u043a\u043e\u043c\u0438\u0441\u0441\u0438\u044f \u00b7 \u0432\u0441\u0451 \u0432\u043a\u043b\u044e\u0447\u0435\u043d\u043e</span></div>\n        <span class=\"cta\">\u041a\u0430\u043a \u044d\u0442\u043e \u0443\u0441\u0442\u0440\u043e\u0435\u043d\u043e <span>\u2192</span></span>\n      </div>\n    </a>\n\n    <a class=\"door reveal\" href=\"/ru/georgia/batumi/invest\" id=\"invest\">\n      <div>\n        <div class=\"num\">ii. \u0418\u043d\u0432\u0435\u0441\u0442\u043e\u0440\u0430\u043c</div>\n        <h3>\u041a\u0443\u043f\u0438 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0443,<br/>\u043a\u043e\u0442\u043e\u0440\u0430\u044f <em>\u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442</em>.</h3>\n        <p>\u041d\u0430\u0445\u043e\u0434\u0438\u043c \u043b\u0443\u0447\u0448\u0438\u0435 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b, \u0434\u0435\u043b\u0430\u0435\u043c \u0440\u0435\u043c\u043e\u043d\u0442, \u0432\u044b\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u043c, \u0443\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u043c. \u0422\u044b \u0432\u0438\u0434\u0438\u0448\u044c \u0446\u0438\u0444\u0440\u044b \u2014 \u043d\u0435 \u0441\u0442\u0440\u0435\u0441\u0441. \u0421\u0440\u0435\u0434\u043d\u044f\u044f \u0447\u0438\u0441\u0442\u0430\u044f \u0434\u043e\u0445\u043e\u0434\u043d\u043e\u0441\u0442\u044c \u043f\u043e \u043d\u0430\u0448\u0435\u043c\u0443 \u043f\u043e\u0440\u0442\u0444\u0435\u043b\u044e.</p>\n      </div>\n      <div>\n        <div class=\"stat\"><b>11%</b><span>\u0433\u043e\u0434\u043e\u0432\u0430\u044f \u0434\u043e\u0445\u043e\u0434\u043d\u043e\u0441\u0442\u044c \u00b7 \u0432 \u0441\u0440\u0435\u0434\u043d\u0435\u043c</span></div>\n        <span class=\"cta\">\u0414\u0430\u0432\u0430\u0439 \u043f\u043e\u0433\u043e\u0432\u043e\u0440\u0438\u043c <span>\u2192</span></span>\n      </div>\n    </a>\n  </div>\n</section>\n\n<section class=\"contact\" id=\"contact\">\n  <h2 class=\"reveal\">\u041d\u0430\u043f\u0438\u0448\u0438<br/><em>\u043f\u0440\u0438\u0432\u0435\u0442</em>.</h2>\n\n  <div class=\"channels reveal\">\n    <a class=\"channel\" href=\"https://t.me/bre_ge\"><span class=\"label\">\u0422\u0435\u043b\u0435\u0433\u0440\u0430\u043c</span><span class=\"value\">@bre_ge</span><span class=\"ar\">\u2192</span></a>\n    <a class=\"channel\" href=\"#\"><span class=\"label\">WhatsApp</span><span class=\"value\">+49 176 596 981 64</span><span class=\"ar\">\u2192</span></a>\n    <a class=\"channel\" href=\"tel:+995585889601\"><span class=\"label\">\u0422\u0435\u043b\u0435\u0444\u043e\u043d</span><span class=\"value\">+995 585 889 601</span><span class=\"ar\">\u2192</span></a>\n    <a class=\"channel\" href=\"https://t.me/batumirealflats\"><span class=\"label\">\u041a\u0430\u043d\u0430\u043b</span><span class=\"value\">t.me/batumirealflats</span><span class=\"ar\">\u2192</span></a>\n    <div class=\"channel\"><span class=\"label\">\u041e\u0444\u0438\u0441</span><span class=\"value\">\u0411\u0430\u0442\u0443\u043c\u0438, \u0413\u0440\u0443\u0437\u0438\u044f</span><span class=\"ar\">\u2014 41.6\u00b0N 41.6\u00b0E</span></div>\n  </div>\n</section>\n\n<section class=\"footer-guide\">\n  <div class=\"footer-guide-head\">\n    <h4>\u041d\u0430 \u043f\u0440\u043e\u0448\u043b\u043e\u0439 \u043d\u0435\u0434\u0435\u043b\u0435<br/>\u043c\u044b <em>\u043f\u0438\u0441\u0430\u043b\u0438</em> \u2193</h4>\n    <a href=\"/ru/georgia/batumi/guide\" class=\"all\">\u0412\u0441\u0435 100+ \u0442\u0435\u043a\u0441\u0442\u043e\u0432 \u2192</a>\n  </div>\n  <div class=\"footer-posts\">\n    <a class=\"fp\" href=\"/ru/georgia/batumi/guide/pure-bistro-oyster-weekend\">\n      <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1559561853-08451507cbe7?w=300&q=80\" alt=\"\"/></div>\n      <div class=\"body\">\n        <div class=\"kicker\">\u043d\u043e\u0432\u043e\u0441\u0442\u044c \u00b7 07/05</div>\n        <h5>\u0423\u0441\u0442\u0440\u0438\u0447\u043d\u044b\u0439 \u0443\u0438\u043a\u0435\u043d\u0434 \u0432 Pure Bistro, 08\u201310/05</h5>\n      </div>\n    </a>\n    <a class=\"fp\" href=\"/ru/georgia/batumi/guide/kava-lova-popup\">\n      <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1551782450-a2132b4ba21d?w=300&q=80\" alt=\"\"/></div>\n      <div class=\"body\">\n        <div class=\"kicker\">\u043d\u043e\u0432\u043e\u0441\u0442\u044c \u00b7 13/05</div>\n        <h5>15/05 \u043a\u043e\u043a\u0442\u0435\u0439\u043b\u044c\u043d\u044b\u0439 \u043f\u043e\u043f-\u0430\u043f \u0432 Kava Lova \u0441 \u0412\u0430\u043d\u0435\u0439</h5>\n      </div>\n    </a>\n    <a class=\"fp\" href=\"/ru/georgia/batumi/guide/japan-33\">\n      <div class=\"ph\"><img src=\"https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=300&q=80\" alt=\"\"/></div>\n      <div class=\"body\">\n        <div class=\"kicker\">\u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d \u00b7 \u043d\u043e\u0432\u043e\u0435</div>\n        <h5>Japan 33 \u2014 \u0437\u0430\u043a\u0430\u0442\u043d\u044b\u0435 \u0443\u0436\u0438\u043d\u044b \u043d\u0430\u0434 \u043c\u043e\u0440\u0435\u043c</h5>\n      </div>\n    </a>\n  </div>\n</section>" } />
