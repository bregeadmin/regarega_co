---
import SiteRu from '../../../../layouts/SiteRu.astro';
import HomeIntro from '../../../../components/HomeIntro.astro';
import { mapTeaserHTML } from '../../../../lib/homeTeaser';
import { supabase, applyNames, type Apartment } from '../../../../lib/supabase';
import { priceShort } from '../../../../lib/price';
const { data } = await supabase.from('apartments_public').select('id,slug,title,title_ru,bedrooms,max_guests,price_from,price_currency,photos,neighborhood').limit(6);
const apts = ((data as Apartment[]) || []).map(applyNames);
const pl = (n: number, one: string, few: string, many: string) => { const m = n % 100, d = n % 10; if (m >= 11 && m <= 14) return many; if (d === 1) return one; if (d >= 2 && d <= 4) return few; return many; };
const homeApts = apts.map((a) => {
  const photo = (a.photos && a.photos[0]) || `https://picsum.photos/seed/${a.slug}/1200/900`;
  const bedType = a.bedrooms === 0 ? 'студия' : `${a.bedrooms ?? 1} ${pl(a.bedrooms ?? 1, 'спальня', 'спальни', 'спален')}`;
  const price = a.price_from ? `${priceShort(a)}<span class="u">/НОЧЬ</span>` : `<span style="font-size:13px;font-weight:700;text-transform:uppercase;letter-spacing:.04em">по запросу</span>`;
  const dist = a.neighborhood ? `<span class="dist">${a.neighborhood}</span>` : '';
  return `<a class="apt reveal" href="/ru/georgia/batumi/stays/${a.slug}"><div class="ph"><img src="${photo}" alt="${a.title_ru || a.title}"/><button class="fav" type="button" aria-label="в избранное">♡</button></div><div class="info"><div class="top"><h4>${a.title_ru || a.title}</h4><div class="price">${price}</div></div><div class="sub"><span>${bedType} · ${a.max_guests ?? 2} ${pl(a.max_guests ?? 2, 'гость', 'гостя', 'гостей')}</span>${dist}</div></div></a>`;
}).join('');

// --- данные гида для главной (из базы) ---
const { data: gpData } = await supabase.from('guide_places')
  .select('slug,title,name,category,tags,photos,image,take_title,summary').eq('status', 'published');
const places = (gpData as any[]) || [];
const { data: newsData } = await supabase.from('news').select('*').eq('status', 'published').order('date', { ascending: false });
const news = newsData || [];
const counts: Record<string, number> = {};
places.forEach((p) => { counts[p.category] = (counts[p.category] || 0) + 1; });
const e2 = (s: any) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const md2 = (s: any) => e2(s).replace(/\*([^*]+)\*/g, '<em>$1</em>');
const gph = (p: any) => (p && ((p.photos && p.photos[0]) || p.image)) || '';
const clip2 = (s: any, n: number) => { const t = String(s || '').replace(/\s+/g, ' ').replace(/\*\*?/g, '').trim(); return t.length > n ? t.slice(0, n).replace(/[ ,;:.]+\S*$/, '') + '…' : t; };
const byCat = (c: string) => places.filter((p) => p.category === c);
const fmtDM = (d: string) => { const m = (d || '').match(/(\d{4})-(\d{2})-(\d{2})/); return m ? (m[3] + '/' + m[2]) : ''; };
const CATLBL: Record<string, string> = { 'eat-drink': 'есть и пить', 'wellness': 'велнес', 'work': 'работа', 'move-around': 'как передвигаться' };
const newsArr = (news as any[]).slice().sort((a, b) => String(b.date || '').localeCompare(String(a.date || '')));
const ed = newsArr[0];

const edSlides = newsArr.filter((n: any) => n.on_home !== false).slice(0, 6);
const heroEdition = edSlides.length
  ? '<div class="hero-card edition" id="heroEdition">' + edSlides.map((n, i) =>
      '<a class="ed-slide' + (i === 0 ? ' active' : '') + '" href="/ru/georgia/batumi/guide/news/' + n.slug + '"><img src="' + e2(n.image || '') + '" alt=""/>' +
      '<div class="ed-no">гайд по батуми · свежее</div><h4>' + md2(n.headline_ru || n.headline || n.title_ru || n.title) + '</h4>' +
      '<div class="ed-foot"><span><b>читать выпуск</b></span><span>↗</span></div></a>'
    ).join('') + '</div>'
  : '';

const PLACE_COLOR: Record<string, string> = { 'eat-drink': '#3A4868', 'wellness': '#1F8A5B' };
const thumb = (u: string) => '/_vercel/image?url=' + encodeURIComponent(u) + '&w=320&q=72';
const flatCands = apts.filter((a) => a.photos && a.photos[0]).slice(0, 6).map((a) => ({
  n: a.title_ru || a.title, s: priceShort(a) ? `квартира · ${priceShort(a)}` : 'по запросу',
  p: thumb(a.photos[0]), h: `/ru/georgia/batumi/stays/${a.slug}`, c: '#FF5E1A',
}));
const placeCands = places.filter((p) => PLACE_COLOR[p.category] && gph(p)).slice(0, 6).map((p) => ({
  n: p.title || p.name, s: CATLBL[p.category] || p.category,
  p: thumb(gph(p)), h: `/ru/georgia/batumi/guide/${p.slug}`, c: PLACE_COLOR[p.category],
}));
const mapTeaser = mapTeaserHTML({ href: '/ru/georgia/batumi/guide#map', label: 'карта · батуми', cta: 'открыть карту', aria: 'открыть карту-гид по батуми', flatCands, placeCands });

const catCol = (key: string, h3: string) => {
  const list = byCat(key); if (!list.length) return '';
  const feat = list[0], posts = list.slice(1, 3);
  const tag = (p: any) => (p.tags && p.tags[0]) ? e2(p.tags[0]) : (CATLBL[key] || key);
  const featHtml = '<a class="feat" href="/ru/georgia/batumi/guide/' + feat.slug + '"><div class="ph"><img src="' + e2(gph(feat)) + '" alt=""/><span class="tag">' + tag(feat) + '</span></div>' +
    '<div class="body"><span class="kicker">' + (CATLBL[key] || key) + '</span><h4>' + e2(feat.title || feat.name) + '</h4><p>' + e2(clip2(feat.summary || feat.take_title, 92)) + '</p></div></a>';
  const postsHtml = posts.map((p) => '<a class="post" href="/ru/georgia/batumi/guide/' + p.slug + '"><div class="ph"><img src="' + e2(gph(p)) + '" alt=""/></div><div class="body"><span class="kicker">' + tag(p) + '</span><h4>' + e2(p.title || p.name) + '</h4></div></a>').join('');
  return '<div class="cat reveal"><div class="cat-head"><h3>' + h3 + '</h3><span class="count">' + (counts[key] || 0) + ' мест</span></div>' + featHtml + '<div class="cat-posts">' + postsHtml + '</div></div>';
};
const guideCats = catCol('eat-drink', 'есть и <em>пить</em>') + catCol('wellness', '<em>велнес</em>') + catCol('move-around', 'как <em>передвигаться</em>');

const nowGuide = ed
  ? '<a href="/ru/georgia/batumi/guide/news/' + ed.slug + '">' + e2(clip2(ed.title_ru || ed.title, 26)) + '</a><span class="small">→ свежее из батуми</span>'
  : '<a href="/ru/georgia/batumi/guide">открыть гайд</a><span class="small">→ ' + places.length + ' мест</span>';

const footPlace = byCat('eat-drink')[0];
const footItems = newsArr.slice(0, 2).map((n) => ({ href: '/ru/georgia/batumi/guide/news/' + n.slug, ph: e2(n.image || ''), kick: 'новость · ' + fmtDM(n.date), title: e2(n.title_ru || n.title) }))
  .concat(footPlace ? [{ href: '/ru/georgia/batumi/guide/' + footPlace.slug, ph: e2(gph(footPlace)), kick: 'есть и пить', title: e2(footPlace.title || footPlace.name) }] : []);
const footPosts = footItems.map((it) => '<a class="fp" href="' + it.href + '"><div class="ph"><img src="' + it.ph + '" alt=""/></div><div class="body"><div class="kicker">' + it.kick + '</div><h5>' + it.title + '</h5></div></a>').join('');
---
<SiteRu title={'rega rega — квартиры и гайд по батуми'}>
<HomeIntro />
<Fragment set:html={'<section class="hero">\n  <div class="hero-main">\n    <a class="hero-main-img" href="/ru/georgia/batumi/stays" aria-label="все квартиры">\n      <img src="https://images.unsplash.com/photo-1502672023488-70e25813eb80?w=2000&q=80" alt="квартира bre" onerror="this.src=\'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=2000&q=80\'"/>\n    </a>\n    <h1 class="hero-h1">\n      найди квартиру,<br/>\n      <span class="row2"><em>влюбись</em> в город</span>\n    </h1>\n    <form class="hero-search" id="heroSearch" onsubmit="return submitHeroSearch(event)">\n      <button type="button" class="hs-field" id="hsDateBtn">\n        <span class="hs-lbl">— даты</span>\n        <span class="hs-val" id="hsDateVal">добавить даты</span>\n      </button>\n      <button type="button" class="hs-field" id="hsGuestBtn">\n        <span class="hs-lbl">— гости</span>\n        <span class="hs-val" id="hsGuestVal">2 гостя</span>\n      </button>\n      <button type="submit" class="hs-submit" aria-label="искать">\n        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>\n      </button>\n    </form>\n  </div>\n\n  <div class="hero-side">\n    ' + mapTeaser + '\n    ' + heroEdition + '\n  </div>\n</section>\n\n<section class="pad" id="stays">\n  <div class="section-head reveal">\n    <div>\n      <div class="meta"><span class="dot"></span>— 01 / свободно сейчас</div>\n      <h2 style="margin-top:18px">остановись<br/>у <em>нас</em>.</h2>\n    </div>\n    <div class="right"><b>квартиры по всему батуми</b>. честное фото, честная цена, всё что забыл взять с собой — уже на месте. к каждой — свой мини-гид.</div>\n  </div>\n\n  <div class="apts">' + homeApts + '</div>\n\n  <div class="more"><a href="/ru/georgia/batumi/stays">все квартиры →</a></div>\n</section>\n\n<section class="spread">\n  <img src="/img/hero-batumi.jpg" alt="старый город батуми"/>\n  <div class="inner">\n    <h2>тот батуми,<br/>что мы <em>правда</em><br/>советуем.</h2>\n    <p class="lede">наш гид по городу — пишем сами, не таскаем с tripadvisor. кафе, рестораны, пляжи, велнес, ночная жизнь — собрано по тому, где правда хочется провести вечер.</p>\n    <div class="spread-cta">\n      <a class="btn" href="/ru/georgia/batumi/guide">открыть гайд →</a>\n    </div>\n  </div>\n</section>\n\n<section class="guide-wrap" id="guide">\n  <div class="section-head reveal">\n    <div>\n      <div class="meta"><span class="dot"></span>— в этом выпуске</div>\n    </div>\n    <div class="right">подборка из <b>четырёх миров</b>. ' + places.length + ' мест, отобранных вручную.</div>\n  </div>\n\n  <div class="guide-categories">' + guideCats + '</div>\n</section>\n\n<section class="now">\n  <div class="now-grid">\n    <div>\n      <div class="now-label"><span class="pulse"></span>прямо сейчас в батуми</div>\n      <div class="now-val"><span id="nowDate">сегодня</span><span class="small" id="nowDesc">смотрим в небо…</span></div>\n    </div>\n    <div>\n      <div class="now-label">температура</div>\n      <div class="now-val"><span id="nowTemp">—</span><em>°</em>C<span class="small" id="nowWind">лёгкий бриз с моря</span></div>\n    </div>\n    <div>\n      <div class="now-label">закат</div>\n      <div class="now-val" id="nowSunset">—:—<span class="small">над чёрным морем</span></div>\n    </div>\n    <div>\n      <div class="now-label">из гайда</div>\n      <div class="now-val">' + nowGuide + '</div>\n    </div>\n  </div>\n</section>\n\n<section class="pull">\n  <blockquote class="reveal">\n    с нас —<br/>тут <span class="underline"><em>квартира</em></span>.<br/>с тебя —<br/>тут <span class="underline"><em>город</em></span>.\n  </blockquote>\n  <div class="sig">— bre, батуми</div>\n</section>\n\n<section class="doors-wrap" id="own">\n  <div class="section-head reveal">\n    <div>\n      <div class="meta"><span class="dot"></span>— не за бронированием?</div>\n      <h2 style="margin-top:18px">помогаем <em>купить</em><br/>и <em>управляем</em> потом.</h2>\n    </div>\n    <div class="right">если у тебя есть квартира в батуми — или ты только думаешь её купить — расскажи. мы уже <b>120+ раз</b> через это прошли.</div>\n  </div>\n\n  <div class="doors">\n    <a class="door reveal" href="/ru/georgia/batumi/own">\n      <div>\n        <div class="num">i. собственникам</div>\n        <h3>просто передай нам<br/><em>ключи</em>.</h3>\n        <p>полный сервис посуточной и среднесрочной аренды. 30% комиссия — всё включено. гости на 5 языках, фото, гибкие цены, уборка, всё остальное.</p>\n      </div>\n      <div>\n        <div class="stat"><b>30%</b><span>комиссия · всё включено</span></div>\n        <span class="cta">как это устроено <span>→</span></span>\n      </div>\n    </a>\n\n    <a class="door reveal" href="/ru/georgia/batumi/invest" id="invest">\n      <div>\n        <div class="num">ii. инвесторам</div>\n        <h3>купи квартиру,<br/>которая <em>работает</em>.</h3>\n        <p>находим лучшие квартиры, делаем ремонт, выставляем, управляем. ты видишь цифры — не стресс. средняя чистая доходность по нашему портфелю.</p>\n      </div>\n      <div>\n        <div class="stat"><b>11%</b><span>годовая доходность · в среднем</span></div>\n        <span class="cta">давай поговорим <span>→</span></span>\n      </div>\n    </a>\n  </div>\n</section>\n\n<section class="contact" id="contact">\n  <h2 class="reveal">напиши<br/><em>привет</em>.</h2>\n\n  <div class="channels reveal">\n    <a class="channel" href="https://t.me/bre_ge"><span class="label">телеграм</span><span class="value">@bre_ge</span><span class="ar">→</span></a>\n    <a class="channel" href="https://wa.me/995585889601" target="_blank" rel="noopener"><span class="label">whatsapp</span><span class="value">+995 585 889 601</span><span class="ar">→</span></a>\n    <a class="channel" href="tel:+995585889601"><span class="label">телефон</span><span class="value">+995 585 889 601</span><span class="ar">→</span></a>\n    <a class="channel" href="https://t.me/batumirealflats"><span class="label">канал</span><span class="value">t.me/batumirealflats</span><span class="ar">→</span></a>\n    <div class="channel"><span class="label">офис</span><span class="value">батуми, грузия</span><span class="ar">— 41.6°N 41.6°E</span></div>\n  </div>\n</section>\n\n<section class="footer-guide">\n  <div class="footer-guide-head">\n    <h4>на прошлой неделе<br/>мы <em>писали</em> ↓</h4>\n    <a href="/ru/georgia/batumi/guide" class="all">все ' + places.length + ' мест →</a>\n  </div>\n  <div class="footer-posts">' + footPosts + '</div>\n</section>'} />
<style is:global set:html={'.hero{\n    position:relative;height:100vh;min-height:640px;max-height:880px;overflow:hidden;\n    padding:88px 24px 24px;\n    display:grid;grid-template-columns:1.4fr 1fr;gap:16px;\n  }\n.hero-main{\n    display:block;position:relative;border-radius:18px;overflow:hidden;background:#0a0908;\n  }\n.hero-main-img{display:block;position:absolute;inset:0;text-decoration:none;color:inherit}\n.hero-main-img img{width:100%;height:100%;object-fit:cover;transform:scale(1.05);animation:slowzoom 22s ease-out infinite alternate}\n.hero-main::after{\n    content:"";position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(180deg, #0a09084d 0%, transparent 25%, transparent 45%, #0a0908e0 100%);\n  }\n.hero-h1{\n    position:absolute;left:32px;right:32px;bottom:118px;z-index:2;color:#FAF7F0;\n    font-family:"Bricolage Grotesque",sans-serif;font-weight:800;\n    font-size:clamp(40px,4.5vw,80px);line-height:.92;letter-spacing:-.04em;\n    text-transform:lowercase;pointer-events:none;\n    opacity:0;animation:rise 1.1s cubic-bezier(.2,.7,.2,1) .3s forwards;\n  }\n.hero-h1 em{font-style:italic;color:var(--accent)}\n.hero-h1 .row2{display:block;margin-left:.5em}\n.hero-search{\n    position:absolute;left:24px;right:24px;bottom:24px;z-index:3;\n    display:grid;grid-template-columns:1.4fr 1fr auto;gap:0;\n    background:rgba(255,255,255,0.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);\n    border-radius:14px;padding:6px;\n    box-shadow:0 8px 32px rgba(0,0,0,0.18);\n    opacity:0;animation:rise 1.1s cubic-bezier(.2,.7,.2,1) .65s forwards;\n  }\n.hs-field{\n    background:transparent;border:none;cursor:pointer;text-align:left;padding:12px 18px;\n    border-radius:10px;display:flex;flex-direction:column;gap:3px;\n    transition:background .12s;\n    border-right:1px solid rgba(10,9,8,0.08);\n  }\n.hs-field:hover{background:rgba(10,9,8,0.04)}\n.hs-field:last-of-type{border-right:none}\n.hs-lbl{\n    font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.18em;\n    color:var(--ink-soft);font-weight:600;text-transform:uppercase;\n  }\n.hs-val{\n    font-family:"Bricolage Grotesque",sans-serif;font-size:15px;color:var(--ink);\n    font-weight:600;text-transform:lowercase;letter-spacing:-.01em;\n  }\n.hs-val.empty{color:var(--ink-fade);font-weight:400}\n.hs-submit{\n    background:var(--ink);border:none;color:#FAF7F0;border-radius:10px;\n    width:54px;height:auto;cursor:pointer;\n    display:flex;align-items:center;justify-content:center;\n    transition:background .15s;\n  }\n.hs-submit:hover{background:var(--accent)}\n.hero-side{display:grid;grid-template-rows:1.5fr 1fr;gap:16px;min-height:0}\n.hero-card{\n    position:relative;border-radius:18px;overflow:hidden;background:var(--bg-2);\n    opacity:0;animation:rise 1.1s cubic-bezier(.2,.7,.2,1) forwards;\n  }\n.hero-card:nth-of-type(1){animation-delay:.5s}\n.hero-card:nth-of-type(2){animation-delay:.7s}\n.hero-card img{width:100%;height:100%;object-fit:cover}\n.hero-card.edition{\n    background:var(--accent);color:#FAF7F0;display:flex;flex-direction:column;justify-content:space-between;padding:24px;\n  }\n.hero-card.edition img{position:absolute;inset:0;filter:grayscale(1) brightness(1.55) contrast(.9)}\n.hero-card.edition::after{\n    content:"";position:absolute;inset:0;background:linear-gradient(170deg, #ff4d2ed9 0%, #ff4d2e99 100%);\n  }\n.hero-card.edition>.ed-slide{position:absolute;inset:0}\n.hero-card.edition .ed-no{\n    font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.22em;font-weight:600;text-transform:uppercase;\n    display:flex;align-items:center;gap:10px;\n  }\n.hero-card.edition .ed-no::before{content:"";width:24px;height:1px;background:#FAF7F0}\n.hero-card.edition h4{\n    font-family:"Bricolage Grotesque",sans-serif;font-weight:800;\n    font-size:clamp(28px,3vw,42px);letter-spacing:-.03em;line-height:.95;text-transform:lowercase;\n  }\n.hero-card.edition h4 em{font-style:italic}\n.hero-card.edition .ed-foot{\n    display:flex;justify-content:space-between;align-items:flex-end;\n    font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.18em;font-weight:500;text-transform:uppercase;\n  }\n.hero-card.edition .ed-foot b{font-weight:600}\nsection{position:relative;z-index:2}\n.pad{padding:140px 28px}\n.section-head{display:flex;justify-content:space-between;align-items:flex-end;gap:32px;margin-bottom:56px;flex-wrap:wrap}\n.section-head .meta{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-soft);font-weight:500;display:flex;align-items:center;gap:18px}\n.section-head .meta .dot{width:6px;height:6px;border-radius:50%;background:var(--accent)}\n.section-head h2{\n    font-family:"Bricolage Grotesque",sans-serif;font-weight:800;\n    font-size:clamp(48px,7vw,108px);line-height:.88;letter-spacing:-.045em;\n    text-transform:lowercase;max-width:18ch;\n  }\n.section-head h2 em{font-style:italic;color:var(--accent)}\n.section-head .right{font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-soft);font-weight:500;text-align:right;max-width:36ch;line-height:1.7}\n.section-head .right b{color:var(--ink);font-weight:600}\n.reveal{opacity:0;transform:translateY(30px);transition:opacity .9s ease,transform .9s cubic-bezier(.2,.7,.2,1)}\n.reveal.in{opacity:1;transform:none}\n.apts{display:grid;grid-template-columns:repeat(3,1fr);gap:32px 24px}\n.apt{position:relative;display:block;overflow:hidden}\n.apt .ph{position:relative;aspect-ratio:4/5;overflow:hidden;background:var(--bg-2);border-radius:6px}\n.apt .ph img{width:100%;height:100%;object-fit:cover;transition:transform 1.1s cubic-bezier(.2,.7,.2,1);filter:saturate(.95) contrast(1.02)}\n.apt:hover .ph img{transform:scale(1.06)}\n.apt .fav{position:absolute;top:14px;right:14px;width:32px;height:32px;border-radius:50%;background:#ffffffcc;backdrop-filter:blur(6px);di