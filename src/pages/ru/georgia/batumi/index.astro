<script is:inline set:html={'(function(){\n    const BATUMI = { lat: 41.6508, lng: 41.6357, tz: \'Asia/Tbilisi\' };\n    function setDate(){\n      const now = new Date();\n      const local = new Date(now.toLocaleString(\'en-US\', {timeZone: BATUMI.tz}));\n      const days = [\'воскресенье\',\'понедельник\',\'вторник\',\'среда\',\'четверг\',\'пятница\',\'суббота\'];\n      const months = [\'января\',\'февраля\',\'марта\',\'апреля\',\'мая\',\'июня\',\'июля\',\'августа\',\'сентября\',\'октября\',\'ноября\',\'декабря\'];\n      const dateStr = `${local.getDate()} ${months[local.getMonth()]}, ${days[local.getDay()]}`;\n      const el = document.getElementById(\'nowDate\');\n      if (el) el.textContent = dateStr;\n    }\n    setDate();\n    setInterval(setDate, 60000);\n    function fetchWeather(){\n      const url = `https://api.open-meteo.com/v1/forecast?latitude=${BATUMI.lat}&longitude=${BATUMI.lng}&current=temperature_2m,wind_speed_10m,weather_code&daily=sunset&timezone=${BATUMI.tz}`;\n      fetch(url).then(r => r.json()).then(d => {\n        if (!d || !d.current) return;\n        const t = Math.round(d.current.temperature_2m);\n        const wind = Math.round(d.current.wind_speed_10m);\n        const code = d.current.weather_code;\n        const sunset = d.daily && d.daily.sunset && d.daily.sunset[0];\n        const tempEl = document.getElementById(\'nowTemp\'); if (tempEl) tempEl.textContent = t;\n        const windEl = document.getElementById(\'nowWind\'); if (windEl) windEl.textContent = describeWind(wind);\n        const descEl = document.getElementById(\'nowDesc\'); if (descEl) descEl.textContent = describeSky(code);\n        if (sunset) { const time = sunset.split(\'T\')[1].slice(0,5); const sunsetEl = document.getElementById(\'nowSunset\'); if (sunsetEl) sunsetEl.innerHTML = `${time}<span class="small">над чёрным морем</span>`; }\n      }).catch(()=>{var d=document.getElementById(\'nowDesc\');if(d)d.textContent=\'погода недоступна\';});\n    }\n    function describeSky(code){\n      if (code === 0) return \'ясное небо\';\n      if (code <= 3) return \'немного облаков\';\n      if (code <= 48) return \'туманное утро\';\n      if (code <= 67) return \'дождь над городом\';\n      if (code <= 77) return \'снег на холмах\';\n      if (code <= 82) return \'ливни\';\n      if (code <= 99) return \'гроза\';\n      return \'переменная погода\';\n    }\n    function describeWind(kmh){\n      if (kmh < 5) return \'штиль\';\n      if (kmh < 15) return \'лёгкий бриз\';\n      if (kmh < 25) return \'свежий ветер\';\n      if (kmh < 40) return \'ветрено\';\n      return \'сильный ветер\';\n    }\n    fetchWeather();\n    setInterval(fetchWeather, 10 * 60000);\n  })();\n\n  function submitHeroSearch(e){ e.preventDefault(); window.location.href = \'/ru/georgia/batumi/stays\'; return false; }\n  [\'hsDateBtn\',\'hsGuestBtn\'].forEach(id=>{ const el = document.getElementById(id); if(el) el.addEventListener(\'click\', ()=>{ window.location.href=\'/ru/georgia/batumi/stays\'; }); });\n\n  (function(){var box=document.getElementById("heroEdition");if(!box)return;var s=box.querySelectorAll(".ed-slide");if(s.length<2)return;var i=0;setInterval(function(){s[i].classList.remove("active");i=(i+1)%s.length;s[i].classList.add("active");},4800);})();'}></script>
