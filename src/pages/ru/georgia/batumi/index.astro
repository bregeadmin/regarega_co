<script is:inline set:html={"// ===== LIVE \"RIGHT NOW IN BATUMI\" =====\n  (function(){\n    const BATUMI = { lat: 41.6508, lng: 41.6357, tz: 'Asia/Tbilisi' };\n\n    // 1. Date \u2014 local Batumi time\n    function setDate(){\n      const now = new Date();\n      const local = new Date(now.toLocaleString('en-US', {timeZone: BATUMI.tz}));\n      const days = ['воскресенье','понедельник','вторник','среда','четверг','пятница','суббота'];\n      const months = ['января','февраля','марта','апреля','мая','июня','июля','августа','сентября','октября','ноября','декабря'];\n      const dateStr = `${local.getDate()} ${months[local.getMonth()]}, ${days[local.getDay()]}`;\n      const el = document.getElementById('nowDate');\n      if (el) el.textContent = dateStr;\n    }\n    setDate();\n    setInterval(setDate, 60000);\n\n    // 2. Weather + sunset \u2014 Open-Meteo, no API key\n    function fetchWeather(){\n      const url = `https://api.open-meteo.com/v1/forecast?latitude=${BATUMI.lat}&longitude=${BATUMI.lng}&current=temperature_2m,wind_speed_10m,weather_code&daily=sunset&timezone=${BATUMI.tz}`;\n      fetch(url).then(r => r.json()).then(d => {\n        if (!d || !d.current) return;\n        const t = Math.round(d.current.temperature_2m);\n        const wind = Math.round(d.current.wind_speed_10m);\n        const code = d.current.weather_code;\n        const sunset = d.daily && d.daily.sunset && d.daily.sunset[0];\n\n        const tempEl = document.getElementById('nowTemp');\n        if (tempEl) tempEl.textContent = t;\n\n        const windEl = document.getElementById('nowWind');\n        if (windEl) windEl.textContent = describeWind(wind);\n\n        const descEl = document.getElementById('nowDesc');\n        if (descEl) descEl.textContent = describeSky(code);\n\n        if (sunset) {\n          const time = sunset.split('T')[1].slice(0,5);\n          const sunsetEl = document.getElementById('nowSunset');\n          if (sunsetEl) sunsetEl.innerHTML = `${time}<span class=\"small\">над чёрным морем</span>`;\n        }\n      }).catch(()=>{});\n    }\n    function describeSky(code){\n      if (code === 0) return 'ясное небо';\n      if (code <= 3) return 'немного облаков';\n      if (code <= 48) return 'туманное утро';\n      if (code <= 67) return 'дождь над городом';\n      if (code <= 77) return 'снег на холмах';\n      if (code <= 82) return 'ливни';\n      if (code <= 99) return 'гроза';\n      return 'переменная погода';\n    }\n    function describeWind(kmh){\n      if (kmh < 5) return 'штиль';\n      if (kmh < 15) return 'лёгкий бриз';\n      if (kmh < 25) return 'свежий ветер';\n      if (kmh < 40) return 'ветрено';\n      return 'сильный ветер';\n    }\n    fetchWeather();\n    setInterval(fetchWeather, 10 * 60000); // refresh every 10 min\n  })();\n\n\n\n  // HERO SEARCHBAR \u2014 redirect to /stays where full pickers live\n  function submitHeroSearch(e){\n    e.preventDefault();\n    window.location.href = '/georgia/batumi/stays';\n    return false;\n  }\n  // Clicking any field also goes to /stays\n  ['hsDateBtn','hsGuestBtn'].forEach(id=>{\n    const el = document.getElementById(id);\n    if(el) el.addEventListener('click', ()=>{ window.location.href='/georgia/batumi/stays'; });\n  });\n\n  // hero edition card — cycle recent news (gentle vertical crossfade)\n  (function(){var box=document.getElementById('heroEdition');if(!box)return;var sl=box.querySelectorAll('.ed-slide');if(sl.length<2)return;var i=0;setInterval(function(){sl[i].classList.remove('active');i=(i+1)%sl.length;sl[i].classList.add('active');},4800);})();" }></script>
<script is:inline>(function(){var box=document.getElementById("heroEdition");if(!box)return;var s=box.querySelectorAll(".ed-slide");if(s.length<2)return;var i=0;setInterval(function(){s[i].classList.remove("active");i=(i+1)%s.length;s[i].classList.add("active");},4800);})();</script>
