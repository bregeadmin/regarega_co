<SiteRu title="\u0421\u0434\u0430\u0439 \u0441 \u043d\u0430\u043c\u0438 \u2014 rega rega" accent="#3D5AFE" accentDeep="#2F49D6">
<Fragment set:html={"<!-- HEADER -->\n<section class=\"head\">\n  <div class=\"inner\">\n    <div>\n      <div class=\"crumbs\">\n        <span class=\"current\"><span class=\"dot\"></span>\u0421\u0434\u0430\u0442\u044c \u0441 \u043d\u0430\u043c\u0438</span>\n      </div>\n      <h1>\u0422\u0432\u043e\u044f <em>\u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430</em>,<br/>\u043d\u0430\u0448\u0430 <em>\u0437\u0430\u0431\u043e\u0442\u0430</em>.</h1>\n    </div>\n    <p class=\"lede\">\u0423 \u0442\u0435\u0431\u044f \u0443\u0436\u0435 \u0435\u0441\u0442\u044c \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430 \u0432 \u0411\u0430\u0442\u0443\u043c\u0438? <b>\u041c\u044b \u0432\u043e\u0437\u044c\u043c\u0451\u043c \u0435\u0451 \u043f\u043e\u0434 \u0441\u0432\u043e\u0451 \u043a\u0440\u044b\u043b\u043e</b> \u2014 \u0444\u043e\u0442\u043e, \u043e\u0431\u044a\u044f\u0432\u043b\u0435\u043d\u0438\u044f, \u0433\u043e\u0441\u0442\u0438, \u0443\u0431\u043e\u0440\u043a\u0430, \u043d\u0430\u043b\u043e\u0433\u0438, \u0432\u0441\u0451 \u043e\u0441\u0442\u0430\u043b\u044c\u043d\u043e\u0435. <b>\u0421 2022 \u0433\u043e\u0434\u0430</b>, \u0441\u0432\u043e\u0438\u043c\u0438 \u0440\u0443\u043a\u0430\u043c\u0438.</p>\n  </div>\n</section>\n\n<!-- THE DEAL \u2014 70/30 -->\n<section class=\"promise\">\n  <div class=\"inner\">\n    <div class=\"col you\">\n      <div>\n        <div class=\"label\">\u2014 \u0442\u0435\u0431\u0435</div>\n        <div class=\"num\">70<span class=\"pc\">%</span></div>\n      </div>\n      <p class=\"desc\">\u043e\u0442 \u0447\u0438\u0441\u0442\u043e\u0439 \u0432\u044b\u0440\u0443\u0447\u043a\u0438 \u0441 \u0430\u0440\u0435\u043d\u0434\u044b. \u041a\u0432\u0430\u0440\u0442\u0438\u0440\u0430 \u0442\u0432\u043e\u044f \u2014 \u0431\u043e\u043b\u044c\u0448\u0430\u044f \u0434\u043e\u043b\u044f \u0442\u0435\u0431\u0435. <b>\u041a\u043e\u043c\u043c\u0443\u043d\u0430\u043b\u043a\u0430 \u0438 \u0440\u0430\u0437\u043e\u0432\u044b\u0435 \u043f\u043e\u043a\u0443\u043f\u043a\u0438</b> \u043e\u0441\u0442\u0430\u044e\u0442\u0441\u044f \u043d\u0430 \u0442\u0435\u0431\u0435. \u0412\u0441\u0451 \u043e\u0441\u0442\u0430\u043b\u044c\u043d\u043e\u0435 \u2014 \u043d\u0430 \u043d\u0430\u0441.</p>\n    </div>\n    <div class=\"col us\">\n      <div>\n        <div class=\"label\">\u2014 \u043d\u0430\u043c</div>\n        <div class=\"num\">30<span class=\"pc\">%</span></div>\n      </div>\n      <p class=\"desc\">\u043f\u043e\u043a\u0440\u044b\u0432\u0430\u044e\u0442 <b>\u0432\u0441\u0451 \u0447\u0442\u043e \u043c\u044b \u0434\u0435\u043b\u0430\u0435\u043c</b> \u2014 \u043e\u0431\u044a\u044f\u0432\u043b\u0435\u043d\u0438\u044f, \u0433\u0438\u0431\u043a\u0438\u0435 \u0446\u0435\u043d\u044b, \u043e\u0431\u0449\u0435\u043d\u0438\u0435 \u0441 \u0433\u043e\u0441\u0442\u044f\u043c\u0438 \u043d\u0430 5 \u044f\u0437\u044b\u043a\u0430\u0445, \u0443\u0431\u043e\u0440\u043a\u0430, \u0441\u0442\u0438\u0440\u043a\u0430, \u043c\u0435\u043b\u043a\u0438\u0439 \u0440\u0435\u043c\u043e\u043d\u0442, welcome-\u043d\u0430\u0431\u043e\u0440\u044b, \u043c\u0435\u0441\u044f\u0447\u043d\u044b\u0439 \u043e\u0442\u0447\u0451\u0442.</p>\n    </div>\n  </div>\n</section>\n\n<!-- WHAT WE DO -->\n<section class=\"pad\">\n  <div class=\"container\">\n    <div class=\"section-head\">\n      <div class=\"left\">\n        <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u0447\u0442\u043e \u043c\u044b \u0440\u0435\u0430\u043b\u044c\u043d\u043e \u0434\u0435\u043b\u0430\u0435\u043c</div>\n        <h2>\u0412\u0441\u0451, <em>\u043a\u0440\u043e\u043c\u0435</em><br/>\u043e\u0442\u043a\u0440\u044b\u0432\u0430\u043d\u0438\u044f \u0434\u0432\u0435\u0440\u0438.</h2>\n      </div>\n      <div class=\"right\">\u0428\u0435\u0441\u0442\u044c \u043f\u0443\u043d\u043a\u0442\u043e\u0432, \u043a\u0430\u0436\u0434\u044b\u0439 \u043c\u0435\u0441\u044f\u0446. \u041f\u0435\u0440\u0435\u0447\u0438\u0441\u043b\u0435\u043d\u044b \u043f\u0440\u044f\u043c\u043e \u2014 \u0447\u0442\u043e\u0431\u044b \u0437\u043d\u0430\u0442\u044c, \u0437\u0430 \u0447\u0442\u043e \u043f\u043b\u0430\u0442\u0438\u0448\u044c \u0441\u0432\u043e\u0438 30%.</div>\n    </div>\n\n    <div class=\"services\">\n      <div class=\"svc\">\n        <div class=\"top\">\n          <span class=\"nr\">01</span>\n          <span class=\"icon\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><rect x=\"1.5\" y=\"2.5\" width=\"11\" height=\"9\" rx=\"1\" stroke=\"currentColor\" stroke-width=\"1.4\"/><path d=\"M3.5 5h7M3.5 7h4\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\"/></svg></span>\n        </div>\n        <h3>\u041e\u0431\u044a\u044f\u0432\u043b\u0435\u043d\u0438\u044f \u0438 \u0441\u044a\u0451\u043c\u043a\u0430</h3>\n        <p>\u0421\u043d\u0438\u043c\u0430\u0435\u043c \u0442\u0432\u043e\u044e \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0443 <b>\u043f\u0440\u0438 \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0435\u043c \u0441\u0432\u0435\u0442\u0435</b>, \u043f\u0438\u0448\u0435\u043c \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u044f \u043d\u0430 \u0434\u0432\u0443\u0445 \u044f\u0437\u044b\u043a\u0430\u0445, \u043f\u0443\u0431\u043b\u0438\u043a\u0443\u0435\u043c \u043d\u0430 <b>3\u20144 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0430\u0445</b> (Airbnb, Booking, \u043d\u0430\u0448 \u0441\u0430\u0439\u0442, \u0442\u0435\u043b\u0435\u0433\u0440\u0430\u043c-\u043a\u0430\u043d\u0430\u043b\u044b). \u041d\u0438\u043a\u0430\u043a\u0438\u0445 \u0441\u0442\u043e\u043a\u043e\u0432\u044b\u0445 \u0444\u043e\u0442\u043e \u0438 \u043d\u0430\u0442\u044f\u043d\u0443\u0442\u044b\u0445 \u044d\u043f\u0438\u0442\u0435\u0442\u043e\u0432.</p>\n      </div>\n\n      <div class=\"svc\">\n        <div class=\"top\">\n          <span class=\"nr\">02</span>\n          <span class=\"icon\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M2 11l3-3 2.5 2.5L12 6\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/><path d=\"M8 6h4v4\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n        </div>\n        <h3>\u0413\u0438\u0431\u043a\u043e\u0435 <em>\u0446\u0435\u043d\u043e\u043e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u043d\u0438\u0435</em></h3>\n        <p>\u0426\u0435\u043d\u044b \u0432 \u0411\u0430\u0442\u0443\u043c\u0438 \u0441\u043a\u0430\u0447\u0443\u0442. \u041f\u043e\u0434\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0435\u043c \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u044c \u043d\u043e\u0447\u0438 \u043f\u043e\u0434 <b>\u0441\u0435\u0437\u043e\u043d, \u043a\u043e\u043d\u043a\u0443\u0440\u0435\u043d\u0442\u043e\u0432 \u0438 \u043a\u0430\u043b\u0435\u043d\u0434\u0430\u0440\u044c \u0441\u043e\u0431\u044b\u0442\u0438\u0439</b> \u2014 \u0447\u0442\u043e\u0431\u044b \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430 \u043d\u0435 \u043f\u0443\u0441\u0442\u043e\u0432\u0430\u043b\u0430 \u0432 \u043c\u0435\u0436\u0441\u0435\u0437\u043e\u043d\u044c\u0435 \u0438 \u043d\u0435 \u0443\u0445\u043e\u0434\u0438\u043b\u0430 \u0437\u0430\u0434\u0451\u0448\u0435\u0432\u043e \u0432 \u043f\u0438\u043a\u043e\u0432\u044b\u0435 \u0434\u0430\u0442\u044b.</p>\n      </div>\n\n      <div class=\"svc\">\n        <div class=\"top\">\n          <span class=\"nr\">03</span>\n          <span class=\"icon\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M2 4.5C2 3.7 2.7 3 3.5 3h7c.8 0 1.5.7 1.5 1.5v4c0 .8-.7 1.5-1.5 1.5H5l-2.5 2V4.5z\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linejoin=\"round\"/></svg></span>\n        </div>\n        <h3>\u0413\u043e\u0441\u0442\u0438, \u043d\u0430 5 \u044f\u0437\u044b\u043a\u0430\u0445</h3>\n        <p>\u0420\u0443\u0441\u0441\u043a\u0438\u0439, \u0430\u043d\u0433\u043b\u0438\u0439\u0441\u043a\u0438\u0439, \u0442\u0443\u0440\u0435\u0446\u043a\u0438\u0439, \u0438\u0432\u0440\u0438\u0442, \u0433\u0440\u0443\u0437\u0438\u043d\u0441\u043a\u0438\u0439. \u041e\u0442\u0432\u0435\u0447\u0430\u0435\u043c <b>\u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u043c\u0438\u043d\u0443\u0442</b>, \u0434\u043d\u0451\u043c \u0438 \u043d\u043e\u0447\u044c\u044e. \u0411\u044b\u0441\u0442\u0440\u044b\u0435 \u043e\u0442\u0432\u0435\u0442\u044b \u043f\u043e\u0434\u043d\u0438\u043c\u0430\u044e\u0442 \u0442\u0432\u043e\u0451 \u043e\u0431\u044a\u044f\u0432\u043b\u0435\u043d\u0438\u0435 \u0432 \u0432\u044b\u0434\u0430\u0447\u0435 \u2014 \u0438 \u0434\u0435\u0440\u0436\u0430\u0442 \u0433\u043e\u0441\u0442\u0435\u0439 \u0432 \u0441\u043f\u043e\u043a\u043e\u0439\u0441\u0442\u0432\u0438\u0438.</p>\n      </div>\n\n      <div class=\"svc\">\n        <div class=\"top\">\n          <span class=\"nr\">04</span>\n          <span class=\"icon\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M3 6c0-2.2 1.8-4 4-4s4 1.8 4 4c0 1.5-.8 2.7-2 3.4V12H5V9.4C3.8 8.7 3 7.5 3 6z\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linejoin=\"round\"/></svg></span>\n        </div>\n        <h3>\u041c\u0435\u043b\u043e\u0447\u0438</h3>\n        <p>\u041c\u044b\u043b\u043e, \u0448\u0430\u043c\u043f\u0443\u043d\u044c, \u043a\u043e\u043d\u0434\u0438\u0446\u0438\u043e\u043d\u0435\u0440, \u0437\u0443\u0431\u043d\u044b\u0435 \u0449\u0451\u0442\u043a\u0438, \u0442\u0430\u043f\u043e\u0447\u043a\u0438, \u043a\u0430\u043f\u0441\u0443\u043b\u044b \u0434\u043b\u044f \u0441\u0442\u0438\u0440\u043a\u0438. \u0427\u0430\u0439, \u043a\u043e\u0444\u0435, \u0441\u043f\u0435\u0446\u0438\u0438, \u043e\u043b\u0438\u0432\u043a\u043e\u0432\u043e\u0435 \u043c\u0430\u0441\u043b\u043e. \u041a\u0430\u0440\u0442\u043e\u0447\u043a\u0430 \u0441 <b>\u043b\u0443\u0447\u0448\u0438\u043c\u0438 \u043c\u0435\u0441\u0442\u0430\u043c\u0438 \u0432 \u043f\u0435\u0448\u0435\u0439 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438</b> \u043e\u0442 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b. \u041c\u0435\u043b\u043e\u0447\u0438 \u2014 \u043d\u043e \u0433\u043e\u0441\u0442\u0438 \u0438\u0445 \u0437\u0430\u043c\u0435\u0447\u0430\u044e\u0442.</p>\n      </div>\n\n      <div class=\"svc\">\n        <div class=\"top\">\n          <span class=\"nr\">05</span>\n          <span class=\"icon\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><circle cx=\"7\" cy=\"4\" r=\"2\" stroke=\"currentColor\" stroke-width=\"1.4\"/><path d=\"M3 12c0-2.2 1.8-4 4-4s4 1.8 4 4\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\"/></svg></span>\n        </div>\n        <h3>\u0423\u0431\u043e\u0440\u043a\u0430, \u0441\u0442\u0438\u0440\u043a\u0430, \u043c\u0435\u043b\u043a\u0438\u0439 \u0440\u0435\u043c\u043e\u043d\u0442</h3>\n        <p>\u041f\u043e\u0441\u043b\u0435 \u043a\u0430\u0436\u0434\u043e\u0433\u043e \u0433\u043e\u0441\u0442\u044f. \u041f\u043b\u044e\u0441 \u043c\u0435\u043b\u043e\u0447\u0438 \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043b\u043e\u043c\u0430\u044e\u0442\u0441\u044f \u2014 \u043b\u0430\u043c\u043f\u043e\u0447\u043a\u0438, \u0440\u0430\u0437\u0431\u043e\u043b\u0442\u0430\u0432\u0448\u0438\u0435\u0441\u044f \u0440\u0443\u0447\u043a\u0438, \u0442\u0435\u043a\u0443\u0449\u0438\u0435 \u043a\u0440\u0430\u043d\u044b. <b>\u0421\u0430\u043d\u0442\u0435\u0445\u043d\u0438\u043a\u0438 \u0438 \u044d\u043b\u0435\u043a\u0442\u0440\u0438\u043a\u0438</b> \u043f\u043e \u043d\u0435\u043e\u0431\u0445\u043e\u0434\u0438\u043c\u043e\u0441\u0442\u0438 \u2014 \u043c\u044b \u043a\u043e\u043e\u0440\u0434\u0438\u043d\u0438\u0440\u0443\u0435\u043c, \u0442\u0435\u0431\u044f \u043d\u0435 \u0434\u0451\u0440\u0433\u0430\u0435\u043c.</p>\n      </div>\n\n      <div class=\"svc\">\n        <div class=\"top\">\n          <span class=\"nr\">06</span>\n          <span class=\"icon\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><rect x=\"2\" y=\"3\" width=\"10\" height=\"8\" rx=\"1\" stroke=\"currentColor\" stroke-width=\"1.4\"/><path d=\"M4 6h6M4 8h4\" stroke=\"currentColor\" stroke-width=\"1.4\" stroke-linecap=\"round\"/></svg></span>\n        </div>\n        <h3>\u041c\u0435\u0441\u044f\u0447\u043d\u044b\u0439 \u043e\u0442\u0447\u0451\u0442</h3>\n        <p>\u0412 \u043d\u0430\u0447\u0430\u043b\u0435 \u043a\u0430\u0436\u0434\u043e\u0433\u043e \u043c\u0435\u0441\u044f\u0446\u0430 \u0442\u044b \u043f\u043e\u043b\u0443\u0447\u0430\u0435\u0448\u044c \u043e\u0442\u0447\u0451\u0442 \u0437\u0430 \u043f\u0440\u043e\u0448\u043b\u044b\u0439 \u2014 \u0444\u043e\u0440\u043c\u0438\u0440\u0443\u0435\u0442\u0441\u044f <b>\u043d\u0430\u043f\u0440\u044f\u043c\u0443\u044e \u0438\u0437 \u043d\u0430\u0448\u0435\u0439 \u0441\u0438\u0441\u0442\u0435\u043c\u044b \u0443\u0447\u0451\u0442\u0430</b>, \u0441\u0442\u0440\u043e\u043a\u0430 \u0437\u0430 \u0441\u0442\u0440\u043e\u043a\u043e\u0439. \u0411\u0440\u043e\u043d\u0438, \u0432\u044b\u0440\u0443\u0447\u043a\u0430, \u043d\u0430\u0448\u0430 \u0434\u043e\u043b\u044f, \u0442\u0432\u043e\u044f \u0434\u043e\u043b\u044f, \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u043e\u043d\u043d\u044b\u0435 \u0440\u0430\u0441\u0445\u043e\u0434\u044b. \u041d\u0438\u0447\u0435\u0433\u043e \u0441\u043a\u0440\u044b\u0442\u043e\u0433\u043e, \u043d\u0438\u0447\u0435\u0433\u043e \u0432\u0440\u0443\u0447\u043d\u0443\u044e.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- WHO PAYS WHAT -->\n<section class=\"split-wrap\">\n  <div class=\"container\">\n    <div class=\"section-head\">\n      <div class=\"left\">\n        <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u043a\u0442\u043e \u0437\u0430 \u0447\u0442\u043e \u043f\u043b\u0430\u0442\u0438\u0442</div>\n        <h2>\u041f\u0440\u043e\u0437\u0440\u0430\u0447\u043d\u043e.<br/>\u0414\u043e <em>\u0441\u043a\u0443\u043a\u043e\u0442\u044b</em>.</h2>\n      </div>\n      <div class=\"right\">\u041d\u0438\u043a\u0430\u043a\u0438\u0445 \u0441\u043a\u0440\u044b\u0442\u044b\u0445 \u043a\u043e\u043c\u0438\u0441\u0441\u0438\u0439 \u0438 \u00ab+ \u0434\u043e\u043f. \u0443\u0441\u043b\u0443\u0433\u00bb. \u0415\u0441\u043b\u0438 \u044d\u0442\u043e\u0433\u043e \u043d\u0435\u0442 \u0432 \u0441\u043f\u0438\u0441\u043a\u0435 \u2014 \u0442\u044b \u0437\u0430 \u044d\u0442\u043e \u043d\u0435 \u043f\u043b\u0430\u0442\u0438\u0448\u044c.</div>\n    </div>\n\n    <div class=\"split\">\n      <div class=\"side us\">\n        <span class=\"badge\">\u2014 \u043d\u0430\u0448\u0430 \u0441\u0442\u043e\u0440\u043e\u043d\u0430</span>\n        <h4>\u041f\u043e\u043a\u0440\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u0442\u0432\u043e\u0438\u043c\u0438 30%</h4>\n        <ul>\n          <li>\u0423\u0431\u043e\u0440\u043a\u0430 \u043f\u043e\u0441\u043b\u0435 \u043a\u0430\u0436\u0434\u043e\u0433\u043e \u0433\u043e\u0441\u0442\u044f</li>\n          <li>\u0421\u0442\u0438\u0440\u043a\u0430 \u043f\u043e\u0441\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u0438 \u043f\u043e\u043b\u043e\u0442\u0435\u043d\u0435\u0446</li>\n          <li>Welcome-\u043d\u0430\u0431\u043e\u0440\u044b (\u0442\u0443\u0430\u043b\u0435\u0442\u043d\u044b\u0435 \u043f\u0440\u0438\u043d\u0430\u0434\u043b\u0435\u0436\u043d\u043e\u0441\u0442\u0438, \u0442\u0430\u043f\u043e\u0447\u043a\u0438, \u043a\u043e\u0444\u0435, \u0447\u0430\u0439, \u0441\u043d\u0435\u043a\u0438)</li>\n          <li>\u041c\u0435\u043b\u043a\u0438\u0439 \u0440\u0435\u043c\u043e\u043d\u0442 \u0432 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0435 (\u043b\u0430\u043c\u043f\u043e\u0447\u043a\u0438, \u0440\u0443\u0447\u043a\u0438, \u043a\u0440\u0430\u043d\u044b)</li>\n          <li>\u041e\u0431\u0449\u0435\u043d\u0438\u0435 \u0441 \u0433\u043e\u0441\u0442\u044f\u043c\u0438, 24/7</li>\n          <li>\u041e\u0431\u044a\u044f\u0432\u043b\u0435\u043d\u0438\u044f \u043d\u0430 \u0432\u0441\u0435\u0445 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0430\u0445, \u0444\u043e\u0442\u043e, \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u044f</li>\n          <li>\u0413\u0438\u0431\u043a\u043e\u0435 \u0446\u0435\u043d\u043e\u043e\u0431\u0440\u0430\u0437\u043e\u0432\u0430\u043d\u0438\u0435, \u0432\u0435\u0434\u0435\u043d\u0438\u0435 \u043a\u0430\u043b\u0435\u043d\u0434\u0430\u0440\u044f</li>\n          <li>\u041c\u0435\u0441\u044f\u0447\u043d\u044b\u0439 \u0444\u0438\u043d\u0430\u043d\u0441\u043e\u0432\u044b\u0439 \u043e\u0442\u0447\u0451\u0442</li>\n        </ul>\n      </div>\n      <div class=\"side you\">\n        <span class=\"badge\">\u2014 \u0442\u0432\u043e\u044f \u0441\u0442\u043e\u0440\u043e\u043d\u0430</span>\n        <h4>\u041e\u0441\u0442\u0430\u0451\u0442\u0441\u044f \u043d\u0430 \u0442\u0435\u0431\u0435</h4>\n        <ul>\n          <li>\u041a\u043e\u043c\u043c\u0443\u043d\u0430\u043b\u043a\u0430 (\u044d\u043b\u0435\u043a\u0442\u0440\u0438\u0447\u0435\u0441\u0442\u0432\u043e, \u0432\u043e\u0434\u0430, \u0433\u0430\u0437, \u0438\u043d\u0442\u0435\u0440\u043d\u0435\u0442) \u2014 <i>\u0438\u043b\u0438 \u043e\u0442\u0434\u0430\u0439 \u043d\u0430\u043c \u0438 \u044d\u0442\u0443 \u043b\u043e\u0433\u0438\u0441\u0442\u0438\u043a\u0443, \u0441\u043a\u043e\u0440\u043e \u0432\u044b\u043d\u0435\u0441\u0435\u043c \u0432 \u043d\u0430\u0448\u0443 \u043f\u043b\u0430\u0442\u0444\u043e\u0440\u043c\u0443</i></li>\n          <li>\u0421\u0431\u043e\u0440\u044b \u0416\u041a / \u0442\u043e\u0432\u0430\u0440\u0438\u0449\u0435\u0441\u0442\u0432\u0430 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u0438\u043a\u043e\u0432</li>\n          <li>\u0422\u0435\u043a\u0441\u0442\u0438\u043b\u044c, \u043c\u0435\u0431\u0435\u043b\u044c, \u043f\u043e\u0441\u0443\u0434\u0430, \u0434\u0435\u043a\u043e\u0440 (\u0437\u0430\u043c\u0435\u043d\u0430 \u0438 \u043e\u0431\u043d\u043e\u0432\u043b\u0435\u043d\u0438\u0435)</li>\n          <li>\u0420\u0430\u0437\u043e\u0432\u044b\u0435 \u043f\u043e\u043a\u0443\u043f\u043a\u0438 \u0442\u0435\u0445\u043d\u0438\u043a\u0438</li>\n          <li>\u041a\u0430\u043f\u0438\u0442\u0430\u043b\u044c\u043d\u044b\u0439 \u0440\u0435\u043c\u043e\u043d\u0442 (\u0438\u0437\u043d\u043e\u0448\u0435\u043d\u043d\u044b\u0435 \u043f\u043e\u043b\u044b, \u0437\u0430\u043c\u0435\u043d\u0430 \u0442\u0435\u0445\u043d\u0438\u043a\u0438)</li>\n          <li>\u041d\u0430\u043b\u043e\u0433 \u043d\u0430 \u0438\u043c\u0443\u0449\u0435\u0441\u0442\u0432\u043e \u0438 \u0434\u0435\u043a\u043b\u0430\u0440\u0430\u0446\u0438\u0438</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- PROCESS -->\n<section class=\"pad\">\n  <div class=\"container\">\n    <div class=\"section-head\">\n      <div class=\"left\">\n        <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u043a\u0430\u043a \u044d\u0442\u043e \u043f\u0440\u043e\u0438\u0441\u0445\u043e\u0434\u0438\u0442</div>\n        <h2>\u041e\u0442 <em>\u0440\u0443\u043a\u043e\u043f\u043e\u0436\u0430\u0442\u0438\u044f</em><br/>\u0434\u043e \u043f\u0435\u0440\u0432\u043e\u0433\u043e \u0433\u043e\u0441\u0442\u044f.</h2>\n      </div>\n      <div class=\"right\">\u041e\u043a\u043e\u043b\u043e 2 \u043d\u0435\u0434\u0435\u043b\u044c, \u0435\u0441\u043b\u0438 \u0432\u0441\u0451 \u0433\u043e\u0442\u043e\u0432\u043e. \u0414\u043e\u043b\u044c\u0448\u0435 \u2014 \u0435\u0441\u043b\u0438 \u0441\u043d\u0430\u0447\u0430\u043b\u0430 \u043d\u0443\u0436\u0435\u043d home staging \u0438\u043b\u0438 \u0440\u0435\u043c\u043e\u043d\u0442.</div>\n    </div>\n\n    <div class=\"process\">\n      <div class=\"step\">\n        <div class=\"nr\">\u0448\u0430\u0433 01</div>\n        <h4>\u0412\u0441\u0442\u0440\u0435\u0447\u0430</h4>\n        <p>30 \u043c\u0438\u043d\u0443\u0442 \u043f\u043e \u0437\u0432\u043e\u043d\u043a\u0443 \u0438\u043b\u0438 \u0432\u0436\u0438\u0432\u0443\u044e \u043d\u0430 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0435. \u0421\u043c\u043e\u0442\u0440\u0438\u043c, \u0441\u043f\u0440\u0430\u0448\u0438\u0432\u0430\u0435\u043c \u043f\u0440\u043e \u0442\u0432\u043e\u0438 \u0446\u0435\u043b\u0438, \u0431\u044e\u0434\u0436\u0435\u0442, \u043d\u0430\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0445\u043e\u0447\u0435\u0448\u044c \u043e\u0442\u043e\u0439\u0442\u0438 \u043e\u0442 \u0432\u043e\u043f\u0440\u043e\u0441\u0430.</p>\n        <span class=\"arr\">\u2192</span>\n      </div>\n      <div class=\"step\">\n        <div class=\"nr\">\u0448\u0430\u0433 02</div>\n        <h4>Home staging</h4>\n        <p>\u041f\u043e\u0434\u0441\u043a\u0430\u0437\u044b\u0432\u0430\u0435\u043c \u0447\u0442\u043e \u0434\u043e\u0431\u0430\u0432\u0438\u0442\u044c \u0438\u043b\u0438 \u0443\u0431\u0440\u0430\u0442\u044c \u2014 \u0442\u0435\u043a\u0441\u0442\u0438\u043b\u044c, \u043a\u0430\u0440\u0442\u0438\u043d\u044b, \u0441\u0432\u0435\u0442 \u2014 \u0447\u0442\u043e\u0431\u044b \u0445\u043e\u0440\u043e\u0448\u043e \u0441\u043d\u0438\u043c\u0430\u043b\u043e\u0441\u044c \u0438 \u0445\u043e\u0440\u043e\u0448\u043e \u0436\u0438\u043b\u043e\u0441\u044c. \u041f\u043e \u0436\u0435\u043b\u0430\u043d\u0438\u044e, \u043d\u043e \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0443\u0435\u043c.</p>\n        <span class=\"arr\">\u2192</span>\n      </div>\n      <div class=\"step\">\n        <div class=\"nr\">\u0448\u0430\u0433 03</div>\n        <h4>\u0424\u043e\u0442\u043e\u0441\u0435\u0441\u0441\u0438\u044f</h4>\n        <p>\u041d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0439 \u0444\u043e\u0442\u043e\u0433\u0440\u0430\u0444, \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0439 \u0441\u0432\u0435\u0442, \u043d\u0430\u0441\u0442\u043e\u044f\u0449\u0438\u0439 \u0448\u0438\u0440\u0438\u043a. 20\u201440 \u043a\u0430\u0434\u0440\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043d\u0435 \u0432\u0440\u0443\u0442. \u0412\u0441\u0435 \u2014 \u0442\u0432\u043e\u0438.</p>\n        <span class=\"arr\">\u2192</span>\n      </div>\n      <div class=\"step\">\n        <div class=\"nr\">\u0448\u0430\u0433 04</div>\n        <h4>\u0420\u0430\u0437\u043c\u0435\u0449\u0435\u043d\u0438\u0435</h4>\n        <p>\u041f\u0438\u0448\u0435\u043c \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u044f (en + ru), \u043d\u0430\u0441\u0442\u0440\u0430\u0438\u0432\u0430\u0435\u043c Airbnb, Booking, \u043d\u0430\u0448\u0438 \u0441\u043e\u0431\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0435 \u043a\u0430\u043d\u0430\u043b\u044b. \u0417\u0430\u043f\u0443\u0441\u043a \u2014 \u0437\u0430 3 \u0440\u0430\u0431\u043e\u0447\u0438\u0445 \u0434\u043d\u044f.</p>\n        <span class=\"arr\">\u2192</span>\n      </div>\n      <div class=\"step\">\n        <div class=\"nr\">\u0448\u0430\u0433 05</div>\n        <h4>\u041f\u0435\u0440\u0432\u044b\u0439 \u0433\u043e\u0441\u0442\u044c</h4>\n        <p>\u041e\u0431\u044b\u0447\u043d\u043e \u0447\u0435\u0440\u0435\u0437 1\u20143 \u043d\u0435\u0434\u0435\u043b\u0438 \u043f\u043e\u0441\u043b\u0435 \u043f\u0443\u0431\u043b\u0438\u043a\u0430\u0446\u0438\u0438, \u0432 \u0441\u0435\u0437\u043e\u043d \u0431\u044b\u0441\u0442\u0440\u0435\u0435. \u0417\u0430\u0441\u0435\u043b\u0435\u043d\u0438\u0435, \u0432\u0441\u0451 \u043e\u0431\u0449\u0435\u043d\u0438\u0435, \u0443\u0431\u043e\u0440\u043a\u0430 \u2014 \u043d\u0430 \u043d\u0430\u0441.</p>\n        <span class=\"arr\">\u2192</span>\n      </div>\n      <div class=\"step\">\n        <div class=\"nr\">\u0448\u0430\u0433 06</div>\n        <h4>\u0415\u0436\u0435\u043c\u0435\u0441\u044f\u0447\u043d\u044b\u0439 \u0440\u0438\u0442\u043c</h4>\n        <p>\u0412 \u043f\u0435\u0440\u0432\u044b\u0435 \u0434\u043d\u0438 \u043d\u043e\u0432\u043e\u0433\u043e \u043c\u0435\u0441\u044f\u0446\u0430 \u2014 \u043e\u0442\u0447\u0451\u0442 \u0437\u0430 \u043f\u0440\u043e\u0448\u043b\u044b\u0439 \u0432 \u043f\u043e\u0447\u0442\u0443, \u0432\u044b\u043f\u043b\u0430\u0442\u0430 \u043d\u0430 \u0441\u0447\u0451\u0442. \u041e\u0442\u0447\u0451\u0442 \u0438\u0434\u0451\u0442 <b>\u043d\u0430\u043f\u0440\u044f\u043c\u0443\u044e \u0438\u0437 \u043d\u0430\u0448\u0435\u0439 \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0435\u0439 \u0441\u0438\u0441\u0442\u0435\u043c\u044b \u0443\u0447\u0451\u0442\u0430</b> \u2014 \u043a\u0430\u0436\u0434\u0430\u044f \u0441\u0442\u0440\u043e\u043a\u0430 \u043f\u0440\u043e\u0437\u0440\u0430\u0447\u043d\u0430. \u0420\u0430\u0437 \u0432 \u043a\u0432\u0430\u0440\u0442\u0430\u043b \u2014 \u0441\u043e\u0437\u0432\u043e\u043d, \u043e\u0431\u0441\u0443\u0434\u0438\u0442\u044c \u0435\u0441\u043b\u0438 \u0447\u0442\u043e-\u0442\u043e \u043d\u0443\u0436\u043d\u043e \u043f\u043e\u043c\u0435\u043d\u044f\u0442\u044c.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- REPORTING -->\n<section class=\"pad\" style=\"padding-top:0\">\n  <div class=\"container\">\n    <div class=\"section-head\">\n      <div class=\"left\">\n        <div class=\"kicker\"><span class=\"dot\"></span>\u2014 \u0447\u0442\u043e \u0442\u044b \u043f\u043e\u043b\u0443\u0447\u0430\u0435\u0448\u044c \u043a\u0430\u0436\u0434\u044b\u0439 \u043c\u0435\u0441\u044f\u0446</div>\n        <h2>\u0414\u0432\u0435 \u0432\u0435\u0449\u0438,<br/>\u043a\u0430\u0436\u0434\u044b\u0439 <em>\u043c\u0435\u0441\u044f\u0446</em>.</h2>\n      </div>\n    </div>\n\n    <div class=\"report\">\n      <div class=\"card\">\n        <div class=\"icn\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 22 22\" fill=\"none\"><rect x=\"3\" y=\"5\" width=\"16\" height=\"13\" rx=\"1.5\" stroke=\"currentColor\" stroke-width=\"1.5\"/><path d=\"M3 9h16M7 3v4M15 3v4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg></div>\n        <h4>\u041a\u0430\u043b\u0435\u043d\u0434\u0430\u0440\u044c \u0431\u0440\u043e\u043d\u0435\u0439</h4>\n        <p>\u0416\u0438\u0432\u043e\u0439 \u0434\u043e\u0441\u0442\u0443\u043f. \u0412\u0438\u0434\u0438\u0448\u044c \u043a\u0442\u043e \u0432 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0435, \u043a\u043e\u0433\u0434\u0430 \u0437\u0430\u0435\u0437\u0436\u0430\u0435\u0442, \u043a\u043e\u0433\u0434\u0430 \u0432\u044b\u0435\u0437\u0436\u0430\u0435\u0442, \u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0437\u0430\u043f\u043b\u0430\u0442\u0438\u043b. \u041d\u0435 \u043d\u0443\u0436\u043d\u043e \u043d\u0438\u0447\u0435\u0433\u0