<script is:inline set:html={"// category counts \u2014 for prototype hardcoded; on supabase: SELECT category, count(*) FROM guide_posts WHERE status='published' GROUP BY category\n  const CAT_COUNTS = {\n    'stay-live':    14,\n    'eat-drink':    42,\n    'wellness':     18,\n    'nightlife':    12,\n    'experiences':  16,\n    'move-around':   9,\n    'work-remote':   8,\n    'explore':      22\n  };\n  document.querySelectorAll('[data-cat]').forEach(el => {\n    const slot = el.querySelector('[data-count]');\n    if (!slot) return;\n    const cat = el.getAttribute('data-cat');\n    const n = CAT_COUNTS[cat];\n    if (typeof n === 'number') slot.textContent = n;\n  });"}></script>
