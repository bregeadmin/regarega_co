<Fragment set:html={"<section class=\"masthead\">\n  <a class=\"masthead-photo\" href=\"#cats\">\n    <img src=\"https://images.unsplash.com/photo-1604542031658-5799ca5d7936?w=2000&q=80\" alt=\"\u0441\u0442\u0430\u0440\u044b\u0439 \u0433\u043e\u0440\u043e\u0434 \u0411\u0430\u0442\u0443\u043c\u0438\">\n    <div class=\"caption\">\n      <h1>\u0422\u043e\u0442 \u0411\u0430\u0442\u0443\u043c\u0438,<br/>\u0447\u0442\u043e \u043c\u044b <em>\u043f\u0440\u0430\u0432\u0434\u0430</em><br/>\u0441\u043e\u0432\u0435\u0442\u0443\u0435\u043c.</h1>\n      <span class=\"credit\">\u2014 \u043d\u0430\u0448<br/>\u043b\u043e\u043a\u0430\u043b\u044c\u043d\u044b\u0439 \u0436\u0443\u0440\u043d\u0430\u043b</span>\n    </div>\n  </a>\n\n  <div class=\"masthead-side\">\n    <div class=\"masthead-intro\">\n      <div class=\"kicker\">\u043e \u0433\u0430\u0439\u0434\u0435</div>\n      <p class=\"lede\"><b>\u041a\u0430\u0444\u0435, \u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d\u044b, \u043f\u043b\u044f\u0436\u0438, \u0432\u0435\u043b\u043d\u0435\u0441, \u043d\u043e\u0447\u043d\u0430\u044f \u0436\u0438\u0437\u043d\u044c \u0438 \u0432\u0441\u0451 \u0434\u043b\u044f \u0440\u0430\u0431\u043e\u0442\u044b</b> \u2014 \u0441\u043e\u0431\u0440\u0430\u043d\u043d\u044b\u0439 \u043d\u0430\u043c\u0438 \u0441\u043f\u0438\u0441\u043e\u043a \u043c\u0435\u0441\u0442, \u043a\u0443\u0434\u0430 \u043c\u044b \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u043c \u0433\u043e\u0441\u0442\u0435\u0439 \u0438 \u043a\u043e\u0442\u043e\u0440\u044b\u0439 <em>\u0431\u0435\u0437 \u0440\u0430\u0437\u0434\u0443\u043c\u0438\u0439 \u0434\u0430\u043b\u0438 \u0431\u044b \u0434\u0440\u0443\u0433\u0443</em>. \u041d\u0435 \u0441 TripAdvisor, \u043d\u0435 \u043f\u043e\u0434 \u043a\u043b\u0438\u043a\u0438.</p>\n      <div class=\"stats\">\n        <div><span class=\"num\">127</span>\u043c\u0435\u0441\u0442</div>\n        <div><span class=\"num\">+12</span>\u0432 \u044d\u0442\u043e\u043c \u043c\u0435\u0441\u044f\u0446\u0435</div>\n        <div><span class=\"num\">2-3</span>\u0442\u0435\u043a\u0441\u0442\u0430 /\u043d\u0435\u0434</div>\n        <div><span class=\"num\">100%</span>\u043f\u0440\u043e\u0432\u0435\u0440\u0435\u043d\u043e</div>\n      </div>\n    </div>\n\n    <a class=\"masthead-cover\" href=\"/ru/guide/oyster-weekend\">\n      <div class=\"kicker-top\"><span class=\"stamp\">\u0447\u0438\u0442\u0430\u0442\u044c \u043d\u0430 \u043d\u0435\u0434\u0435\u043b\u0435</span></div>\n      <div class=\"body\">\n        <div class=\"top\"><span class=\"dot\"></span>\u0442\u043e\u043b\u044c\u043a\u043e \u0447\u0442\u043e \u00b7 7 \u043c\u0430\u044f</div>\n        <h3>\u0423\u0441\u0442\u0440\u0438\u0447\u043d\u044b\u0439 <em>\u0443\u0438\u043a\u0435\u043d\u0434</em>,<br/>\u0438 \u0433\u0434\u0435 \u0432 \u0411\u0430\u0442\u0443\u043c\u0438<br/>\u043b\u0443\u0447\u0448\u0438\u0439 <span class=\"under\">\u043a\u043e\u0444\u0435</span>.</h3>\n        <div class=\"meta\">\n          <span>4 \u043c\u0438\u043d \u0447\u0438\u0442\u0430\u0442\u044c</span><span class=\"sep\"></span>\n          <span>\u0435\u0441\u0442\u044c \u0438 \u043f\u0438\u0442\u044c</span><span class=\"sep\"></span>\n          <span>\u0442\u0435\u043a\u0441\u0442 \u2014 \u043a\u043e\u043c\u0430\u043d\u0434\u0430 bre</span>\n        </div>\n        <span class=\"arrow\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 14 14\" fill=\"none\"><path d=\"M3 11L11 3M11 3H4.5M11 3V9.5\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n        </span>\n      </div>\n    </a>\n  </div>\n</section>\n\n<section class=\"cats-section\" id=\"cats\">\n  <div class=\"cats-head\">\n    <h2>\u0412\u043e\u0441\u0435\u043c\u044c <em>\u043c\u0438\u0440\u043e\u0432</em>,<br/>\u043e\u0434\u0438\u043d \u0411\u0430\u0442\u0443\u043c\u0438.</h2>\n    <div class=\"right\">\u2014 \u0412\u044b\u0431\u0438\u0440\u0430\u0439 \u043c\u0438\u0440, \u0432 \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u043d\u044b\u0440\u043d\u0443\u0442\u044c. \u041a\u0430\u0436\u0434\u044b\u0439 \u2014 <b>\u0441\u043e\u0431\u0440\u0430\u043d\u043d\u044b\u0439 \u043c\u0438\u043d\u0438-\u0433\u0430\u0439\u0434</b> \u0441\u043e \u0441\u0432\u043e\u0438\u043c\u0438 \u043c\u0435\u0441\u0442\u0430\u043c\u0438, \u043f\u043e\u0434\u043a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u044f\u043c\u0438 \u0438 \u043a\u0430\u0440\u0442\u043e\u0439.</div>\n  </div>\n\n  <div class=\"cats-grid\">\n    <a class=\"cat-tile stay primary featured\" href=\"/ru/\" data-cat=\"stay-live\">\n      <div class=\"top\">\n        <span class=\"num\" data-count>\u2014</span>\n        <span class=\"badge\"><span class=\"pulse\"></span>\u043d\u0430\u0447\u043d\u0438 \u0442\u0443\u0442</span>\n      </div>\n      <h3>\u0416\u0438\u0442\u044c \u0438 \u043e\u0441\u0442\u0430\u0432\u0430\u0442\u044c\u0441\u044f</h3>\n      <div class=\"sub\">\u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b \u00b7 \u043e\u0442\u0435\u043b\u0438 \u00b7 \u0434\u043e\u043b\u0433\u043e\u0441\u0440\u043e\u0447\u043d\u043e</div>\n      <p class=\"desc\">\u043d\u0430\u0448\u0438 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u044b, \u043e\u0442\u0435\u043b\u0438 \u043a\u0443\u0434\u0430 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u043c \u0433\u043e\u0441\u0442\u0435\u0439, \u0440\u0430\u0439\u043e\u043d\u044b \u0433\u0434\u0435 \u0441\u0430\u043c\u0438 \u0436\u0438\u0432\u0451\u043c.</p>\n      <span class=\"cta\">\n        \u0437\u0430\u0431\u0440\u043e\u043d\u0438\u0440\u043e\u0432\u0430\u0442\u044c\n        <svg width=\"11\" height=\"11\" viewBox=\"0 0 11 11\" fill=\"none\"><path d=\"M3 8L8 3M8 3H4M8 3V7\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n      </span>\n    </a>\n\n    <a class=\"cat-tile eat primary\" href=\"/ru/guide/eat-drink/\" data-cat=\"eat-drink\">\n      <div class=\"top\">\n        <span class=\"num\" data-count>\u2014</span>\n        <span class=\"ico\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M4 1V8M4 8C3 8 2.5 8 2.5 9V15M4 8C5 8 5.5 8 5.5 9V15M11 1C9.5 1 9 2 9 3.5C9 5 9.5 6 11 6.5V14.5C11 14.7 11.2 15 11.5 15S12 14.7 12 14.5V6.5C13.5 6 14 5 14 3.5C14 2 13.5 1 12 1\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linecap=\"round\"/></svg></span>\n      </div>\n      <h3>\u0415\u0441\u0442\u044c \u0438 \u043f\u0438\u0442\u044c</h3>\n      <div class=\"sub\">\u043a\u0430\u0444\u0435 \u00b7 \u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d\u044b \u00b7 \u0431\u0430\u0440\u044b</div>\n      <p class=\"desc\">\u043b\u044e\u0431\u0438\u043c\u044b\u0435 \u043a\u0430\u0444\u0435, \u043c\u0435\u0441\u0442\u0430 \u0434\u043b\u044f \u0431\u0440\u0430\u043d\u0447\u0430, \u0440\u0435\u0441\u0442\u043e\u0440\u0430\u043d\u044b, \u043a\u043e\u043a\u0442\u0435\u0439\u043b\u044c\u043d\u044b\u0435 \u0431\u0430\u0440\u044b \u0438 \u043f\u0435\u043a\u0430\u0440\u043d\u0438.</p>\n      <span class=\"go\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 9L9 3M9 3H4M9 3V8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n    </a>\n\n    <a class=\"cat-tile wellness primary\" href=\"#\" data-cat=\"wellness\">\n      <div class=\"top\">\n        <span class=\"num\" data-count>\u2014</span>\n        <span class=\"ico\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M8 2C7 5 5 6 4 7C2.5 8 3 10 5 10.5C7 11 8.5 9.5 8 7M8 7C7.5 5 9 4 11 4.5C13 5 13.5 7 12 8.5C11 9.5 9 9 8 7Z\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n      </div>\n      <h3>\u0412\u0435\u043b\u043d\u0435\u0441</h3>\n      <div class=\"sub\">\u0441\u043f\u0430 \u00b7 \u0431\u0430\u043d\u0438 \u00b7 \u0439\u043e\u0433\u0430 \u00b7 \u043c\u0430\u0441\u0441\u0430\u0436</div>\n      <p class=\"desc\">\u043c\u0435\u0434\u043b\u0435\u043d\u043d\u0430\u044f \u0436\u0438\u0437\u043d\u044c \u043a\u0430\u043a \u043d\u0430\u0434\u043e: \u0441\u0435\u0440\u043d\u044b\u0435 \u0431\u0430\u043d\u0438, \u043c\u0430\u0441\u0441\u0430\u0436\u043d\u044b\u0435, \u0439\u043e\u0433\u0430-\u043a\u043b\u0430\u0441\u0441\u044b.</p>\n      <span class=\"go\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 9L9 3M9 3H4M9 3V8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n    </a>\n\n    <a class=\"cat-tile nightlife primary\" href=\"#\" data-cat=\"nightlife\">\n      <div class=\"top\">\n        <span class=\"num\" data-count>\u2014</span>\n        <span class=\"ico\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M4 2L8 8L12 2M8 8V14M5 14H11\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n      </div>\n      <h3>\u041d\u043e\u0447\u043d\u0430\u044f \u0436\u0438\u0437\u043d\u044c</h3>\n      <div class=\"sub\">\u0432\u0438\u043d\u043d\u044b\u0435 \u0431\u0430\u0440\u044b \u00b7 \u043a\u043b\u0443\u0431\u044b \u00b7 \u043d\u043e\u0447\u043d\u044b\u0435 \u043c\u0435\u0441\u0442\u0430</div>\n      <p class=\"desc\">\u0433\u0434\u0435 \u0432\u044b\u043f\u0438\u0442\u044c \u043f\u043e\u0437\u0434\u043d\u043e, \u043f\u043e\u0442\u0430\u043d\u0446\u0435\u0432\u0430\u0442\u044c \u043a\u0430\u043a \u0441\u043b\u0435\u0434\u0443\u0435\u0442, \u0438\u043b\u0438 \u043d\u0430\u0439\u0442\u0438 \u0432\u0438\u043d\u043d\u044b\u0439 \u0431\u0430\u0440 \u0441 \u0432\u0438\u043d\u0438\u043b\u043e\u043c.</p>\n      <span class=\"go\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 9L9 3M9 3H4M9 3V8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n    </a>\n\n    <a class=\"cat-tile experiences primary\" href=\"#\" data-cat=\"experiences\">\n      <div class=\"top\">\n        <span class=\"num\" data-count>\u2014</span>\n        <span class=\"ico\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><circle cx=\"8\" cy=\"8\" r=\"6\" stroke=\"currentColor\" stroke-width=\"1.3\"/><path d=\"M8 4V8L10.5 9.5\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linecap=\"round\"/></svg></span>\n      </div>\n      <h3>\u0412\u043f\u0435\u0447\u0430\u0442\u043b\u0435\u043d\u0438\u044f</h3>\n      <div class=\"sub\">\u0442\u0443\u0440\u044b \u00b7 \u043c\u0430\u0441\u0442\u0435\u0440-\u043a\u043b\u0430\u0441\u0441\u044b \u00b7 \u043f\u043e\u0435\u0437\u0434\u043a\u0438 \u043d\u0430 \u0434\u0435\u043d\u044c</div>\n      <p class=\"desc\">\u0432\u0438\u043d\u043d\u044b\u0435 \u0434\u0435\u0433\u0443\u0441\u0442\u0430\u0446\u0438\u0438, \u043a\u0443\u043b\u0438\u043d\u0430\u0440\u043d\u044b\u0435 \u043a\u043b\u0430\u0441\u0441\u044b, \u043b\u043e\u0434\u043e\u0447\u043d\u044b\u0435 \u043f\u0440\u043e\u0433\u0443\u043b\u043a\u0438, \u043f\u043e\u0435\u0437\u0434\u043a\u0438, \u043d\u0430 \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0441\u0430\u043c\u0438 \u0432\u0435\u0440\u043d\u0443\u043b\u0438\u0441\u044c \u0431\u044b.</p>\n      <span class=\"go\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 9L9 3M9 3H4M9 3V8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n    </a>\n\n    <a class=\"cat-tile move secondary\" href=\"#\" data-cat=\"move-around\">\n      <div class=\"top\">\n        <span class=\"num\" data-count>\u2014</span>\n        <span class=\"ico\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><circle cx=\"5\" cy=\"11\" r=\"2\" stroke=\"currentColor\" stroke-width=\"1.3\"/><circle cx=\"11\" cy=\"11\" r=\"2\" stroke=\"currentColor\" stroke-width=\"1.3\"/><path d=\"M5 9L7 4H10L12 8M3 4H6\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linecap=\"round\"/></svg></span>\n      </div>\n      <h3>\u041f\u0435\u0440\u0435\u0434\u0432\u0438\u0436\u0435\u043d\u0438\u0435</h3>\n      <div class=\"sub\">\u0442\u0430\u043a\u0441\u0438 \u00b7 \u0430\u0432\u0442\u043e\u0431\u0443\u0441 \u00b7 \u0441\u0430\u043c\u043e\u043a\u0430\u0442 \u00b7 \u043c\u0430\u0448\u0438\u043d\u0430</div>\n      <p class=\"desc\">\u043a\u0430\u043a \u043c\u0435\u0441\u0442\u043d\u044b\u0435 \u043f\u0440\u0430\u0432\u0434\u0430 \u043f\u0435\u0440\u0435\u0434\u0432\u0438\u0433\u0430\u044e\u0442\u0441\u044f. \u041f\u0440\u0438\u043b\u043e\u0436\u0435\u043d\u0438\u044f, \u0430\u0440\u0435\u043d\u0434\u0430, \u043f\u0435\u0448\u0438\u0435 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u044b.</p>\n      <span class=\"go\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 9L9 3M9 3H4M9 3V8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n    </a>\n\n    <a class=\"cat-tile work secondary\" href=\"#\" data-cat=\"work-remote\">\n      <div class=\"top\">\n        <span class=\"num\" data-count>\u2014</span>\n        <span class=\"ico\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><rect x=\"2\" y=\"3\" width=\"12\" height=\"9\" rx=\"1\" stroke=\"currentColor\" stroke-width=\"1.3\"/><path d=\"M5 14H11M8 12V14\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linecap=\"round\"/></svg></span>\n      </div>\n      <h3>\u0414\u043b\u044f \u0440\u0430\u0431\u043e\u0442\u044b</h3>\n      <div class=\"sub\">\u043a\u043e\u0432\u043e\u0440\u043a\u0438\u043d\u0433\u0438 \u00b7 \u043a\u0430\u0444\u0435 \u0441 \u0432\u0430\u0439\u0444\u0430\u0435\u043c</div>\n      <p class=\"desc\">\u043a\u0430\u0444\u0435 \u0441 \u043d\u0430\u0434\u0451\u0436\u043d\u044b\u043c \u0438\u043d\u0442\u0435\u0440\u043d\u0435\u0442\u043e\u043c, \u043a\u043e\u0432\u043e\u0440\u043a\u0438\u043d\u0433\u0438, \u0442\u0438\u0445\u0438\u0435 \u0443\u0433\u043b\u044b \u0434\u043b\u044f \u0433\u043b\u0443\u0431\u043e\u043a\u043e\u0439 \u0440\u0430\u0431\u043e\u0442\u044b.</p>\n      <span class=\"go\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 9L9 3M9 3H4M9 3V8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n    </a>\n\n    <a class=\"cat-tile explore secondary\" href=\"#\" data-cat=\"explore\">\n      <div class=\"top\">\n        <span class=\"num\" data-count>\u2014</span>\n        <span class=\"ico\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M8 1L9.5 6.5L15 8L9.5 9.5L8 15L6.5 9.5L1 8L6.5 6.5L8 1Z\" stroke=\"currentColor\" stroke-width=\"1.3\" stroke-linejoin=\"round\"/></svg></span>\n      </div>\n      <h3>\u041f\u0440\u043e \u0433\u043e\u0440\u043e\u0434</h3>\n      <div class=\"sub\">\u043f\u043b\u044f\u0436\u0438 \u00b7 \u0441\u0442\u0430\u0440\u044b\u0439 \u0433\u043e\u0440\u043e\u0434 \u00b7 \u043f\u0430\u0440\u043a\u0438</div>\n      <p class=\"desc\">\u0440\u0430\u0439\u043e\u043d\u044b \u0411\u0430\u0442\u0443\u043c\u0438, \u043f\u043b\u044f\u0436\u0438, \u043f\u0430\u0440\u043a\u0438 \u0438 \u0432\u0438\u0434\u043e\u0432\u044b\u0435 \u0442\u043e\u0447\u043a\u0438, \u0434\u043e \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0441\u0442\u043e\u0438\u0442 \u0434\u043e\u0439\u0442\u0438.</p>\n      <span class=\"go\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M3 9L9 3M9 3H4M9 3V8\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n    </a>\n  </div>\n</section>\n\n<section class=\"stories-wrap\">\n  <div class=\"stories-head\">\n    <div><h3>\u0414\u043b\u0438\u043d\u043d\u044b\u0435 <em>\u0442\u0435\u043a\u0441\u0442\u044b</em>.</h3></div>\n    <div class=\"right\">\n      <span>\u0418\u0441\u0442\u043e\u0440\u0438\u0438 \u0442\u0440\u0435\u0431\u0443\u044e\u0442 \u0432\u0440\u0435\u043c\u0435\u043d\u0438. \u041f\u0443\u0431\u043b\u0438\u043a\u0443\u0435\u043c \u043f\u043e \u043e\u0434\u043d\u043e\u0439 \u0440\u0430\u0437 \u0432 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043d\u0435\u0434\u0435\u043b\u044c \u2014 <b>\u043b\u044e\u0434\u0438, \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u043b\u044e\u0431\u0438\u043c</b>, <b>\u043f\u0440\u0438\u0432\u044b\u0447\u043d\u044b\u0435 \u043c\u0430\u0440\u0448\u0440\u0443\u0442\u044b</b>, <b>\u0444\u043e\u0442\u043e\u044d\u0441\u0441\u0435</b>.</span>\n      <span class=\"scroll-hint\">\u043b\u0438\u0441\u0442\u0430\u0439 \u2192</span>\n    </div>\n  </div>\n  <div class=\"stories\">\n    <a class=\"story\" href=\"#\">\n      <div class=\"ph\">\n        <img src=\"https://images.unsplash.com/photo-1521336575822-6da63fb45455?w=1200&q=80\" alt=\"\">\n        <span class=\"nr\">people \u00b7 03</span>\n      </div>\n      <span class=\"kicker\">\u0435\u0433\u043e \u0432\u044b\u0431\u043e\u0440</span>\n      <h4>15 \u043c\u0435\u0441\u0442 \u043e\u0442 <em>\u041d\u0438\u043a\u0438</em>,<br/>\u043d\u0430\u0448\u0435\u0433\u043e \u043b\u044e\u0431\u0438\u043c\u043e\u0433\u043e<br/>\u0431\u0430\u0440\u0438\u0441\u0442\u0430.</h4>\n      <p class=\"summary\">\u041f\u043e\u043f\u0440\u043e\u0441\u0438\u043b\u0438 \u041d\u0438\u043a\u0443 \u0438\u0437 Milevski \u043f\u043e\u043a\u0430\u0437\u0430\u0442\u044c \u0435\u0433\u043e \u0411\u0430\u0442\u0443\u043c\u0438 \u2014 \u0433\u0434\u0435 \u0435\u0441\u0442, \u0433\u0434\u0435 \u043f\u044c\u0451\u0442, \u043a\u0443\u0434\u0430 \u043e\u0442\u043f\u0440\u0430\u0432\u043b\u044f\u0435\u0442 \u0434\u0440\u0443\u0437\u0435\u0439 \u0438\u0437-\u0437\u0430 \u0433\u0440\u0430\u043d\u0438\u0446\u044b.</p>\n      <span class=\"read\">\u0447\u0438\u0442\u0430\u0442\u044c \u0438\u043d\u0442\u0435\u0440\u0432\u044c\u044e \u2192</span>\n    </a>\n    <a class=\"story\" href=\"/ru/guide/morning-in-old-batumi\">\n      <div class=\"ph\">\n        <img src=\"https://images.unsplash.com/photo-1604542031658-5799ca5d7936?w=1200&q=80\" alt=\"\">\n        <span class=\"nr\">routine \u00b7 02</span>\n      </div>\n      <span class=\"kicker\">\u043c\u0430\u0440\u0448\u0440\u0443\u0442</span>\n      <h4>\u0423\u0442\u0440\u043e \u0432 <em>\u0421\u0442\u0430\u0440\u043e\u043c \u0411\u0430\u0442\u0443\u043c\u0438</em>.</h4>\n      <p class=\"summary\">\u0422\u0440\u0438 \u043a\u043e\u0444\u0435, \u043a\u043d\u0438\u0436\u043d\u044b\u0439, \u0434\u0432\u0435 \u0446\u0435\u0440\u043a\u0432\u0438, \u0441\u0438\u043d\u0430\u0433\u043e\u0433\u0430 \u0438 \u043e\u0431\u0435\u0434 \u0432 \u043c\u0435\u0441\u0442\u0435 \u0431\u0435\u0437 \u0432\u044b\u0432\u0435\u0441\u043a\u0438.</p>\n      <span class=\"read\">\u0447\u0438\u0442\u0430\u0442\u044c \u043c\u0430\u0440\u0448\u0440\u0443\u0442 \u2192</span>\n    </a>\n    <a class=\"story\" href=\"#\">\n      <div class=\"ph\">\n        <img src=\"https://images.unsplash.com/photo-1554995207-c18c203602cb?w=1200&q=80\" alt=\"\">\n        <span class=\"nr\">photo \u00b7 01</span>\n      </div>\n      <span class=\"kicker\">\u0444\u043e\u0442\u043e\u044d\u0441\u0441\u0435</span>\n      <h4>\u0414\u0435\u043d\u044c <em>\u0432 \u0413\u043e\u043d\u0438\u043e</em>.</h4>\n      <p class=\"summary\">\u041c\u044b\u0441, \u043a\u0440\u0435\u043f\u043e\u0441\u0442\u044c, \u043e\u0431\u0435\u0434 \u0441 \u0440\u044b\u0431\u043e\u0439, \u0435\u0434\u0438\u043d\u0441\u0442\u0432\u0435\u043d\u043d\u044b\u0439 \u0445\u043e\u0440\u043e\u0448\u0438\u0439 \u043f\u043b\u044f\u0436 \u043a \u044e\u0433\u0443 \u043e\u0442 \u0411\u0430\u0442\u0443\u043c\u0438 \u0438 \u043e\u0431\u0440\u0430\u0442\u043d\u044b\u0439 \u043f\u0443\u0442\u044c \u0447\u0435\u0440\u0435\u0437 \u0447\u0430\u0439\u043d\u044b\u0435 \u043f\u043b\u0430\u043d\u0442\u0430\u0446\u0438\u0438.</p>\n      <span class=\"read\">\u043e\u0442\u043a\u0440\u044b\u0442\u044c \u044d\u0441\u0441\u0435 \u2192</span>\n    </a>\n    <a class=\"story\" href=\"#\">\n      <div class=\"ph\">\n        <img src=\"https://images.unsplash.com/photo-1559496417941-fd6b9c34c4ef?w=1200&q=80\" alt=\"\">\n        <span class=\"nr\">deep dive \u00b7 04</span>\n      </div>\n      <span class=\"kicker\">\u043f\u043e\u0433\u0440\u0443\u0436\u0435\u043d\u0438\u0435</span>\n      <h4>\u041f\u043e\u0447\u0435\u043c\u0443 <em>\u0445\u0430\u0447\u0430\u043f\u0443\u0440\u0438</em><br/>\u044d\u0442\u043e \u043d\u0438\u043a\u043e\u0433\u0434\u0430<br/>\u043d\u0435 \u043f\u0440\u043e\u0441\u0442\u043e \u0445\u043b\u0435\u0431.</h4>\n      <p class=\"summary\">\u041c\u0430\u043b\u0435\u043d\u044c\u043a\u0430\u044f \u043e\u0434\u0435\u0440\u0436\u0438\u043c\u043e\u0441\u0442\u044c \u0430\u0434\u0436\u0430\u0440\u0441\u043a\u0438\u043c \u0445\u0430\u0447\u0430\u043f\u0443\u0440\u0438 \u2014 \u043f\u044f\u0442\u044c \u043c\u0435\u0441\u0442, \u043f\u044f\u0442\u044c \u0440\u0435\u0446\u0435\u043f\u0442\u043e\u0432, \u043f\u043e\u0447\u0435\u043c\u0443 \u0432\u0430\u0436\u0435\u043d \u0436\u0435\u043b\u0442\u043e\u043a \u0438 \u0433\u0434\u0435 \u043c\u044b \u043e\u0448\u0438\u0431\u0430\u043b\u0438\u0441\u044c.</p>\n      <span class=\"read\">\u0447\u0438\u0442\u0430\u0442\u044c \u044d\u0441\u0441\u0435 \u2192</span>\n    </a>\n    <a class=\"story\" href=\"#\">\n      <div class=\"ph\">\n        <img src=\"https://images.unsplash.com/photo-1493663284031-b7e3aefcae8e?w=1200&q=80\" alt=\"\">\n        <span class=\"nr\">people \u00b7 05</span>\n      </div>\n      <span class=\"kicker\">\u0435\u0433\u043e \u0432\u044b\u0431\u043e\u0440</span>\n      <h4>10 \u0432\u0438\u043d \u043e\u0442 <em>\u041d\u0438\u043d\u043e</em>,<br/>\u0441\u043e\u043c\u0435\u043b\u044c\u0435<br/>\u0432 8000.</h4>\n      <p class=\"summary\">\u042f\u043d\u0442\u0430\u0440\u043d\u043e\u0435, \u043a\u0432\u0435\u0432\u0440\u0438, \u0441\u0430\u043f\u0435\u0440\u0430\u0432\u0438 \u2014 \u041d\u0438\u043d\u043e \u043f\u0440\u043e\u0432\u043e\u0434\u0438\u0442 \u043d\u0430\u0441 \u043f\u043e \u0434\u0435\u0441\u044f\u0442\u0438 \u0431\u0443\u0442\u044b\u043b\u043a\u0430\u043c, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043e\u0442\u043a\u0440\u044b\u043b\u0430 \u0431\u044b \u0434\u043b\u044f \u0434\u0440\u0443\u0437\u0435\u0439 \u0438\u0437-\u0437\u0430 \u0433\u0440\u0430\u043d\u0438\u0446\u044b.</p>\n      <span class=\"read\">\u0447\u0438\u0442\u0430\u0442\u044c \u0438\u043d\u0442\u0435\u0440\u0432\u044c\u044e \u2192</span>\n    </a>\n    <a class=\"story\" href=\"#\">\n      <div class=\"ph\">\n        <img src=\"https://images.unsplash.com/photo-1545162033-ee5d77b56b22?w=1200&q=80\" alt=\"\">\n        <span class=\"nr\">routine \u00b7 06</span>\n      </div>\n      <span class=\"kicker\">\u043c\u0430\u0440\u0448\u0440\u0443\u0442</span>\n      <h4>\u041c\u0435\u0434\u043b\u0435\u043d\u043d\u043e\u0435 <em>\u0432\u043e\u0441\u043a\u0440\u0435\u0441\u0435\u043d\u044c\u0435</em><br/>\u0432 \u0411\u0430\u0442\u0443\u043c\u0438.</h4>\n      <p class=\"summary\">\u0411\u043b\u043e\u0448\u0438\u043d\u044b\u0439 \u0440\u044b\u043d\u043e\u043a \u043d\u0430 \u041f\u044c\u044f\u0446\u0446\u0435, \u0447\u0430\u0441 \u0432 \u0441\u0435\u0440\u043d\u044b\u0445 \u0431\u0430\u043d\u044f\u0445, \u043e\u0431\u0435\u0434 \u0441 \u0434\u0440\u0443\u0437\u044c\u044f\u043c\u0438, \u0434\u0440\u0451\u043c\u0430. \u041d\u0430\u0448 \u043f\u0440\u043e\u0442\u043e\u043a\u043e\u043b \u0432\u044b\u0445\u043e\u0434\u043d\u043e\u0433\u043e \u0434\u043d\u044f.</p>\n      <span class=\"read\">\u0447\u0438\u0442\u0430\u0442\u044c \u043c\u0430\u0440\u0448\u0440\u0443\u0442 \u2192</span>\n    </a>\n  </div>\n</section>\n\n<section class=\"news-wrap\">\n  <div class=\"news-head\">\n    <div><h3>\u0427\u0442\u043e <em>\u043f\u0440\u043e\u0438\u0441\u0445\u043e\u0434\u0438\u0442</em>.</h3></div>\n    <div class=\"right\">\n      <span>\u0421\u043e\u0431\u044b\u0442\u0438\u044f, \u0440\u0430\u0434\u0438 \u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0441\u0442\u043e\u0438\u0442 \u0432\u044b\u0439\u0442\u0438 \u2014<br/>\u0441\u0432\