<SiteRu title="rega rega \u2014 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0430 \u043d\u0435 \u043d\u0430\u0439\u0434\u0435\u043d\u0430">
<Fragment set:html={"<div class=\"wrap\">\n    <div class=\"stamp\"><span class=\"dot\"></span>404 \u00b7 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u0430 \u043d\u0435 \u043d\u0430\u0439\u0434\u0435\u043d\u0430</div>\n    <h1>\u044d\u0442\u043e\u0439 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u044b <em>\u043d\u0435</em> \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442.</h1>\n    <p>\u043c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c, \u043e\u043d\u0430 \u043f\u0435\u0440\u0435\u0435\u0445\u0430\u043b\u0430. \u041c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c, \u043c\u044b \u0435\u0451 \u0435\u0449\u0451 \u043d\u0435 \u043f\u043e\u0441\u0442\u0440\u043e\u0438\u043b\u0438. \u041c\u043e\u0436\u0435\u0442 \u0431\u044b\u0442\u044c, \u043e\u0448\u0438\u0431\u0441\u044f \u0432 \u0430\u0434\u0440\u0435\u0441\u0435. \u041d\u0438\u0447\u0435\u0433\u043e \u0441\u0442\u0440\u0430\u0448\u043d\u043e\u0433\u043e \u2014 \u0432\u044b\u0431\u0435\u0440\u0438 \u043e\u0434\u043d\u0443 \u0438\u0437 \u0434\u0432\u0435\u0440\u0435\u0439 \u043d\u0438\u0436\u0435.</p>\n    <div class=\"links\">\n      <a class=\"btn\" href=\"/ru/\">\u2190 \u043d\u0430 \u0433\u043b\u0430\u0432\u043d\u0443\u044e</a>\n      <a class=\"btn alt\" href=\"/ru/guide\">the guide</a>\n      <a class=\"btn alt\" href=\"https://t.me/bre_ge\">\u2197 telegram</a>\n    </div>\n  </div>" } />
