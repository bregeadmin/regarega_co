---
import Site from '../layouts/Site.astro';
import '../styles/guide-hub.css';
import { supabase } from '../lib/supabase';
import { GMAPS_KEY } from '../lib/maps';
import news from '../data/news.json';

const { data: gp } = await supabase
  .from('guide_places').select('slug,title,name,category,lat,lng,photos,price,show_on_map')
  .eq('status', 'published');
const places = gp || [];
const counts: Record<string, number> = {};
places.forEach((p) => { counts[p.category] = (counts[p.category] || 0) + 1; });
const { data: apts } = await supabase.from('apartments_public').select('slug,title,lat,lng,photos,price_from');
const aptCount = (apts || []).length;
const total = places.length;

const CAT_COLOR: Record<string, string> = { 'eat-drink': '#ff5e1a', 'wellness': '#00b5b0', 'work': '#7f77dd', 'move-around': '#3D5AFE' };
const placePins = places.filter((p) => p.show_on_map && p.lat != null && p.lng != null).map((p) => ({
  slug: 'g-' + p.slug, title: p.title || p.name, lat: p.lat, lng: p.lng,
  photo: (p.photos && p.photos[0]) || '', href: '/guide/' + p.slug,
  sub: String(p.category).replace('-', ' '), cta: p.price || 'see place →',
  color: CAT_COLOR[p.category] || '#ff5e1a', ring: '#ffffff',
}));
const aptPins = (apts || []).filter((a) => a.lat != null && a.lng != null).map((a) => ({
  slug: 'a-' + a.slug, title: a.title, lat: a.lat, lng: a.lng,
  photo: (a.photos && a.photos[0]) || '', href: '/stays/' + a.slug,
  sub: 'bre flat', cta: a.price_from ? ('₾' + a.price_from + ' / night') : 'on request',
  color: '#ff5e1a', ring: '#0a0908',
}));
const mapData = placePins.concat(aptPins);

const esc = (s: any) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const goArrow = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

// category tiles — real worlds wired + counts; future worlds kept as placeholders (— / coming)
const ICO = {
  eat: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 1V8M4 8C3 8 2.5 8 2.5 9V15M4 8C5 8 5.5 8 5.5 9V15M11 1C9.5 1 9 2 9 3.5C9 5 9.5 6 11 6.5V14.5C11 14.7 11.2 15 11.5 15S12 14.7 12 14.5V6.5C13.5 6 14 5 14 3.5C14 2 13.5 1 12 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  wellness: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2C7 5 5 6 4 7C2.5 8 3 10 5 10.5C7 11 8.5 9.5 8 7M8 7C7.5 5 9 4 11 4.5C13 5 13.5 7 12 8.5C11 9.5 9 9 8 7Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  nightlife: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 2L8 8L12 2M8 8V14M5 14H11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  experiences: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.3"/><path d="M8 4V8L10.5 9.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  move: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="5" cy="11" r="2" stroke="currentColor" stroke-width="1.3"/><circle cx="11" cy="11" r="2" stroke="currentColor" stroke-width="1.3"/><path d="M5 9L7 4H10L12 8M3 4H6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  work: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="9" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M5 14H11M8 12V14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  explore: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 1L9.5 6.5L15 8L9.5 9.5L8 15L6.5 9.5L1 8L6.5 6.5L8 1Z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>',
};
const CATS = [
  { cls: 'stay primary featured', href: '/stays', n: aptCount || '', h: 'stay &amp; live', sub: 'flats · hotels · long-term', desc: 'our flats, hotels we send guests to, neighbourhoods we live in.', featured: true },
  { cls: 'eat primary', href: '/guide/eat-drink', n: counts['eat-drink'] || 0, ico: ICO.eat, h: 'eat &amp; drink', sub: 'cafés · restaurants · bars', desc: 'our favourite cafés, brunch spots, restaurants, cocktail bars and bakeries.' },
  { cls: 'wellness primary', href: '/guide/wellness', n: counts['wellness'] || 0, ico: ICO.wellness, h: 'wellness', sub: 'spa · baths · yoga · massage', desc: 'slow living done right: sulphur baths, massage rooms, spa days.' },
  { cls: 'nightlife primary', href: '#', n: '—', ico: ICO.nightlife, h: 'nightlife', sub: 'wine bars · clubs · late spots', desc: 'where to drink late, dance properly, or find a wine bar with vinyl.', soon: true },
  { cls: 'experiences primary', href: '#', n: '—', ico: ICO.experiences, h: 'experiences', sub: 'tours · classes · day trips', desc: 'wine tastings, cooking classes, boat trips, day trips we\'d go on again.', soon: true },
  { cls: 'move secondary', href: '/guide/move-around', n: counts['move-around'] || 0, ico: ICO.move, h: 'move around', sub: 'taxi · scooter · car', desc: 'how locals actually get around. apps, rentals, the ones we use.' },
  { cls: 'work secondary', href: '/guide/work', n: counts['work'] || 0, ico: ICO.work, h: 'work &amp; remote', sub: 'co-workings · cafes with wifi', desc: 'cafés with reliable wifi, co-workings, and quiet corners for deep work.' },
  { cls: 'explore secondary', href: '#', n: '—', ico: ICO.explore, h: 'explore', sub: 'beaches · old town · parks', desc: 'batumi\'s neighbourhoods, beaches, parks and viewpoints worth a walk.', soon: true },
];
const tile = (c: any) => {
  const top = '<div class="top"><span class="num">' + c.n + '</span>' +
    (c.featured ? '<span class="badge"><span class="pulse"></span>start here</span>'
      : (c.soon ? '<span class="badge" style="opacity:.6">soon</span>' : '<span class="ico">' + c.ico + '</span>')) + '</div>';
  const foot = c.featured ? '<span class="cta">book a stay' + goArrow + '</span>' : '<span class="go">' + goArrow + '</span>';
  return '<a class="cat-tile ' + c.cls + '" href="' + c.href + '" data-cat="' + esc(c.h) + '">' + top +
    '<h3>' + c.h + '</h3><div class="sub">' + c.sub + '</div><p class="desc">' + c.desc + '</p>' + foot + '</a>';
};
const catsHtml = CATS.map(tile).join('');

// latest-news cover plate (restored) — top news item from tilda
const fmtDate = (d: string) => { const m = (d || '').match(/(\d{4})-(\d{2})-(\d{2})/); if (!m) return 'this week'; const mo = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'][+m[2] - 1]; return (+m[3]) + ' ' + mo; };
const newsArr = news as any[];
const slidesHtml = newsArr.map((nx, i) =>
  '<a class="cover-slide' + (i === 0 ? ' active' : '') + '" href="/guide/news/' + nx.slug + '">' +
  '<img class="cs-bg" src="' + esc(nx.image || (nx.photos && nx.photos[0]) || '') + '" alt=""><span class="cs-tint"></span><span class="cs-shade"></span>' +
  '<div class="body"><div class="top"><span class="dot"></span>just posted · ' + esc(fmtDate(nx.date)) + '</div>' +
  '<h3>' + esc(String(nx.title).slice(0, 80)) + '</h3>' +
  '<div class="meta"><span>news</span><span class="sep"></span><span>by the bre team</span></div>' +
  '<span class="arrow"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 11L11 3M11 3H4.5M11 3V9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></div></a>'
).join('');
const dotsHtml = newsArr.length > 1 ? '<div class="rot-dots">' + newsArr.map((_, i) => '<button class="rot-dot' + (i === 0 ? ' active' : '') + '" data-i="' + i + '" aria-label="news ' + (i + 1) + '"></button>').join('') + '</div>' : '';
const coverHtml = newsArr.length ? (
  '<div class="masthead-cover rotator"><div class="kicker-top"><span class="stamp">latest · this week</span></div>' +
  '<div class="slides">' + slidesHtml + '</div>' + dotsHtml + '</div>'
) : '';

// longreads (stories) — templates kept; articles to be written
const storiesHtml = (
  '<a class="story" href="#"><div class="ph"><img src="https://images.unsplash.com/photo-1521336575822-6da63fb45455?w=1200&q=80" alt=""><span class="nr">people · 03</span></div><span class="kicker">mr. x recommends</span><h4>15 places by<br/><em>nika</em>, our<br/>favourite barista.</h4><p class="summary">we asked nika from milevski to show us his batumi — where he eats, drinks, and sends friends from abroad.</p><span class="read">read interview →</span></a>' +
  '<a class="story" href="/guide/morning-in-old-batumi"><div class="ph"><img src="https://images.unsplash.com/photo-1604542031658-5799ca5d7936?w=1200&q=80" alt=""><span class="nr">routine · 02</span></div><span class="kicker">routine</span><h4>a morning in <em>old batumi</em>.</h4><p class="summary">three coffees, a bookstore, two churches, the synagogue, and lunch at a place with no sign.</p><span class="read">read routine →</span></a>' +
  '<a class="story" href="#"><div class="ph"><img src="https://images.unsplash.com/photo-1554995207-c18c203602cb?w=1200&q=80" alt=""><span class="nr">photo · 01</span></div><span class="kicker">photo essay</span><h4>one day <em>in gonio</em>.</h4><p class="summary">cape, fortress, a fish lunch, the best beach south of batumi, and the trip back through tea plantations.</p><span class="read">open the essay →</span></a>' +
  '<a class="story" href="#"><div class="ph"><img src="https://images.unsplash.com/photo-1559496417941-fd6b9c34c4ef?w=1200&q=80" alt=""><span class="nr">deep dive · 04</span></div><span class="kicker">deep dive</span><h4>why <em>khachapuri</em> is never just bread.</h4><p class="summary">a small obsession with adjaran khachapuri — five places, five recipes, why the yolk matters.</p><span class="read">read essay →</span></a>'
);

// news — real items from tilda
const newsHtml = (news as any[]).map((n) =>
  '<a class="news-card" href="/guide/news/' + n.slug + '"><div class="ph"><img src="' + esc(n.image) + '" alt=""></div>' +
  '<div class="body"><span class="date"><span class="pulse"></span>' + esc(fmtDate(n.date)) + '</span>' +
  '<h4>' + esc(String(n.title).slice(0, 80)) + '</h4>' +
  '<p class="summary">' + esc(n.descr) + '</p></div></a>'
).join('');

const content =
  '<section class="masthead">' +
    '<a class="masthead-photo" href="#cats"><img src="https://images.unsplash.com/photo-1604542031658-5799ca5d7936?w=2000&q=80" alt="batumi old town">' +
    '<div class="caption"><h1>the batumi<br/>we <em>actually</em><br/>recommend.</h1><span class="credit">— our own<br/>local journal</span></div></a>' +
    '<div class="masthead-side"><div class="masthead-intro"><div class="kicker">about the guide</div>' +
      '<p class="lede"><b>cafés, restaurants, wellness, work spots and how to get around</b> — places we send our guests to, and would <em>hand to a friend without thinking</em>. not from tripadvisor, not optimised for clicks.</p>' +
      '<div class="stats"><div><span class="num">' + total + '</span>places</div><div><span class="num">4</span>worlds</div><div><span class="num">100%</span>tried by us</div></div></div>' +
      coverHtml +
    '</div>' +
  '</section>' +

  '<section class="cats-section" id="cats"><div class="cats-head"><h2>our <em>worlds</em>,<br/>one batumi.</h2>' +
    '<div class="right">— pick a world to dive in. each is <b>a curated mini-guide</b> with its own places, sub-categories, and a map.</div></div>' +
    '<div class="cats-grid">' + catsHtml + '</div></section>' +

  '<section class="stories-wrap"><div class="stories-head"><div><h3>longer <em>reads</em>.</h3></div>' +
    '<div class="right"><span>stories take time. we publish one every few weeks — <b>people we love</b>, <b>routines we keep</b>, <b>photo essays</b>.</span><span class="scroll-hint">scroll →</span></div></div>' +
    '<div class="stories">' + storiesHtml + '</div></section>' +

  '<section class="news-wrap" id="news"><div class="news-head"><div><h3>what\'s <em>happening</em>.</h3></div>' +
    '<div class="right"><span>news worth showing up for —<br/>fresh from batumi</span><span class="scroll-hint">scroll →</span></div></div>' +
    '<div class="news-scroll">' + newsHtml + '</div></section>' +

  '<section class="pull"><blockquote>we don\'t <span class="under"><em>rate</em></span>.<br/>we just <span class="under"><em>recommend</em></span>.</blockquote><div class="sig">— bre, batumi</div></section>' +

  '<section class="mapblock" id="map"><div class="mapblock-head"><h3>everything we love,<br/><em>on a map</em>.</h3>' +
    '<div class="right"><span class="legend">' +
      '<span class="dot"><span class="sw" style="background:#ff5e1a"></span>eat</span>' +
      '<span class="dot"><span class="sw" style="background:#00b5b0"></span>wellness</span>' +
      '<span class="dot"><span class="sw" style="background:#7f77dd"></span>work</span>' +
      '<span class="dot"><span class="sw" style="background:#ff5e1a;box-shadow:0 0 0 2px #0a0908"></span>bre flat</span>' +
    '</span></div></div>' +
    '<div class="map"><div id="guideMap"></div></div></section>' +
  '<a class="map-fab" href="#map" aria-label="open the map"><svg viewBox="0 0 48 48" class="mini"><defs><clipPath id="mfc"><circle cx="24" cy="24" r="24"/></clipPath></defs><g clip-path="url(#mfc)"><rect width="48" height="48" fill="#f4f0e7"/><path d="M0 37 Q14 33 26 35 T48 29 L48 48 L0 48 Z" fill="#bfdaee" opacity="0.6"/><path d="M0 37 Q14 33 26 35 T48 29" stroke="#7bafd2" stroke-width="1.2" fill="none" opacity="0.7"/><line x1="0" y1="17" x2="48" y2="17" stroke="#00000010" stroke-width="2"/><line x1="17" y1="0" x2="17" y2="48" stroke="#00000010" stroke-width="2"/><line x1="34" y1="0" x2="34" y2="48" stroke="#00000010" stroke-width="2"/><circle cx="20" cy="19" r="3.4" fill="#ff5e1a" stroke="#fff" stroke-width="1.5"/><circle cx="33" cy="26" r="2.6" fill="#00b5b0" stroke="#fff" stroke-width="1.3"/></g></svg><span class="map-fab-label">map</span></a>';
---
<Site title={"the batumi guide — rega rega"}>
<Fragment set:html={content} />
<style is:inline set:html={"#guideMap{position:absolute;inset:0;width:100%;height:100%}\n.masthead-cover.rotator{position:relative}\n.masthead-cover.rotator .slides{position:absolute;inset:0;overflow:hidden;z-index:1}\n.masthead-cover .cover-slide{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;color:#fff;transform:translateY(100%);opacity:0;transition:transform .6s cubic-bezier(.2,.7,.2,1),opacity .5s ease;pointer-events:none;overflow:hidden}\n.masthead-cover .cover-slide.active{transform:translateY(0);opacity:1;pointer-events:auto}\n.masthead-cover .cover-slide.leaving{transform:translateY(-100%);opacity:0}\n.masthead-cover .cs-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;filter:grayscale(1) contrast(1.05)}\n.masthead-cover .cs-tint{position:absolute;inset:0;z-index:1;background:#ff5e1a;mix-blend-mode:multiply}\n.masthead-cover .cs-shade{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(255,94,26,.22) 0%,rgba(255,94,26,0) 38%,rgba(10,9,8,.58) 100%)}\n.masthead-cover .cover-slide .body{position:relative;z-index:2}\n.masthead-cover .rot-dots{position:absolute;bottom:14px;right:18px;z-index:5;display:flex;gap:6px}\n.masthead-cover .rot-dot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.4);border:0;cursor:pointer;padding:0;transition:background .2s ease}\n.masthead-cover .rot-dot.active{background:#fff}\n.map-fab{position:fixed;right:20px;bottom:20px;z-index:60;width:60px;height:60px;border-radius:50%;overflow:hidden;border:2.5px solid var(--ink);box-shadow:0 6px 20px rgba(0,0,0,.28);transition:transform .2s ease}\n.map-fab .mini{width:100%;height:100%;display:block}\n.map-fab .map-fab-label{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(10,9,8,.6);color:#fff;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.2em;text-transform:uppercase;font-weight:700;opacity:0;transition:opacity .2s ease}\n.map-fab:hover{transform:scale(1.08)}\n.map-fab:hover .map-fab-label{opacity:1}"}></style>
<script is:inline>
(function(){
  var rot=document.querySelector('.masthead-cover.rotator'); if(!rot) return;
  var slides=rot.querySelectorAll('.cover-slide'), dots=rot.querySelectorAll('.rot-dot');
  if(slides.length<2) return;
  var i=0, t;
  function go(n){ var prev=i; i=(n+slides.length)%slides.length; if(prev!==i){ slides[prev].classList.add('leaving'); slides[prev].classList.remove('active'); (function(p){ setTimeout(function(){ slides[p].classList.remove('leaving'); },650); })(prev); } if(dots[prev])dots[prev].classList.remove('active'); slides[i].classList.add('active'); if(dots[i])dots[i].classList.add('active'); }
  function start(){ t=setInterval(function(){ go(i+1); },5000); }
  dots.forEach(function(d){ d.addEventListener('click',function(e){ e.preventDefault(); clearInterval(t); go(+d.getAttribute('data-i')); start(); }); });
  start();
})();
</script>
<script is:inline src="/rega-map.js"></script>
<script is:inline set:html={'const MAP_DATA=' + JSON.stringify(mapData) + ';window.__initGuideMap=function(){RegaMap.stays("guideMap",MAP_DATA,{cardSel:".__no-list"});};'}></script>
<script is:inline async src={'https://maps.googleapis.com/maps/api/js?key=' + GMAPS_KEY + '&callback=__initGuideMap&loading=async&language=en&region=GE'}></script>
</Site>
