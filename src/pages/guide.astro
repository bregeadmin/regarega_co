"round\" stroke-linejoin=\"round\"/></svg>\n        </a>\n      </div>\n    </div>\n    <span class=\"pin\" style=\"left:52%;top:42%;background:var(--accent)\"></span>\n    <span class=\"pin\" style=\"left:58%;top:18%;background:var(--purple)\"></span>\n    <span class=\"pin\" style=\"left:64%;top:38%;background:var(--accent)\"></span>\n    <span class=\"pin\" style=\"left:72%;top:48%;background:var(--teal)\"></span>\n    <span class=\"pin\" style=\"left:84%;top:52%;background:var(--accent)\"></span>\n    <span class=\"pin\" style=\"left:20%;top:50%;background:var(--purple)\"></span>\n    <span class=\"pin\" style=\"left:28%;top:65%;background:var(--yellow)\"></span>\n    <span class=\"pin\" style=\"left:40%;top:55%;background:var(--teal)\"></span>\n    <span class=\"pin\" style=\"left:50%;top:62%;background:var(--accent)\"></span>\n\n    <span class=\"pin apt\" style=\"left:42%;top:36%\"></span>\n    <span class=\"pin apt\" style=\"left:34%;top:48%\"></span>\n    <span class=\"pin apt\" style=\"left:80%;top:60%\"></span>\n  </div>\n</section>"} />
