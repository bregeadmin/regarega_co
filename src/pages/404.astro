---
// Global catch-all 404 → builds to dist/404.html, which Vercel serves for
// any unmatched route (EN or RU). Branded, with doors back into the site.
import Site from '../layouts/Site.astro';
---
<Site title={'rega rega — page not found'}>
<Fragment set:html={'<div class="wrap">\n    <div class="stamp"><span class="dot"></span>404 · page not found</div>\n    <h1>this page <em>doesn\'t</em> exist.</h1>\n    <p>maybe it moved, maybe we haven\'t built it yet, maybe you mistyped the address. no worries — try one of the doors below.</p>\n    <div class="links">\n      <a class="btn" href="/georgia/batumi">← home</a>\n      <a class="btn alt" href="/georgia/batumi/stays">apartments</a>\n      <a class="btn alt" href="/georgia/batumi/guide">the guide</a>\n      <a class="btn alt" href="https://t.me/bre_ge">↗ telegram</a>\n    </div>\n  </div>'} />
<style is:global set:html={'.wrap{max-width:640px;text-align:left;padding:160px 28px 96px;margin:0 auto}\n.wrap h1{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:clamp(40px,7vw,84px);line-height:.95;letter-spacing:-.04em;text-transform:lowercase;margin-bottom:18px}\n.wrap h1 em{font-style:italic;color:var(--accent)}\n.wrap p{font-size:18px;line-height:1.55;color:var(--ink-soft);max-width:46ch}\n.stamp{\n    display:inline-flex;align-items:center;gap:10px;\n    font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;\n    text-transform:uppercase;font-weight:600;color:var(--accent-deep);background:var(--accent-soft);padding:5px 11px;border-radius:999px;\n    margin-bottom:24px;\n  }\n.stamp .dot{width:7px;height:7px;border-radius:50%;background:var(--accent)}\n.links{margin-top:36px;display:flex;flex-wrap:wrap;gap:10px}\n.links .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 22px;border-radius:999px;font-family:"JetBrains Mono",monospace;font-size:11px;letter-spacing:.22em;text-transform:uppercase;font-weight:700;transition:all .2s ease;border:1px solid var(--ink);background:var(--ink);color:#FAF7F0}\n.links .btn:hover{background:var(--accent);border-color:var(--accent)}\n.links .btn.alt{background:transparent;color:var(--ink)}\n.links .btn.alt:hover{background:var(--ink);color:#FAF7F0;border-color:var(--ink)}\n@media(max-width:880px){.wrap{padding:120px 16px 64px}}'}></style>
</Site>
