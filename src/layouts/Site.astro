---
// Shared shell for the Rega Rega Batumi edition — edit nav/logo/footer ONCE here.
// Path-aware: highlights the active page, builds the RU link from the current path,
// and applies a per-page accent (--page) passed as a prop.
import '../styles/shell.css';

export interface Props {
  title?: string;
  description?: string;
  accent?: string;       // --page  (per-page accent)
  accentDeep?: string;   // --page-deep
}
const {
  title = 'rega rega — apartments & the batumi guide',
  description = 'checked flats and a city guide. batumi edition. local operations by bre.',
  accent = 'var(--accent)',
  accentDeep = 'var(--accent-deep)',
} = Astro.props;

// normalise current path (strip trailing slash, keep "/")
const path = (Astro.url.pathname.replace(/\/$/, '') || '/');
const isActive = (href: string) => path === href;
const ru = path === '/' ? '/ru/' : `/ru${path}`;

const nav = [
  { href: '/stays', label: 'stays' },
  { href: '/guide', label: 'guide' },
  { href: '/own', label: 'own with us' },
  { href: '/invest', label: 'invest' },
];
const bodyStyle = `--page:${accent};--page-deep:${accentDeep}`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@10..48,200..900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#0a0908" />
</head>
<body style={bodyStyle}>
<span id="flyingDot"></span>
<div class="cursor" id="cursor"></div>

<header class="topbar" id="top">
  <div class="left">
    <a class="home-dot" href="/" aria-label="home"></a>
    {nav.map((n) => (
      <a href={n.href} class:list={[{ active: isActive(n.href) }]}>{n.label}</a>
    ))}
  </div>
  <a href="/" class="ctr" title="home">rega<span class="d"></span><span class="twin">rega</span></a>
  <div class="right">
    <a href="#" class="city">batumi <span class="arr">▾</span></a>
    <a href={ru} class="lang">ru</a>
    <button class="burger" id="burger" aria-label="menu" type="button"><span></span><span></span></button>
  </div>
</header>

<div class="menu-overlay" id="menuOverlay" hidden>
  <div class="menu-inner">
    {nav.map((n) => (
      <a href={n.href} class:list={['menu-item', { active: isActive(n.href) }]}>{n.label}</a>
    ))}
    <a href="/contact" class:list={['menu-item', { active: isActive('/contact') }]}>contact</a>
    <div class="menu-foot">
      <div class="menu-row"><span class="menu-row-label">language</span><a href={ru} class="menu-row-val"><b>en</b> · ru</a></div>
      <a href="https://t.me/bre_ge" class="menu-tg">↗ telegram @bre_ge</a>
    </div>
  </div>
</div>

<slot />

<footer>
  <div class="foot-line">
    <div class="foot-left">
      <span class="foot-copy">© 2026 rega rega · local operations by bre</span>
      <span class="sep">·</span>
      <a href="/stays">stays</a>
      <a href="/guide">guide</a>
      <a href="/own">own</a>
      <a href="/invest">invest</a>
      <a href="/about">about</a>
      <a href="/contact">contact</a>
      <span class="sep">·</span>
      <a href="/privacy">privacy</a>
      <a href="/terms">terms</a>
      <a href="/agents">agents</a>
    </div>
    <div class="foot-right">
      <a href={ru} class="foot-lang">RU · <b>EN</b></a>
      <a href="#" class="foot-top" onclick="event.preventDefault();window.scrollTo(0,0)">↑ back to top</a>
    </div>
  </div>
</footer>
</body>
</html>
