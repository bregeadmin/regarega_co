---
// Base layout — html shell, fonts, global brand tokens.
import '../styles/tokens.css';
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'rega rega · find a flat. fall for the city.',
  description = 'the city-stay platform. checked flats and a city guide, batumi edition.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@10..48,200..900&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>
