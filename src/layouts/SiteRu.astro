---
import '../styles/shell.css';
import '../styles/date-sheet.css';
export interface Props { title?: string; description?: string; ogTitle?: string; ogDescription?: string; accent?: string; accentDeep?: string; image?: string; ogType?: string; }
const {
  title = 'rega rega — квартиры и гайд по батуми',
  description = 'проверенные квартиры и гайд по батуми. локальные операции — bre.',
  accent = 'var(--accent)',
  accentDeep = 'var(--accent-deep)',
  image = '/og/default-ru.png',
  ogType = 'website',
} = Astro.props;
// Social preview text: the OG card image is the hero — keep link-preview text minimal.
// ogTitle defaults to the page title; pass ogDescription='' to drop og/twitter description entirely.
const ogTitle = Astro.props.ogTitle ?? title;
const ogDescription = Astro.props.ogDescription === undefined ? description : Astro.props.ogDescription;
// Language toggle → same page in English (not the EN home).
const enHref = Astro.url.pathname.replace(/^\/ru/, '') || '/';
// Absolute URLs for social link previews (Open Graph needs absolute).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
---
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="rega rega" />
  <meta property="og:locale" content="ru_RU" />
  <meta property="og:title" content={ogTitle} />
  {ogDescription && <meta property="og:description" content={ogDescription} />}
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:alt" content={ogTitle} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle} />
  {ogDescription && <meta name="twitter:description" content={ogDescription} />}
  <meta name="twitter:image" content={ogImage} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@10..48,200..900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="icon" href="/favicon.ico?v=2" sizes="48x48" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=2" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=2" />
  <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png?v=7" />
  <meta name="theme-color" content="#0a0908" />
  <link rel="manifest" href="/manifest.webmanifest" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Rega Rega" />
  <script is:inline>if('serviceWorker' in navigator){window.addEventListener('load',function(){navigator.serviceWorker.register('/sw.js').catch(function(){});});}</script>
  <!-- Google Analytics (GA4) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-Y7CLMKHX41" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-Y7CLMKHX41');
  </script>
  <!-- Operator referral mode: a guest arriving from an operator's own site (?from=<op>)
       sees only that operator's apartments until they choose to see all of rega rega. -->
  <script is:inline>
    (function(){
      var OP_IDS = { bre:'041fc1a6-8452-446a-921e-2a8544fab809', sunset:'f05b7eaf-8de8-4eda-a0a1-3093b5b75f3f' };
      try {
        var from = new URLSearchParams(location.search).get('from');
        if (from) sessionStorage.setItem('rr_op', from);
        window.__rrOp = sessionStorage.getItem('rr_op') || '';
      } catch(e) { window.__rrOp = ''; }
      window.__rrOpId = (window.__rrOp && OP_IDS[window.__rrOp]) || '';
      window.__rrClearOp = function(){ try{ sessionStorage.removeItem('rr_op'); }catch(e){} window.__rrOp=''; window.__rrOpId=''; };
    })();
  </script>
</head>
<body style={`--page:${accent};--page-deep:${accentDeep}`}>
<a class="skip-link" href="#main">к содержимому</a>
<span id="flyingDot"></span>
<a class="brand-sign" href="/ru/georgia/batumi" aria-label="rega rega — на главную"><svg viewBox="0 0 100 100" aria-hidden="true"><path fill-rule="evenodd" fill="#FF5E1A" d="M 50,50 m -50,0 a 50,50 0 1,1 100,0 a 50,50 0 1,1 -100,0 z M 64,64 m -12,0 a 12,12 0 1,1 24,0 a 12,12 0 1,1 -24,0 z"/></svg></a>

<header class="topbar" id="top">
  <div class="left">
    <a href="/ru/georgia/batumi/stays">квартиры</a>
    <a href="/ru/georgia/batumi/guide">гайд</a>
  </div>
