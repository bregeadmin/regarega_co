---
import type { Apartment } from '../lib/supabase';
interface Props { apt: Apartment; }
const { apt } = Astro.props;
const photo = (apt.photos && apt.photos[0]) || 'https://picsum.photos/seed/' + apt.slug + '/1200/900';
---
<a class="apt-card" href={`/stays/${apt.slug}`}>
  <div class="apt-photo"><img src={photo} alt={apt.title} loading="lazy" /></div>
  <div class="apt-body">
    <div class="apt-top">
      <h3 class="apt-title">{apt.title}</h3>
      {apt.neighborhood && <span class="apt-hood">{apt.neighborhood}</span>}
    </div>
    {apt.summary && <p class="apt-sum">{apt.summary}</p>}
    <div class="apt-meta">
      <span>{apt.bedrooms ?? 1} bd</span><i>·</i>
      <span>{apt.max_guests ?? 2} guests</span>
      {apt.price_from && <span class="apt-price">from ₾{apt.price_from} / night</span>}
    </div>
  </div>
</a>

<style>
.apt-card{display:flex;flex-direction:column;text-decoration:none;color:var(--ink);background:var(--paper,#fdfbf6);border:1px solid var(--line,#0a090818);border-radius:14px;overflow:hidden;transition:transform .25s ease,box-shadow .25s ease}
.apt-card:hover{transform:translateY(-3px);box-shadow:0 16px 40px rgba(0,0,0,.12)}
.apt-photo{aspect-ratio:4/3;overflow:hidden;background:var(--bg-2,#f1ecdf)}
.apt-photo img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease}
.apt-card:hover .apt-photo img{transform:scale(1.04)}
.apt-body{padding:18px 18px 20px;display:flex;flex-direction:column;gap:8px}
.apt-top{display:flex;align-items:baseline;justify-content:space-between;gap:10px}
.apt-title{font-family:"Bricolage Grotesque",sans-serif;font-weight:800;font-size:20px;letter-spacing:-.02em;text-transform:lowercase;line-height:1.05}
.apt-hood{font-family:"JetBrains Mono",monospace;font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-soft,#4d544e);white-space:nowrap}
.apt-sum{font-size:14px;line-height:1.45;color:var(--ink-soft,#4d544e)}
.apt-meta{display:flex;align-items:center;gap:8px;font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-soft,#4d544e);margin-top:2px;flex-wrap:wrap}
.apt-meta i{opacity:.4;font-style:normal}
.apt-price{margin-left:auto;color:var(--page,#ff5e1a);font-weight:700}
</style>
