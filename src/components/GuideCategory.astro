---
import { supabase } from '../lib/supabase';
import { GMAPS_KEY } from '../lib/maps';
const { category } = Astro.props as { category: string };

const CAT: Record<string, any> = {
  'eat-drink':   { color: '#ff5e1a', label: 'eat & drink', h1: 'eat <em>&amp;</em> drink.',
    lede: 'our favourite <b>cafés, restaurants, bars, wine spots and bakeries</b> in batumi — the places <em>we actually go to ourselves</em>.' },
  'wellness':    { color: '#00b5b0', label: 'wellness & slow living', h1: 'wellness <em>&amp;</em> slow.',
    lede: '<b>spas, baths and slow-living spots</b> for a proper <em>reset day</em> in batumi.' },
  'work':        { color: '#7f77dd', label: 'work & remote life', h1: 'work <em>&amp;</em> remote.',
    lede: '<b>cafés and coworkings</b> that actually work for a remote day — <em>wifi, power, room to think</em>.' },
  'move-around': { color: '#3D5AFE', label: 'move around', h1: 'move <em>around</em>.',
    lede: 'how we get around batumi and beyond — <b>taxis, scooters and car rentals</b> we use ourselves.' },
};
const cat = CAT[category] || { color: '#ff5e1a', label: category, h1: category + '.', lede: '' };

// world metadata for the "more from the guide" tiles — mirrors the hub's world cards
const ICO: Record<string, string> = {
  eat: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 1V8M4 8C3 8 2.5 8 2.5 9V15M4 8C5 8 5.5 8 5.5 9V15M11 1C9.5 1 9 2 9 3.5C9 5 9.5 6 11 6.5V14.5C11 14.7 11.2 15 11.5 15S12 14.7 12 14.5V6.5C13.5 6 14 5 14 3.5C14 2 13.5 1 12 1" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  wellness: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 2C7 5 5 6 4 7C2.5 8 3 10 5 10.5C7 11 8.5 9.5 8 7M8 7C7.5 5 9 4 11 4.5C13 5 13.5 7 12 8.5C11 9.5 9 9 8 7Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  work: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="2" y="3" width="12" height="9" rx="1" stroke="currentColor" stroke-width="1.3"/><path d="M5 14H11M8 12V14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
  move: '<svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="5" cy="11" r="2" stroke="currentColor" stroke-width="1.3"/><circle cx="11" cy="11" r="2" stroke="currentColor" stroke-width="1.3"/><path d="M5 9L7 4H10L12 8M3 4H6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>',
};
const WMETA: Record<string, any> = {
  'eat-drink': { ico: ICO.eat, sub: 'cafés · restaurants · bars', desc: 'our favourite cafés, brunch spots, restaurants, cocktail bars and bakeries.' },
  'wellness': { ico: ICO.wellness, sub: 'spa · baths · yoga · massage', desc: 'slow living done right: sulphur baths, massage rooms, spa days.' },
  'work': { ico: ICO.work, sub: 'co-workings · cafes with wifi', desc: 'cafés with reliable wifi, co-workings, and quiet corners for deep work.' },
  'move-around': { ico: ICO.move, sub: 'taxi · scooter · car', desc: 'how locals actually get around. apps, rentals, the ones we use.' },
};
const goArrow = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 9L9 3M9 3H4M9 3V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';

const { data } = await supabase.from('guide_places').select('*').eq('status', 'published').eq('category', category);
const places = (data || []).slice().sort((a, b) => (b.rating || 0) - (a.rating || 0));
const { data: allCats } = await supabase.from('guide_places').select('category').eq('status', 'published');
const counts: Record<string, number> = {};
(allCats || []).forEach((r) => { counts[r.category] = (counts[r.category] || 0) + 1; });

const esc = (s: any) => String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const clip = (s: any, n: number) => { const t = String(s || '').replace(/\s+/g, ' ').trim(); return t.length > n ? t.slice(0, n).replace(/[ ,;:.]+\S*$/, '') + '…' : t; };
const photo = (p: any) => (p.photos && p.photos[0]) || p.image || `https://picsum.photos/seed/${p.slug}/900/700`;

const featured = places[0];
const rest = featured ? places.slice(1) : places;

// subcategory filter chips from tags
const tagCount: Record<string, number> = {};
places.forEach((p) => (p.tags || []).forEach((t: any) => { const k = String(t).toLowerCase(); tagCount[k] = (tagCount[k] || 0) + 1; }));
const tagList = Object.entries(tagCount).sort((a, b) => b[1] - a[1]);
const subnavHtml = tagList.length ? (
  '<nav class="subnav"><span class="label">filter</span><div class="subs">' +
  '<button class="active" data-tag="all">all · ' + places.length + '</button>' +
  tagList.map(([t, n]) => '<button data-tag="' + esc(t) + '">' + esc(t) + ' · ' + n + '</button>').join('') +
  '</div>' +
  '<div class="sort"><span class="lab">sort:</span><button class="active" data-sort="rec">recommended</button><button data-sort="az">a–z</button><button data-sort="near">nearby</button></div>' +
  '</nav>'
) : '';
const tagAttr = (p: any) => esc((p.tags || []).map((t: any) => String(t).toLowerCase()).join(','));

const featuredHtml = featured ? (
  '<section class="featured" data-tags="' + tagAttr(featured) + '"><a href="/guide/' + featured.slug + '">' +
  '<div class="ph"><img src="' + esc(photo(featured)) + '" alt=""><span class="badge">our pick</span></div>' +
  '<div class="body"><div class="meta"><span class="pill"><span class="swatch"></span>' + esc(cat.label) + '</span>' +
  (featured.rating ? '<span>★ ' + featured.rating + '</span>' : '') + '</div>' +
  '<h2>' + esc(featured.title || featured.name) + '.</h2>' +
  '<p class="summary">' + esc(clip(featured.summary || featured.body, 180)) + '</p>' +
  '<div class="info-row">' +
  (featured.address ? '<span>' + esc(clip(featured.address, 36)) + '</span><span class="dot"></span>' : '') +
  (featured.price ? '<span><b>' + esc(featured.price) + '</b></span>' : '') + '</div>' +
  '<span class="read">read the post →</span>' +
  '</div></a></section>'
) : '';

const cardHtml = (p: any, i: number) =>
  '<a class="place" data-i="' + i + '" data-slug="g-' + p.slug + '" data-tags="' + tagAttr(p) + '" data-lat="' + (p.lat ?? '') + '" data-lng="' + (p.lng ?? '') + '" data-name="' + esc(String(p.title || p.name).toLowerCase()) + '" href="/guide/' + p.slug + '">' +
  '<div class="ph"><img src="' + esc(photo(p)) + '" alt="" loading="lazy"><span class="pill"><span class="sw"></span>' + esc(cat.label) + '</span></div>' +
  '<div class="info"><div class="top-row"><h4>' + esc(p.title || p.name) + '</h4>' +
  (p.price ? '<span class="price"><b>' + esc(p.price) + '</b></span>' : '') + '</div>' +
  '<p class="summary">' + esc(clip(p.summary || p.body, 96)) + '</p></div></a>';

// featured place also appears as a card — hidden in list view, shown in the map split so the left list is complete
const featCardHtml = featured ? cardHtml(featured, -1).replace('class="place"', 'class="place feat-card"') : '';
const placesHtml = featCardHtml + rest.map((p, i) => cardHtml(p, i)).join('');

// map pins for this category's places (list <-> map toggle)
const catPins = places.filter((p) => p.lat != null && p.lng != null).map((p) => ({
  slug: 'g-' + p.slug, title: p.title || p.name, lat: p.lat, lng: p.lng,
  photo: (p.photos && p.photos[0]) || p.image || '', href: '/guide/' + p.slug,
  sub: cat.label, cta: p.price || 'see place →', color: cat.color, ring: '#ffffff',
  hours: Array.isArray(p.hours) ? p.hours : [],
}));
const locSvg = '<svg width="13" height="13" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="2.6" fill="currentColor"/><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4"/><path d="M8 0.5v3M8 12.5v3M0.5 8h3M12.5 8h3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>';
const expandSvg = '<svg class="ic-exp" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 2H2v4M10 2h4v4M6 14H2v-4M10 14h4v-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>';
const closeSvg = '<svg class="ic-close" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>';
const viewToggle = catPins.length ? '<div class="view-toggle"><button class="vt active" data-view="list">list</button><button class="vt" data-view="map">map</button></div>' : '';
const catMapHtml = catPins.length ? (
  '<div class="cat-map" hidden>' +
    '<div class="map-controls"><div class="seg">' +
      '<button class="mc active" data-act="all">all · ' + catPins.length + '</button>' +
      '<button class="mc" data-act="opennow">open now</button></div>' +
      '<button class="mc near" data-act="near">' + locSvg + ' near me</button></div>' +
    '<div class="map"><button class="map-expand" type="button" aria-label="expand map">' + expandSvg + closeSvg + '</button><div id="catMap"></div></div>' +
  '</div>'
) : '';

const otherCats = Object.keys(CAT).filter((c) => c !== category);
const moreHtml = otherCats.map((c) => {
  const w = WMETA[c] || {};
  return '<a class="cat-tile primary" href="/guide/' + c + '" style="--tile-color:' + CAT[c].color + '">' +
    '<div class="top"><span class="num">' + (counts[c] || 0) + '</span>' + (w.ico ? '<span class="ico">' + w.ico + '</span>' : '') + '</div>' +
    '<h3>' + esc(CAT[c].label) + '</h3>' +
    (w.sub ? '<div class="sub">' + w.sub + '</div>' : '') +
    (w.desc ? '<p class="desc">' + esc(w.desc) + '</p>' : '') +
    '<span class="go">' + goArrow + '</span></a>';
}).join('');

const content =
  '<section class="cat-header"><div class="crumbs">' +
  '<a href="/guide/">← back to the guide</a><span class="sep">/</span>' +
  '<span class="current"><span class="dot"></span>' + esc(cat.label) + '</span></div>' +
  '<h1>' + cat.h1 + '</h1>' +
  '<p class="lede">' + cat.lede + '</p>' +
  '<div class="cat-stats"><div><span class="num">' + places.length + '</span>places we love</div>' +
  '<div><span class="num">100%</span>tried by us</div></div></section>' +
  subnavHtml +
  featuredHtml +
  '<section class="places-wrap"><div class="places-head"><h3><em>' + places.length + '</em> places · sorted by recommended</h3>' + viewToggle + '</div>' +
  '<div class="places">' + placesHtml + '</div>' + catMapHtml + '</section>' +
  '<section class="more-cats"><div class="more-cats-head"><h3>more from <em>the guide</em>.</h3><a href="/guide/" class="right">all worlds →</a></div>' +
  '<div class="more-cats-grid">' + moreHtml + '</div></section>';
---
<style is:inline set:html={`:root{--cat-color:${cat.color}}`}></style>
<Fragment set:html={content} />
<script is:inline>
(function(){
  var btns=document.querySelectorAll('.subnav .subs button');
  var cards=document.querySelectorAll('.places .place');
  var feat=document.querySelector('.featured');
  btns.forEach(function(b){
    b.addEventListener('click', function(){
      btns.forEach(function(x){ x.classList.remove('active'); });
      b.classList.add('active');
      var tag=b.getAttribute('data-tag');
      var vis=0;
      if(feat){ var ft=(feat.getAttribute('data-tags')||'').split(','); var fm=(tag==='all'||ft.indexOf(tag)>=0); feat.style.display=fm?'':'none'; if(fm) vis++; }
      cards.forEach(function(c){
        var tags=(c.getAttribute('data-tags')||'').split(',');
        var m=(tag==='all' || tags.indexOf(tag)>=0);
        c.style.display = m ? '' : 'none';
        if(m) vis++;
      });
      var head=document.querySelector('.places-head h3 em');
      if(head) head.textContent=vis;
    });
  });
  // sort
  var sortBtns=document.querySelectorAll('.subnav .sort button');
  var grid=document.querySelector('.places');
  function reorder(cmp){ if(!grid) return; var arr=[].slice.call(grid.children); arr.sort(cmp); arr.forEach(function(c){ grid.appendChild(c); }); }
  sortBtns.forEach(function(b){
    b.addEventListener('click', function(){
      sortBtns.forEach(function(x){ x.classList.remove('active'); }); b.classList.add('active');
      var s=b.getAttribute('data-sort');
      if(s==='rec') reorder(function(a,c){ return (+a.dataset.i)-(+c.dataset.i); });
      else if(s==='az') reorder(function(a,c){ return (a.dataset.name||'').localeCompare(c.dataset.name||''); });
      else if(s==='near'){
        if(!navigator.geolocation){ return; }
        navigator.geolocation.getCurrentPosition(function(pos){
          var ul=pos.coords.latitude, ug=pos.coords.longitude;
          function d(c){ var la=+c.dataset.lat, ln=+c.dataset.lng; if(!la||!ln) return 1e12; var dx=(la-ul)*111, dy=(ln-ug)*83; return dx*dx+dy*dy; }
          reorder(function(a,c){ return d(a)-d(c); });
        }, function(){});
      }
    });
  });
})();
</script>
<style is:inline set:html={".places-head{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap}\n.view-toggle{display:inline-flex;background:var(--paper);border:1px solid var(--line);border-radius:999px;padding:3px}\n.view-toggle .vt{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:600;color:var(--ink-soft);padding:8px 16px;border:0;background:transparent;border-radius:999px;cursor:pointer;transition:all .18s ease}\n.view-toggle .vt.active{background:var(--ink);color:#fff}\n.cat-map{margin-top:6px}\n.cat-map .map-controls{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin:0 0 16px}\n.cat-map .map-controls .seg{display:inline-flex;background:var(--paper);border:1px solid var(--line);border-radius:999px;padding:3px}\n.cat-map .mc{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.14em;text-transform:uppercase;font-weight:600;color:var(--ink-soft);padding:9px 16px;border-radius:999px;cursor:pointer;display:inline-flex;align-items:center;gap:7px;border:0;background:transparent;transition:all .18s ease}\n.cat-map .seg .mc.active{background:var(--ink);color:#fff}\n.cat-map .mc.near{border:1px solid var(--line);background:var(--paper);color:var(--ink)}\n.cat-map .mc.near:hover{border-color:var(--cat-color);color:var(--cat-color)}\n.cat-map .mc.near.loading{opacity:.55;pointer-events:none}\n.cat-map .mc.near.err{border-color:#d9402a;color:#d9402a}\n.cat-map .map{position:relative;height:560px;border-radius:14px;overflow:hidden;border:1px solid var(--line);background:var(--bg-2)}\n#catMap{position:absolute;inset:0;width:100%;height:100%}\n.feat-card{display:none}\n.places-wrap.split{display:grid;grid-template-columns:minmax(0,1.04fr) minmax(0,1fr);grid-template-rows:auto 1fr;column-gap:28px;align-items:start;padding:96px 28px 8px;margin:0;min-height:100vh}\n.places-wrap.split .places-head{grid-column:1;grid-row:1;margin:0 0 16px}\n.places-wrap.split .places{grid-column:1;grid-row:2;grid-template-columns:1fr 1fr;gap:16px;align-self:start}\n.places-wrap.split .feat-card{display:flex}\n.places-wrap.split .cat-map{grid-column:2;grid-row:1 / span 2;position:sticky;top:76px;height:calc(100vh - 96px);margin:0;display:flex;flex-direction:column}\n.places-wrap.split .cat-map .map-controls{flex:none;margin:0 0 10px}\n.places-wrap.split .cat-map .map{flex:1;height:auto}\n.places-wrap.split .place.active{outline:2px solid var(--cat-color);outline-offset:3px;border-radius:12px}\n@media(max-width:880px){.cat-map .map{height:440px}.places-wrap.split{display:block;padding:0}.places-wrap.split .places{grid-template-columns:1fr}.places-wrap.split .cat-map{position:static;height:auto;display:block}.places-wrap.split .cat-map .map{height:62vh}}\n.more-cats-grid{grid-template-columns:repeat(3,1fr);gap:16px}\n.more-cats .cat-tile{position:relative;display:flex;flex-direction:column;justify-content:space-between;padding:24px;min-height:240px;border-radius:14px;overflow:hidden;transition:transform .3s cubic-bezier(.2,.7,.2,1);border:1px solid transparent;color:#fff;background:var(--tile-color)}\n.more-cats .cat-tile:hover{transform:translateY(-4px)}\n.more-cats .cat-tile > *{position:relative;z-index:2}\n.more-cats .cat-tile .top{display:flex;justify-content:space-between;align-items:flex-start;gap:12px}\n.more-cats .cat-tile .num{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:44px;line-height:.9;letter-spacing:-.03em}\n.more-cats .cat-tile .ico{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.2)}\n.more-cats .cat-tile h3{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:26px;line-height:1;letter-spacing:-.03em;text-transform:lowercase;margin-top:auto}\n.more-cats .cat-tile .sub{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.18em;text-transform:uppercase;font-weight:500;margin-top:8px;opacity:.75}\n.more-cats .cat-tile .desc{font-size:13px;line-height:1.45;margin-top:8px;max-width:24ch;opacity:.92}\n.more-cats .cat-tile .go{position:absolute;right:18px;bottom:18px;z-index:3;width:32px;height:32px;border-radius:50%;border:1px solid currentColor;display:flex;align-items:center;justify-content:center;opacity:.6;transition:all .25s ease}\n.more-cats .cat-tile:hover .go{opacity:1;transform:translate(2px,-2px);background:#fff;color:var(--tile-color);border-color:#fff}\n.more-cats .cat-tile::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at top right,rgba(255,255,255,.16) 0%,transparent 60%);z-index:0}\n.more-cats .cat-tile::after{content:'';position:absolute;left:-30%;bottom:-40%;width:140%;height:80%;background:radial-gradient(ellipse at center,rgba(0,0,0,.12) 0%,transparent 60%);z-index:0}\n@media(max-width:880px){.more-cats-grid{grid-template-columns:1fr}}\n.cat-map .map-expand{position:absolute;top:12px;right:12px;z-index:6;width:40px;height:40px;border-radius:10px;background:#fff;border:1px solid var(--line);box-shadow:0 2px 10px rgba(0,0,0,.14);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--ink);transition:background .18s ease}\n.cat-map .map-expand:hover{background:var(--bg-2)}\n.cat-map .map-expand .ic-close{display:none}\n.places-wrap.split .cat-map.expanded{position:fixed;top:76px;left:0;right:0;height:calc(100vh - 96px);z-index:60;margin:0;padding:0 16px 16px 16px;background:var(--bg)}\n.cat-map.expanded .map{flex:1;height:auto;border-radius:14px}\n.cat-map.expanded .map-controls{margin:0 0 10px}\n.cat-map.expanded .map-expand .ic-exp{display:none}\n.cat-map.expanded .map-expand .ic-close{display:block}\nhtml.map-locked,body.map-locked{overflow:hidden}\n.places-wrap.split .cat-map .map{margin:0 10px 16px 0}\n.places-wrap.split .cat-map.expanded .map{margin:0}\n@media(max-width:880px){.places-wrap.split .cat-map .map{margin:0}}"}></style>
<script is:inline src="/rega-map.js"></script>
<script is:inline define:vars={{ CAT_PINS: catPins, GKEY: GMAPS_KEY }}>
(function () {
  var vt = document.querySelectorAll('.view-toggle .vt');
  var mapWrap = document.querySelector('.cat-map');
  var wrap = document.querySelector('.places-wrap');
  var hideEls = ['.featured', '.subnav', '.cat-header'].map(function (s) { return document.querySelector(s); });
  if (!vt.length || !mapWrap || !wrap) return;
  var api = null;
  function wire() {
    var bar = mapWrap.querySelector('.map-controls');
    var bAll = bar.querySelector('[data-act="all"]'), bOpen = bar.querySelector('[data-act="opennow"]'), bNear = bar.querySelector('[data-act="near"]');
    function seg(a) { bAll.classList.toggle('active', a === 'all'); bOpen.classList.toggle('active', a === 'opennow'); }
    bAll.addEventListener('click', function () { seg('all'); api.clearFilter(); });
    bOpen.addEventListener('click', function () { seg('opennow'); api.setFilter(function (it) { return RegaMap.isOpenNow(it.hours) !== false; }); });
    bNear.addEventListener('click', function () { var b = this; b.classList.add('loading'); api.locate(function (u) { b.classList.remove('loading'); if (!u) { b.classList.add('err'); setTimeout(function () { b.classList.remove('err'); }, 2200); } }); });
    var expBtn = mapWrap.querySelector('.map-expand');
    function setExpanded(on) {
      mapWrap.classList.toggle('expanded', on);
      document.documentElement.classList.toggle('map-locked', on);
      document.body.classList.toggle('map-locked', on);
      if (api && window.google && api.map) setTimeout(function () { google.maps.event.trigger(api.map, 'resize'); api.refit(); }, 90);
    }
    if (expBtn) expBtn.addEventListener('click', function () { setExpanded(!mapWrap.classList.contains('expanded')); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && mapWrap.classList.contains('expanded')) setExpanded(false); });
  }
  function make() {
    if (api) { if (window.google && api.map) { google.maps.event.trigger(api.map, 'resize'); api.refit(); } return; }
    if (!window.markerClusterer && (make._t = (make._t || 0) + 1) < 10) { setTimeout(make, 150); return; }
    api = RegaMap.stays('catMap', CAT_PINS, { cardSel: '.places .place', cluster: true, fullscreen: false }); if (api) wire();
  }
  window.__catMapReady = function () { window.__gReady = true; if (window.__wantMap) make(); };
  function loadG() {
    if (window.__gLoading) return; window.__gLoading = true;
    var c = document.createElement('script'); c.async = true;
    c.src = 'https://unpkg.com/@googlemaps/markerclusterer@2.5.3/dist/index.min.js';
    document.head.appendChild(c);
    var s = document.createElement('script'); s.async = true;
    s.src = 'https://maps.googleapis.com/maps/api/js?key=' + GKEY + '&callback=__catMapReady&loading=async&language=en&region=GE';
    document.head.appendChild(s);
  }
  vt.forEach(function (b) {
    b.addEventListener('click', function () {
      vt.forEach(function (x) { x.classList.remove('active'); }); b.classList.add('active');
      var showMap = b.getAttribute('data-view') === 'map';
      wrap.classList.toggle('split', showMap);
      mapWrap.hidden = !showMap;
