{
  "buildCommand": "astro build && node scripts/optimize-images.mjs && node scripts/gen-og.mjs",
  "redirects": [
    { "source": "/", "destination": "/georgia/batumi", "permanent": false },
    { "source": "/guide/:path*", "destination": "/georgia/batumi/guide/:path*", "permanent": false },
    { "source": "/stays/:path*", "destination": "/georgia/batumi/stays/:path*", "permanent": false },
    { "source": "/ru/guide/:path*", "destination": "/ru/georgia/batumi/guide/:path*", "permanent": false },
    { "source": "/ru/stays/:path*", "destination": "/ru/georgia/batumi/stays/:path*", "permanent": false },
    { "source": "/(own|invest|about|contact|agents|privacy|terms)", "destination": "/georgia/batumi/$1", "permanent": false },
    { "source": "/ru/(own|invest|about|contact|agents|privacy|terms)", "destination": "/ru/georgia/batumi/$1", "permanent": false },
    { "source": "/ru", "destination": "/ru/georgia/batumi", "permanent": false }
  ],
  "images": {
    "sizes": [320, 480, 640, 750, 828, 1080, 1200, 1920],
    "formats": ["image/avif", "image/webp"],
    "minimumCacheTTL": 2592000,
    "remotePatterns": [
      { "protocol": "https", "hostname": "qkzinjawtumhjbezlyog.supabase.co" },
      { "protocol": "https", "hostname": "images.unsplash.com" },
      { "protocol": "https", "hostname": "static.tildacdn.com" },
      { "protocol": "https", "hostname": "static.tildacdn.one" },
      { "protocol": "https", "hostname": "picsum.photos" }
    ]
  }
}
